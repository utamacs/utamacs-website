{
  "name": "utamacs-website",
  "version": "2.0.0",
  "description": "Urban Trilla Apartments MACS — Community Operating System",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:portal": "astro build --config astro.portal.config.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "supabase:types": "supabase gen types typescript --local > src/lib/supabase/database.types.ts",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:api": "vitest run --config tests/api/vitest.config.ts",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@types/sanitize-html": "^2.16.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "docx": "^9.6.1",
    "jose": "^5.9.6",
    "pdfmake": "^0.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "sanitize-html": "^2.17.4"
  },
  "devDependencies": {
    "@astrojs/react": "^3.6.2",
    "@astrojs/tailwind": "^5.1.0",
    "@astrojs/vercel": "^7.8.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/forms": "^0.5.9",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "astro": "^4.16.0",
    "autoprefixer": "^10.4.20",
    "supabase": "^2.98.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "nonprofit",
    "association",
    "community",
    "tailwindcss"
  ],
  "author": "Urban Trilla Apartments Residents Association",
  "license": "MIT"
}

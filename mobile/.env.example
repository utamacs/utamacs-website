# UTA MACS Mobile App — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
#
# For CI/CD (GitHub Actions), pass these as --dart-define flags instead:
#   flutter build apk \
#     --dart-define=SUPABASE_URL=$SUPABASE_URL \
#     --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY \
#     --dart-define=SOCIETY_ID=$SOCIETY_ID \
#     --dart-define=SENTRY_DSN=$SENTRY_DSN \
#     --dart-define=SUPABASE_CERT_PIN_1=$SUPABASE_CERT_PIN_1 \
#     --dart-define=SUPABASE_CERT_PIN_2=$SUPABASE_CERT_PIN_2

# Supabase project URL (from Supabase Dashboard → Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon (public) key — safe to expose in client apps; RLS enforces access
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# UUID of your society row in the `societies` table
# Supabase Dashboard → Table Editor → societies → copy the id column value
SOCIETY_ID=YOUR_SOCIETY_UUID_HERE

# Optional: Sentry DSN for crash reporting
# Create a project at sentry.io → Settings → Projects → DSN
SENTRY_DSN=

# Portal base URL — used for native file uploads (without trailing slash)
PORTAL_URL=https://portal.utamacs.org

# Optional: Certificate pinning — SPKI-SHA256 fingerprints of your Supabase cert
# Get fingerprints with:
#   openssl s_client -connect <project>.supabase.co:443 </dev/null 2>/dev/null \
#     | openssl x509 -pubkey -noout \
#     | openssl pkey -pubin -outform der \
#     | openssl dgst -sha256 -binary \
#     | base64
# Leave empty to disable pinning (production should always set these).
SUPABASE_CERT_PIN_1=
SUPABASE_CERT_PIN_2=

---
import ThemeToggle from '../ui/ThemeToggle.astro';

const navLinks = [
  { href: '/', label: 'Home', icon: 'fa-home' },
  { href: '/about', label: 'About', icon: 'fa-info-circle' },
  { href: '/committee', label: 'Committee', icon: 'fa-users' },
  { href: '/notices', label: 'Notices', icon: 'fa-bell' },
  { href: '/events', label: 'Events', icon: 'fa-calendar-alt' },
  { href: '/downloads', label: 'Downloads', icon: 'fa-download' },
  { href: '/contact', label: 'Contact', icon: 'fa-envelope' },
  { href: '/portal', label: 'Portal', icon: 'fa-user-shield' },
  { href: '/login', label: 'Login', icon: 'fa-sign-in-alt' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<nav
  class="bg-background shadow-soft sticky top-0 z-50 border-b border-border-light transition-all duration-300"
  role="navigation"
  aria-label="Main navigation"
  id="main-nav"
>
  <div class="container-custom">
    <div class="flex justify-between items-center py-4">
      <!-- Brand -->
      <a
        href="/"
        class="text-card-lg font-bold text-primary-600 hover:text-primary-700 transition-colors duration-200 flex items-center space-x-2"
        aria-label="UTA MACS Home"
      >
        <i class="fas fa-building text-primary-600" aria-hidden="true"></i>
        <span>UTA MACS</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center space-x-6">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={['nav-link', { active: currentPath === href || (href !== '/' && currentPath.startsWith(href)) }]}
            aria-label={label}
          >
            {label}
          </a>
        ))}
      </div>

      <!-- Theme + Mobile toggle -->
      <div class="flex items-center space-x-3">
        <ThemeToggle />
        <button
          id="mobile-menu-toggle"
          class="lg:hidden p-2 text-text-secondary hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary-600"
          aria-label="Open menu"
          aria-expanded="false"
          type="button"
        >
          <i class="fas fa-bars text-lg" aria-hidden="true" id="hamburger-icon"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="mobile-menu"
    role="dialog"
    aria-modal="true"
    aria-label="Mobile navigation menu"
  >
    <div class="flex flex-col h-full">
      <!-- Mobile Header -->
      <div class="flex justify-between items-center p-4 border-b border-border-light">
        <a href="/" class="text-card font-bold text-primary-600 flex items-center space-x-2">
          <i class="fas fa-building" aria-hidden="true"></i>
          <span>UTA MACS</span>
        </a>
        <button
          id="mobile-menu-close"
          class="p-2 text-text-secondary hover:text-primary-600 rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-primary-600"
          aria-label="Close menu"
          type="button"
        >
          <i class="fas fa-times text-lg" aria-hidden="true"></i>
        </button>
      </div>

      <!-- Mobile Links -->
      <div class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
        {navLinks.map(({ href, label, icon }) => (
          <a
            href={href}
            class:list={[
              'flex items-center space-x-3 p-3 rounded-xl transition-colors duration-200 font-medium',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'bg-primary-50 text-primary-600'
                : 'text-text-secondary hover:bg-primary-50 hover:text-primary-600',
            ]}
            aria-label={label}
          >
            <i class={`fas ${icon} text-primary-600 w-5`} aria-hidden="true"></i>
            <span class="text-body">{label}</span>
          </a>
        ))}
      </div>

      <!-- Mobile Footer -->
      <div class="p-4 border-t border-border-light">
        <div class="flex items-center justify-between">
          <span class="text-small text-text-secondary">UTA MACS © 2026</span>
          <div class="flex space-x-3">
            <a href="#" class="text-text-secondary hover:text-primary-600 transition-colors" aria-label="Facebook">
              <i class="fab fa-facebook-f" aria-hidden="true"></i>
            </a>
            <a href="#" class="text-text-secondary hover:text-primary-600 transition-colors" aria-label="Twitter">
              <i class="fab fa-twitter" aria-hidden="true"></i>
            </a>
            <a href="#" class="text-text-secondary hover:text-primary-600 transition-colors" aria-label="Instagram">
              <i class="fab fa-instagram" aria-hidden="true"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
  const menuToggle = document.getElementById('mobile-menu-toggle') as HTMLButtonElement;
  const menuClose = document.getElementById('mobile-menu-close') as HTMLButtonElement;
  const hamburgerIcon = document.getElementById('hamburger-icon');
  let lastFocused: HTMLElement | null = null;

  function openMobileMenu() {
    mobileMenu.classList.add('open');
    menuToggle.setAttribute('aria-expanded', 'true');
    if (hamburgerIcon) hamburgerIcon.className = 'fas fa-times text-lg';
    document.body.style.overflow = 'hidden';
    lastFocused = document.activeElement as HTMLElement;
    menuClose.focus();
  }

  function closeMobileMenu() {
    mobileMenu.classList.remove('open');
    menuToggle.setAttribute('aria-expanded', 'false');
    if (hamburgerIcon) hamburgerIcon.className = 'fas fa-bars text-lg';
    document.body.style.overflow = '';
    lastFocused?.focus();
  }

  menuToggle?.addEventListener('click', openMobileMenu);
  menuClose?.addEventListener('click', closeMobileMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu.classList.contains('open')) {
      closeMobileMenu();
    }
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024 && mobileMenu.classList.contains('open')) {
      closeMobileMenu();
    }
  });

  // Focus trap
  mobileMenu.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab') return;
    const focusable = mobileMenu.querySelectorAll<HTMLElement>(
      'a[href], button, input, textarea, select, [tabindex]:not([tabindex="-1"])'
    );
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  });

  // Close when clicking a mobile nav link
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });

  // Scroll-based nav shadow
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      nav?.classList.add('shadow-medium');
    } else {
      nav?.classList.remove('shadow-medium');
    }
  });
</script>

---
interface Props {
  name: string;
  role: string;
  description: string;
  phone?: string;
  email?: string;
  initials: string;
  colorVariant?: 'primary' | 'secondary' | 'accent';
  animationDelay?: string;
}

const {
  name,
  role,
  description,
  phone,
  email,
  initials,
  colorVariant = 'primary',
  animationDelay,
} = Astro.props;

const colorMap = {
  primary: { avatar: 'bg-primary-100 text-primary-600', badge: 'bg-primary-50 text-primary-700' },
  secondary: { avatar: 'bg-secondary-100 text-secondary-600', badge: 'bg-secondary-50 text-secondary-700' },
  accent: { avatar: 'bg-accent-100 text-accent-700', badge: 'bg-accent-50 text-accent-700' },
};
const colors = colorMap[colorVariant];
---
<div
  class="card-premium animate-on-scroll text-center group"
  style={animationDelay ? `transition-delay: ${animationDelay}` : undefined}
>
  <!-- Avatar -->
  <div class={`w-20 h-20 ${colors.avatar} rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl font-bold shadow-soft group-hover:shadow-medium transition-shadow duration-300`}>
    {initials}
  </div>
  <!-- Name & Role -->
  <h3 class="text-card font-semibold text-text-primary mb-1">{name}</h3>
  <span class={`inline-block text-xs font-semibold px-3 py-1 rounded-full mb-3 ${colors.badge}`}>
    {role}
  </span>
  <p class="text-small text-text-secondary leading-relaxed mb-4">{description}</p>
  <!-- Contact -->
  <div class="space-y-2 pt-4 border-t border-border-light">
    {email && (
      <a
        href={`mailto:${email}`}
        class="flex items-center justify-center space-x-2 text-small text-text-secondary hover:text-primary-600 transition-colors"
        aria-label={`Email ${name}`}
      >
        <i class="fas fa-envelope text-xs text-primary-500" aria-hidden="true"></i>
        <span class="truncate">{email}</span>
      </a>
    )}
    {phone && (
      <div class="flex items-center justify-center space-x-2 text-small text-text-secondary">
        <i class="fas fa-phone text-xs text-secondary-500" aria-hidden="true"></i>
        <span>{phone}</span>
      </div>
    )}
  </div>
</div>

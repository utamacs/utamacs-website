---
interface Props {
  name: string;
  initials: string;
  residentSince: string;
  quote: string;
  colorVariant?: 'primary' | 'secondary' | 'accent';
  animationDelay?: string;
}

const {
  name,
  initials,
  residentSince,
  quote,
  colorVariant = 'primary',
  animationDelay,
} = Astro.props;

const colorMap = {
  primary: 'bg-primary-100 text-primary-600',
  secondary: 'bg-secondary-100 text-secondary-600',
  accent: 'bg-accent-100 text-accent-700',
};
---
<div
  class="card-premium animate-on-scroll"
  style={animationDelay ? `transition-delay: ${animationDelay}` : undefined}
>
  <!-- Stars -->
  <div class="flex text-secondary-400 mb-4" aria-label="5 out of 5 stars">
    {Array(5).fill(null).map(() => (
      <i class="fas fa-star text-sm" aria-hidden="true"></i>
    ))}
  </div>
  <!-- Quote -->
  <blockquote class="text-body text-text-secondary italic leading-relaxed mb-6">
    "{quote}"
  </blockquote>
  <!-- Author -->
  <div class="flex items-center space-x-3 pt-4 border-t border-border-light">
    <div class={`w-12 h-12 ${colorMap[colorVariant]} rounded-full flex items-center justify-center font-semibold flex-shrink-0`}>
      {initials}
    </div>
    <div>
      <p class="text-small font-semibold text-text-primary">{name}</p>
      <p class="text-xs text-text-secondary">{residentSince}</p>
    </div>
  </div>
</div>

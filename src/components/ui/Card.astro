---
interface Props {
  variant?: 'premium' | 'feature' | 'stats' | 'hero';
  class?: string;
  animateOnScroll?: boolean;
  animationDelay?: string;
}

const {
  variant = 'premium',
  class: extraClass = '',
  animateOnScroll = false,
  animationDelay,
} = Astro.props;

const classes = [
  `card-${variant}`,
  animateOnScroll ? 'animate-on-scroll' : '',
  extraClass,
].filter(Boolean).join(' ');
---
<div
  class={classes}
  style={animationDelay ? `transition-delay: ${animationDelay}` : undefined}
>
  <slot />
</div>

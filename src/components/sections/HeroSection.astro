---
---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700">
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-secondary-400/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-accent-400/10 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary-600/20 rounded-full blur-3xl"></div>
  </div>

  <!-- Floating elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute top-20 left-10 w-4 h-4 bg-secondary-400/40 rounded-full animate-float"></div>
    <div class="absolute top-40 right-20 w-6 h-6 bg-accent-400/30 rounded-full animate-float" style="animation-delay: 1s;"></div>
    <div class="absolute bottom-32 left-1/4 w-3 h-3 bg-secondary-300/50 rounded-full animate-float" style="animation-delay: 2s;"></div>
    <div class="absolute bottom-20 right-1/3 w-5 h-5 bg-primary-300/40 rounded-full animate-float" style="animation-delay: 0.5s;"></div>
  </div>

  <div class="container-custom relative z-10 text-center px-4 py-20">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 text-sm font-medium px-4 py-2 rounded-full mb-8 animate-on-scroll">
      <i class="fas fa-building text-secondary-400" aria-hidden="true"></i>
      <span>Urban Trilla Apartment MACS</span>
    </div>

    <!-- Heading -->
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6 animate-on-scroll" style="transition-delay: 0.1s;">
      Welcome to
      <span class="block text-transparent bg-clip-text bg-gradient-to-r from-secondary-300 to-accent-300 mt-2">
        UTA MACS
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg sm:text-xl text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed animate-on-scroll" style="transition-delay: 0.2s;">
      Your trusted Mutually Aided Cooperative Society — building a vibrant, well-managed, and connected residential community at Kondakal, Hyderabad.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16 animate-on-scroll" style="transition-delay: 0.3s;">
      <a href="/notices" class="btn-secondary text-base px-8 py-4">
        <i class="fas fa-bell mr-2" aria-hidden="true"></i>
        Latest Notices
      </a>
      <a href="/about" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-sm border border-white/30 text-white font-semibold px-8 py-4 rounded-xl transition-all duration-200">
        <i class="fas fa-info-circle mr-2" aria-hidden="true"></i>
        Learn More
      </a>
    </div>

    <!-- Quick stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto animate-on-scroll" style="transition-delay: 0.4s;">
      {[
        { number: '136', label: 'Flats', icon: 'fa-home' },
        { number: '2.9', label: 'Acres', icon: 'fa-leaf' },
        { number: '24/7', label: 'Security', icon: 'fa-shield-alt' },
        { number: '10+', label: 'Amenities', icon: 'fa-star' },
      ].map(stat => (
        <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl p-4 text-center">
          <i class={`fas ${stat.icon} text-secondary-300 text-xl mb-2 block`} aria-hidden="true"></i>
          <p class="text-2xl font-bold text-white">{stat.number}</p>
          <p class="text-xs text-white/70 uppercase tracking-wide">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce" aria-hidden="true">
    <i class="fas fa-chevron-down text-white/60 text-xl"></i>
  </div>
</section>

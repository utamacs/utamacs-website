---
import type { UserClaims } from '@lib/services/interfaces/IAuthService';
import { featureFlagService } from '@lib/services/index';
import { resolveNavRole, NAV_ROLE_RANK, GROUP_ORDER } from '@lib/navRoles';
import '../../styles/global.css';

export interface Props {
  title: string;
  user: UserClaims;
  activeModule?: string;
}

const { title, user, activeModule } = Astro.props;

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';

// ── Module system (DB-backed with hardcoded fallback) ─────────────────────────

type FallbackModule = { moduleKey: string; displayName: string; icon: string; navGroup: string; minNavRole: string };

const FALLBACK_MODULES: FallbackModule[] = [
  { moduleKey: 'members',          displayName: 'Member Directory',      icon: 'fa-users',              navGroup: 'Community',      minNavRole: 'member'    },
  { moduleKey: 'complaints',       displayName: 'Complaints',             icon: 'fa-tools',              navGroup: 'Community',      minNavRole: 'member'    },
  { moduleKey: 'notices',          displayName: 'Notices & Circulars',    icon: 'fa-bell',               navGroup: 'Community',      minNavRole: 'member'    },
  { moduleKey: 'events',           displayName: 'Events',                 icon: 'fa-calendar-alt',       navGroup: 'Community',      minNavRole: 'member'    },
  { moduleKey: 'polls',            displayName: 'Polls & Voting',         icon: 'fa-vote-yea',           navGroup: 'Community',      minNavRole: 'member'    },
  { moduleKey: 'finance',          displayName: 'Finance & Dues',         icon: 'fa-rupee-sign',         navGroup: 'Services',       minNavRole: 'member'    },
  { moduleKey: 'facility_booking', displayName: 'Facility Booking',       icon: 'fa-building',           navGroup: 'Services',       minNavRole: 'member'    },
  { moduleKey: 'visitor_mgmt',     displayName: 'Visitor Management',     icon: 'fa-id-badge',           navGroup: 'Services',       minNavRole: 'member'    },
  { moduleKey: 'vendors',          displayName: 'Vendors & Work Orders',  icon: 'fa-hard-hat',           navGroup: 'HOTO Platform',  minNavRole: 'member'    },
  { moduleKey: 'hoto',             displayName: 'HOTO Tracker',           icon: 'fa-tasks',              navGroup: 'HOTO Platform',  minNavRole: 'member'    },
  { moduleKey: 'snags',            displayName: 'Snag List',              icon: 'fa-bug',                navGroup: 'HOTO Platform',  minNavRole: 'member'    },
  { moduleKey: 'community',        displayName: 'Community Board',        icon: 'fa-comments',           navGroup: 'Community',      minNavRole: 'member'    },
  { moduleKey: 'documents',        displayName: 'Documents',              icon: 'fa-file-alt',           navGroup: 'Community',      minNavRole: 'member'    },
  { moduleKey: 'parking',          displayName: 'Parking Management',     icon: 'fa-car',                navGroup: 'Services',       minNavRole: 'member'    },
  { moduleKey: 'agm',              displayName: 'AGM & Governance',       icon: 'fa-landmark',           navGroup: 'Governance',     minNavRole: 'member'    },
  { moduleKey: 'notifications',    displayName: 'Notifications',          icon: 'fa-envelope',           navGroup: 'Community',      minNavRole: 'member'    },
  { moduleKey: 'analytics',        displayName: 'Analytics & Reports',    icon: 'fa-chart-bar',          navGroup: 'Governance',     minNavRole: 'executive' },
  { moduleKey: 'letters',          displayName: 'Official Letters',        icon: 'fa-envelope-open-text', navGroup: 'Governance',     minNavRole: 'executive' },
  { moduleKey: 'policies',         displayName: 'Policies',               icon: 'fa-shield-alt',         navGroup: 'Governance',     minNavRole: 'member'    },
  { moduleKey: 'maids',            displayName: 'Domestic Help Registry', icon: 'fa-user-friends',       navGroup: 'Services',       minNavRole: 'member'    },
  { moduleKey: 'gallery',          displayName: 'Photo Gallery',          icon: 'fa-images',             navGroup: 'Community',      minNavRole: 'member'    },
  { moduleKey: 'feedback',         displayName: 'Resident Feedback',      icon: 'fa-star',               navGroup: 'Community',      minNavRole: 'member'    },
  { moduleKey: 'water_tankers',    displayName: 'Water Management',       icon: 'fa-tint',               navGroup: 'Services',       minNavRole: 'member'    },
  { moduleKey: 'security_patrol',  displayName: 'Security Patrol Log',    icon: 'fa-shield-alt',         navGroup: 'Governance',     minNavRole: 'executive' },
  { moduleKey: 'tenant_kyc',       displayName: 'Tenant KYC',             icon: 'fa-id-card',            navGroup: 'Governance',     minNavRole: 'executive' },
  { moduleKey: 'memberships',      displayName: 'Membership Registry',    icon: 'fa-id-card-alt',        navGroup: 'Administration', minNavRole: 'admin'     },
  { moduleKey: 'staff_kyc',        displayName: 'Staff & Maid KYC',       icon: 'fa-user-check',         navGroup: 'Administration', minNavRole: 'admin'     },
  { moduleKey: 'staff_management', displayName: 'Staff Management',       icon: 'fa-users-cog',          navGroup: 'Administration', minNavRole: 'executive' },
  { moduleKey: 'register',         displayName: 'Society Membership',     icon: 'fa-certificate',        navGroup: 'Governance',     minNavRole: 'member'    },
];

// Canonical path for each module key. DB never stores this — it's tied to code.
const MODULE_PATHS: Record<string, string> = {
  members:          '/portal/members',
  complaints:       '/portal/complaints',
  notices:          '/portal/notices',
  events:           '/portal/events',
  polls:            '/portal/polls',
  finance:          '/portal/finance',
  facility_booking: '/portal/facilities',
  visitor_mgmt:     '/portal/visitors',
  vendors:          '/portal/vendors',
  hoto:             '/portal/hoto',
  snags:            '/portal/snags',
  community:        '/portal/community',
  documents:        '/portal/documents',
  parking:          '/portal/parking',
  agm:              '/portal/agm',
  notifications:    '/portal/notifications',
  analytics:        '/portal/analytics',
  letters:          '/portal/letters',
  policies:         '/portal/policies',
  maids:            '/portal/maids',
  gallery:          '/portal/gallery',
  feedback:         '/portal/feedback',
  water_tankers:    '/portal/water-tankers',
  security_patrol:  '/portal/security-patrol',
  tenant_kyc:       '/portal/tenant-kyc',
  memberships:      '/portal/admin/memberships',
  staff_kyc:        '/portal/admin/staff-kyc',
  staff_management: '/portal/staff-management',
  register:         '/portal/register/membership',
};

type ActiveModule = { moduleKey: string; displayName: string; icon: string | null; navGroup: string; minNavRole: string; isActive?: boolean };

let allModules: ActiveModule[] = FALLBACK_MODULES;
try {
  const dbModules = await featureFlagService.getModules(SOCIETY_ID);
  if (dbModules.length > 0) {
    const dbMap = new Map(dbModules.map((m) => [m.moduleKey, m]));
    allModules = FALLBACK_MODULES.map((f) => dbMap.get(f.moduleKey) ?? f);
  }
} catch {
  // keep FALLBACK_MODULES
}

// ── Nav role resolution ───────────────────────────────────────────────────────

const navRole = resolveNavRole(user);
const navRank = NAV_ROLE_RANK[navRole];

// ── Nav item type and helper ──────────────────────────────────────────────────

type NavItem = { label: string; href: string; icon: string; activeKey: string };

function link(label: string, href: string, icon: string, activeKey: string): NavItem {
  return { label, href, icon, activeKey };
}

// ── Build grouped nav ─────────────────────────────────────────────────────────

type NavGroup = { label: string; items: NavItem[] };
const navGroups: NavGroup[] = [];

if (navRole === 'guard') {
  // Security guards: visitor log only
  const vm = allModules.find((m) => m.moduleKey === 'visitor_mgmt');
  if (vm) navGroups.push({ label: 'Operations', items: [link(vm.displayName, MODULE_PATHS.visitor_mgmt, vm.icon ?? 'fa-id-badge', 'visitor_mgmt')] });

} else if (navRole === 'vendor') {
  // Vendors: their work orders only
  const vm = allModules.find((m) => m.moduleKey === 'vendors');
  if (vm) navGroups.push({ label: 'My Work', items: [link(vm.displayName, MODULE_PATHS.vendors, vm.icon ?? 'fa-hard-hat', 'vendors')] });

} else if (['staff', 'supervisor', 'afm'].includes(user.portalRole)) {
  // Staff portal roles: only see staff operations — no resident data
  const staffItems: NavItem[] = [
    link('My Dashboard',    '/portal/staff-management',             'fa-tachometer-alt', 'staff_dashboard'),
    link('My Tasks',        '/portal/staff-management/tasks',       'fa-check-square',   'staff_tasks'),
    link('My Attendance',   '/portal/staff-management/attendance',  'fa-clock',          'staff_attendance'),
  ];
  if (user.portalRole === 'supervisor' || user.portalRole === 'afm') {
    staffItems.push(
      link('Team Roster',      '/portal/staff-management/team',             'fa-users',          'staff_team'),
      link('Task Assignment',  '/portal/staff-management/assign',           'fa-tasks',          'staff_assign'),
      link('Compliance Logs',  '/portal/staff-management/compliance',       'fa-clipboard-check','staff_compliance'),
      link('Reports',          '/portal/staff-management/reports',          'fa-chart-bar',      'staff_reports'),
    );
  }
  if (user.portalRole === 'afm') {
    staffItems.push(
      link('Proposals Queue',  '/portal/staff-management/proposals',        'fa-inbox',          'staff_proposals'),
      link('All Departments',  '/portal/staff-management/departments',      'fa-sitemap',        'staff_departments'),
    );
  }
  navGroups.push({ label: 'Staff Operations', items: staffItems });

} else {
  // ── DB-driven nav for member / executive / admin ──────────────────────────

  // 1. Filter modules the current user can see and group them by nav_group.
  const groupMap = new Map<string, NavItem[]>();
  for (const m of allModules) {
    const moduleRank = NAV_ROLE_RANK[m.minNavRole as keyof typeof NAV_ROLE_RANK] ?? NAV_ROLE_RANK.member;
    if (navRank < moduleRank) continue;
    const group = m.navGroup ?? 'Community';
    if (!groupMap.has(group)) groupMap.set(group, []);
    groupMap.get(group)!.push(link(
      m.displayName,
      MODULE_PATHS[m.moduleKey] ?? `/portal/${m.moduleKey}`,
      m.icon ?? 'fa-circle',
      m.moduleKey,
    ));
  }

  // 2. Inject exec-only HOTO Platform sub-page links (sub-pages, not modules).
  if (navRank >= NAV_ROLE_RANK.executive) {
    const hotoItems = groupMap.get('HOTO Platform') ?? [];
    hotoItems.push(
      link('Vendor Procurement', '/portal/vendors/procurement',      'fa-clipboard-list', 'vendors_procurement'),
      link('HOTO Progress',      '/portal/hoto/progress',            'fa-chart-pie',      'hoto_progress'),
      link('Pending Approvals',  '/portal/hoto/pending',             'fa-clock',          'hoto_pending'),
      link('HOTO Finance',       '/portal/hoto/finance',             'fa-coins',          'hoto_finance'),
      link('Board Resolutions',  '/portal/hoto/finance/resolutions', 'fa-scroll',         'hoto_resolutions'),
    );
    groupMap.set('HOTO Platform', hotoItems);
  }

  // 3. Inject Secretary/President governance admin links.
  if (['secretary', 'president'].includes(user.portalRole) || user.isAdmin) {
    const govItems = groupMap.get('Governance') ?? [];
    govItems.push(
      link('Role Management', '/portal/hoto/admin/users',      'fa-user-cog',  'hoto_roles'),
      link('Elections',       '/portal/hoto/admin/elections',  'fa-vote-yea',  'hoto_elections'),
      link('Delegations',     '/portal/hoto/admin/delegation', 'fa-handshake', 'hoto_delegation'),
    );
    groupMap.set('Governance', govItems);
  }

  // 4a. Inject Staff Management sub-page links for exec+ users.
  if (navRank >= NAV_ROLE_RANK.executive) {
    const adminItems = groupMap.get('Administration') ?? [];
    const smIdx = adminItems.findIndex(i => i.activeKey === 'staff_management');
    const smLinks = [
      link('Staff Directory',    '/portal/staff-management/staff',       'fa-id-card',         'staff_management_staff'),
      link('Activity Templates', '/portal/staff-management/activities',  'fa-list-alt',        'staff_management_activities'),
      link('Shift Config',       '/portal/staff-management/shifts',      'fa-calendar-alt',    'staff_management_shifts'),
      link('Agency Management',  '/portal/staff-management/agencies',    'fa-building',        'staff_management_agencies'),
      link('Proposals Queue',    '/portal/staff-management/proposals',   'fa-inbox',           'staff_management_proposals'),
    ];
    if (smIdx >= 0) {
      adminItems.splice(smIdx + 1, 0, ...smLinks);
    } else {
      adminItems.push(link('Staff Management', '/portal/staff-management', 'fa-users-cog', 'staff_management'), ...smLinks);
    }
    groupMap.set('Administration', adminItems);
  }

  // 4b. Prepend hardcoded admin tool links to the Administration group.
  if (user.isAdmin) {
    const adminItems = groupMap.get('Administration') ?? [];
    adminItems.unshift(
      link('Society Profile',     '/portal/admin/society-profile', 'fa-building',          'admin_society'),
      link('Holiday Calendar',   '/portal/admin/holidays',        'fa-calendar-day',      'admin_holidays'),
      link('Audit Logs',         '/portal/admin/audit',           'fa-shield-alt',        'admin_audit'),
      link('Asset Register',     '/portal/admin/assets',          'fa-cogs',              'admin_assets'),
      link('Rules Engine',       '/portal/admin/rules',           'fa-sliders-h',         'admin_rules'),
      link('RBAC & Permissions', '/portal/admin/rbac',            'fa-lock',              'admin_rbac'),
      link('Email Drafts',       '/portal/admin/email-drafts',    'fa-envelope-open-text','admin_email'),
      link('Feature Config',     '/portal/admin/features',        'fa-toggle-on',         'admin_features'),
      link('Staff Attendance',   '/portal/admin/staff',           'fa-user-clock',        'admin_staff'),
      link('TDS Tracking',       '/portal/admin/tds',             'fa-file-invoice',      'admin_tds'),
      link('Consent Mgmt',       '/portal/admin/consent',         'fa-user-shield',       'admin_consent'),
    );
    groupMap.set('Administration', adminItems);
  }

  // 5. Emit groups in canonical order; append any unknown groups last.
  for (const groupLabel of GROUP_ORDER) {
    const items = groupMap.get(groupLabel);
    if (items?.length) navGroups.push({ label: groupLabel, items });
  }
  for (const [label, items] of groupMap) {
    if (!(GROUP_ORDER as readonly string[]).includes(label) && items.length) {
      navGroups.push({ label, items });
    }
  }
}
---

<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} – UTA MACS Portal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" />
  <meta name="theme-color" content="#1E3A8A" />
</head>
<body class="h-full bg-gray-50 font-sans text-text-primary">

  <!-- Mobile header -->
  <header class="lg:hidden bg-white border-b border-border-light px-4 py-3 flex items-center justify-between sticky top-0 z-40">
    <a href="/portal" class="flex items-center gap-2">
      <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
        <i class="fas fa-building text-white text-sm" aria-hidden="true"></i>
      </div>
      <span class="font-semibold text-primary-600 text-sm">UTA MACS</span>
    </a>
    <button id="sidebar-toggle" class="p-2 rounded-lg text-text-secondary hover:bg-gray-100" aria-label="Toggle menu">
      <i class="fas fa-bars" aria-hidden="true"></i>
    </button>
  </header>

  <div class="flex h-full lg:h-screen overflow-hidden">

    <!-- Sidebar -->
    <aside
      id="sidebar"
      class="fixed inset-y-0 left-0 z-50 w-64 bg-white border-r border-border-light flex flex-col transform -translate-x-full transition-transform duration-200 ease-in-out lg:static lg:translate-x-0 lg:flex"
      aria-label="Portal navigation"
    >
      <!-- Logo -->
      <div class="p-6 border-b border-border-light">
        <a href="/portal" class="flex items-center gap-3">
          <div class="w-10 h-10 bg-primary-600 rounded-xl flex items-center justify-center flex-shrink-0">
            <i class="fas fa-building text-white" aria-hidden="true"></i>
          </div>
          <div>
            <div class="font-bold text-primary-600 text-sm leading-tight">UTA MACS</div>
            <div class="text-xs text-text-secondary">Resident Portal</div>
          </div>
        </a>
      </div>

      <!-- User info -->
      <div class="px-4 py-3 border-b border-border-light bg-gray-50">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center flex-shrink-0">
            <i class="fas fa-user text-primary-600 text-sm" aria-hidden="true"></i>
          </div>
          <div class="min-w-0">
            <div class="text-sm font-medium text-text-primary truncate">{user.email}</div>
            <div class="text-xs text-text-secondary capitalize">{user.committeeTitle ?? user.role.replace('_', ' ')}</div>
          </div>
        </div>
      </div>

      <!-- Nav search + controls -->
      <div class="border-b border-border-light bg-gray-50/60">
        <!-- Search input -->
        <div class="px-3 pt-2 pb-1.5">
          <div class="relative">
            <i class="fas fa-search absolute left-2.5 top-1/2 -translate-y-1/2 text-text-secondary text-[11px]" aria-hidden="true"></i>
            <input
              id="nav-search"
              type="search"
              placeholder="Search navigation…"
              autocomplete="off"
              aria-label="Search navigation items"
              class="w-full pl-7 pr-7 py-1.5 text-xs rounded-md border border-border-light bg-white text-text-primary placeholder-text-secondary focus:outline-none focus:ring-1 focus:ring-primary-600 focus:border-primary-600 transition-colors"
            />
            <button
              id="nav-search-clear"
              type="button"
              aria-label="Clear search"
              class="absolute right-2 top-1/2 -translate-y-1/2 text-text-secondary hover:text-text-primary hidden"
            >
              <i class="fas fa-times text-[11px]" aria-hidden="true"></i>
            </button>
          </div>
        </div>
        <!-- Collapse / expand controls -->
        <div class="flex items-center justify-end px-4 pb-1.5">
          <div class="flex gap-0.5">
            <button id="collapse-all-btn" title="Collapse all groups" aria-label="Collapse all navigation groups"
              class="w-6 h-6 flex items-center justify-center rounded text-text-secondary hover:text-primary-600 hover:bg-primary-50 transition-colors">
              <i class="fas fa-angle-double-up text-[10px]" aria-hidden="true"></i>
            </button>
            <button id="expand-all-btn" title="Expand all groups" aria-label="Expand all navigation groups"
              class="w-6 h-6 flex items-center justify-center rounded text-text-secondary hover:text-primary-600 hover:bg-primary-50 transition-colors">
              <i class="fas fa-angle-double-down text-[10px]" aria-hidden="true"></i>
            </button>
          </div>
        </div>
      </div>

      <!-- Navigation -->
      <nav id="portal-nav" class="flex-1 overflow-y-auto py-3 px-3" aria-label="Module navigation">
        <!-- Dashboard -->
        <a
          href="/portal"
          class={`nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium mb-3 transition-colors ${
            activeModule === 'dashboard'
              ? 'bg-primary-50 text-primary-600'
              : 'text-text-secondary hover:bg-gray-100 hover:text-text-primary'
          }`}
        >
          <i class="fas fa-home w-4 text-center" aria-hidden="true"></i>
          Dashboard
        </a>

        {navGroups.map((group) => {
          const groupKey = group.label.toLowerCase().replace(/[\s&]+/g, '-');
          const hasActive = group.items.some((i) => i.activeKey === activeModule);
          return (
            <div class="mb-2" data-group-key={groupKey}>
              <button
                type="button"
                class={`nav-group-btn w-full flex items-center justify-between px-3 py-1.5 rounded-md text-xs font-semibold uppercase tracking-wider mb-0.5 transition-colors ${
                  hasActive
                    ? 'text-primary-600 bg-primary-50'
                    : 'text-text-secondary hover:text-text-primary hover:bg-gray-50'
                }`}
                data-group-key={groupKey}
                aria-expanded="true"
              >
                <span>{group.label}</span>
                <i class="fas fa-chevron-down nav-chevron text-[10px] transition-transform duration-200" aria-hidden="true"></i>
              </button>
              <div class="nav-group-items">
                {group.items.map((item) => {
                  const isActive = activeModule === item.activeKey;
                  return (
                    {(() => {
                      const badgeKey: string | undefined = {
                        notifications: 'unread_notifications',
                        notices:        'unread_notices',
                        complaints:     'open_complaints',
                        analytics:      'onboarding_pending',
                        feedback:       'unread_feedback',
                      }[item.activeKey];
                      return (
                        <a
                          href={item.href}
                          class={`nav-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium mb-0.5 transition-colors ${
                            isActive
                              ? 'bg-primary-50 text-primary-600'
                              : 'text-text-secondary hover:bg-gray-100 hover:text-text-primary'
                          }`}
                          {...(badgeKey ? { 'data-badge-key': badgeKey } : {})}
                        >
                          <i class={`fas ${item.icon} w-4 text-center text-[13px]`} aria-hidden="true"></i>
                          {item.label}
                          {badgeKey && (
                            <span
                              class="nav-badge hidden ml-auto min-w-[18px] h-[18px] bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center px-1 leading-none"
                              aria-label="Unread count"
                            ></span>
                          )}
                        </a>
                      );
                    })()}
                  );
                })}
              </div>
            </div>
          );
        })}
      </nav>

      <!-- Footer actions -->
      <div class="p-4 border-t border-border-light space-y-1">
        <a
          href="/portal/profile"
          class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:bg-gray-100 hover:text-text-primary transition-colors"
        >
          <i class="fas fa-user-cog w-4 text-center" aria-hidden="true"></i>
          My Profile
        </a>
        <form method="POST" action="/api/v1/auth/signout">
          <button
            type="submit"
            class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-red-600 hover:bg-red-50 transition-colors"
          >
            <i class="fas fa-sign-out-alt w-4 text-center" aria-hidden="true"></i>
            Sign Out
          </button>
        </form>
      </div>
    </aside>

    <!-- Sidebar overlay (mobile) -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/40 z-40 hidden lg:hidden" aria-hidden="true"></div>

    <!-- Main content -->
    <main class="flex-1 overflow-y-auto">
      <div class="p-6 max-w-7xl mx-auto">
        <slot />
      </div>
    </main>
  </div>

  <script>
    // ── Nav search ────────────────────────────────────────────────────────────
    (function () {
      const searchInput = document.getElementById('nav-search') as HTMLInputElement | null;
      const clearBtn    = document.getElementById('nav-search-clear') as HTMLButtonElement | null;
      const navEl       = document.getElementById('portal-nav') as HTMLElement | null;
      if (!searchInput || !navEl) return;

      // Dashboard link is the first child of the nav (before any groups)
      const dashLink = navEl.querySelector<HTMLElement>('a.nav-link');

      function filterNav(query: string) {
        const q = query.trim().toLowerCase();
        clearBtn?.classList.toggle('hidden', q === '');

        // No query → restore everything to natural collapsed/expanded state
        if (q === '') {
          // Show dashboard
          if (dashLink) dashLink.style.display = '';
          // Let each group and its items go back to their sessionStorage-driven state
          navEl!.querySelectorAll<HTMLElement>('[data-group-key]').forEach((group) => {
            group.style.display = '';
          });
          navEl!.querySelectorAll<HTMLElement>('.nav-group-items').forEach((items) => {
            // Restore the hidden class that the collapse logic controls — don't touch it
            items.style.display = '';
          });
          navEl!.querySelectorAll<HTMLElement>('.nav-group-items a.nav-link').forEach((a) => {
            a.style.display = '';
          });
          // Remove no-results placeholder if present
          document.getElementById('nav-no-results')?.remove();
          return;
        }

        // Hide dashboard unless it matches
        if (dashLink) {
          dashLink.style.display = dashLink.textContent!.toLowerCase().includes(q) ? '' : 'none';
        }

        let anyVisible = dashLink?.style.display !== 'none' && dashLink != null
          ? dashLink.textContent!.toLowerCase().includes(q)
          : false;

        // For each group, show/hide individual links and hide the whole group if none match
        navEl!.querySelectorAll<HTMLElement>('[data-group-key]').forEach((group) => {
          const itemsEl = group.querySelector<HTMLElement>('.nav-group-items');
          if (!itemsEl) return;

          const links = [...itemsEl.querySelectorAll<HTMLElement>('a.nav-link')];
          let groupHasMatch = false;

          links.forEach((a) => {
            const matches = a.textContent!.trim().toLowerCase().includes(q);
            a.style.display = matches ? '' : 'none';
            if (matches) groupHasMatch = true;
          });

          // Show group (always expanded while searching) or hide it entirely
          group.style.display   = groupHasMatch ? '' : 'none';
          itemsEl.style.display = groupHasMatch ? '' : 'none';
          if (groupHasMatch) anyVisible = true;
        });

        // No-results state
        const existing = document.getElementById('nav-no-results');
        if (!anyVisible) {
          if (!existing) {
            const el = document.createElement('p');
            el.id = 'nav-no-results';
            el.className = 'text-xs text-text-secondary text-center py-6 px-3';
            el.textContent = 'No results for "' + query.trim() + '"';
            navEl!.appendChild(el);
          } else {
            existing.textContent = 'No results for "' + query.trim() + '"';
          }
        } else {
          existing?.remove();
        }
      }

      searchInput.addEventListener('input', () => filterNav(searchInput.value));
      clearBtn?.addEventListener('click', () => {
        searchInput.value = '';
        filterNav('');
        searchInput.focus();
      });

      // Keyboard shortcut: / focuses search when nav is visible
      document.addEventListener('keydown', (e) => {
        if (e.key === '/' && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
          e.preventDefault();
          searchInput.focus();
          searchInput.select();
        }
      });
    })();

    // ── Mobile sidebar toggle ─────────────────────────────────────────────────
    const toggle  = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    function openSidebar()  { sidebar?.classList.remove('-translate-x-full'); overlay?.classList.remove('hidden'); }
    function closeSidebar() { sidebar?.classList.add('-translate-x-full');    overlay?.classList.add('hidden'); }

    toggle?.addEventListener('click', openSidebar);
    overlay?.addEventListener('click', closeSidebar);

    // ── Nav scroll position preservation ─────────────────────────────────────
    const navEl = document.getElementById('portal-nav') as HTMLElement | null;
    const SCROLL_KEY    = 'portal-nav-scroll';
    const COLLAPSE_PFX  = 'portal-nav-col-';

    if (navEl) {
      // Restore scroll — defer one tick so layout is complete
      const savedScroll = sessionStorage.getItem(SCROLL_KEY);
      if (savedScroll) requestAnimationFrame(() => { navEl.scrollTop = parseInt(savedScroll, 10); });

      // Save scroll on every nav link click before navigation
      navEl.querySelectorAll('a.nav-link').forEach((a) => {
        a.addEventListener('click', () => sessionStorage.setItem(SCROLL_KEY, String(navEl.scrollTop)));
      });
    }

    // ── Group collapse / expand ───────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('.nav-group-btn').forEach((btn) => {
      const groupKey = btn.getAttribute('data-group-key') ?? '';
      const itemsEl  = btn.nextElementSibling as HTMLElement | null;
      const chevron  = btn.querySelector<HTMLElement>('.nav-chevron');
      if (!itemsEl) return;

      const hasActive = !!itemsEl.querySelector('.bg-primary-50');
      // Default: collapsed unless this group contains the active page or user explicitly expanded it
      const stored = sessionStorage.getItem(`${COLLAPSE_PFX}${groupKey}`);
      const isCollapsed = !hasActive && stored !== '0';

      function applyCollapse(collapsed: boolean) {
        itemsEl!.classList.toggle('hidden', collapsed);
        if (chevron) chevron.style.transform = collapsed ? 'rotate(-90deg)' : '';
        btn.setAttribute('aria-expanded', String(!collapsed));
      }

      applyCollapse(isCollapsed);

      btn.addEventListener('click', () => {
        const nowCollapsed = !itemsEl.classList.contains('hidden');
        applyCollapse(nowCollapsed);
        sessionStorage.setItem(`${COLLAPSE_PFX}${groupKey}`, nowCollapsed ? '1' : '0');
      });
    });

    // ── Collapse all / Expand all ─────────────────────────────────────────────
    function setAllGroups(collapsed: boolean) {
      document.querySelectorAll<HTMLButtonElement>('.nav-group-btn').forEach((btn) => {
        const groupKey  = btn.getAttribute('data-group-key') ?? '';
        const itemsEl   = btn.nextElementSibling as HTMLElement | null;
        const chevron   = btn.querySelector<HTMLElement>('.nav-chevron');
        if (!itemsEl) return;
        itemsEl.classList.toggle('hidden', collapsed);
        if (chevron) chevron.style.transform = collapsed ? 'rotate(-90deg)' : '';
        btn.setAttribute('aria-expanded', String(!collapsed));
        sessionStorage.setItem(`${COLLAPSE_PFX}${groupKey}`, collapsed ? '1' : '0');
      });
    }

    document.getElementById('collapse-all-btn')?.addEventListener('click', () => setAllGroups(true));
    document.getElementById('expand-all-btn')?.addEventListener('click', () => setAllGroups(false));

    // Snake process-flow layout
    (function () {
      const CARD_W = 208; // w-52
      const GAP    = 8;   // gap-2
      const ARR_W  = 14;  // approx font-icon width
      const UNIT   = CARD_W + GAP + ARR_W + GAP; // ~238px per card+arrow slot

      const savedCards = new WeakMap<HTMLElement, HTMLElement[]>();

      function buildSnake(container: HTMLElement) {
        const cRect = container.getBoundingClientRect();
        if (cRect.width < 10) return; // inside a closed <details> — width is 0, skip

        let cards = savedCards.get(container);
        if (!cards) {
          cards = [...container.querySelectorAll<HTMLElement>(':scope > .flex-shrink-0')];
          if (cards.length < 2) return;
          savedCards.set(container, cards);
        }

        container.innerHTML = '';
        const w = cRect.width;
        const perRow = Math.max(2, Math.floor((w + GAP + ARR_W) / UNIT));

        const rows: HTMLElement[][] = [];
        for (let i = 0; i < cards.length; i += perRow) rows.push(cards.slice(i, i + perRow));

        // prevEndCenterX: center-X (relative to container left) of the turn card from the previous row.
        // Used to pixel-align each next row's starting card under the turn card above it.
        let prevEndCenterX = 0;

        rows.forEach((rowCards, rowIdx) => {
          const isRTL = rowIdx % 2 === 1;
          // Reverse display order for RTL rows so steps flow right→left visually
          const displayCards = isRTL ? [...rowCards].reverse() : rowCards;

          const rowEl = document.createElement('div');
          rowEl.className = 'flex items-center gap-2';

          if (isRTL) {
            // justify-end + padding-right: the last DOM card (step N+1, rightmost visual)
            // lands exactly at prevEndCenterX — directly below the last card of the LTR row above.
            rowEl.style.justifyContent = 'flex-end';
            rowEl.style.paddingRight = `${Math.max(0, w - prevEndCenterX - CARD_W / 2)}px`;
          } else if (rowIdx > 0) {
            // padding-left: the first card of this LTR row starts at prevEndCenterX,
            // directly below the leftmost card of the RTL row above.
            rowEl.style.paddingLeft = `${Math.max(0, prevEndCenterX - CARD_W / 2)}px`;
          }

          displayCards.forEach((card, i) => {
            rowEl.appendChild(card);
            if (i < displayCards.length - 1) {
              const arr = document.createElement('i');
              arr.className = `fas fa-arrow-${isRTL ? 'left' : 'right'} text-gray-300 text-sm flex-shrink-0`;
              arr.setAttribute('aria-hidden', 'true');
              rowEl.appendChild(arr);
            }
          });

          container.appendChild(rowEl);

          if (rowIdx < rows.length - 1) {
            // Measure the turn card after it's in the DOM to get its true pixel position.
            const cLeft = container.getBoundingClientRect().left;
            const cardEls = [...rowEl.children].filter(
              el => (el as HTMLElement).tagName === 'DIV'
            ) as HTMLElement[];

            // LTR: turn card = last DOM card (rightmost visual)
            // RTL: turn card = first DOM card (leftmost visual, since displayCards is reversed + justify-end)
            const turnCard = isRTL ? cardEls[0] : cardEls[cardEls.length - 1];
            const tr = turnCard.getBoundingClientRect();
            prevEndCenterX = tr.left + tr.width / 2 - cLeft;

            // Down arrow: padding-left positions it precisely at prevEndCenterX
            const turnEl = document.createElement('div');
            turnEl.style.cssText = `display:flex; padding-left:${Math.max(0, prevEndCenterX - 7)}px; padding-top:3px; padding-bottom:3px;`;
            const turnArr = document.createElement('i');
            turnArr.className = 'fas fa-arrow-down text-gray-400 text-sm';
            turnArr.setAttribute('aria-hidden', 'true');
            turnEl.appendChild(turnArr);
            container.appendChild(turnEl);
          }
        });
      }

      // Initial build for any panels already visible on load
      document.querySelectorAll<HTMLElement>('.process-snake-flow').forEach(c => buildSnake(c));

      // Build when a <details> panel is opened (panels start collapsed by default)
      document.querySelectorAll('details').forEach(det => {
        det.addEventListener('toggle', () => {
          if ((det as HTMLDetailsElement).open) {
            det.querySelectorAll<HTMLElement>('.process-snake-flow').forEach(c => buildSnake(c));
          }
        });
      });

      // Rebuild open panels on resize
      let resizeTimer: ReturnType<typeof setTimeout>;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
          document.querySelectorAll<HTMLElement>('.process-snake-flow').forEach(c => {
            const det = c.closest('details');
            if (!det || (det as HTMLDetailsElement).open) buildSnake(c);
          });
        }, 250);
      });
    })();

    // ── Nav badges (unread counts) ────────────────────────────────────────────
    (async function () {
      try {
        const res = await fetch('/api/v1/nav/badges', { credentials: 'include' });
        if (!res.ok) return;
        const counts = await res.json() as Record<string, number>;
        document.querySelectorAll<HTMLElement>('[data-badge-key]').forEach((link) => {
          const key = link.getAttribute('data-badge-key')!;
          const count = counts[key] ?? 0;
          if (count > 0) {
            const badge = link.querySelector<HTMLElement>('.nav-badge');
            if (badge) {
              badge.textContent = count > 99 ? '99+' : String(count);
              badge.classList.remove('hidden');
            }
          }
        });
      } catch { /* non-critical */ }
    })();
  </script>
</body>
</html>

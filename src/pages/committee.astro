---
import Layout from '@components/layout/Layout.astro';
import SectionHero from '@components/ui/SectionHero.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import CommitteeMemberCard from '@components/ui/CommitteeMemberCard.astro';
import { committeeMembers, executiveMembers } from '@data/committee';
---
<Layout
  title="Committee Members – UTA MACS"
  description="Meet the elected committee members who manage and serve the UTA MACS residential community."
>
  <SectionHero
    title="Our Committee"
    subtitle="Unanimously elected representatives dedicated to serving our community."
  />

  <!-- Election note -->
  <section class="section bg-section-alt">
    <div class="container-custom">
      <div class="max-w-2xl mx-auto text-center animate-on-scroll">
        <div class="card-premium bg-primary-50 border-primary-200">
          <i class="fas fa-award text-3xl text-primary-600 mb-3 block" aria-hidden="true"></i>
          <p class="text-body text-text-secondary leading-relaxed">
            Thanks one and all for electing our Association unanimously. We are also thankful to
            <strong class="text-text-primary">Sri C. L. N. Gandhi garu</strong>, Election Officer,
            for conducting the election in a smooth and transparent manner.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Committee -->
  <section class="section">
    <div class="container-custom">
      <SectionHeader
        title="Elected Committee Members"
        subtitle="The following members have been unanimously elected."
        centered={true}
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {committeeMembers.map((member, i) => (
          <CommitteeMemberCard
            {...member}
            animationDelay={`${i * 0.07}s`}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Executive Members -->
  <section class="section bg-section-alt">
    <div class="container-custom">
      <SectionHeader
        title="Executive Members"
        subtitle="Portfolio holders responsible for key community functions."
        centered={true}
      />

      <div class="max-w-3xl mx-auto grid grid-cols-1 sm:grid-cols-2 gap-4">
        {executiveMembers.map((member, i) => (
          <div
            class="card-premium animate-on-scroll flex items-center gap-4"
            style={`transition-delay: ${i * 0.07}s`}
          >
            <div class="w-12 h-12 bg-secondary-100 text-secondary-700 rounded-xl flex items-center justify-center font-bold text-sm flex-shrink-0">
              {member.initials}
            </div>
            <div>
              <p class="font-semibold text-text-primary text-small">{member.name}</p>
              <p class="text-xs text-text-secondary mt-0.5">
                <i class="fas fa-briefcase mr-1 text-secondary-500" aria-hidden="true"></i>
                {member.portfolio}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact committee section -->
  <section class="section">
    <div class="container-custom">
      <div class="max-w-2xl mx-auto text-center animate-on-scroll">
        <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
          <i class="fas fa-envelope text-2xl text-primary-600" aria-hidden="true"></i>
        </div>
        <h2 class="text-section font-bold text-text-primary mb-4">Reach Out to the Committee</h2>
        <p class="text-body text-text-secondary mb-8">
          Have a concern, suggestion, or feedback? Write to us at
          <a href="mailto:urbantrillaresidents@gmail.com" class="text-primary-600 font-semibold hover:underline">urbantrillaresidents@gmail.com</a>
          or use the contact form.
        </p>
        <a href="/contact" class="btn-primary px-8 py-3">
          <i class="fas fa-paper-plane mr-2" aria-hidden="true"></i>
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Layout>

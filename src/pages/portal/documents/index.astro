---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const canUpload = ['executive', 'admin'].includes(user.role) || user.isAdmin;
---

<PortalLayout title="Documents" user={user} activeModule="documents">
  <!-- Process info panel -->
  <details class="mb-6 group rounded-xl border border-primary-100 bg-gradient-to-r from-primary-50/50 to-blue-50/20 overflow-hidden">
    <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer list-none select-none hover:bg-primary-50/60 transition-colors">
      <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-project-diagram text-white text-xs" aria-hidden="true"></i>
      </div>
      <span class="text-sm font-medium text-text-primary flex-1">Official society documents — bye-laws, audit reports, AGM minutes, and circulars — stored and categorised for resident access.</span>
      <span class="text-xs text-primary-600 flex items-center gap-1.5 flex-shrink-0 font-medium">
        How it works
        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200 group-open:rotate-180" aria-hidden="true"></i>
      </span>
    </summary>
    <div class="px-5 pb-5">
      <div class="pt-4 border-t border-primary-100 space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 py-2">
          <div class="bg-white rounded-lg border border-border-light p-4">
            <div class="w-8 h-8 rounded-lg bg-primary-50 flex items-center justify-center mb-2">
              <i class="fas fa-folder-open text-primary-600 text-sm"></i>
            </div>
            <div class="text-sm font-semibold text-text-primary mb-1">Document Categories</div>
            <div class="text-xs text-text-secondary">Society records organised into Governance, Finance, Legal, Minutes, HOTO, Circulars, and more.</div>
          </div>
          <div class="bg-white rounded-lg border border-border-light p-4">
            <div class="w-8 h-8 rounded-lg bg-secondary-50 flex items-center justify-center mb-2">
              <i class="fas fa-lock text-secondary-500 text-sm"></i>
            </div>
            <div class="text-sm font-semibold text-text-primary mb-1">Access Control</div>
            <div class="text-xs text-text-secondary">Some documents are restricted to executives. Members can view all member-level and public documents.</div>
          </div>
          <div class="bg-white rounded-lg border border-border-light p-4">
            <div class="w-8 h-8 rounded-lg bg-accent-500/10 flex items-center justify-center mb-2">
              <i class="fas fa-upload text-accent-500 text-sm"></i>
            </div>
            <div class="text-sm font-semibold text-text-primary mb-1">Uploading Documents</div>
            <div class="text-xs text-text-secondary">Only Secretary and above can upload or archive documents. PDF, DOCX, XLSX, and CSV supported.</div>
          </div>
        </div>
      </div>
    </div>
  </details>

  <div class="mb-5 flex items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-primary-600 font-poppins">Documents</h1>
      <p class="text-text-secondary text-sm mt-1">Society bylaws, meeting minutes, circulars, and more.</p>
    </div>
    <div class="flex items-center gap-3">
      <div class="relative">
        <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-text-secondary text-xs" aria-hidden="true"></i>
        <input id="search-input" type="text" placeholder="Search documents…" class="form-input pl-8 py-2 text-sm" style="width:200px" />
      </div>
      {canUpload && (
        <button id="upload-btn" class="btn-primary text-sm flex items-center gap-2">
          <i class="fas fa-upload" aria-hidden="true"></i>
          Upload
        </button>
      )}
    </div>
  </div>

  <!-- Category tabs (include new categories from migration 050) -->
  <div class="flex gap-2 flex-wrap mb-5" id="category-filters">
    {['All','Bylaws','Minutes','Financial','Legal','Circulars','Governance','HOTO','Maintenance','Forms','Other'].map(cat => (
      <button data-cat={cat === 'All' ? '' : cat}
        class={`filter-btn text-xs px-3 py-1.5 rounded-full font-medium border transition-colors ${cat === 'All' ? 'bg-primary-600 text-white border-primary-600' : 'bg-white text-text-secondary border-border-light hover:border-primary-600 hover:text-primary-600'}`}>
        {cat}
      </button>
    ))}
  </div>

  <div id="documents-container">
    <div class="text-center py-10 text-text-secondary text-sm">Loading…</div>
  </div>

  <!-- Version history drawer -->
  <div id="history-drawer" class="fixed inset-y-0 right-0 w-full sm:w-96 bg-white shadow-large z-40 transform translate-x-full transition-transform duration-300 overflow-y-auto">
    <div class="sticky top-0 bg-white border-b border-border-light p-4 flex items-center justify-between">
      <div>
        <h2 class="text-lg font-semibold text-primary-600">Version History</h2>
        <p id="history-doc-title" class="text-xs text-text-secondary mt-0.5"></p>
      </div>
      <button id="close-history" class="text-text-secondary hover:text-text-primary p-1" aria-label="Close">
        <i class="fas fa-times text-xl" aria-hidden="true"></i>
      </button>
    </div>
    <div id="history-list" class="p-4 space-y-3">
      <div class="text-sm text-text-secondary text-center py-8">Loading…</div>
    </div>
  </div>
  <div id="history-backdrop" class="fixed inset-0 bg-black/40 z-30 hidden"></div>

  <!-- Upload modal (exec/admin only) -->
  {canUpload && (
    <div id="upload-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
      <div class="bg-white rounded-2xl shadow-large w-full max-w-md overflow-hidden">
        <div class="px-6 py-4 border-b border-border-light flex items-center justify-between">
          <h3 class="text-lg font-semibold text-primary-600">Upload Document</h3>
          <button id="modal-close" class="text-text-secondary hover:text-text-primary p-2" aria-label="Close">
            <i class="fas fa-times" aria-hidden="true"></i>
          </button>
        </div>
        <div class="p-6 space-y-4">
          <div id="upload-error" class="hidden p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>

          <div>
            <label class="form-label" for="up-file">File <span class="text-red-500">*</span></label>
            <div id="file-drop-zone"
              class="border-2 border-dashed border-border-light rounded-xl p-5 text-center text-sm text-text-secondary hover:border-primary-400 hover:bg-primary-50/30 transition-colors cursor-pointer">
              <i class="fas fa-cloud-upload-alt text-2xl text-primary-300 mb-2 block" aria-hidden="true"></i>
              <span id="file-drop-label">Drop file here or <span class="text-primary-600 font-medium">click to select</span></span>
              <div class="text-xs mt-1 text-text-secondary">PDF, DOCX, XLSX, CSV, JPG, PNG — up to 20 MB</div>
            </div>
            <input type="file" id="up-file" accept=".pdf,.docx,.xlsx,.xls,.csv,.jpg,.jpeg,.png" class="hidden" />
          </div>

          <div>
            <label class="form-label" for="up-title">Title <span class="text-red-500">*</span></label>
            <input id="up-title" type="text" maxlength="200" class="form-input" placeholder="e.g. AGM Minutes April 2025" />
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="form-label" for="up-category">Category <span class="text-red-500">*</span></label>
              <select id="up-category" class="form-input bg-white">
                <option value="">Select</option>
                {['Bylaws','Minutes','Financial','Legal','Circulars','Governance','HOTO','Maintenance','Forms','Other'].map(c => (
                  <option value={c}>{c}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="form-label" for="up-access">Access</label>
              <select id="up-access" class="form-input bg-white">
                <option value="member">Members</option>
                <option value="executive">Exec only</option>
              </select>
            </div>
          </div>

          <div>
            <label class="form-label" for="up-description">Description</label>
            <textarea id="up-description" rows="2" maxlength="500" class="form-input resize-none" placeholder="Brief description (optional)"></textarea>
          </div>

          <div class="flex items-center gap-2">
            <input type="checkbox" id="up-public" class="w-4 h-4 accent-primary-600" />
            <label for="up-public" class="text-sm text-text-primary">Public (visible without login)</label>
          </div>
        </div>
        <div class="px-6 pb-6 flex gap-3">
          <button id="upload-submit-btn" class="btn-primary flex-1 flex items-center justify-center gap-2 text-sm">
            <i class="fas fa-upload" aria-hidden="true"></i>
            <span id="upload-submit-label">Upload Document</span>
          </button>
          <button id="modal-cancel" class="btn-outline flex-1 text-sm">Cancel</button>
        </div>
      </div>
    </div>
  )}

  <!-- New version modal (exec/admin only) -->
  {canUpload && (
    <div id="nv-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
      <div class="bg-white rounded-2xl shadow-large w-full max-w-md overflow-hidden">
        <div class="px-6 py-4 border-b border-border-light flex items-center justify-between">
          <div>
            <h3 class="text-lg font-semibold text-primary-600">Upload New Version</h3>
            <p id="nv-doc-name" class="text-xs text-text-secondary mt-0.5 truncate"></p>
          </div>
          <button id="nv-close" class="text-text-secondary hover:text-text-primary p-2" aria-label="Close">
            <i class="fas fa-times" aria-hidden="true"></i>
          </button>
        </div>
        <div class="p-6 space-y-4">
          <div id="nv-error" class="hidden p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
          <div>
            <label class="form-label" for="nv-file">Replacement file <span class="text-red-500">*</span></label>
            <div id="nv-drop-zone"
              class="border-2 border-dashed border-border-light rounded-xl p-5 text-center text-sm text-text-secondary hover:border-primary-400 hover:bg-primary-50/30 transition-colors cursor-pointer">
              <i class="fas fa-code-branch text-2xl text-primary-300 mb-2 block" aria-hidden="true"></i>
              <span id="nv-drop-label">Drop replacement file here or <span class="text-primary-600 font-medium">click to select</span></span>
              <div class="text-xs mt-1 text-text-secondary">Same formats as upload — max 20 MB</div>
            </div>
            <input type="file" id="nv-file" accept=".pdf,.docx,.xlsx,.xls,.csv,.jpg,.jpeg,.png" class="hidden" />
          </div>
          <div>
            <label class="form-label" for="nv-notes">Change notes</label>
            <input id="nv-notes" type="text" maxlength="300" class="form-input" placeholder="e.g. Updated clause 4.2 and appendix B" />
          </div>
        </div>
        <div class="px-6 pb-6 flex gap-3">
          <button id="nv-submit" class="btn-primary flex-1 flex items-center justify-center gap-2 text-sm">
            <i class="fas fa-code-branch" aria-hidden="true"></i>
            <span id="nv-submit-label">Save New Version</span>
          </button>
          <button id="nv-cancel" class="btn-outline flex-1 text-sm">Cancel</button>
        </div>
      </div>
    </div>
  )}

  <script define:vars={{ canUpload }}>
    const MIME_ICONS = {
      'application/pdf': 'fa-file-pdf text-red-500',
      'application/msword': 'fa-file-word text-blue-500',
      'application/vnd.openxmlformats-officedocument.wordprocessingml.document': 'fa-file-word text-blue-500',
      'application/vnd.ms-excel': 'fa-file-excel text-green-500',
      'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet': 'fa-file-excel text-green-500',
      'text/csv': 'fa-file-csv text-green-600',
      'image/jpeg': 'fa-file-image text-purple-500',
      'image/png': 'fa-file-image text-purple-500',
    };

    function formatSize(bytes) {
      if (!bytes) return '';
      if (bytes < 1024) return `${bytes} B`;
      if (bytes < 1048576) return `${(bytes / 1024).toFixed(1)} KB`;
      return `${(bytes / 1048576).toFixed(1)} MB`;
    }

    function showToast(message, type = 'success') {
      const toast = document.createElement('div');
      const color = type === 'success' ? 'bg-secondary-500' : 'bg-red-500';
      toast.className = `fixed bottom-6 right-6 z-50 px-4 py-3 rounded-xl shadow-large text-sm font-medium text-white transform translate-y-4 opacity-0 transition-all duration-300 ${color}`;
      toast.textContent = message;
      document.body.appendChild(toast);
      requestAnimationFrame(() => toast.classList.remove('translate-y-4', 'opacity-0'));
      setTimeout(() => { toast.classList.add('translate-y-4', 'opacity-0'); setTimeout(() => toast.remove(), 300); }, 3000);
    }

    let currentCategory = '';
    let searchQuery = '';
    let searchTimeout = null;

    async function loadDocuments() {
      const container = document.getElementById('documents-container');
      const params = new URLSearchParams();
      if (currentCategory) params.set('category', currentCategory);
      if (searchQuery)     params.set('q', searchQuery);

      const res = await fetch(`/api/v1/documents?${params}`, { credentials: 'include' });
      const docs = res.ok ? await res.json() : [];

      if (!docs.length) {
        container.innerHTML = '<div class="text-center py-10 text-text-secondary text-sm">No documents found.</div>';
        return;
      }

      // Group by category when not filtered
      const grouped = {};
      docs.forEach(d => {
        if (!grouped[d.category]) grouped[d.category] = [];
        grouped[d.category].push(d);
      });

      container.innerHTML = Object.entries(grouped).map(([cat, items]) => `
        <div class="mb-6">
          <h2 class="text-sm font-semibold text-text-secondary uppercase tracking-wide mb-3 flex items-center gap-2">
            <i class="fas fa-folder text-primary-300 text-xs" aria-hidden="true"></i>
            ${cat}
            <span class="text-xs font-normal text-text-secondary">(${items.length})</span>
          </h2>
          <div class="bg-white rounded-xl border border-border-light overflow-hidden">
            ${items.map((d) => {
              const icon = MIME_ICONS[d.mime_type] ?? 'fa-file text-gray-400';
              return `
                <div class="flex items-center gap-4 px-5 py-4 border-b border-border-light last:border-b-0 hover:bg-gray-50 transition-colors">
                  <i class="fas ${icon} text-xl w-6 text-center flex-shrink-0" aria-hidden="true"></i>
                  <div class="flex-1 min-w-0 cursor-pointer" onclick="location.href='/portal/documents/${d.id}'">
                    <div class="flex items-center gap-2">
                      <span class="text-sm font-medium text-text-primary truncate hover:text-primary-600 transition-colors">${d.title}</span>
                      ${(d.version ?? 1) > 1 ? `<span class="text-xs bg-primary-100 text-primary-700 px-1.5 py-0.5 rounded font-medium flex-shrink-0">v${d.version}</span>` : ''}
                    </div>
                    <div class="text-xs text-text-secondary mt-0.5">
                      ${d.file_name ? `${d.file_name} · ` : ''}${formatSize(d.file_size_bytes)}
                      · ${new Date(d.created_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </div>
                    ${d.description ? `<div class="text-xs text-text-secondary mt-0.5 truncate">${d.description}</div>` : ''}
                  </div>
                  <div class="flex items-center gap-1 flex-shrink-0">
                    ${d.requires_role === 'executive' ? '<span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded-full font-medium mr-1">Exec only</span>' : ''}
                    <a href="/portal/documents/${d.id}"
                       class="btn-ghost text-xs px-2 py-1.5 text-primary-600 hover:text-primary-700" title="View details">
                      <i class="fas fa-eye text-xs" aria-hidden="true"></i>
                    </a>
                    ${(d.version ?? 1) > 1
                      ? `<button onclick="openHistory('${d.id}', '${d.title.replace(/'/g, "\\'")}')"
                           class="btn-ghost text-xs px-2 py-1.5 text-text-secondary hover:text-primary-600" title="Version history">
                           <i class="fas fa-history text-xs" aria-hidden="true"></i>
                         </button>`
                      : ''
                    }
                    ${d.download_url
                      ? `<a href="${d.download_url}" target="_blank" rel="noopener"
                           class="btn-ghost text-xs px-3 py-1.5 flex items-center gap-1 text-primary-600">
                           <i class="fas fa-download text-xs" aria-hidden="true"></i> Download
                         </a>`
                      : ''
                    }
                    ${canUpload
                      ? `<button onclick="openNewVersion('${d.id}', '${d.title.replace(/'/g, "\\'")}')"
                           class="btn-ghost text-xs px-2 py-1.5 text-text-secondary hover:text-primary-600" title="Upload new version">
                           <i class="fas fa-code-branch text-xs" aria-hidden="true"></i>
                         </button>
                         <button onclick="archiveDoc('${d.id}')"
                           class="btn-ghost text-xs px-2 py-1.5 text-text-secondary hover:text-red-600" title="Archive">
                           <i class="fas fa-archive text-xs" aria-hidden="true"></i>
                         </button>`
                      : ''
                    }
                  </div>
                </div>
              `;
            }).join('')}
          </div>
        </div>
      `).join('');
    }

    async function archiveDoc(id) {
      if (!confirm('Archive this document? It can be recovered by administrators.')) return;
      const res = await fetch(`/api/v1/documents?id=${id}`, { method: 'DELETE', credentials: 'include' });
      if (res.ok) { showToast('Document archived.'); loadDocuments(); }
      else { showToast('Failed to archive document.', 'error'); }
    }

    // ── Version history drawer ────────────────────────────────────────────────
    const historyDrawer   = document.getElementById('history-drawer');
    const historyBackdrop = document.getElementById('history-backdrop');
    const historyList     = document.getElementById('history-list');
    const historyTitle    = document.getElementById('history-doc-title');

    function closeHistory() {
      historyDrawer.classList.add('translate-x-full');
      historyBackdrop.classList.add('hidden');
    }
    document.getElementById('close-history').addEventListener('click', closeHistory);
    historyBackdrop.addEventListener('click', closeHistory);

    async function openHistory(docId, title) {
      historyTitle.textContent = title;
      historyList.innerHTML = '<div class="text-sm text-text-secondary text-center py-8">Loading…</div>';
      historyDrawer.classList.remove('translate-x-full');
      historyBackdrop.classList.remove('hidden');

      const res = await fetch(`/api/v1/documents/${docId}/history`, { credentials: 'include' });
      const versions = res.ok ? await res.json() : [];

      if (!versions.length) {
        historyList.innerHTML = '<div class="text-sm text-text-secondary text-center py-8">No version history found.</div>';
        return;
      }

      historyList.innerHTML = versions.map(v => `
        <div class="bg-white rounded-xl border border-border-light p-4 flex items-start gap-3">
          <div class="flex-shrink-0 mt-0.5">
            ${v.is_current
              ? '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-secondary-500 text-white">Current</span>'
              : `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-text-secondary">v${v.version}</span>`
            }
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-xs text-text-secondary">${v.file_name ?? '—'} · ${formatSize(v.file_size_bytes)}</div>
            <div class="text-xs text-text-secondary mt-0.5">${new Date(v.created_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</div>
          </div>
          ${v.download_url
            ? `<a href="${v.download_url}" target="_blank" rel="noopener" class="btn-ghost text-xs px-2 py-1.5 text-primary-600 flex-shrink-0">
                 <i class="fas fa-download text-xs" aria-hidden="true"></i>
               </a>`
            : ''
          }
        </div>
      `).join('');
    }

    // ── New version upload ────────────────────────────────────────────────────
    let newVersionDocId = '';

    function openNewVersion(docId, title) {
      newVersionDocId = docId;
      document.getElementById('nv-doc-name').textContent = title;
      document.getElementById('nv-file').value = '';
      document.getElementById('nv-drop-label').innerHTML = 'Drop replacement file here or <span class="text-primary-600 font-medium">click to select</span>';
      document.getElementById('nv-notes').value = '';
      document.getElementById('nv-error').classList.add('hidden');
      document.getElementById('nv-modal').classList.remove('hidden');
    }

    // ── New version modal wiring ──────────────────────────────────────────────
    if (canUpload) {
      const nvModal    = document.getElementById('nv-modal');
      const nvFileInp  = document.getElementById('nv-file');
      const nvDropZone = document.getElementById('nv-drop-zone');
      const nvDropLbl  = document.getElementById('nv-drop-label');
      const nvErrEl    = document.getElementById('nv-error');
      const nvSubmit   = document.getElementById('nv-submit');
      const nvLbl      = document.getElementById('nv-submit-label');

      function closeNvModal() { nvModal.classList.add('hidden'); newVersionDocId = ''; }
      document.getElementById('nv-close').addEventListener('click', closeNvModal);
      document.getElementById('nv-cancel').addEventListener('click', closeNvModal);
      nvModal.addEventListener('click', (e) => { if (e.target === nvModal) closeNvModal(); });

      nvDropZone.addEventListener('click', () => nvFileInp.click());
      nvDropZone.addEventListener('dragover', (e) => { e.preventDefault(); nvDropZone.classList.add('border-primary-400', 'bg-primary-50/50'); });
      nvDropZone.addEventListener('dragleave', () => nvDropZone.classList.remove('border-primary-400', 'bg-primary-50/50'));
      nvDropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        nvDropZone.classList.remove('border-primary-400', 'bg-primary-50/50');
        const f = e.dataTransfer?.files[0];
        if (f) { nvFileInp.files = e.dataTransfer.files; nvDropLbl.textContent = f.name; }
      });
      nvFileInp.addEventListener('change', () => { if (nvFileInp.files?.[0]) nvDropLbl.textContent = nvFileInp.files[0].name; });

      nvSubmit.addEventListener('click', async () => {
        nvErrEl.classList.add('hidden');
        const file = nvFileInp.files?.[0];
        if (!file) { nvErrEl.textContent = 'Please select a replacement file.'; nvErrEl.classList.remove('hidden'); return; }

        nvSubmit.disabled = true;
        nvLbl.textContent = 'Saving…';

        const fd = new FormData();
        fd.append('file', file);
        fd.append('notes', document.getElementById('nv-notes').value.trim());

        try {
          const res = await fetch(`/api/v1/documents/${newVersionDocId}`, { method: 'PUT', credentials: 'include', body: fd });
          const data = await res.json();
          if (!res.ok) throw new Error(data.message ?? data.error ?? 'Upload failed');
          showToast(`Version ${data.version} saved.`);
          closeNvModal();
          loadDocuments();
        } catch (err) {
          nvErrEl.textContent = err.message;
          nvErrEl.classList.remove('hidden');
        } finally {
          nvSubmit.disabled = false;
          nvLbl.textContent = 'Save New Version';
        }
      });
    }

    window.archiveDoc = archiveDoc;
    window.openHistory = openHistory;
    window.openNewVersion = openNewVersion;

    // Category filter
    document.getElementById('category-filters').addEventListener('click', (e) => {
      const btn = e.target.closest('.filter-btn');
      if (!btn) return;
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('bg-primary-600', 'text-white', 'border-primary-600');
        b.classList.add('bg-white', 'text-text-secondary', 'border-border-light');
      });
      btn.classList.add('bg-primary-600', 'text-white', 'border-primary-600');
      btn.classList.remove('bg-white', 'text-text-secondary', 'border-border-light');
      currentCategory = btn.dataset.cat ?? '';
      loadDocuments();
    });

    // Search
    document.getElementById('search-input').addEventListener('input', (e) => {
      if (searchTimeout) clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        searchQuery = e.target.value.trim();
        loadDocuments();
      }, 300);
    });

    // Upload modal
    if (canUpload) {
      const modal      = document.getElementById('upload-modal');
      const fileInput  = document.getElementById('up-file');
      const dropZone   = document.getElementById('file-drop-zone');
      const dropLabel  = document.getElementById('file-drop-label');
      const errEl      = document.getElementById('upload-error');
      const submitBtn  = document.getElementById('upload-submit-btn');
      const submitLabel= document.getElementById('upload-submit-label');

      function openModal() { modal.classList.remove('hidden'); errEl.classList.add('hidden'); fileInput.value = ''; dropLabel.innerHTML = 'Drop file here or <span class="text-primary-600 font-medium">click to select</span>'; }
      function closeModal() { modal.classList.add('hidden'); }

      document.getElementById('upload-btn').addEventListener('click', openModal);
      document.getElementById('modal-close').addEventListener('click', closeModal);
      document.getElementById('modal-cancel').addEventListener('click', closeModal);
      modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

      dropZone.addEventListener('click', () => fileInput.click());
      dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-primary-400', 'bg-primary-50/50'); });
      dropZone.addEventListener('dragleave', ()  => { dropZone.classList.remove('border-primary-400', 'bg-primary-50/50'); });
      dropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('border-primary-400', 'bg-primary-50/50');
        const file = e.dataTransfer?.files[0];
        if (file) { fileInput.files = e.dataTransfer.files; dropLabel.textContent = file.name; }
      });
      fileInput.addEventListener('change', () => {
        if (fileInput.files?.[0]) dropLabel.textContent = fileInput.files[0].name;
      });

      document.getElementById('upload-submit-btn').addEventListener('click', async () => {
        errEl.classList.add('hidden');
        const file     = fileInput.files?.[0];
        const title    = document.getElementById('up-title').value.trim();
        const category = document.getElementById('up-category').value;

        if (!file)     { errEl.textContent = 'Please select a file.';       errEl.classList.remove('hidden'); return; }
        if (!title)    { errEl.textContent = 'Title is required.';           errEl.classList.remove('hidden'); return; }
        if (!category) { errEl.textContent = 'Category is required.';        errEl.classList.remove('hidden'); return; }

        submitBtn.disabled = true;
        submitLabel.textContent = 'Uploading…';

        const fd = new FormData();
        fd.append('file',         file);
        fd.append('title',        title);
        fd.append('category',     category);
        fd.append('description',  document.getElementById('up-description').value.trim());
        fd.append('requires_role', document.getElementById('up-access').value);
        fd.append('is_public',    String(document.getElementById('up-public').checked));

        try {
          const res = await fetch('/api/v1/documents', { method: 'POST', credentials: 'include', body: fd });
          const data = await res.json();
          if (!res.ok) throw new Error(data.message ?? data.error ?? 'Upload failed');
          showToast('Document uploaded successfully.');
          closeModal();
          loadDocuments();
        } catch (err) {
          errEl.textContent = err.message;
          errEl.classList.remove('hidden');
        } finally {
          submitBtn.disabled = false;
          submitLabel.textContent = 'Upload Document';
        }
      });
    }

    loadDocuments();
  </script>
</PortalLayout>

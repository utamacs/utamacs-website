---
export const prerender = false;
import Layout from '@components/layout/PortalAuthLayout.astro';
---

<Layout title="Forgot Password – UTA MACS" description="Reset your UTA MACS portal password.">
  <section class="min-h-screen bg-gray-50 flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-3 justify-center">
          <div class="w-12 h-12 bg-primary-600 rounded-xl flex items-center justify-center">
            <i class="fas fa-building text-white text-xl" aria-hidden="true"></i>
          </div>
          <div class="text-left">
            <div class="font-bold text-primary-600 text-lg leading-tight">UTA MACS</div>
            <div class="text-xs text-text-secondary">Resident Portal</div>
          </div>
        </a>
      </div>

      <div class="bg-white rounded-2xl shadow-medium p-8">
        <!-- Default: form -->
        <div id="form-view">
          <h1 class="text-xl font-semibold text-text-primary mb-1">Reset your password</h1>
          <p class="text-sm text-text-secondary mb-6">Enter your email and we'll send a reset link.</p>

          <div id="error-banner" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>

          <form id="reset-form" class="space-y-4">
            <div>
              <label for="email" class="block text-sm font-medium text-text-primary mb-1.5">Email Address</label>
              <input type="email" id="email" name="email" required autocomplete="email"
                placeholder="you@example.com"
                class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 focus:border-transparent" />
            </div>
            <button type="submit" id="submit-btn" class="btn-primary w-full flex items-center justify-center gap-2">
              <span id="btn-text">Send Reset Link</span>
              <span id="btn-spinner" class="hidden"><i class="fas fa-spinner fa-spin" aria-hidden="true"></i></span>
            </button>
          </form>
        </div>

        <!-- Success state -->
        <div id="success-view" class="hidden text-center py-4">
          <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <i class="fas fa-envelope text-green-600 text-2xl" aria-hidden="true"></i>
          </div>
          <h2 class="text-lg font-semibold text-text-primary mb-2">Check your inbox</h2>
          <p class="text-sm text-text-secondary mb-6">
            If an account exists for that email, a password reset link has been sent.
            It expires in 60 minutes.
          </p>
          <a href="/portal/login" class="btn-primary inline-flex">Back to Sign In</a>
        </div>

        <p class="mt-6 text-center text-xs text-text-secondary">
          <a href="/portal/login" class="text-primary-600 hover:underline">← Back to sign in</a>
        </p>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('reset-form') as HTMLFormElement;
    const errorBanner = document.getElementById('error-banner')!;
    const btnText = document.getElementById('btn-text')!;
    const btnSpinner = document.getElementById('btn-spinner')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBanner.classList.add('hidden');
      btnText.classList.add('hidden');
      btnSpinner.classList.remove('hidden');
      submitBtn.disabled = true;

      const email = (document.getElementById('email') as HTMLInputElement).value.trim();

      const res = await fetch('/api/v1/auth/forgot-password', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (res.ok) {
        document.getElementById('form-view')!.classList.add('hidden');
        document.getElementById('success-view')!.classList.remove('hidden');
      } else {
        const data = await res.json();
        errorBanner.textContent = data.detail ?? data.error ?? 'Something went wrong. Please try again.';
        errorBanner.classList.remove('hidden');
        btnText.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
        submitBtn.disabled = false;
      }
    });
  </script>
</Layout>

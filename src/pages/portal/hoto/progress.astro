---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
---

<PortalLayout title="HOTO Completion Progress" user={user} activeModule="hoto_progress">
  <!-- Process info panel -->
  <details class="mb-6 group rounded-xl border border-primary-100 bg-gradient-to-r from-primary-50/50 to-blue-50/20 overflow-hidden">
    <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer list-none select-none hover:bg-primary-50/60 transition-colors">
      <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-project-diagram text-white text-xs" aria-hidden="true"></i>
      </div>
      <span class="text-sm font-medium text-text-primary flex-1">A live dashboard showing handover completion across all infrastructure and system categories.</span>
      <span class="text-xs text-primary-600 flex items-center gap-1.5 flex-shrink-0 font-medium">
        How it works
        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200 group-open:rotate-180" aria-hidden="true"></i>
      </span>
    </summary>
    <div class="px-5 pb-5">
      <div class="pt-4 border-t border-primary-100 space-y-4">
        <svg viewBox="0 0 600 70" class="w-full" role="img" aria-label="HOTO progress category groups: Infrastructure, Safety & Services, Documentation">
          <defs>
            <marker id="arr" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
              <path d="M0,0 L0,6 L8,3 z" fill="#94a3b8"/>
            </marker>
          </defs>
          <!-- Infrastructure -->
          <rect x="10" y="8" width="175" height="54" rx="8" fill="#dbeafe" stroke="#1E3A8A" stroke-width="1.5"/>
          <text x="97" y="30" text-anchor="middle" font-size="11" font-weight="600" fill="#1e40af">Infrastructure</text>
          <text x="97" y="47" text-anchor="middle" font-size="9" fill="#1e40af">Electrical, Lifts, DG, Water…</text>
          <!-- Safety & Services -->
          <rect x="212" y="8" width="175" height="54" rx="8" fill="#fef3c7" stroke="#d97706" stroke-width="1.5"/>
          <text x="299" y="30" text-anchor="middle" font-size="11" font-weight="600" fill="#92400e">Safety &amp; Services</text>
          <text x="299" y="47" text-anchor="middle" font-size="9" fill="#92400e">Fire, Security, HVAC…</text>
          <!-- Documentation -->
          <rect x="414" y="8" width="175" height="54" rx="8" fill="#d1fae5" stroke="#059669" stroke-width="1.5"/>
          <text x="501" y="30" text-anchor="middle" font-size="11" font-weight="600" fill="#065f46">Documentation</text>
          <text x="501" y="47" text-anchor="middle" font-size="9" fill="#065f46">As-Builts, Assets, AMC…</text>
        </svg>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mt-1">
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Progress is calculated as % of items in Approved or Closed status per category</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>A category is fully handed over only when all its items reach Closed status</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-exclamation-circle text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Overdue items (past builder SLA) are flagged regardless of status</span>
          </div>
        </div>
      </div>
    </div>
  </details>

  <div class="mb-6 flex items-center justify-between flex-wrap gap-3">
    <div>
      <h1 class="text-2xl font-bold text-text-primary">HOTO Completion Progress</h1>
      <p class="text-sm text-text-secondary mt-1">Overall handover status across all system categories.</p>
    </div>
    <a href="/portal/hoto" class="text-sm text-text-secondary hover:text-primary-600 flex items-center gap-1.5">
      <i class="fas fa-arrow-left text-xs"></i> HOTO Tracker
    </a>
  </div>

  <!-- Overall progress card -->
  <div id="overall-card" class="bg-white rounded-2xl border border-border-light p-6 mb-6">
    <div class="animate-pulse text-center text-sm text-text-secondary">Loading…</div>
  </div>

  <!-- Per-category breakdown -->
  <div id="category-breakdown" class="bg-white rounded-2xl border border-border-light overflow-hidden mb-6">
    <div class="p-4 border-b border-border-light flex items-center justify-between">
      <h2 class="text-lg font-semibold text-text-primary text-sm">By System Category</h2>
      <span class="text-xs text-text-secondary">Click a category to expand items</span>
    </div>
    <div id="category-rows" class="divide-y divide-border-light">
      <div class="p-4 text-center text-sm text-text-secondary animate-pulse">Loading…</div>
    </div>
  </div>

  <!-- Overdue SLA items -->
  <div class="bg-white rounded-2xl border border-red-200 overflow-hidden">
    <div class="p-4 border-b border-red-100 flex items-center gap-2">
      <i class="fas fa-exclamation-triangle text-red-500 text-sm"></i>
      <h2 class="text-lg font-semibold text-text-primary text-sm">Overdue Builder SLA Commitments</h2>
    </div>
    <div id="overdue-list" class="divide-y divide-border-light">
      <div class="p-4 text-center text-sm text-text-secondary animate-pulse">Loading…</div>
    </div>
  </div>

  <script>
    // APPROVED/CLOSED = done; REJECTED = builder-blocked (excluded from denominator);
    // all other statuses = in-progress
    const DONE_STATUSES = ['CLOSED', 'APPROVED'];
    let allItems: any[] = [];

    async function load() {
      const res = await fetch('/api/v1/hoto/items?limit=200&include_closed=true', { credentials: 'include' });
      if (!res.ok) { document.getElementById('overall-card')!.innerHTML = '<p class="text-red-600 text-sm">Failed to load.</p>'; return; }
      const data = await res.json();
      allItems = data.items ?? data;

      const today = new Date().toISOString().slice(0, 10);
      const total = allItems.length;
      const done = allItems.filter((i: any) => DONE_STATUSES.includes(i.status)).length;
      const rejected = allItems.filter((i: any) => i.status === 'REJECTED').length;
      // Denominator excludes REJECTED (builder-blocked items aren't "pending" work)
      const activeDenominator = total - rejected;
      const pct = activeDenominator > 0 ? Math.round((done / activeDenominator) * 100) : 0;
      const overdue = allItems.filter((i: any) => i.builder_sla_date && i.builder_sla_date < today && !DONE_STATUSES.includes(i.status) && i.status !== 'REJECTED');
      const pendingApproval = allItems.filter((i: any) => ['PENDING_SECRETARY','PENDING_PRESIDENT'].includes(i.status));

      // Overall card
      document.getElementById('overall-card')!.innerHTML = `
        <div class="flex flex-col sm:flex-row sm:items-center gap-6">
          <div class="relative size-28 sm:size-36 mx-auto sm:mx-0 shrink-0">
            <svg viewBox="0 0 120 120" class="w-full h-full -rotate-90">
              <circle cx="60" cy="60" r="52" fill="none" stroke="#E5E7EB" stroke-width="12"/>
              <circle cx="60" cy="60" r="52" fill="none" stroke="${pct >= 80 ? '#16A34A' : pct >= 50 ? '#D97706' : '#DC2626'}" stroke-width="12"
                stroke-dasharray="${2 * Math.PI * 52}" stroke-dashoffset="${2 * Math.PI * 52 * (1 - pct / 100)}" stroke-linecap="round"/>
            </svg>
            <div class="absolute inset-0 flex items-center justify-center flex-col">
              <span class="text-2xl font-bold text-text-primary">${pct}%</span>
              <span class="text-xs text-text-secondary">Complete</span>
            </div>
          </div>
          <div class="flex-1 grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
            <div class="p-3 rounded-xl bg-gray-50">
              <div class="text-2xl font-bold text-text-primary">${total}</div>
              <div class="text-xs text-text-secondary mt-0.5">Total Items</div>
            </div>
            <div class="p-3 rounded-xl bg-green-50">
              <div class="text-2xl font-bold text-green-700">${done}</div>
              <div class="text-xs text-text-secondary mt-0.5">Closed / Approved</div>
            </div>
            <div class="p-3 rounded-xl bg-purple-50">
              <div class="text-2xl font-bold text-purple-700">${pendingApproval.length}</div>
              <div class="text-xs text-text-secondary mt-0.5">Pending Approval</div>
            </div>
            <div class="p-3 rounded-xl bg-red-50">
              <div class="text-2xl font-bold text-red-700">${overdue.length}</div>
              <div class="text-xs text-text-secondary mt-0.5">SLA Overdue</div>
            </div>
          </div>
        </div>
        ${rejected > 0 ? `<div class="mt-4 flex items-center gap-2 text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2"><i class="fas fa-exclamation-circle"></i> ${rejected} item${rejected !== 1 ? 's' : ''} rejected by builder — excluded from completion % (${done}/${activeDenominator} active items).</div>` : ''}`;

      // Category breakdown
      const cats: Record<string, { total: number; done: number; rejected: number; items: any[] }> = {};
      for (const it of allItems) {
        const cat = it.hoto_category ?? 'Uncategorised';
        if (!cats[cat]) cats[cat] = { total: 0, done: 0, rejected: 0, items: [] };
        cats[cat].total++;
        cats[cat].items.push(it);
        if (DONE_STATUSES.includes(it.status)) cats[cat].done++;
        if (it.status === 'REJECTED') cats[cat].rejected++;
      }
      const sortedCats = Object.entries(cats).sort(([, a], [, b]) => b.total - a.total);

      const PRIORITY_COLOR: Record<string, string> = { CRITICAL: 'text-red-600 bg-red-50', HIGH: 'text-orange-600 bg-orange-50', MEDIUM: 'text-amber-600 bg-amber-50', LOW: 'text-blue-600 bg-blue-50' };
      const STATUS_SHORT: Record<string, string> = { NOT_STARTED: 'Not started', IN_PROGRESS: 'In progress', UNDER_REVIEW: 'Under review', PENDING_SECRETARY: 'Awaiting Sec', PENDING_PRESIDENT: 'Awaiting Pres', APPROVED: 'Approved', REJECTED: 'Rejected', CLOSED: 'Closed' };

      document.getElementById('category-rows')!.innerHTML = sortedCats.map(([cat, { total: catTotal, done: catDone, rejected: catRej, items: catItems }]) => {
        const activeDen = catTotal - catRej;
        const catPct = activeDen > 0 ? Math.round((catDone / activeDen) * 100) : (catDone > 0 ? 100 : 0);
        const barColor = catPct === 100 ? 'bg-green-500' : catPct >= 50 ? 'bg-primary-600' : 'bg-amber-400';
        const encodedCat = encodeURIComponent(cat);
        const rowId = `cat-${encodedCat}`;

        const itemsHtml = catItems
          .sort((a: any, b: any) => {
            const order: Record<string,number> = { CRITICAL: 0, HIGH: 1, MEDIUM: 2, LOW: 3 };
            return (order[a.priority] ?? 9) - (order[b.priority] ?? 9);
          })
          .map((it: any) => {
            const prioStyle = PRIORITY_COLOR[it.priority] ?? 'text-gray-600 bg-gray-50';
            const statusLabel = STATUS_SHORT[it.status] ?? it.status;
            return `<a href="/portal/hoto/${it.id}" class="flex items-center gap-3 px-5 py-2.5 hover:bg-blue-50 transition-colors border-t border-border-light first:border-t-0">
              <span class="text-xs px-1.5 py-0.5 rounded font-medium ${prioStyle}">${it.priority}</span>
              <span class="flex-1 text-xs text-text-primary truncate">${it.title}</span>
              <span class="text-xs text-text-secondary shrink-0">${statusLabel}</span>
              <i class="fas fa-chevron-right text-[10px] text-text-secondary"></i>
            </a>`;
          }).join('');

        return `
          <div>
            <button onclick="toggleCat('${rowId}')" class="w-full flex items-center gap-4 p-4 hover:bg-gray-50 transition-colors group text-left">
              <div class="flex-1 min-w-0">
                <div class="flex justify-between mb-1">
                  <span class="text-sm text-text-primary font-medium truncate group-hover:text-primary-600 transition-colors">${cat}</span>
                  <span class="text-xs text-text-secondary ml-2 shrink-0">${catDone}/${activeDen}${catRej > 0 ? ` · <span class="text-amber-600">${catRej} rejected</span>` : ''}</span>
                </div>
                <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                  <div class="h-full ${barColor} rounded-full transition-all" style="width:${catPct}%"></div>
                </div>
              </div>
              <span class="text-sm font-semibold ${catPct === 100 ? 'text-green-600' : 'text-text-secondary'} w-10 text-right">${catPct}%</span>
              <i id="${rowId}-chevron" class="fas fa-chevron-down text-xs text-text-secondary transition-transform"></i>
            </button>
            <div id="${rowId}" class="hidden bg-gray-50">
              ${itemsHtml}
              <div class="px-5 py-2 border-t border-border-light">
                <a href="/portal/hoto?category=${encodedCat}" class="text-xs text-primary-600 hover:underline">View all in HOTO tracker →</a>
              </div>
            </div>
          </div>`;
      }).join('') || '<div class="p-4 text-center text-sm text-text-secondary">No items.</div>';

      // Overdue SLA
      if (!overdue.length) {
        document.getElementById('overdue-list')!.innerHTML = '<div class="p-6 text-center text-sm text-green-600"><i class="fas fa-check-circle mr-1.5"></i>No overdue SLA commitments.</div>';
      } else {
        document.getElementById('overdue-list')!.innerHTML = overdue.slice(0, 20).map((it: any) => {
          const daysOverdue = Math.floor((Date.now() - new Date(it.builder_sla_date).getTime()) / 86_400_000);
          return `
            <a href="/portal/hoto/${it.id}" class="flex items-center gap-4 p-4 hover:bg-red-50 transition-colors">
              <div class="flex-1 min-w-0">
                <div class="text-sm font-medium text-text-primary truncate">${it.title}</div>
                <div class="text-xs text-text-secondary mt-0.5">${it.hoto_category} · ${it.status.replace(/_/g, ' ')}</div>
              </div>
              <div class="text-right shrink-0">
                <div class="text-sm font-semibold text-red-600">${daysOverdue}d overdue</div>
                <div class="text-xs text-text-secondary">${it.priority} priority</div>
              </div>
            </a>`;
        }).join('');
      }
    }

    function toggleCat(id: string) {
      const el = document.getElementById(id);
      const chevron = document.getElementById(`${id}-chevron`);
      if (!el || !chevron) return;
      const isHidden = el.classList.contains('hidden');
      el.classList.toggle('hidden', !isHidden);
      chevron.classList.toggle('rotate-180', isHidden);
    }
    (window as any).toggleCat = toggleCat;

    load();
  </script>
</PortalLayout>

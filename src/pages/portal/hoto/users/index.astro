---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const EXECUTIVE_ROLES = new Set(['executive', 'secretary', 'president']);
if (!EXECUTIVE_ROLES.has(user.portalRole) && !user.isAdmin) {
  return Astro.redirect('/portal');
}

const isAdmin = user.isAdmin;
---

<PortalLayout title="Member Directory" user={user} activeModule="hoto">
  <div class="mb-6 flex items-center justify-between flex-wrap gap-3">
    <div>
      <nav class="text-sm text-text-secondary mb-2">
        <a href="/portal" class="hover:text-primary-600">Portal</a>
        <span class="mx-2">›</span><span class="text-text-primary">Members</span>
      </nav>
      <h1 class="text-2xl font-bold text-text-primary">Member Directory</h1>
      <p class="text-sm text-text-secondary mt-1">Residents and committee members of Urban Trilla Apartments.</p>
    </div>
    {isAdmin && (
      <a href="/portal/hoto/admin/users" class="btn-primary text-sm flex items-center gap-2">
        <i class="fas fa-user-cog" aria-hidden="true"></i> Manage Roles
      </a>
    )}
  </div>

  <!-- Filters -->
  <div class="mb-5 flex flex-wrap gap-3">
    <div class="relative flex-1 min-w-[200px] max-w-sm">
      <i class="fas fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-text-secondary text-sm" aria-hidden="true"></i>
      <input type="search" id="search-input" placeholder="Search by name…"
        class="w-full pl-10 pr-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
    </div>
    <select id="role-filter" class="px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
      <option value="">All roles</option>
      <option value="president">President</option>
      <option value="secretary">Secretary</option>
      <option value="executive">Executive</option>
      <option value="member">Member</option>
    </select>
  </div>

  <div id="member-count" class="text-xs text-text-secondary mb-4">Loading…</div>

  <div id="members-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {Array.from({length: 6}).map(() => (
      <div class="bg-white rounded-xl border border-border-light p-4 animate-pulse">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-gray-200"></div>
          <div class="flex-1">
            <div class="h-3 bg-gray-200 rounded w-24 mb-2"></div>
            <div class="h-2.5 bg-gray-100 rounded w-16"></div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <script>
    const ROLE_BADGE: Record<string, string> = {
      president:  'bg-primary-600 text-white',
      secretary:  'bg-blue-100 text-blue-700',
      executive:  'bg-purple-100 text-purple-700',
      member:     'bg-gray-100 text-gray-600',
    };
    const ROLE_LABEL: Record<string, string> = {
      president: 'President',
      secretary: 'Secretary',
      executive: 'Executive',
      member:    'Member',
    };

    let debounceTimer: ReturnType<typeof setTimeout>;

    async function loadMembers(q = '', role = '') {
      const params = new URLSearchParams({ limit: '200' });
      if (q) params.set('q', q);
      if (role) params.set('role', role);

      const res = await fetch(`/api/v1/hoto/users?${params}`, { credentials: 'include' });
      const members = res.ok ? await res.json() : [];

      document.getElementById('member-count')!.textContent =
        `${members.length} member${members.length !== 1 ? 's' : ''} found`;

      const grid = document.getElementById('members-grid')!;
      if (!members.length) {
        grid.innerHTML = '<div class="col-span-full text-center py-10 text-text-secondary text-sm">No members found.</div>';
        return;
      }

      grid.innerHTML = members.map((m: any) => {
        const initials = (m.full_name as string).split(' ').map((n: string) => n[0]).slice(0, 2).join('').toUpperCase();
        const unitDisplay = [m.unit_number, m.block ? `Block ${m.block}` : null].filter(Boolean).join(' · ');
        const portalRole = m.portal_role ?? 'member';
        const roleCls = ROLE_BADGE[portalRole] ?? 'bg-gray-100 text-gray-600';
        const roleLabel = ROLE_LABEL[portalRole] ?? portalRole;
        const titleLine = m.committee_title
          ? `<div class="text-xs text-text-secondary mt-0.5 italic">${m.committee_title}</div>`
          : '';
        const adminBadge = m.is_admin
          ? '<span class="text-xs px-1.5 py-0.5 rounded bg-red-100 text-red-700 font-medium">Admin</span>'
          : '';

        return `
          <div class="bg-white rounded-xl border border-border-light p-4 hover:shadow-soft transition-shadow">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 rounded-full bg-primary-600 text-white flex items-center justify-center font-bold text-sm flex-shrink-0">
                ${initials}
              </div>
              <div class="min-w-0 flex-1">
                <div class="font-medium text-text-primary text-sm truncate">${m.full_name}</div>
                <div class="text-xs text-text-secondary mt-0.5">${unitDisplay || '—'}</div>
                ${titleLine}
              </div>
              <div class="flex flex-col items-end gap-1 flex-shrink-0">
                <span class="text-xs px-2 py-0.5 rounded-full font-medium ${roleCls}">${roleLabel}</span>
                ${adminBadge}
              </div>
            </div>
          </div>
        `;
      }).join('');
    }

    document.getElementById('search-input')!.addEventListener('input', (e) => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        const role = (document.getElementById('role-filter') as HTMLSelectElement).value;
        loadMembers((e.target as HTMLInputElement).value.trim(), role);
      }, 350);
    });

    document.getElementById('role-filter')!.addEventListener('change', (e) => {
      const q = (document.getElementById('search-input') as HTMLInputElement).value.trim();
      loadMembers(q, (e.target as HTMLSelectElement).value);
    });

    loadMembers();
  </script>
</PortalLayout>

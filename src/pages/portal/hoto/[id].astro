---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const itemId = Astro.params.id!;
const canCreate  = ['executive','secretary','president'].includes(user.portalRole) || user.isAdmin;
const canEdit    = canCreate;
const canComment = canCreate;
const canAdvance = canCreate;
const canUpload  = canCreate;
const canApprovePresident = user.isAdmin || user.portalRole === 'president';
const canApproveSecretary = user.isAdmin || ['secretary','president'].includes(user.portalRole);
const canBypass  = user.isAdmin || ['secretary','president'].includes(user.portalRole);
---

<PortalLayout title="HOTO Item" user={user} activeModule="hoto">
  <div class="mb-4">
    <nav class="text-sm text-text-secondary mb-2">
      <a href="/portal/hoto" class="hover:text-primary-600">HOTO Tracker</a>
      <span class="mx-2">›</span><span id="breadcrumb-title" class="text-text-primary">Loading…</span>
    </nav>
  </div>

  <div id="page-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm mb-4"></div>

  <!-- Item header skeleton → filled by JS -->
  <div id="item-header" class="bg-white rounded-xl border border-border-light p-5 mb-5 animate-pulse">
    <div class="h-4 bg-gray-200 rounded w-64 mb-3"></div>
    <div class="h-3 bg-gray-100 rounded w-40"></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
    <!-- Left column: required docs + files + advance controls -->
    <div class="lg:col-span-2 space-y-5">

      <!-- State transition panel -->
      {canAdvance && (
        <div id="advance-panel" class="hidden bg-white rounded-xl border border-border-light p-5">
          <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
            <i class="fas fa-arrow-right text-primary-600" aria-hidden="true"></i> Advance Status
          </h2>
          <div id="advance-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
          <div id="advance-buttons" class="flex flex-wrap gap-2"></div>

          <div id="advance-notes-block" class="hidden mt-4">
            <label class="block text-sm font-medium text-text-primary mb-1.5">Governance Notes <span class="text-red-500">*</span></label>
            <textarea id="advance-notes" rows="3" placeholder="Reason for this decision…"
              class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none"></textarea>
          </div>
        </div>
      )}

      <!-- Required documents checklist -->
      <div class="bg-white rounded-xl border border-border-light overflow-hidden">
        <div class="px-5 py-4 border-b border-border-light flex items-center justify-between">
          <h2 class="text-lg font-semibold text-text-primary flex items-center gap-2">
            <i class="fas fa-clipboard-check text-blue-600" aria-hidden="true"></i> Required Documents
          </h2>
          {canCreate && (
            <button id="add-req-doc-btn" class="text-xs text-primary-600 hover:text-primary-700 font-medium">
              + Add checklist item
            </button>
          )}
        </div>
        <div id="req-docs-list" class="divide-y divide-border-light">
          <div class="px-5 py-3 text-sm text-text-secondary">Loading…</div>
        </div>
      </div>

      <!-- Uploaded files -->
      <div class="bg-white rounded-xl border border-border-light overflow-hidden">
        <div class="px-5 py-4 border-b border-border-light flex items-center justify-between">
          <h2 class="text-lg font-semibold text-text-primary flex items-center gap-2">
            <i class="fas fa-paperclip text-green-600" aria-hidden="true"></i> Files
          </h2>
          {canUpload && (
            <button id="upload-btn" class="text-xs text-primary-600 hover:text-primary-700 font-medium">
              + Upload file
            </button>
          )}
        </div>
        <div id="files-list" class="divide-y divide-border-light">
          <div class="px-5 py-3 text-sm text-text-secondary">Loading…</div>
        </div>
        <!-- Upload form (hidden by default) -->
        {canUpload && (
          <div id="upload-form-wrapper" class="hidden px-5 py-4 bg-gray-50 border-t border-border-light">
            <div id="upload-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
            <div id="upload-success" class="hidden mb-3 p-3 bg-green-50 border border-green-200 rounded-xl text-sm text-green-700"></div>
            <div class="space-y-3">
              <div>
                <label class="block text-xs font-medium text-text-primary mb-1">File <span class="text-red-500">*</span></label>
                <input type="file" id="upload-file" accept=".pdf,.jpg,.jpeg,.png,.xlsx,.csv,.docx"
                  class="w-full text-sm text-text-secondary file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-primary-600 file:text-white hover:file:bg-primary-700" />
              </div>
              <div>
                <label class="block text-xs font-medium text-text-primary mb-1">Source Description</label>
                <input type="text" id="upload-desc" placeholder="e.g. Received from builder on 15 Jan 2025"
                  class="w-full px-3 py-2 border border-border-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
              </div>
              <div class="flex gap-2">
                <button id="upload-submit-btn" class="btn-primary text-xs py-2 px-4">Upload</button>
                <button id="upload-cancel-btn" class="btn-outline text-xs py-2 px-4">Cancel</button>
              </div>
            </div>
          </div>
        )}
      </div>

      <!-- Comment thread -->
      <div class="bg-white rounded-xl border border-border-light overflow-hidden">
        <div class="px-5 py-4 border-b border-border-light">
          <h2 class="text-lg font-semibold text-text-primary flex items-center gap-2">
            <i class="fas fa-comments text-indigo-600" aria-hidden="true"></i> Comments
          </h2>
        </div>
        <div id="comments-list" class="px-5 py-3 space-y-4">
          <div class="text-sm text-text-secondary">Loading…</div>
        </div>
        {canComment && (
          <div class="px-5 py-4 border-t border-border-light bg-gray-50">
            <textarea id="comment-input" rows="3" placeholder="Add a comment… (Shift+Enter for new line)"
              class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none"></textarea>
            <div class="mt-2 flex justify-end">
              <button id="comment-submit-btn" class="btn-primary text-sm">Post Comment</button>
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Right column: item metadata -->
    <div class="space-y-5">
      <div id="item-meta" class="bg-white rounded-xl border border-border-light p-5 animate-pulse">
        <div class="space-y-3">
          {Array.from({length: 5}).map(() => (
            <div><div class="h-2 bg-gray-100 rounded w-20 mb-1"></div><div class="h-3 bg-gray-200 rounded w-32"></div></div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- SLA overdue banner -->
  <div id="sla-banner" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-800 flex items-center gap-2">
    <i class="fas fa-exclamation-triangle text-red-500"></i>
    <span id="sla-banner-text"></span>
  </div>

  <!-- Edit modal -->
  {canEdit && (
    <div id="edit-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
      <div class="bg-white rounded-2xl max-w-lg w-full p-6 shadow-large max-h-[90vh] overflow-y-auto">
        <h2 class="text-lg font-semibold text-text-primary text-lg mb-4">Edit HOTO Item</h2>
        <div id="edit-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">Title <span class="text-red-500">*</span></label>
            <input type="text" id="e-title" class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">Description</label>
            <textarea id="e-description" rows="3" class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none"></textarea>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1.5">Priority</label>
              <select id="e-priority" class="w-full px-3 py-2 border border-border-light rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-600">
                <option value="LOW">Low</option>
                <option value="MEDIUM">Medium</option>
                <option value="HIGH">High</option>
                <option value="CRITICAL">Critical</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1.5">Responsible Role</label>
              <input type="text" id="e-responsible-role" placeholder="e.g. Secretary"
                class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1.5">Deadline</label>
              <input type="date" id="e-deadline" class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1.5">Builder SLA Date</label>
              <input type="date" id="e-builder-sla-date" class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">Builder Contact</label>
            <input type="text" id="e-builder-contact" placeholder="Name or phone"
              class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">Governance Notes</label>
            <textarea id="e-governance-notes" rows="2" class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none"></textarea>
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" id="e-rera" class="rounded accent-primary-600" />
            <label for="e-rera" class="text-sm text-text-primary">RERA escalation eligible</label>
          </div>
          <div class="flex gap-3 pt-1">
            <button id="edit-save-btn" class="btn-primary flex-1">Save Changes</button>
            <button id="edit-cancel-btn" class="btn-outline flex-1">Cancel</button>
          </div>
        </div>
      </div>
    </div>
  )}

  <script define:vars={{ itemId, canCreate, canEdit, canUpload, canComment, canAdvance, canApprovePresident, canApproveSecretary, canBypass }}>
    const STATUS_LABEL = {
      NOT_STARTED:'Not Started', IN_PROGRESS:'In Progress', UNDER_REVIEW:'Under Review',
      PENDING_PRESIDENT:'Pending President', PENDING_SECRETARY:'Pending Secretary',
      APPROVED:'Approved', REJECTED:'Rejected', CLOSED:'Closed',
    };
    const STATUS_CLS = {
      NOT_STARTED:'bg-gray-100 text-gray-600', IN_PROGRESS:'bg-blue-100 text-blue-700',
      UNDER_REVIEW:'bg-indigo-100 text-indigo-700',
      PENDING_PRESIDENT:'bg-amber-100 text-amber-700', PENDING_SECRETARY:'bg-orange-100 text-orange-700',
      APPROVED:'bg-green-100 text-green-700', REJECTED:'bg-red-100 text-red-700',
      CLOSED:'bg-gray-200 text-gray-600',
    };
    const PRIORITY_CLS = {
      CRITICAL:'bg-red-600 text-white', HIGH:'bg-orange-100 text-orange-700',
      MEDIUM:'bg-amber-100 text-amber-700', LOW:'bg-gray-100 text-gray-500',
    };

    let itemData = null;

    // Determine which transitions the current user can trigger from a given status
    function availableTransitions(status) {
      const map = {
        NOT_STARTED: [{ to:'IN_PROGRESS', label:'Start Progress', ok: canAdvance }],
        IN_PROGRESS: [{ to:'UNDER_REVIEW', label:'Submit for Review', ok: canAdvance }],
        UNDER_REVIEW: [
          { to:'PENDING_PRESIDENT', label:'Send to President', ok: canAdvance && (canApproveSecretary || canApprovePresident) },
          { to:'REJECTED', label:'Reject', ok: canBypass, requiresNotes: true },
        ],
        PENDING_PRESIDENT: [
          { to:'PENDING_SECRETARY', label:'President Approved ✓', ok: canApprovePresident },
          { to:'REJECTED', label:'President Rejected', ok: canApprovePresident, requiresNotes: true },
        ],
        PENDING_SECRETARY: [
          { to:'APPROVED', label:'Secretary Approved ✓', ok: canApproveSecretary },
          { to:'REJECTED', label:'Secretary Rejected', ok: canApproveSecretary, requiresNotes: true },
        ],
        APPROVED: [
          { to:'CLOSED', label:'Close Item', ok: canAdvance && canApproveSecretary },
          { to:'REJECTED', label:'Dispute / Reject', ok: canBypass, requiresNotes: true },
        ],
        REJECTED: [{ to:'IN_PROGRESS', label:'Reopen', ok: canAdvance }],
        CLOSED: [],
      };
      return (map[status] ?? []).filter(t => t.ok);
    }

    async function loadPage() {
      const res = await fetch(`/api/v1/hoto/items/${itemId}`, { credentials: 'include' });
      if (!res.ok) {
        document.getElementById('page-error').textContent = 'HOTO item not found or access denied.';
        document.getElementById('page-error').classList.remove('hidden');
        return;
      }

      const { item, required_docs, files, comments } = await res.json();
      itemData = item;

      // Breadcrumb + header
      const titleEl = document.getElementById('breadcrumb-title');
      titleEl.textContent = item.title;
      document.title = `${item.title} — HOTO`;

      const headerEl = document.getElementById('item-header');
      headerEl.classList.remove('animate-pulse');
      // SLA overdue banner
      const today = new Date().toISOString().slice(0, 10);
      if (item.builder_sla_date && item.builder_sla_date < today && !['CLOSED','APPROVED'].includes(item.status)) {
        const days = Math.floor((Date.now() - new Date(item.builder_sla_date).getTime()) / 86_400_000);
        document.getElementById('sla-banner-text').textContent = `Builder SLA date passed ${days} day${days !== 1 ? 's' : ''} ago (${new Date(item.builder_sla_date).toLocaleDateString('en-IN')}). Escalation may be required.`;
        document.getElementById('sla-banner').classList.remove('hidden');
      }

      headerEl.innerHTML = `
        <div class="flex items-start gap-3 flex-wrap">
          <div class="flex-1 min-w-0">
            <h1 class="text-2xl font-bold text-text-primary mb-1">${item.title}</h1>
            <div class="flex items-center gap-2 flex-wrap text-xs">
              <span class="px-2 py-0.5 rounded-full font-medium ${PRIORITY_CLS[item.priority] ?? ''}">${item.priority}</span>
              <span class="px-2 py-0.5 rounded-full font-medium ${STATUS_CLS[item.status] ?? ''}">${STATUS_LABEL[item.status] ?? item.status}</span>
              <span class="text-text-secondary">${item.ascenza_category}</span>
              ${item.days_overdue > 0 ? `<span class="text-red-600 font-medium"><i class="fas fa-clock"></i> ${item.days_overdue}d overdue</span>` : ''}
            </div>
            ${item.description ? `<p class="text-sm text-text-secondary mt-2">${item.description}</p>` : ''}
          </div>
          ${canEdit ? `<button id="header-edit-btn" class="text-xs text-primary-600 hover:text-primary-700 font-medium shrink-0"><i class="fas fa-pen mr-1"></i>Edit</button>` : ''}
        </div>
      `;

      if (canEdit) {
        document.getElementById('header-edit-btn')?.addEventListener('click', () => openEditModal(item));
      }

      // Metadata panel
      const metaEl = document.getElementById('item-meta');
      metaEl.classList.remove('animate-pulse');
      const fmtDate = d => d ? new Date(d).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) : '—';
      metaEl.innerHTML = `
        <h3 class="font-semibold text-text-primary mb-4 text-sm">Details</h3>
        <dl class="space-y-3 text-sm">
          ${[
            ['Category', item.ascenza_category],
            ['Priority', item.priority],
            ['Status', STATUS_LABEL[item.status] ?? item.status],
            ['Deadline', fmtDate(item.deadline)],
            ['Builder SLA', fmtDate(item.builder_sla_date)],
            ['Builder Contact', item.builder_contact ?? '—'],
            ['Responsible Role', item.responsible_role ?? '—'],
            ['RERA Eligible', item.rera_escalation_eligible ? 'Yes' : 'No'],
            ['Created', fmtDate(item.created_at)],
            ['Updated', fmtDate(item.last_updated_at)],
          ].map(([k,v]) => `
            <div><dt class="text-text-secondary text-xs">${k}</dt><dd class="text-text-primary font-medium">${v}</dd></div>
          `).join('')}
          ${item.governance_notes ? `<div><dt class="text-text-secondary text-xs">Notes</dt><dd class="text-text-primary italic text-xs mt-0.5">${item.governance_notes}</dd></div>` : ''}
          ${item.president_approved_by ? `
            <div class="pt-2 border-t border-border-light">
              <dt class="text-text-secondary text-xs mb-1 font-medium">President Approval</dt>
              <dd class="text-text-primary text-xs">${item.president_approved_by_name ?? 'Unknown'}</dd>
              <dd class="text-text-secondary text-xs">${fmtDate(item.president_approved_at)}</dd>
            </div>` : ''}
          ${item.secretary_approved_by ? `
            <div class="${item.president_approved_by ? '' : 'pt-2 border-t border-border-light'}">
              <dt class="text-text-secondary text-xs mb-1 font-medium">Secretary Approval</dt>
              <dd class="text-text-primary text-xs">${item.secretary_approved_by_name ?? 'Unknown'}</dd>
              <dd class="text-text-secondary text-xs">${fmtDate(item.secretary_approved_at)}</dd>
            </div>` : ''}
        </dl>
      `;

      // Advance panel
      if (canAdvance) {
        const transitions = availableTransitions(item.status);
        const panel = document.getElementById('advance-panel');
        if (transitions.length) {
          panel.classList.remove('hidden');
          const btns = document.getElementById('advance-buttons');
          btns.innerHTML = transitions.map(t => `
            <button data-to="${t.to}" data-requires-notes="${!!t.requiresNotes}"
              class="px-4 py-2 rounded-xl text-sm font-medium border transition-colors ${
                t.to === 'REJECTED' ? 'border-red-200 text-red-600 hover:bg-red-50' : 'btn-primary'
              }" onclick="handleAdvance('${t.to}', ${!!t.requiresNotes})">${t.label}</button>
          `).join('');
        }
      }

      // Required docs
      renderRequiredDocs(required_docs);

      // Files
      renderFiles(files);

      // Comments
      renderComments(comments);
    }

    function renderRequiredDocs(docs) {
      const container = document.getElementById('req-docs-list');
      if (!docs.length) {
        container.innerHTML = '<div class="px-5 py-4 text-sm text-text-secondary">No required documents defined.</div>';
        return;
      }
      container.innerHTML = docs.map(d => {
        const done = d.uploaded || d.bypass_by;
        const bypassNote = d.bypass_by ? `<span class="text-xs text-amber-600 ml-1">Bypassed</span>` : '';
        const bypassBtn = canBypass && !done
          ? `<button onclick="bypassDoc('${d.id}')" class="text-xs text-amber-600 hover:text-amber-700 ml-2">Bypass</button>`
          : '';
        return `
          <div class="px-5 py-3 flex items-center gap-3">
            <i class="fas fa-${done ? 'check-circle text-green-500' : 'circle text-gray-300'} text-base flex-shrink-0" aria-hidden="true"></i>
            <div class="flex-1 text-sm ${done ? 'text-text-primary' : 'text-text-secondary'}">
              ${d.doc_name}${d.required ? '' : ' <span class="text-xs text-text-secondary">(optional)</span>'}${bypassNote}
            </div>
            ${bypassBtn}
          </div>
        `;
      }).join('');
    }

    function renderFiles(files) {
      const container = document.getElementById('files-list');
      if (!files.length) {
        container.innerHTML = '<div class="px-5 py-4 text-sm text-text-secondary">No files uploaded yet.</div>';
        return;
      }
      const fmt = bytes => bytes < 1024 ? bytes + 'B' : bytes < 1048576 ? (bytes/1024).toFixed(0)+'KB' : (bytes/1048576).toFixed(1)+'MB';
      container.innerHTML = files.map(f => `
        <div class="px-5 py-3 flex items-center gap-3">
          <i class="fas fa-file-alt text-text-secondary flex-shrink-0" aria-hidden="true"></i>
          <div class="flex-1 min-w-0">
            <div class="text-sm text-text-primary truncate">${f.name}</div>
            <div class="text-xs text-text-secondary mt-0.5">${fmt(f.file_size_bytes ?? 0)} · ${new Date(f.uploaded_at).toLocaleDateString('en-IN')}</div>
          </div>
          ${f.is_confidential ? '<span class="text-xs px-1.5 py-0.5 bg-red-100 text-red-700 rounded">Confidential</span>' : ''}
        </div>
      `).join('');
    }

    function renderComments(comments) {
      const container = document.getElementById('comments-list');
      if (!comments.length) {
        container.innerHTML = '<div class="text-sm text-text-secondary py-2">No comments yet.</div>';
        return;
      }
      container.innerHTML = comments.map(c => {
        const author = c.author?.full_name ?? 'Unknown';
        const role = c.author?.portal_role ?? '';
        const title = c.author?.committee_title ? ` · ${c.author.committee_title}` : '';
        return `
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-full bg-primary-600 text-white text-xs font-bold flex items-center justify-center flex-shrink-0">
              ${author.split(' ').map(n => n[0]).slice(0,2).join('').toUpperCase()}
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-xs font-medium text-text-primary mb-0.5">
                ${author}<span class="text-text-secondary font-normal"> · ${role}${title}</span>
              </div>
              <div class="text-sm text-text-primary whitespace-pre-wrap">${c.content}</div>
              <div class="text-xs text-text-secondary mt-1">${new Date(c.created_at).toLocaleString('en-IN',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'})}</div>
            </div>
          </div>
        `;
      }).join('');
    }

    // Advance state machine
    let pendingToStatus = null;
    let pendingRequiresNotes = false;

    window.handleAdvance = function(toStatus, requiresNotes) {
      pendingToStatus = toStatus;
      pendingRequiresNotes = requiresNotes;
      const notesBlock = document.getElementById('advance-notes-block');
      if (requiresNotes) {
        notesBlock.classList.remove('hidden');
        document.getElementById('advance-notes').focus();
      } else {
        notesBlock.classList.add('hidden');
        submitAdvance(toStatus, null);
      }
    };

    async function submitAdvance(toStatus, notes) {
      const errEl = document.getElementById('advance-error');
      errEl.classList.add('hidden');

      const res = await fetch(`/api/v1/hoto/items/${itemId}/advance`, {
        method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ to_status: toStatus, ...(notes ? { governance_notes: notes } : {}) }),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        const d = await res.json().catch(() => ({}));
        errEl.textContent = d.message ?? d.error ?? 'Failed to advance status.';
        errEl.classList.remove('hidden');
      }
    }

    // Wire up advance confirmation when notes are written
    document.getElementById('advance-notes')?.addEventListener('keydown', e => {
      if (e.key === 'Enter' && !e.shiftKey && pendingRequiresNotes && pendingToStatus) {
        e.preventDefault();
        const notes = e.target.value.trim();
        if (notes) submitAdvance(pendingToStatus, notes);
      }
    });

    // Also add a submit button next to notes (delegated to panel)
    document.getElementById('advance-panel')?.addEventListener('click', e => {
      if (e.target.id === 'advance-submit-notes-btn') {
        const notes = document.getElementById('advance-notes').value.trim();
        if (!notes) { document.getElementById('advance-error').textContent = 'Notes required.'; document.getElementById('advance-error').classList.remove('hidden'); return; }
        submitAdvance(pendingToStatus, notes);
      }
    });

    // Bypass required doc
    window.bypassDoc = async function(docId) {
      const reason = prompt('Enter bypass reason (required):');
      if (!reason?.trim()) return;

      const res = await fetch(`/api/v1/hoto/items/${itemId}/required-docs/${docId}/bypass`, {
        method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bypass_reason: reason.trim() }),
      });

      if (res.ok) {
        loadPage();
      } else {
        const d = await res.json().catch(() => ({}));
        alert(d.message ?? 'Failed to bypass document.');
      }
    };

    // Add required doc
    if (canCreate) {
      document.getElementById('add-req-doc-btn')?.addEventListener('click', async () => {
        const name = prompt('Document name (e.g. "Lift commissioning certificate"):');
        if (!name?.trim()) return;

        const res = await fetch(`/api/v1/hoto/items/${itemId}/required-docs`, {
          method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ doc_name: name.trim() }),
        });

        if (res.ok) loadPage();
        else alert('Failed to add required document.');
      });
    }

    // Upload file
    if (canUpload) {
      document.getElementById('upload-btn')?.addEventListener('click', () => {
        document.getElementById('upload-form-wrapper').classList.toggle('hidden');
      });

      document.getElementById('upload-cancel-btn')?.addEventListener('click', () => {
        document.getElementById('upload-form-wrapper').classList.add('hidden');
      });

      document.getElementById('upload-submit-btn')?.addEventListener('click', async () => {
        const fileInput = document.getElementById('upload-file');
        const file = fileInput.files?.[0];
        const errEl = document.getElementById('upload-error');
        const successEl = document.getElementById('upload-success');
        errEl.classList.add('hidden'); successEl.classList.add('hidden');

        if (!file) { errEl.textContent = 'Please select a file.'; errEl.classList.remove('hidden'); return; }

        // Build target path: hoto/{itemId}/{filename}
        const safeName = file.name.replace(/[^a-zA-Z0-9._-]/g, '_');
        const targetPath = `hoto/${itemId}/${Date.now()}_${safeName}`;

        const fd = new FormData();
        fd.append('file', file);
        fd.append('item_id', itemId);
        fd.append('item_type', 'hoto_item');
        fd.append('target_path', targetPath);
        fd.append('source_description', document.getElementById('upload-desc').value.trim());

        const btn = document.getElementById('upload-submit-btn');
        btn.disabled = true; btn.textContent = 'Uploading…';

        const res = await fetch('/api/v1/hoto/upload', {
          method: 'POST', credentials: 'include', body: fd,
        });

        btn.disabled = false; btn.textContent = 'Upload';

        if (res.ok) {
          successEl.textContent = 'File uploaded successfully.';
          successEl.classList.remove('hidden');
          fileInput.value = '';
          document.getElementById('upload-desc').value = '';
          loadPage();
        } else {
          const d = await res.json().catch(() => ({}));
          errEl.textContent = d.message ?? d.error ?? 'Upload failed.';
          errEl.classList.remove('hidden');
        }
      });
    }

    // Comments
    if (canComment) {
      document.getElementById('comment-submit-btn')?.addEventListener('click', async () => {
        const input = document.getElementById('comment-input');
        const content = input.value.trim();
        if (!content) return;

        const res = await fetch(`/api/v1/hoto/items/${itemId}/comments`, {
          method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content }),
        });

        if (res.ok) { input.value = ''; loadPage(); }
        else alert('Failed to post comment.');
      });

      document.getElementById('comment-input')?.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          document.getElementById('comment-submit-btn').click();
        }
      });
    }

    // Edit modal
    if (canEdit) {
      function openEditModal(item) {
        (document.getElementById('e-title')).value = item.title ?? '';
        (document.getElementById('e-description')).value = item.description ?? '';
        (document.getElementById('e-priority')).value = item.priority ?? 'MEDIUM';
        (document.getElementById('e-responsible-role')).value = item.responsible_role ?? '';
        (document.getElementById('e-deadline')).value = item.deadline ?? '';
        (document.getElementById('e-builder-sla-date')).value = item.builder_sla_date ?? '';
        (document.getElementById('e-builder-contact')).value = item.builder_contact ?? '';
        (document.getElementById('e-governance-notes')).value = item.governance_notes ?? '';
        (document.getElementById('e-rera')).checked = !!item.rera_escalation_eligible;
        document.getElementById('edit-error').classList.add('hidden');
        document.getElementById('edit-modal').classList.remove('hidden');
      }
      window.openEditModal = openEditModal;

      document.getElementById('edit-cancel-btn')?.addEventListener('click', () => {
        document.getElementById('edit-modal').classList.add('hidden');
      });

      document.getElementById('edit-save-btn')?.addEventListener('click', async () => {
        const title = (document.getElementById('e-title')).value.trim();
        const errEl = document.getElementById('edit-error');
        errEl.classList.add('hidden');
        if (!title) { errEl.textContent = 'Title is required.'; errEl.classList.remove('hidden'); return; }

        const btn = document.getElementById('edit-save-btn');
        btn.disabled = true; btn.textContent = 'Saving…';

        const res = await fetch(`/api/v1/hoto/items/${itemId}`, {
          method: 'PATCH', credentials: 'include', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            title,
            description: (document.getElementById('e-description')).value.trim() || null,
            priority: (document.getElementById('e-priority')).value,
            responsible_role: (document.getElementById('e-responsible-role')).value.trim() || null,
            deadline: (document.getElementById('e-deadline')).value || null,
            builder_sla_date: (document.getElementById('e-builder-sla-date')).value || null,
            builder_contact: (document.getElementById('e-builder-contact')).value.trim() || null,
            governance_notes: (document.getElementById('e-governance-notes')).value.trim() || null,
            rera_escalation_eligible: (document.getElementById('e-rera')).checked,
          }),
        });
        btn.disabled = false; btn.textContent = 'Save Changes';
        if (res.ok) {
          document.getElementById('edit-modal').classList.add('hidden');
          await loadPage();
        } else {
          const d = await res.json().catch(() => ({}));
          errEl.textContent = d.message ?? d.error ?? 'Failed to save changes.';
          errEl.classList.remove('hidden');
        }
      });
    }

    loadPage();
  </script>
</PortalLayout>

---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const isSecretary = user.portalRole === 'secretary';
const isPresident = user.portalRole === 'president';
const isAdmin = user.isAdmin;

if (!isSecretary && !isPresident && !isAdmin) return Astro.redirect('/portal/hoto');

// Which statuses this user can act on
const myPendingStatuses = isAdmin
  ? ['PENDING_SECRETARY', 'PENDING_PRESIDENT']
  : isPresident
    ? ['PENDING_PRESIDENT']
    : ['PENDING_SECRETARY'];
---

<PortalLayout title="Pending Approvals" user={user} activeModule="hoto_pending">
  <!-- Process info panel -->
  <details open class="mb-6 group rounded-xl border border-primary-100 bg-gradient-to-r from-primary-50/50 to-blue-50/20 overflow-hidden">
    <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer list-none select-none hover:bg-primary-50/60 transition-colors">
      <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-project-diagram text-white text-xs" aria-hidden="true"></i>
      </div>
      <span class="text-sm font-medium text-text-primary flex-1">Items waiting for Secretary or President sign-off — approval here moves items toward closure.</span>
      <span class="text-xs text-primary-600 flex items-center gap-1.5 flex-shrink-0 font-medium">
        How it works
        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200 group-open:rotate-180" aria-hidden="true"></i>
      </span>
    </summary>
    <div class="px-5 pb-5">
      <div class="pt-4 border-t border-primary-100 space-y-4">
        <!-- Main flow -->
        <div class="flex items-start gap-1.5 overflow-x-auto pb-2 -mx-1 px-1">
          <div class="flex-shrink-0 w-44 rounded-lg border border-amber-300 bg-amber-50 px-2 py-2 text-center">
            <p class="text-[11px] font-semibold text-amber-800 whitespace-nowrap">Awaiting Secretary</p>
            <p class="text-[10px] text-amber-700 mt-0.5 whitespace-nowrap">Documents verified?</p>
          </div>
          <i class="fas fa-arrow-right text-gray-300 text-xs self-center flex-shrink-0" aria-hidden="true"></i>
          <div class="flex-shrink-0 w-44 rounded-lg border border-primary-300 bg-blue-50 px-2 py-2 text-center">
            <p class="text-[11px] font-semibold text-primary-700 whitespace-nowrap">Awaiting President</p>
            <p class="text-[10px] text-primary-600 mt-0.5 whitespace-nowrap">Final sign-off</p>
          </div>
          <i class="fas fa-arrow-right text-gray-300 text-xs self-center flex-shrink-0" aria-hidden="true"></i>
          <div class="flex-shrink-0 w-44 rounded-lg border border-green-300 bg-green-50 px-2 py-2 text-center">
            <p class="text-[11px] font-semibold text-green-800 whitespace-nowrap">Approved</p>
            <p class="text-[10px] text-green-700 mt-0.5 whitespace-nowrap">Closes automatically</p>
          </div>
        </div>
        <!-- Exception row -->
        <div class="flex items-center gap-2 text-xs text-red-600">
          <i class="fas fa-arrow-turn-down text-red-400 text-[10px]" aria-hidden="true"></i>
          <span class="font-medium">Send Back</span>
          <span class="text-red-500">— Returns to Docs Pending to request more evidence</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mt-1">
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Secretary approval is required first; President cannot skip ahead</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-exclamation-circle text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Rejecting an item sends it back to 'Docs Pending' and notifies the responsible executive</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Approved items remain visible for 7 days before moving off this queue</span>
          </div>
        </div>
      </div>
    </div>
  </details>

  <div class="mb-6 flex items-center justify-between flex-wrap gap-3">
    <div>
      <h1 class="text-2xl font-bold text-text-primary">Pending Approvals</h1>
      <p class="text-sm text-text-secondary mt-1">HOTO items awaiting your sign-off.</p>
    </div>
    <a href="/portal/hoto" class="text-sm text-text-secondary hover:text-primary-600 flex items-center gap-1.5">
      <i class="fas fa-arrow-left text-xs"></i> HOTO Tracker
    </a>
  </div>

  <!-- Role filter tabs -->
  <div class="border-b border-border-light mb-5 flex gap-0">
    {isAdmin && (
      <>
        <button class="tab-btn whitespace-nowrap px-4 py-2.5 text-sm font-medium border-b-2 border-primary-600 text-primary-600" data-filter="all">All Pending</button>
        <button class="tab-btn whitespace-nowrap px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-text-secondary hover:text-text-primary" data-filter="PENDING_SECRETARY">Secretary</button>
        <button class="tab-btn whitespace-nowrap px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-text-secondary hover:text-text-primary" data-filter="PENDING_PRESIDENT">President</button>
      </>
    )}
    {!isAdmin && (
      <span class="px-4 py-2.5 text-sm font-medium border-b-2 border-primary-600 text-primary-600">
        Items awaiting {isPresident ? 'President' : 'Secretary'} approval
      </span>
    )}
  </div>

  <div id="pending-container">
    <div class="text-center py-10 text-text-secondary text-sm animate-pulse">Loading…</div>
  </div>

  <script define:vars={{ myPendingStatuses, isAdmin }}>
    let currentFilter = isAdmin ? 'all' : null;

    async function loadPending(statusFilter) {
      // Fetch all relevant pending statuses in two requests (API only takes one status at a time)
      const statusesToFetch = statusFilter && statusFilter !== 'all'
        ? [statusFilter]
        : isAdmin
          ? ['PENDING_SECRETARY', 'PENDING_PRESIDENT']
          : myPendingStatuses;

      const container = document.getElementById('pending-container');

      try {
        const results = await Promise.all(
          statusesToFetch.map(s =>
            fetch(`/api/v1/hoto/items?status=${s}&limit=100`, { credentials: 'include' })
              .then(r => r.ok ? r.json() : { items: [] })
              .then(d => d.items ?? d)
          )
        );
        const items = results.flat().sort((a, b) => new Date(a.last_updated_at).getTime() - new Date(b.last_updated_at).getTime());
        renderItems(items);
      } catch {
        container.innerHTML = '<p class="text-red-600 text-sm">Failed to load items.</p>';
      }
    }

    function renderItems(items) {
      const container = document.getElementById('pending-container');
      if (!items.length) {
        container.innerHTML = '<div class="bg-white rounded-2xl border border-border-light p-12 text-center text-text-secondary text-sm"><i class="fas fa-check-circle text-3xl mb-3 block text-green-400"></i>No items pending approval.</div>';
        return;
      }

      const PRIORITY_COLOR = { CRITICAL: 'text-red-600 bg-red-50', HIGH: 'text-orange-600 bg-orange-50', MEDIUM: 'text-amber-600 bg-amber-50', LOW: 'text-blue-600 bg-blue-50' };
      const STATUS_LABEL = { PENDING_SECRETARY: 'Awaiting Secretary', PENDING_PRESIDENT: 'Awaiting President' };

      container.innerHTML = `
        <div class="space-y-3">
          ${items.map(item => {
            const overdue = item.builder_sla_date && item.builder_sla_date < new Date().toISOString().slice(0,10);
            const prioStyle = PRIORITY_COLOR[item.priority] ?? 'text-gray-600 bg-gray-50';
            const waitingSince = item.status_changed_at ?? item.last_updated_at;
            const daysSince = waitingSince
              ? Math.floor((Date.now() - new Date(waitingSince).getTime()) / 86_400_000)
              : null;
            return `
              <a href="/portal/hoto/${item.id}" class="block bg-white rounded-2xl border border-border-light hover:border-primary-600 hover:shadow-medium transition-all p-5">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap mb-1">
                      <span class="text-xs px-2 py-0.5 rounded-full font-medium ${prioStyle}">${item.priority}</span>
                      <span class="text-xs px-2 py-0.5 rounded-full bg-purple-50 text-purple-700 font-medium">${STATUS_LABEL[item.status] ?? item.status}</span>
                      ${overdue ? '<span class="text-xs px-2 py-0.5 rounded-full bg-red-50 text-red-700 font-medium">SLA Overdue</span>' : ''}
                    </div>
                    <h3 class="font-semibold text-text-primary truncate">${item.title}</h3>
                    <p class="text-xs text-text-secondary mt-0.5">${item.hoto_category}</p>
                  </div>
                  <div class="text-right shrink-0 text-xs text-text-secondary">
                    ${daysSince !== null ? `<div class="${daysSince >= 3 ? 'text-red-600 font-medium' : ''}">Waiting ${daysSince}d</div>` : ''}
                    ${item.builder_sla_date ? `<div>SLA: ${item.builder_sla_date}</div>` : ''}
                    <div class="mt-1 text-primary-600 font-medium">Review →</div>
                  </div>
                </div>
              </a>`;
          }).join('')}
        </div>
        <p class="text-xs text-text-secondary text-center mt-4">${items.length} item${items.length !== 1 ? 's' : ''} pending</p>`;
    }

    // Tab switching (admin only)
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => {
          b.classList.remove('border-primary-600','text-primary-600');
          b.classList.add('border-transparent','text-text-secondary');
        });
        btn.classList.add('border-primary-600','text-primary-600');
        btn.classList.remove('border-transparent','text-text-secondary');
        currentFilter = btn.dataset.filter;
        loadPending(currentFilter);
      });
    });

    loadPending(currentFilter);
  </script>
</PortalLayout>

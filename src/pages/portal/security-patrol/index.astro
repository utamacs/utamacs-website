---
export const prerender = false;
import PortalLayout from '@components/portal/PortalLayout.astro';
import { resolveFromRequest } from '@lib/permissions';

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const user = await resolveFromRequest(Astro.request, SOCIETY_ID);
if (!user) return Astro.redirect('/portal/login');

const isGuard = user.role === 'security_guard';
const isPrivileged = ['executive', 'secretary', 'president'].includes(user.portalRole ?? '') || user.isAdmin;
const canLog = isGuard || isPrivileged;
---

<PortalLayout title="Security Patrol Log" user={user} activeModule="security_patrol">
  <div class="mb-6 flex items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-primary-600 font-poppins">Security Patrol Log</h1>
      <p class="text-text-secondary text-sm mt-1">Daily patrol records and incident reports.</p>
    </div>
    <div class="flex items-center gap-2">
      {isPrivileged && (
        <a id="export-csv-btn" href="/api/v1/security-patrol/export" target="_blank"
           class="btn-ghost text-sm flex items-center gap-1.5">
          <i class="fas fa-download" aria-hidden="true"></i>Export CSV
        </a>
      )}
      {canLog && (
        <button id="log-btn" class="btn-primary text-sm flex items-center gap-2">
          <i class="fas fa-plus" aria-hidden="true"></i> Log Patrol
        </button>
      )}
    </div>
  </div>

  <!-- Exec summary stats panel (hidden until loaded) -->
  {isPrivileged && (
    <div id="summary-panel" class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6 hidden">
      <!-- filled by JS -->
    </div>
  )}

  <!-- Tabs -->
  <div class="flex gap-1 mb-5 border-b border-border-light">
    <button data-tab="logs" class="tab-btn px-4 py-2 text-sm font-medium text-primary-600 border-b-2 border-primary-600">Patrol Logs</button>
    {isPrivileged && (
      <button data-tab="incidents" class="tab-btn px-4 py-2 text-sm font-medium text-text-secondary hover:text-primary-600 border-b-2 border-transparent">
        Open Incidents
        <span id="open-incident-count" class="hidden ml-1.5 text-xs bg-red-100 text-red-700 px-1.5 py-0.5 rounded-full font-medium"></span>
      </button>
    )}
    {isPrivileged && (
      <button data-tab="schedules" class="tab-btn px-4 py-2 text-sm font-medium text-text-secondary hover:text-primary-600 border-b-2 border-transparent">Schedules</button>
    )}
    {isPrivileged && (
      <button data-tab="attendance" class="tab-btn px-4 py-2 text-sm font-medium text-text-secondary hover:text-primary-600 border-b-2 border-transparent">Guard Attendance</button>
    )}
  </div>

  <!-- Logs tab -->
  <div id="panel-logs">
    <div class="flex gap-3 mb-5 flex-wrap items-center">
      <button data-filter="all" class="filter-btn text-xs px-3 py-1.5 rounded-full font-medium border bg-primary-600 text-white border-primary-600">All</button>
      <button data-filter="incidents" class="filter-btn text-xs px-3 py-1.5 rounded-full font-medium border bg-white text-text-secondary border-border-light hover:border-primary-600 hover:text-primary-600">
        <i class="fas fa-exclamation-triangle mr-1 text-amber-500" aria-hidden="true"></i>Incidents only
      </button>
      <div class="flex items-center gap-2 ml-auto">
        <label class="text-xs text-text-secondary">From</label>
        <input id="date-from" type="date" class="form-input py-1.5 text-xs" style="width:130px" />
        <label class="text-xs text-text-secondary">To</label>
        <input id="date-to" type="date" class="form-input py-1.5 text-xs" style="width:130px" />
      </div>
    </div>
    <div class="bg-white rounded-xl border border-border-light overflow-hidden">
      <div id="patrol-list">
        <div class="text-sm text-text-secondary text-center py-10">Loading…</div>
      </div>
    </div>
  </div>

  <!-- Open Incidents tab -->
  {isPrivileged && (
    <div id="panel-incidents" class="hidden">
      <div class="bg-white rounded-xl border border-border-light overflow-hidden">
        <div id="incidents-list">
          <div class="text-sm text-text-secondary text-center py-10">Loading…</div>
        </div>
      </div>
    </div>
  )}

  <!-- Schedules tab -->
  {isPrivileged && (
    <div id="panel-schedules" class="hidden">
      <div class="mb-4 flex justify-end">
        <button id="add-schedule-btn" class="btn-primary text-sm flex items-center gap-2">
          <i class="fas fa-plus" aria-hidden="true"></i> Add Schedule
        </button>
      </div>
      <div class="bg-white rounded-xl border border-border-light overflow-hidden">
        <div id="schedules-list">
          <div class="text-sm text-text-secondary text-center py-10">Loading…</div>
        </div>
      </div>
    </div>
  )}

  <!-- Guard Attendance tab -->
  {isPrivileged && (
    <div id="panel-attendance" class="hidden">
      <div class="flex items-center gap-3 mb-4 flex-wrap">
        <label class="text-sm text-text-secondary">Window (days):</label>
        <select id="attendance-days" class="form-input py-1.5 text-sm" style="width:110px">
          <option value="7">Last 7</option>
          <option value="30" selected>Last 30</option>
          <option value="60">Last 60</option>
          <option value="90">Last 90</option>
        </select>
        <button id="attendance-refresh" class="btn-ghost text-xs px-3 py-1.5 flex items-center gap-1.5">
          <i class="fas fa-sync-alt" aria-hidden="true"></i>Refresh
        </button>
      </div>
      <div id="attendance-kpis" class="grid grid-cols-3 gap-4 mb-5"></div>
      <div class="bg-white rounded-xl border border-border-light overflow-hidden">
        <div id="attendance-list">
          <div class="text-sm text-text-secondary text-center py-10">Loading…</div>
        </div>
      </div>
    </div>
  )}

  <!-- Log patrol modal -->
  {canLog && (
    <div id="patrol-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" role="dialog">
      <div class="bg-white rounded-2xl shadow-large w-full max-w-lg overflow-hidden">
        <div class="px-6 py-4 border-b border-border-light flex items-center justify-between">
          <h3 class="text-lg font-semibold text-primary-600">Log Patrol Entry</h3>
          <button id="pm-close" class="text-text-secondary hover:text-text-primary p-2">
            <i class="fas fa-times" aria-hidden="true"></i>
          </button>
        </div>
        <div class="p-6 space-y-4 max-h-[75vh] overflow-y-auto">
          <div id="pm-error" class="hidden p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="form-label" for="pm-date">Patrol date <span class="text-red-500">*</span></label>
              <input id="pm-date" type="date" class="form-input" required />
            </div>
            <div>
              <label class="form-label" for="pm-shift">Shift <span class="text-red-500">*</span></label>
              <select id="pm-shift" class="form-input bg-white">
                <option value="">Select</option>
                <option value="morning">Morning (6am–2pm)</option>
                <option value="afternoon">Afternoon (2pm–10pm)</option>
                <option value="evening">Evening (6pm–10pm)</option>
                <option value="night">Night (10pm–6am)</option>
                <option value="full_day">Full Day</option>
              </select>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="form-label" for="pm-guard">Guard name <span class="text-red-500">*</span></label>
              <input id="pm-guard" type="text" maxlength="200" class="form-input" placeholder="e.g. Suresh Kumar" />
            </div>
            <div class="grid grid-cols-2 gap-2">
              <div>
                <label class="form-label" for="pm-start">Start time</label>
                <input id="pm-start" type="time" class="form-input" />
              </div>
              <div>
                <label class="form-label" for="pm-end">End time</label>
                <input id="pm-end" type="time" class="form-input" />
              </div>
            </div>
          </div>
          <div>
            <label class="form-label">Checkpoints completed</label>
            <div class="grid grid-cols-2 gap-2" id="checkpoint-grid">
              {['Gate 1','Gate 2','Parking','Lift Lobby','Terrace','Water Tank','Generator Room','Children\'s Play Area'].map(cp => (
                <label class="flex items-center gap-2 text-sm text-text-primary cursor-pointer">
                  <input type="checkbox" value={cp} class="checkpoint-cb w-4 h-4 accent-primary-600" />
                  {cp}
                </label>
              ))}
            </div>
          </div>
          <div class="flex items-center gap-2 p-3 bg-amber-50 rounded-xl border border-amber-100">
            <input type="checkbox" id="pm-incident" class="w-4 h-4 accent-amber-500" />
            <label for="pm-incident" class="text-sm font-medium text-amber-700 cursor-pointer">
              <i class="fas fa-exclamation-triangle mr-1" aria-hidden="true"></i>Incident / Alert occurred this shift
            </label>
          </div>
          <div>
            <label class="form-label" for="pm-incidents">Incident details</label>
            <textarea id="pm-incidents" rows="3" maxlength="2000" class="form-input resize-none" placeholder="Describe what happened (required if incident checked)"></textarea>
          </div>
          <div>
            <label class="form-label" for="pm-remarks">General remarks</label>
            <textarea id="pm-remarks" rows="2" maxlength="1000" class="form-input resize-none" placeholder="Any other observations"></textarea>
          </div>
        </div>
        <div class="px-6 pb-6 flex gap-3">
          <button id="pm-submit" class="btn-primary flex-1 flex items-center justify-center gap-2 text-sm">
            <i class="fas fa-save" aria-hidden="true"></i>
            <span id="pm-submit-label">Save Patrol Log</span>
          </button>
          <button id="pm-cancel" class="btn-outline flex-1 text-sm">Cancel</button>
        </div>
      </div>
    </div>
  )}

  <!-- Resolve incident modal -->
  {isPrivileged && (
    <div id="resolve-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" role="dialog">
      <div class="bg-white rounded-2xl shadow-large w-full max-w-md p-6">
        <h3 class="text-lg font-semibold text-primary-600 mb-4">Mark Incident Resolved</h3>
        <div id="resolve-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
        <input type="hidden" id="resolve-id" />
        <div class="mb-4">
          <label class="form-label" for="resolve-note">Resolution note <span class="text-red-500">*</span></label>
          <textarea id="resolve-note" rows="3" maxlength="500" class="form-input resize-none"
            placeholder="Describe how the incident was handled…"></textarea>
        </div>
        <div class="flex gap-3">
          <button id="resolve-submit" class="btn-primary flex-1 text-sm">Confirm Resolved</button>
          <button id="resolve-cancel" class="btn-outline flex-1 text-sm">Cancel</button>
        </div>
      </div>
    </div>
  )}

  <!-- Add Schedule modal -->
  {isPrivileged && (
    <div id="schedule-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" role="dialog">
      <div class="bg-white rounded-2xl shadow-large w-full max-w-lg p-6">
        <h3 class="text-lg font-semibold text-primary-600 mb-4">Add Guard Schedule</h3>
        <div id="sched-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="form-label" for="sched-guard">Guard name <span class="text-red-500">*</span></label>
              <input id="sched-guard" type="text" maxlength="200" class="form-input" placeholder="e.g. Suresh Kumar" />
            </div>
            <div>
              <label class="form-label" for="sched-shift">Shift <span class="text-red-500">*</span></label>
              <select id="sched-shift" class="form-input bg-white">
                <option value="">Select shift</option>
                <option value="morning">Morning (6am–2pm)</option>
                <option value="afternoon">Afternoon (2pm–10pm)</option>
                <option value="evening">Evening (6pm–10pm)</option>
                <option value="night">Night (10pm–6am)</option>
                <option value="full_day">Full Day</option>
              </select>
            </div>
          </div>
          <div>
            <label class="form-label">Days of week <span class="text-red-500">*</span></label>
            <div class="flex gap-2 flex-wrap mt-1">
              {[['Sun',0],['Mon',1],['Tue',2],['Wed',3],['Thu',4],['Fri',5],['Sat',6]].map(([lbl, val]) => (
                <label class="flex items-center gap-1.5 text-sm cursor-pointer select-none">
                  <input type="checkbox" value={val} class="dow-cb w-4 h-4 accent-primary-600" />
                  {lbl}
                </label>
              ))}
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="form-label" for="sched-from">Effective from <span class="text-red-500">*</span></label>
              <input id="sched-from" type="date" class="form-input" />
            </div>
            <div>
              <label class="form-label" for="sched-to">Effective to <span class="text-text-secondary text-xs">(leave blank = indefinite)</span></label>
              <input id="sched-to" type="date" class="form-input" />
            </div>
          </div>
          <div>
            <label class="form-label" for="sched-notes">Notes</label>
            <input id="sched-notes" type="text" maxlength="300" class="form-input" placeholder="Any additional notes" />
          </div>
        </div>
        <div class="flex gap-3 mt-5">
          <button id="sched-submit" class="btn-primary flex-1 text-sm">Save Schedule</button>
          <button id="sched-cancel" class="btn-outline flex-1 text-sm">Cancel</button>
        </div>
      </div>
    </div>
  )}

  <script define:vars={{ canLog, isPrivileged }}>
    let activeTab = 'logs';
    let incidentFilter = false;
    let dateFrom = '';
    let dateTo = '';

    function showToast(msg, type = 'success') {
      const toast = document.createElement('div');
      toast.className = `fixed bottom-6 right-6 z-50 px-4 py-3 rounded-xl shadow-large text-sm font-medium text-white transform translate-y-4 opacity-0 transition-all duration-300 ${type === 'success' ? 'bg-secondary-500' : 'bg-red-500'}`;
      toast.textContent = msg;
      document.body.appendChild(toast);
      requestAnimationFrame(() => toast.classList.remove('translate-y-4', 'opacity-0'));
      setTimeout(() => { toast.classList.add('translate-y-4', 'opacity-0'); setTimeout(() => toast.remove(), 300); }, 3500);
    }

    const SHIFT_LABELS = { morning:'Morning', afternoon:'Afternoon', evening:'Evening', night:'Night', full_day:'Full Day' };
    const SHIFT_COLORS = {
      morning:'bg-yellow-100 text-yellow-700', afternoon:'bg-orange-100 text-orange-700',
      evening:'bg-purple-100 text-purple-700', night:'bg-blue-100 text-blue-700', full_day:'bg-gray-100 text-gray-700',
    };
    const DOW_LABELS = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

    // ── Tabs ────────────────────────────────────────────────────────────────────
    function switchTab(tab) {
      activeTab = tab;
      ['logs','incidents','schedules','attendance'].forEach(t => {
        const panel = document.getElementById(`panel-${t}`);
        const btn   = document.querySelector(`[data-tab="${t}"]`);
        if (panel) panel.classList.toggle('hidden', t !== tab);
        if (btn) {
          btn.classList.toggle('text-primary-600', t === tab);
          btn.classList.toggle('border-primary-600', t === tab);
          btn.classList.toggle('text-text-secondary', t !== tab);
          btn.classList.toggle('border-transparent', t !== tab);
        }
      });
      if (tab === 'incidents') loadOpenIncidents();
      if (tab === 'schedules') loadSchedules();
      if (tab === 'attendance') loadAttendance();
    }

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => switchTab(btn.dataset.tab));
    });

    // ── Summary stats ───────────────────────────────────────────────────────────
    if (isPrivileged) {
      fetch('/api/v1/security-patrol/summary', { credentials: 'include' })
        .then(r => r.ok ? r.json() : null)
        .then(s => {
          if (!s) return;
          const panel = document.getElementById('summary-panel');
          panel.innerHTML = [
            { icon: 'fa-shield-alt', color: 'text-primary-600 bg-primary-50', label: 'Shifts this week', value: s.shifts_this_week },
            { icon: 'fa-exclamation-triangle', color: 'text-red-600 bg-red-50', label: 'Open incidents', value: s.open_incidents,
              extra: s.overdue_incidents > 0 ? `<span class="text-xs text-red-600 font-medium">${s.overdue_incidents} overdue</span>` : '' },
            { icon: 'fa-calendar-alt', color: 'text-blue-600 bg-blue-50', label: `Shifts (${s.window_days}d)`, value: s.total_shifts },
            { icon: 'fa-map-marker-check', color: 'text-green-600 bg-green-50', label: 'Avg checkpoints/shift', value: s.avg_checkpoints },
          ].map(c => `
            <div class="bg-white rounded-xl border border-border-light p-4 flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl ${c.color} flex items-center justify-center flex-shrink-0">
                <i class="fas ${c.icon}" aria-hidden="true"></i>
              </div>
              <div>
                <div class="text-xl font-bold text-text-primary">${c.value}</div>
                <div class="text-xs text-text-secondary">${c.label}</div>
                ${c.extra ?? ''}
              </div>
            </div>
          `).join('');
          panel.classList.remove('hidden');

          // Badge on incidents tab
          if (s.open_incidents > 0) {
            const badge = document.getElementById('open-incident-count');
            if (badge) { badge.textContent = String(s.open_incidents); badge.classList.remove('hidden'); }
          }
        }).catch(() => {});
    }

    // ── Patrol Logs ─────────────────────────────────────────────────────────────
    async function load() {
      const container = document.getElementById('patrol-list');
      container.innerHTML = '<div class="text-sm text-text-secondary text-center py-10"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';
      const params = new URLSearchParams();
      if (incidentFilter) params.set('incidents', 'true');
      if (dateFrom) params.set('from', dateFrom);
      if (dateTo) params.set('to', dateTo);
      const res = await fetch(`/api/v1/security-patrol?${params}`, { credentials: 'include' });
      const logs = res.ok ? await res.json() : [];

      if (!logs.length) {
        container.innerHTML = '<div class="text-sm text-text-secondary text-center py-10">No patrol logs found.</div>';
        return;
      }

      container.innerHTML = logs.map(l => renderLogRow(l, true)).join('');
    }

    function renderLogRow(l, showDelete = false) {
      const shiftBadge = `<span class="text-xs px-2 py-0.5 rounded-full font-medium ${SHIFT_COLORS[l.shift] ?? 'bg-gray-100 text-gray-700'}">${SHIFT_LABELS[l.shift] ?? l.shift}</span>`;
      const incidentBadge = l.is_incident ? '<span class="text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded-full font-medium"><i class="fas fa-exclamation-triangle mr-1"></i>Incident</span>' : '';
      const resolvedBadge = l.resolved_at ? '<span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-medium"><i class="fas fa-check mr-1"></i>Resolved</span>' : '';
      const timeRange = (l.start_time || l.end_time) ? `${l.start_time ?? '?'} – ${l.end_time ?? '?'}` : '';
      const cps = Array.isArray(l.checkpoints) && l.checkpoints.length ? l.checkpoints.join(' · ') : null;

      const actions = isPrivileged ? `
        <div class="flex items-center gap-1 flex-shrink-0">
          ${l.is_incident && !l.resolved_at ? `<button onclick="openResolve('${l.id}')" class="text-xs px-2 py-1 rounded-lg bg-green-50 text-green-700 hover:bg-green-100 font-medium">Resolve</button>` : ''}
          ${showDelete ? `<button onclick="deleteLog('${l.id}')" class="btn-ghost text-xs px-2 py-1.5 text-text-secondary hover:text-red-600"><i class="fas fa-trash text-xs"></i></button>` : ''}
        </div>` : '';

      return `
        <div class="px-5 py-4 border-b border-border-light last:border-b-0 ${l.is_incident && !l.resolved_at ? 'bg-red-50/40' : 'hover:bg-gray-50'} transition-colors">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <span class="text-sm font-semibold text-text-primary">${new Date(l.patrol_date + 'T00:00:00').toLocaleDateString('en-IN', { weekday:'short', day:'numeric', month:'short', year:'numeric' })}</span>
                ${shiftBadge}${incidentBadge}${resolvedBadge}
              </div>
              <div class="text-xs text-text-secondary flex items-center gap-3 flex-wrap">
                <span><i class="fas fa-user-shield mr-1 text-primary-300"></i>${l.guard_name}</span>
                ${timeRange ? `<span><i class="fas fa-clock mr-1 text-primary-300"></i>${timeRange}</span>` : ''}
              </div>
              ${cps ? `<div class="text-xs text-text-secondary mt-1.5"><i class="fas fa-map-marker-alt mr-1 text-primary-300"></i>${cps}</div>` : ''}
              ${l.incidents ? `<div class="text-xs text-red-600 mt-1.5 font-medium"><i class="fas fa-exclamation-circle mr-1"></i>${l.incidents}</div>` : ''}
              ${l.resolution_note ? `<div class="text-xs text-green-700 mt-1 italic"><i class="fas fa-check-circle mr-1"></i>${l.resolution_note}</div>` : ''}
              ${l.remarks ? `<div class="text-xs text-text-secondary mt-1 italic">${l.remarks}</div>` : ''}
            </div>
            ${actions}
          </div>
        </div>
      `;
    }

    async function loadOpenIncidents() {
      const container = document.getElementById('incidents-list');
      if (!container) return;
      container.innerHTML = '<div class="text-sm text-text-secondary text-center py-10"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';
      const res = await fetch('/api/v1/security-patrol?incidents=true', { credentials: 'include' });
      const logs = res.ok ? (await res.json()).filter(l => !l.resolved_at) : [];

      if (!logs.length) {
        container.innerHTML = '<div class="text-sm text-text-secondary text-center py-10"><i class="fas fa-check-circle text-green-500 mr-2"></i>No open incidents — all clear!</div>';
        return;
      }
      container.innerHTML = logs.map(l => renderLogRow(l, false)).join('');
    }

    window.openResolve = function(id) {
      document.getElementById('resolve-id').value = id;
      document.getElementById('resolve-note').value = '';
      document.getElementById('resolve-error').classList.add('hidden');
      document.getElementById('resolve-modal').classList.remove('hidden');
    };

    if (isPrivileged) {
      document.getElementById('resolve-cancel')?.addEventListener('click', () => {
        document.getElementById('resolve-modal').classList.add('hidden');
      });
      document.getElementById('resolve-submit')?.addEventListener('click', async () => {
        const id   = document.getElementById('resolve-id').value;
        const note = document.getElementById('resolve-note').value.trim();
        const errEl = document.getElementById('resolve-error');
        errEl.classList.add('hidden');
        if (!note) { errEl.textContent = 'Resolution note is required.'; errEl.classList.remove('hidden'); return; }
        const btn = document.getElementById('resolve-submit');
        btn.disabled = true; btn.textContent = 'Saving…';
        const res = await fetch(`/api/v1/security-patrol?id=${id}`, {
          method: 'PATCH', credentials: 'include', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ resolution_note: note }),
        });
        btn.disabled = false; btn.textContent = 'Confirm Resolved';
        if (res.ok) {
          document.getElementById('resolve-modal').classList.add('hidden');
          showToast('Incident marked resolved.');
          await load();
          if (activeTab === 'incidents') await loadOpenIncidents();
        } else {
          const d = await res.json().catch(() => ({}));
          errEl.textContent = d.message ?? 'Failed to resolve.';
          errEl.classList.remove('hidden');
        }
      });
    }

    async function deleteLog(id) {
      if (!confirm('Delete this patrol log?')) return;
      const res = await fetch(`/api/v1/security-patrol?id=${id}`, { method: 'DELETE', credentials: 'include' });
      if (res.ok) { showToast('Log deleted.'); load(); }
      else showToast('Failed to delete log.', 'error');
    }

    // ── Schedules ───────────────────────────────────────────────────────────────
    async function loadSchedules() {
      const container = document.getElementById('schedules-list');
      if (!container) return;
      container.innerHTML = '<div class="text-sm text-text-secondary text-center py-10"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';
      const res = await fetch('/api/v1/security-patrol/schedules', { credentials: 'include' });
      const schedules = res.ok ? await res.json() : [];

      if (!schedules.length) {
        container.innerHTML = '<div class="text-sm text-text-secondary text-center py-10">No schedules defined yet.</div>';
        return;
      }

      container.innerHTML = schedules.map(s => {
        const days = (s.days_of_week ?? []).map(d => DOW_LABELS[d] ?? d).join(', ');
        const from = s.effective_from ? new Date(s.effective_from + 'T00:00:00').toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) : '—';
        const to   = s.effective_to   ? new Date(s.effective_to   + 'T00:00:00').toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) : 'Ongoing';
        return `
          <div class="px-5 py-4 border-b border-border-light last:border-b-0 flex items-start gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <span class="text-sm font-semibold text-text-primary">${s.guard_name}</span>
                <span class="text-xs px-2 py-0.5 rounded-full font-medium ${SHIFT_COLORS[s.shift] ?? 'bg-gray-100 text-gray-700'}">${SHIFT_LABELS[s.shift] ?? s.shift}</span>
              </div>
              <div class="text-xs text-text-secondary flex gap-3 flex-wrap">
                <span><i class="fas fa-calendar-week mr-1"></i>${days}</span>
                <span><i class="fas fa-calendar-alt mr-1"></i>${from} → ${to}</span>
              </div>
              ${s.notes ? `<div class="text-xs text-text-secondary mt-1 italic">${s.notes}</div>` : ''}
            </div>
            <button onclick="deleteSchedule('${s.id}')" class="btn-ghost text-xs px-2 py-1.5 text-text-secondary hover:text-red-600 flex-shrink-0">
              <i class="fas fa-trash text-xs"></i>
            </button>
          </div>
        `;
      }).join('');
    }

    window.deleteSchedule = async function(id) {
      if (!confirm('Remove this schedule entry?')) return;
      const res = await fetch(`/api/v1/security-patrol/schedules?id=${id}`, { method: 'DELETE', credentials: 'include' });
      if (res.ok) { showToast('Schedule removed.'); loadSchedules(); }
      else showToast('Failed to remove schedule.', 'error');
    };

    if (isPrivileged) {
      document.getElementById('add-schedule-btn')?.addEventListener('click', () => {
        document.getElementById('sched-guard').value = '';
        document.getElementById('sched-shift').value = '';
        document.querySelectorAll('.dow-cb').forEach(cb => { cb.checked = false; });
        document.getElementById('sched-from').value = new Date().toISOString().slice(0, 10);
        document.getElementById('sched-to').value = '';
        document.getElementById('sched-notes').value = '';
        document.getElementById('sched-error').classList.add('hidden');
        document.getElementById('schedule-modal').classList.remove('hidden');
      });
      document.getElementById('sched-cancel')?.addEventListener('click', () => {
        document.getElementById('schedule-modal').classList.add('hidden');
      });
      document.getElementById('sched-submit')?.addEventListener('click', async () => {
        const guard_name = document.getElementById('sched-guard').value.trim();
        const shift      = document.getElementById('sched-shift').value;
        const days_of_week = [...document.querySelectorAll('.dow-cb:checked')].map(c => parseInt(c.value));
        const from = document.getElementById('sched-from').value;
        const to   = document.getElementById('sched-to').value || undefined;
        const notes = document.getElementById('sched-notes').value.trim() || undefined;
        const errEl = document.getElementById('sched-error');
        errEl.classList.add('hidden');

        if (!guard_name) { errEl.textContent = 'Guard name is required.'; errEl.classList.remove('hidden'); return; }
        if (!shift) { errEl.textContent = 'Shift is required.'; errEl.classList.remove('hidden'); return; }
        if (!days_of_week.length) { errEl.textContent = 'At least one day of week is required.'; errEl.classList.remove('hidden'); return; }
        if (!from) { errEl.textContent = 'Effective from date is required.'; errEl.classList.remove('hidden'); return; }

        const btn = document.getElementById('sched-submit');
        btn.disabled = true; btn.textContent = 'Saving…';

        const res = await fetch('/api/v1/security-patrol/schedules', {
          method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ guard_name, shift, days_of_week, effective_from: from, effective_to: to, notes }),
        });
        btn.disabled = false; btn.textContent = 'Save Schedule';
        if (res.ok) {
          document.getElementById('schedule-modal').classList.add('hidden');
          showToast('Schedule saved.');
          loadSchedules();
        } else {
          const d = await res.json().catch(() => ({}));
          errEl.textContent = d.message ?? 'Failed to save schedule.';
          errEl.classList.remove('hidden');
        }
      });
    }

    // ── Guard Attendance ─────────────────────────────────────────────────────────
    let attendanceLoaded = false;

    async function loadAttendance(force = false) {
      if (attendanceLoaded && !force) return;
      attendanceLoaded = true;
      const days = document.getElementById('attendance-days')?.value ?? '30';
      const listEl = document.getElementById('attendance-list');
      const kpisEl = document.getElementById('attendance-kpis');
      if (listEl) listEl.innerHTML = '<div class="text-sm text-text-secondary text-center py-10"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';

      try {
        const res = await fetch(`/api/v1/security-patrol/attendance?days=${days}`, { credentials: 'include' });
        if (!res.ok) throw new Error();
        const data = await res.json();

        // KPI strip
        if (kpisEl) {
          kpisEl.innerHTML = [
            { icon: 'fa-shield-alt', color: 'text-primary-600 bg-primary-50', label: `Shifts (${data.window_days}d)`, value: data.total_shifts },
            { icon: 'fa-user-shield', color: 'text-secondary-500 bg-green-50', label: 'Guards tracked', value: data.guard_count },
            { icon: 'fa-exclamation-triangle', color: 'text-red-600 bg-red-50', label: 'Open incidents', value: data.open_incidents },
          ].map(c => `
            <div class="bg-white rounded-xl border border-border-light p-4 flex items-center gap-3">
              <div class="w-9 h-9 rounded-xl ${c.color} flex items-center justify-center flex-shrink-0">
                <i class="fas ${c.icon} text-sm" aria-hidden="true"></i>
              </div>
              <div>
                <div class="text-xl font-bold text-text-primary">${c.value}</div>
                <div class="text-xs text-text-secondary">${c.label}</div>
              </div>
            </div>
          `).join('');
        }

        if (!data.attendance?.length) {
          if (listEl) listEl.innerHTML = '<div class="text-sm text-text-secondary text-center py-10">No patrol records in this window.</div>';
          return;
        }

        const SHIFT_SHORT = { morning:'M', afternoon:'A', evening:'E', night:'N', full_day:'FD' };

        if (listEl) listEl.innerHTML = `
          <div class="grid text-xs font-medium text-text-secondary px-5 py-3 border-b border-border-light bg-gray-50"
               style="grid-template-columns:1fr 80px 80px 80px 80px 120px">
            <span>Guard</span><span class="text-right">Shifts</span><span class="text-right">Incidents</span>
            <span class="text-right">Open</span><span class="text-right">Avg CPs</span><span class="text-right">Last Active</span>
          </div>
          ${data.attendance.map(g => {
            const shiftBreak = Object.entries(g.shift_breakdown ?? {})
              .map(([sh, cnt]) => `${SHIFT_SHORT[sh] ?? sh}:${cnt}`).join(' ');
            const lastActive = g.last_active
              ? new Date(g.last_active + 'T00:00:00').toLocaleDateString('en-IN', { day:'numeric', month:'short' })
              : '—';
            const staleCls = (g.days_since_last ?? 0) > 7 ? 'text-amber-600' : 'text-text-secondary';
            return `
              <div class="grid text-sm px-5 py-3 border-b border-border-light last:border-b-0 hover:bg-gray-50"
                   style="grid-template-columns:1fr 80px 80px 80px 80px 120px">
                <div>
                  <span class="font-medium text-text-primary">${g.guard_name}</span>
                  ${shiftBreak ? `<span class="ml-2 text-xs text-text-secondary">(${shiftBreak})</span>` : ''}
                </div>
                <span class="text-right font-medium text-primary-600">${g.total_shifts}</span>
                <span class="text-right ${g.total_incidents > 0 ? 'text-red-600 font-medium' : 'text-text-secondary'}">${g.total_incidents}</span>
                <span class="text-right ${g.open_incidents > 0 ? 'text-red-600 font-bold' : 'text-text-secondary'}">${g.open_incidents}</span>
                <span class="text-right text-text-secondary">${g.avg_checkpoints}</span>
                <span class="text-right ${staleCls}">${lastActive}${g.days_since_last != null ? ` <span class="text-xs">(${g.days_since_last}d)</span>` : ''}</span>
              </div>
            `;
          }).join('')}
        `;
      } catch (_) {
        if (listEl) listEl.innerHTML = '<div class="text-sm text-text-secondary text-center py-10">Could not load attendance data.</div>';
      }
    }

    document.getElementById('attendance-days')?.addEventListener('change', () => {
      attendanceLoaded = false;
      loadAttendance();
    });
    document.getElementById('attendance-refresh')?.addEventListener('click', () => loadAttendance(true));

    // ── Export URL sync ───────────────────────────────────────────────────────────
    function syncExportUrl() {
      const btn = document.getElementById('export-csv-btn');
      if (!btn) return;
      const params = new URLSearchParams();
      if (dateFrom) params.set('from', dateFrom);
      if (dateTo)   params.set('to', dateTo);
      if (incidentFilter) params.set('incidents_only', 'true');
      const qs = params.toString();
      btn.href = `/api/v1/security-patrol/export${qs ? '?' + qs : ''}`;
    }

    // ── Filters ──────────────────────────────────────────────────────────────────
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => {
          b.classList.remove('bg-primary-600', 'text-white', 'border-primary-600');
          b.classList.add('bg-white', 'text-text-secondary', 'border-border-light');
        });
        btn.classList.add('bg-primary-600', 'text-white', 'border-primary-600');
        btn.classList.remove('bg-white', 'text-text-secondary', 'border-border-light');
        incidentFilter = btn.dataset.filter === 'incidents';
        load();
        syncExportUrl();
      });
    });

    document.getElementById('date-from')?.addEventListener('change', e => { dateFrom = e.target.value; load(); syncExportUrl(); });
    document.getElementById('date-to')?.addEventListener('change',   e => { dateTo   = e.target.value; load(); syncExportUrl(); });

    // ── Patrol modal ─────────────────────────────────────────────────────────────
    if (canLog) {
      const modal  = document.getElementById('patrol-modal');
      const errEl  = document.getElementById('pm-error');
      const submitBtn  = document.getElementById('pm-submit');
      const submitLbl  = document.getElementById('pm-submit-label');

      function openModal() {
        modal.classList.remove('hidden');
        errEl.classList.add('hidden');
        document.getElementById('pm-date').value = new Date().toISOString().slice(0, 10);
        document.querySelectorAll('.checkpoint-cb').forEach(cb => { cb.checked = false; });
        document.getElementById('pm-incident').checked = false;
      }
      function closeModal() { modal.classList.add('hidden'); }

      document.getElementById('log-btn').addEventListener('click', openModal);
      document.getElementById('pm-close').addEventListener('click', closeModal);
      document.getElementById('pm-cancel').addEventListener('click', closeModal);
      modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });

      submitBtn.addEventListener('click', async () => {
        errEl.classList.add('hidden');
        const patrol_date = document.getElementById('pm-date').value;
        const shift       = document.getElementById('pm-shift').value;
        const guard_name  = document.getElementById('pm-guard').value.trim();

        if (!patrol_date || !shift || !guard_name) {
          errEl.textContent = 'Date, shift and guard name are required.';
          errEl.classList.remove('hidden');
          return;
        }

        const is_incident = document.getElementById('pm-incident').checked;
        const incidents   = document.getElementById('pm-incidents').value.trim();
        if (is_incident && !incidents) {
          errEl.textContent = 'Please describe the incident.';
          errEl.classList.remove('hidden');
          return;
        }

        submitBtn.disabled = true; submitLbl.textContent = 'Saving…';

        const checkpoints = [];
        document.querySelectorAll('.checkpoint-cb').forEach(cb => { if (cb.checked) checkpoints.push(cb.value); });

        const res = await fetch('/api/v1/security-patrol', {
          method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            patrol_date, shift, guard_name,
            start_time: document.getElementById('pm-start').value || undefined,
            end_time:   document.getElementById('pm-end').value   || undefined,
            checkpoints: checkpoints.length ? checkpoints : undefined,
            is_incident,
            incidents:  incidents || undefined,
            remarks:    document.getElementById('pm-remarks').value.trim() || undefined,
          }),
        });
        submitBtn.disabled = false; submitLbl.textContent = 'Save Patrol Log';

        if (res.ok) {
          showToast(is_incident ? 'Incident logged and saved.' : 'Patrol log saved.');
          closeModal();
          load();
        } else {
          const d = await res.json().catch(() => ({}));
          errEl.textContent = d.message ?? d.error ?? 'Save failed';
          errEl.classList.remove('hidden');
        }
      });
    }

    window.deleteLog = deleteLog;
    load();
  </script>
</PortalLayout>

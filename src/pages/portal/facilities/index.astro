---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
---

<PortalLayout title="Facility Booking" user={user} activeModule="facility_booking">
  <!-- Process info panel -->
  <details open class="mb-6 group rounded-xl border border-primary-100 bg-gradient-to-r from-primary-50/50 to-blue-50/20 overflow-hidden">
    <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer list-none select-none hover:bg-primary-50/60 transition-colors">
      <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-project-diagram text-white text-xs" aria-hidden="true"></i>
      </div>
      <span class="text-sm font-medium text-text-primary flex-1">Residents book shared amenities (clubhouse, terrace, pool) — bookings are subject to availability and committee approval.</span>
      <span class="text-xs text-primary-600 flex items-center gap-1.5 flex-shrink-0 font-medium">
        How it works
        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200 group-open:rotate-180" aria-hidden="true"></i>
      </span>
    </summary>
    <div class="px-5 pb-5">
      <div class="pt-4 border-t border-primary-100 space-y-4">
        <!-- Main flow -->
        <div class="flex items-start gap-1.5 overflow-x-auto pb-2 -mx-1 px-1">
          <div class="flex-shrink-0 w-52 rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 text-center">
            <p class="text-[11px] font-semibold text-gray-700 whitespace-nowrap">Select Slot</p>
            <p class="text-[10px] text-gray-500 mt-0.5 whitespace-nowrap">Choose facility &amp; time</p>
          </div>
          <i class="fas fa-arrow-right text-gray-300 text-xs self-center flex-shrink-0" aria-hidden="true"></i>
          <div class="flex-shrink-0 w-52 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[11px] font-semibold text-primary-700 whitespace-nowrap">Request Sent</p>
            <p class="text-[10px] text-primary-600 mt-0.5 whitespace-nowrap">Booking submitted</p>
          </div>
          <i class="fas fa-arrow-right text-gray-300 text-xs self-center flex-shrink-0" aria-hidden="true"></i>
          <div class="flex-shrink-0 w-52 rounded-lg border border-amber-300 bg-amber-50 px-3 py-3 text-center">
            <p class="text-[11px] font-semibold text-amber-800 whitespace-nowrap">Under Review</p>
            <p class="text-[10px] text-amber-700 mt-0.5 whitespace-nowrap">Committee checks</p>
          </div>
          <i class="fas fa-arrow-right text-gray-300 text-xs self-center flex-shrink-0" aria-hidden="true"></i>
          <div class="flex-shrink-0 w-52 rounded-lg border border-green-300 bg-green-50 px-3 py-3 text-center">
            <p class="text-[11px] font-semibold text-green-800 whitespace-nowrap">Confirmed</p>
            <p class="text-[10px] text-green-700 mt-0.5 whitespace-nowrap">Slot reserved</p>
          </div>
          <i class="fas fa-arrow-right text-gray-300 text-xs self-center flex-shrink-0" aria-hidden="true"></i>
          <div class="flex-shrink-0 w-52 rounded-lg border border-gray-300 bg-gray-100 px-3 py-3 text-center">
            <p class="text-[11px] font-semibold text-gray-700 whitespace-nowrap">Completed</p>
            <p class="text-[10px] text-gray-500 mt-0.5 whitespace-nowrap">Usage recorded</p>
          </div>
        </div>
        <!-- Exception row -->
        <div class="flex items-center gap-2 text-xs text-red-600">
          <i class="fas fa-arrow-turn-down text-red-400 text-[10px]" aria-hidden="true"></i>
          <span class="font-medium">Rejected</span>
          <span class="text-red-500">— Slot unavailable or booking declined by committee</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mt-1">
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Bookings must be made at least 24 hours in advance</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-exclamation-circle text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Security deposit may be required for clubhouse bookings</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-exclamation-circle text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Repeated no-shows may result in booking privileges being suspended</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-exclamation-circle text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Emergency maintenance can override confirmed bookings with 4-hour notice</span>
          </div>
        </div>
      </div>
    </div>
  </details>

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-text-primary">Facility Booking</h1>
    <p class="text-sm text-text-secondary mt-1">Book community facilities for your events and activities.</p>
  </div>

  <div id="facilities-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
    <div class="col-span-full flex items-center justify-center h-32 text-text-secondary">
      <i class="fas fa-spinner fa-spin mr-2" aria-hidden="true"></i>
      Loading facilities…
    </div>
  </div>

  <!-- My Bookings -->
  <div class="mt-8">
    <h2 class="text-lg font-semibold text-text-primary mb-4">My Bookings</h2>
    <div id="my-bookings" class="space-y-3">
      <div class="text-sm text-text-secondary text-center py-6">
        <i class="fas fa-spinner fa-spin mr-2" aria-hidden="true"></i>Loading your bookings…
      </div>
    </div>
  </div>

  <script>
    const BOOKING_BADGE: Record<string, string> = {
      pending:   'bg-yellow-100 text-yellow-700',
      confirmed: 'bg-green-100 text-green-700',
      waitlisted:'bg-blue-100 text-blue-700',
      in_use:    'bg-teal-100 text-teal-700',
      completed: 'bg-gray-100 text-gray-600',
      cancelled: 'bg-red-100 text-red-600',
      no_show:   'bg-orange-100 text-orange-700',
    };

    async function loadFacilities() {
      const container = document.getElementById('facilities-list');
      if (!container) return;
      try {
        const res = await fetch('/api/v1/facilities', { credentials: 'include' });
        const facilities = await res.json();
        container.innerHTML = facilities.map((f: any) => `
          <div class="bg-white rounded-xl border border-border-light overflow-hidden hover:shadow-soft transition-shadow">
            <div class="h-2 bg-primary-600"></div>
            <div class="p-5">
              <h2 class="text-lg font-semibold text-text-primary mb-1">${f.name}</h2>
              ${f.description ? `<p class="text-xs text-text-secondary mb-3 line-clamp-2">${f.description}</p>` : ''}
              <div class="space-y-1 text-xs text-text-secondary mb-4">
                ${f.capacity ? `<div class="flex items-center gap-2"><i class="fas fa-users w-3.5 text-center" aria-hidden="true"></i>Capacity: ${f.capacity} persons</div>` : ''}
                ${f.booking_fee > 0 ? `<div class="flex items-center gap-2"><i class="fas fa-rupee-sign w-3.5 text-center" aria-hidden="true"></i>Booking fee: ₹${Number(f.booking_fee).toLocaleString('en-IN')}</div>` : '<div class="flex items-center gap-2"><i class="fas fa-gift w-3.5 text-center" aria-hidden="true"></i>Free to book</div>'}
                ${f.deposit_amount > 0 ? `<div class="flex items-center gap-2"><i class="fas fa-shield-alt w-3.5 text-center" aria-hidden="true"></i>Deposit: ₹${Number(f.deposit_amount).toLocaleString('en-IN')}</div>` : ''}
                <div class="flex items-center gap-2"><i class="fas fa-calendar-check w-3.5 text-center" aria-hidden="true"></i>Free cancellation: ${f.cancellation_hours_free}h before</div>
              </div>
              ${f.amenities?.length ? `
                <div class="flex flex-wrap gap-1 mb-4">
                  ${f.amenities.map((a: string) => `<span class="text-xs bg-gray-100 text-text-secondary px-2 py-0.5 rounded">${a}</span>`).join('')}
                </div>
              ` : ''}
              <a href="/portal/facilities/book?facility=${f.id}" class="btn-primary text-xs w-full py-2 text-center block">Book Now</a>
            </div>
          </div>
        `).join('');
      } catch {
        container.innerHTML = '<p class="col-span-full text-center text-red-600 py-12">Failed to load facilities.</p>';
      }
    }

    async function loadMyBookings() {
      const container = document.getElementById('my-bookings');
      if (!container) return;
      try {
        const res = await fetch('/api/v1/facilities/bookings', { credentials: 'include' });
        const bookings = await res.json();
        if (!bookings.length) {
          container.innerHTML = '<p class="text-sm text-text-secondary text-center py-4">No bookings yet.</p>';
          return;
        }
        container.innerHTML = bookings.map((b: any) => {
          const start = new Date(b.start_time);
          const canCancel = ['pending','confirmed','waitlisted'].includes(b.status) && start > new Date();
          return `
            <div class="bg-white rounded-xl border border-border-light p-4 flex items-start justify-between gap-4">
              <div class="min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-medium text-text-primary text-sm">${b.facilities?.name ?? 'Facility'}</span>
                  <span class="text-xs px-2 py-0.5 rounded-full font-medium ${BOOKING_BADGE[b.status] ?? 'bg-gray-100 text-gray-600'}">${b.status.replace('_',' ')}</span>
                </div>
                <div class="text-xs text-text-secondary">
                  ${start.toLocaleDateString('en-IN',{weekday:'short',day:'numeric',month:'short',year:'numeric'})}
                  · ${start.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})}
                  ${b.end_time ? ` – ${new Date(b.end_time).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})}` : ''}
                </div>
                ${b.fee_charged > 0 ? `<div class="text-xs text-text-secondary mt-0.5">Fee: ₹${Number(b.fee_charged).toLocaleString('en-IN')}${b.deposit_paid > 0 ? ` · Deposit: ₹${Number(b.deposit_paid).toLocaleString('en-IN')}` : ''}</div>` : ''}
              </div>
              ${canCancel ? `<button onclick="cancelBooking('${b.id}')" class="text-sm text-red-500 hover:text-red-700 font-medium whitespace-nowrap flex-shrink-0">Cancel</button>` : ''}
            </div>
          `;
        }).join('');
      } catch {
        container.innerHTML = '<p class="text-sm text-red-600 text-center py-4">Failed to load bookings.</p>';
      }
    }

    async function cancelBooking(bookingId: string) {
      const reason = prompt('Reason for cancellation (optional):') ?? '';
      if (!confirm('Cancel this booking?')) return;
      const res = await fetch(`/api/v1/facilities/bookings/${bookingId}/cancel`, {
        method: 'PUT', credentials: 'include', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reason }),
      });
      if (res.ok) {
        const d = await res.json();
        alert(d.message);
        loadMyBookings();
      } else {
        const d = await res.json();
        alert(d.error ?? 'Failed to cancel booking.');
      }
    }

    (window as any).cancelBooking = cancelBooking;
    loadFacilities();
    loadMyBookings();
  </script>
</PortalLayout>

---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const isExec = ['executive', 'admin'].includes(user.role);
---

<PortalLayout title="Parking Management" user={user} activeModule="parking">
  <!-- Process info panel -->
  <details class="mb-6 group rounded-xl border border-primary-100 bg-gradient-to-r from-primary-50/50 to-blue-50/20 overflow-hidden">
    <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer list-none select-none hover:bg-primary-50/60 transition-colors">
      <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-project-diagram text-white text-xs" aria-hidden="true"></i>
      </div>
      <span class="text-sm font-medium text-text-primary flex-1">Parking slots are tracked per flat — covered slots assigned from the allotment agreement, with RC and insurance documents on file; guest and visitor slots managed separately.</span>
      <span class="text-xs text-primary-600 flex items-center gap-1.5 flex-shrink-0 font-medium">
        How it works
        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200 group-open:rotate-180" aria-hidden="true"></i>
      </span>
    </summary>
    <div class="px-5 pb-5">
      <div class="pt-4 border-t border-primary-100 space-y-4">
        <!-- Main flow -->
        <div class="process-snake-flow -mx-1 px-1">
          <div class="flex-shrink-0 w-44 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">Slot Request</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">Member applies + RC upload</p>
          </div>

          <div class="flex-shrink-0 w-44 rounded-lg border border-amber-300 bg-amber-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-amber-800 whitespace-nowrap">Review</p>
            <p class="text-[11px] text-amber-700 mt-0.5 whitespace-nowrap">Availability + docs check</p>
          </div>

          <div class="flex-shrink-0 w-44 rounded-lg border border-green-300 bg-green-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-green-800 whitespace-nowrap">Assigned</p>
            <p class="text-[11px] text-green-700 mt-0.5 whitespace-nowrap">Slot + vehicle confirmed</p>
          </div>

          <div class="flex-shrink-0 w-44 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">Transfer</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">Flat sale / vehicle change</p>
          </div>

          <div class="flex-shrink-0 w-44 rounded-lg border border-gray-300 bg-gray-100 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Released</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">Slot freed to pool</p>
          </div>
        </div>
        <!-- Exception rows -->
        <div class="flex items-center gap-2 text-xs text-amber-600">
          <i class="fas fa-arrow-turn-down text-amber-400 text-[10px]" aria-hidden="true"></i>
          <span class="font-medium">Waitlisted</span>
          <span class="text-amber-700">— If all covered slots are occupied, member goes on waitlist; notified automatically when a slot becomes available</span>
        </div>
        <div class="flex items-center gap-2 text-xs text-red-600">
          <i class="fas fa-arrow-turn-down text-red-400 text-[10px]" aria-hidden="true"></i>
          <span class="font-medium">Disputed</span>
          <span class="text-red-500">— Conflicting slot claims escalated to Secretary; disputed slot frozen until Secretary resolution is recorded</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mt-1">
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-car text-primary-400 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Each flat is entitled to one covered slot per its builder allotment agreement — exec can check per-flat entitlement in the Members directory; multiple vehicles per flat require additional open-slot request</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-file-alt text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>RC book and vehicle insurance documents are uploaded at assignment — stored in private GitHub Docs; insurance expiry is tracked and exec alerted when it lapses</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-user-friends text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Guest and visitor parking slots are managed separately — they cannot be permanently assigned to a flat; visitors log entry via the <strong>Visitor Management</strong> module</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-exchange-alt text-gray-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>On flat sale or transfer, the slot must be explicitly re-assigned to the new owner — the system does not inherit slot automatically to prevent silent re-assignment</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-shield-alt text-primary-400 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Security guards can verify a vehicle's registered slot via the <strong>Visitor Management</strong> gate — vehicle number is cross-checked against parking records in real time</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-rupee-sign text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Parking charges (if applicable) are invoiced through the <strong>Finance</strong> module — rules-engine configurable per slot type (covered, open, basement)</span>
          </div>
        </div>
      </div>
    </div>
  </details>

  <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-text-primary">Parking Management</h1>
      <p class="text-sm text-text-secondary mt-1">
        {isExec ? 'Manage parking slots and allocations for the society.' : 'View your parking allocation and waitlist status.'}
      </p>
    </div>
    {isExec && (
      <button id="add-slot-btn" class="btn-primary text-sm whitespace-nowrap">
        <i class="fas fa-plus mr-2" aria-hidden="true"></i>Add Slot
      </button>
    )}
  </div>

  <!-- Tabs -->
  <div class="flex gap-1 mb-6 bg-gray-100 p-1 rounded-lg w-fit">
    <button onclick="switchTab('slots')" id="tab-slots"
      class="tab-btn px-4 py-2 rounded-md text-sm font-medium bg-white text-primary-600 shadow-sm">
      Slot Grid
    </button>
    <button onclick="switchTab('my')" id="tab-my"
      class="tab-btn px-4 py-2 rounded-md text-sm font-medium text-text-secondary hover:text-text-primary">
      My Allocation
    </button>
    <button onclick="switchTab('waitlist')" id="tab-waitlist"
      class="tab-btn px-4 py-2 rounded-md text-sm font-medium text-text-secondary hover:text-text-primary">
      Waitlist
    </button>
    {isExec && (
      <button onclick="switchTab('audit')" id="tab-audit"
        class="tab-btn px-4 py-2 rounded-md text-sm font-medium text-text-secondary hover:text-text-primary">
        Audit Log
      </button>
    )}
    {isExec && (
      <button onclick="switchTab('transfers')" id="tab-transfers"
        class="tab-btn px-4 py-2 rounded-md text-sm font-medium text-text-secondary hover:text-text-primary">
        Transfers
        <span id="transfers-badge" class="hidden ml-1.5 px-1.5 py-0.5 bg-amber-500 text-white text-xs rounded-full"></span>
      </button>
    )}
  </div>

  <!-- Slot Grid Panel -->
  <div id="panel-slots">
    <!-- Filters -->
    <div class="flex flex-wrap gap-3 mb-4">
      <select id="filter-slot-type" onchange="loadSlots()"
        class="text-sm border border-border-light rounded-lg px-3 py-2 bg-white">
        <option value="">All Types</option>
        <option value="covered">Covered</option>
        <option value="open">Open</option>
        <option value="basement">Basement</option>
        <option value="visitor">Visitor</option>
      </select>
      <select id="filter-vehicle-type" onchange="loadSlots()"
        class="text-sm border border-border-light rounded-lg px-3 py-2 bg-white">
        <option value="">All Vehicles</option>
        <option value="car">Car</option>
        <option value="bike">Bike</option>
        <option value="cycle">Cycle</option>
        <option value="ev">EV</option>
        <option value="any">Any</option>
      </select>
      <select id="filter-available" onchange="loadSlots()"
        class="text-sm border border-border-light rounded-lg px-3 py-2 bg-white">
        <option value="">All Slots</option>
        <option value="true">Available Only</option>
      </select>
      <div class="flex gap-3 text-xs text-text-secondary items-center ml-auto">
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-sm bg-green-500 inline-block"></span>Available</span>
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-sm bg-red-400 inline-block"></span>Occupied</span>
      </div>
    </div>
    <div id="slots-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
      <div class="col-span-full text-center text-text-secondary py-12">
        <i class="fas fa-spinner fa-spin mr-2" aria-hidden="true"></i>Loading slots…
      </div>
    </div>
  </div>

  <!-- My Allocation Panel -->
  <div id="panel-my" class="hidden">
    <div id="my-allocation-container">
      <div class="text-center text-text-secondary py-12">
        <i class="fas fa-spinner fa-spin mr-2" aria-hidden="true"></i>Loading…
      </div>
    </div>
  </div>

  <!-- Waitlist Panel -->
  <div id="panel-waitlist" class="hidden">
    <div id="waitlist-container">
      <div class="text-center text-text-secondary py-12">
        <i class="fas fa-spinner fa-spin mr-2" aria-hidden="true"></i>Loading waitlist…
      </div>
    </div>
  </div>

  <!-- Audit Panel (exec only) -->
  {isExec && (
    <div id="panel-audit" class="hidden">
      <div id="audit-container">
        <div class="text-center text-text-secondary py-12">
          <i class="fas fa-spinner fa-spin mr-2" aria-hidden="true"></i>Loading audit log…
        </div>
      </div>
    </div>
  )}

  <!-- Transfers Panel (exec only) -->
  {isExec && (
    <div id="panel-transfers" class="hidden">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-base font-semibold text-text-primary">Slot Transfer Requests</h2>
        <select id="transfer-status-filter" onchange="loadTransfers()" class="text-sm border border-border-light rounded-lg px-3 py-2 bg-white">
          <option value="pending">Pending</option>
          <option value="approved">Approved</option>
          <option value="rejected">Rejected</option>
          <option value="">All</option>
        </select>
      </div>
      <div id="transfers-container">
        <div class="text-center text-text-secondary py-12">
          <i class="fas fa-spinner fa-spin mr-2" aria-hidden="true"></i>Loading transfers…
        </div>
      </div>
    </div>
  )}

  <!-- Allocate Modal (exec only) -->
  {isExec && (
    <div id="allocate-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div class="bg-white rounded-2xl shadow-large w-full max-w-md">
        <div class="p-6 border-b border-border-light flex items-center justify-between">
          <h2 class="text-lg font-semibold text-text-primary">Allocate Parking Slot</h2>
          <button onclick="closeAllocateModal()" class="p-2 rounded-lg hover:bg-gray-100 text-text-secondary">
            <i class="fas fa-times" aria-hidden="true"></i>
          </button>
        </div>
        <div class="p-6 space-y-4">
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1">Slot</label>
            <input id="alloc-slot-display" type="text" readonly
              class="w-full border border-border-light rounded-lg px-3 py-2 bg-gray-50 text-sm text-text-primary" />
            <input id="alloc-slot-id" type="hidden" />
          </div>
          <div>
            <label for="alloc-unit" class="block text-sm font-medium text-text-primary mb-1">Unit *</label>
            <input id="alloc-unit-id" type="hidden" />
            <select id="alloc-unit" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm">
              <option value="">Loading units…</option>
            </select>
          </div>
          <div>
            <label for="alloc-user" class="block text-sm font-medium text-text-primary mb-1">Resident *</label>
            <select id="alloc-user" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm">
              <option value="">Select unit first</option>
            </select>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="alloc-vehicle-number" class="block text-sm font-medium text-text-primary mb-1">Vehicle Reg. No.</label>
              <input id="alloc-vehicle-number" type="text" placeholder="TS09AB1234"
                class="w-full border border-border-light rounded-lg px-3 py-2 text-sm" />
            </div>
            <div>
              <label for="alloc-vehicle-make" class="block text-sm font-medium text-text-primary mb-1">Make</label>
              <input id="alloc-vehicle-make" type="text" placeholder="Maruti"
                class="w-full border border-border-light rounded-lg px-3 py-2 text-sm" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="alloc-vehicle-model" class="block text-sm font-medium text-text-primary mb-1">Model</label>
              <input id="alloc-vehicle-model" type="text" placeholder="Swift Dzire"
                class="w-full border border-border-light rounded-lg px-3 py-2 text-sm" />
            </div>
            <div>
              <label for="alloc-vehicle-colour" class="block text-sm font-medium text-text-primary mb-1">Colour</label>
              <input id="alloc-vehicle-colour" type="text" placeholder="White"
                class="w-full border border-border-light rounded-lg px-3 py-2 text-sm" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1">RC Document <span class="text-text-secondary font-normal">(optional, PDF/image, max 5 MB)</span></label>
            <div id="rc-drop-zone" class="border-2 border-dashed border-border-light rounded-lg p-3 text-center cursor-pointer hover:border-primary-600 transition-colors text-sm">
              <i class="fas fa-file-upload text-text-secondary mr-2" aria-hidden="true"></i>
              <span class="text-text-secondary">Click or drag RC document here</span>
              <input type="file" id="rc-file-input" accept="image/jpeg,image/png,image/webp,application/pdf" class="hidden" aria-hidden="true" />
            </div>
            <p id="rc-file-name" class="text-xs text-primary-600 mt-1 hidden"></p>
          </div>
          <div>
            <label for="alloc-expires-at" class="block text-sm font-medium text-text-primary mb-1">Expires At (optional)</label>
            <input id="alloc-expires-at" type="date"
              class="w-full border border-border-light rounded-lg px-3 py-2 text-sm" />
          </div>
          <div>
            <label for="alloc-notes" class="block text-sm font-medium text-text-primary mb-1">Notes</label>
            <textarea id="alloc-notes" rows="2" placeholder="Any notes…"
              class="w-full border border-border-light rounded-lg px-3 py-2 text-sm resize-none"></textarea>
          </div>
          <div id="alloc-error" class="hidden text-sm text-red-600 bg-red-50 rounded-lg p-3"></div>
        </div>
        <div class="p-6 pt-0 flex gap-3">
          <button onclick="closeAllocateModal()" class="flex-1 btn-outline text-sm">Cancel</button>
          <button id="alloc-save-btn" class="flex-1 btn-primary text-sm">Allocate</button>
        </div>
      </div>
    </div>
  )}

  <!-- Transfer Request Modal (all authenticated members) -->
  <div id="transfer-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-large w-full max-w-md">
      <div class="p-6 border-b border-border-light flex items-center justify-between">
        <h2 class="text-lg font-semibold text-text-primary">Request Slot Transfer</h2>
        <button onclick="closeTransferModal()" class="p-2 rounded-lg hover:bg-gray-100 text-text-secondary">
          <i class="fas fa-times" aria-hidden="true"></i>
        </button>
      </div>
      <div class="p-6 space-y-4">
        <p class="text-sm text-text-secondary">Request to transfer your slot to another flat. The management committee will review and approve.</p>
        <input type="hidden" id="transfer-slot-id" />
        <div>
          <label class="block text-sm font-medium text-text-primary mb-1">Your Slot</label>
          <input id="transfer-slot-display" type="text" readonly
            class="w-full border border-border-light rounded-lg px-3 py-2 bg-gray-50 text-sm text-text-primary" />
        </div>
        <div>
          <label for="transfer-to-unit" class="block text-sm font-medium text-text-primary mb-1">Transfer To (Unit) *</label>
          <select id="transfer-to-unit" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm">
            <option value="">Loading units…</option>
          </select>
        </div>
        <div>
          <label for="transfer-reason" class="block text-sm font-medium text-text-primary mb-1">Reason</label>
          <textarea id="transfer-reason" rows="3" maxlength="500" placeholder="Why are you requesting this transfer?"
            class="w-full border border-border-light rounded-lg px-3 py-2 text-sm resize-none"></textarea>
        </div>
        <div id="transfer-error" class="hidden text-sm text-red-600 bg-red-50 rounded-lg p-3"></div>
      </div>
      <div class="p-6 pt-0 flex gap-3">
        <button onclick="closeTransferModal()" class="flex-1 btn-outline text-sm">Cancel</button>
        <button id="transfer-save-btn" class="flex-1 btn-primary text-sm">Submit Request</button>
      </div>
    </div>
  </div>

  <!-- Add Slot Modal (exec only) -->
  {isExec && (
    <div id="add-slot-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div class="bg-white rounded-2xl shadow-large w-full max-w-md">
        <div class="p-6 border-b border-border-light flex items-center justify-between">
          <h2 class="text-lg font-semibold text-text-primary">Add New Parking Slot</h2>
          <button onclick="closeAddSlotModal()" class="p-2 rounded-lg hover:bg-gray-100 text-text-secondary">
            <i class="fas fa-times" aria-hidden="true"></i>
          </button>
        </div>
        <div class="p-6 space-y-4">
          <div>
            <label for="new-slot-number" class="block text-sm font-medium text-text-primary mb-1">Slot Number *</label>
            <input id="new-slot-number" type="text" placeholder="e.g. A-P-01"
              class="w-full border border-border-light rounded-lg px-3 py-2 text-sm" />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="new-slot-type" class="block text-sm font-medium text-text-primary mb-1">Slot Type</label>
              <select id="new-slot-type" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm">
                <option value="open">Open</option>
                <option value="covered">Covered</option>
                <option value="basement">Basement</option>
                <option value="visitor">Visitor</option>
              </select>
            </div>
            <div>
              <label for="new-vehicle-type" class="block text-sm font-medium text-text-primary mb-1">Vehicle Type</label>
              <select id="new-vehicle-type" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm">
                <option value="car">Car</option>
                <option value="bike">Bike</option>
                <option value="cycle">Cycle</option>
                <option value="ev">EV</option>
                <option value="any">Any</option>
              </select>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="new-level" class="block text-sm font-medium text-text-primary mb-1">Level/Floor</label>
              <input id="new-level" type="number" value="0" min="0"
                class="w-full border border-border-light rounded-lg px-3 py-2 text-sm" />
            </div>
            <div>
              <label for="new-monthly-charge" class="block text-sm font-medium text-text-primary mb-1">Monthly Charge (₹)</label>
              <input id="new-monthly-charge" type="number" value="0" min="0"
                class="w-full border border-border-light rounded-lg px-3 py-2 text-sm" />
            </div>
          </div>
          <div>
            <label for="new-slot-notes" class="block text-sm font-medium text-text-primary mb-1">Notes</label>
            <input id="new-slot-notes" type="text" placeholder="Optional notes"
              class="w-full border border-border-light rounded-lg px-3 py-2 text-sm" />
          </div>
          <div id="add-slot-error" class="hidden text-sm text-red-600 bg-red-50 rounded-lg p-3"></div>
        </div>
        <div class="p-6 pt-0 flex gap-3">
          <button onclick="closeAddSlotModal()" class="flex-1 btn-outline text-sm">Cancel</button>
          <button id="add-slot-save-btn" class="flex-1 btn-primary text-sm">Create Slot</button>
        </div>
      </div>
    </div>
  )}

  <script define:vars={{ isExec, userRole: user.role }}>
    const SLOT_TYPE_ICONS = {
      covered:  'fa-warehouse',
      open:     'fa-parking',
      basement: 'fa-layer-group',
      visitor:  'fa-user-clock',
    };
    const VEHICLE_ICONS = {
      car: 'fa-car',
      bike: 'fa-motorcycle',
      cycle: 'fa-bicycle',
      ev: 'fa-bolt',
      any: 'fa-car',
    };

    let allSlots = [];
    let allMembers = [];
    let currentTab = 'slots';
    let rcFile = null;

    function initRcDropZone() {
      const dropZone = document.getElementById('rc-drop-zone');
      const fileInput = document.getElementById('rc-file-input');
      const fileNameEl = document.getElementById('rc-file-name');
      if (!dropZone || dropZone._rcInit) return;
      dropZone._rcInit = true;

      function handleRcFile(file) {
        const allowed = ['image/jpeg', 'image/png', 'image/webp', 'application/pdf'];
        if (!allowed.includes(file.type)) { alert('Only PDF, JPEG, PNG, or WebP allowed.'); return; }
        if (file.size > 5 * 1024 * 1024) { alert('RC document must be under 5 MB.'); return; }
        rcFile = file;
        fileNameEl.textContent = `Selected: ${file.name}`;
        fileNameEl.classList.remove('hidden');
      }

      dropZone.addEventListener('click', () => fileInput.click());
      dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('border-primary-600'); });
      dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-primary-600'));
      dropZone.addEventListener('drop', e => {
        e.preventDefault();
        dropZone.classList.remove('border-primary-600');
        const f = e.dataTransfer?.files[0];
        if (f) handleRcFile(f);
      });
      fileInput.addEventListener('change', () => {
        if (fileInput.files?.[0]) handleRcFile(fileInput.files[0]);
      });
    }

    function switchTab(tab) {
      currentTab = tab;
      const panels = ['slots', 'my', 'waitlist', 'audit', 'transfers'];
      panels.forEach(p => {
        const el = document.getElementById(`panel-${p}`);
        if (el) el.classList.toggle('hidden', p !== tab);
        const btn = document.getElementById(`tab-${p}`);
        if (btn) {
          btn.classList.toggle('bg-white', p === tab);
          btn.classList.toggle('text-primary-600', p === tab);
          btn.classList.toggle('shadow-sm', p === tab);
          btn.classList.toggle('text-text-secondary', p !== tab);
          btn.classList.toggle('hover:text-text-primary', p !== tab);
        }
      });

      if (tab === 'slots' && allSlots.length === 0) loadSlots();
      if (tab === 'my') loadMyAllocation();
      if (tab === 'waitlist') loadWaitlist();
      if (tab === 'audit' && isExec) loadAudit();
      if (tab === 'transfers' && isExec) loadTransfers();
    }

    async function loadTransfers() {
      const container = document.getElementById('transfers-container');
      if (!container) return;
      const statusFilter = (document.getElementById('transfer-status-filter') as HTMLSelectElement)?.value ?? 'pending';
      try {
        const res  = await fetch('/api/v1/parking/transfers', { credentials: 'include' });
        let list   = await res.json();
        if (!Array.isArray(list)) list = [];
        if (statusFilter) list = list.filter((t: any) => t.status === statusFilter);

        // update pending badge
        const pending = list.filter((t: any) => t.status === 'pending');
        const badge = document.getElementById('transfers-badge');
        if (badge) {
          badge.textContent = String(pending.length);
          badge.classList.toggle('hidden', pending.length === 0);
        }

        if (!list.length) {
          container.innerHTML = `<div class="text-center py-12 text-text-secondary text-sm">No ${statusFilter || ''} transfer requests.</div>`;
          return;
        }

        const STATUS_BADGE: Record<string, string> = {
          pending:  'bg-amber-100 text-amber-700',
          approved: 'bg-green-100 text-green-700',
          rejected: 'bg-red-100 text-red-700',
        };

        const rows = list.map((t: any) => {
          const badge = STATUS_BADGE[t.status] ?? 'bg-gray-100 text-gray-600';
          const actionCell = t.status === 'pending'
            ? `<div class="flex gap-2">
                <button onclick="approveTransfer('${t.id}','approve')"
                  class="text-xs bg-secondary-500 text-white px-3 py-1 rounded-lg hover:bg-green-600">Approve</button>
                <button onclick="openRejectTransfer('${t.id}')"
                  class="text-xs border border-red-300 text-red-600 px-3 py-1 rounded-lg hover:bg-red-50">Reject</button>
              </div>`
            : `<span class="text-xs text-text-secondary">${t.approved_at ? new Date(t.approved_at).toLocaleDateString('en-IN') : '—'}</span>`;
          return `
          <tr class="border-b border-border-light hover:bg-gray-50">
            <td class="py-3 px-4 text-sm font-medium">${t.parking_slots?.slot_number ?? '—'}</td>
            <td class="py-3 px-4 text-sm text-text-secondary">${t.from_unit?.unit_number ?? '—'}</td>
            <td class="py-3 px-4 text-sm text-text-secondary">${t.to_unit?.unit_number ?? '—'}</td>
            <td class="py-3 px-4 text-sm text-text-secondary">${t.reason ? t.reason.slice(0,60) : '—'}</td>
            <td class="py-3 px-4 text-sm">${new Date(t.created_at).toLocaleDateString('en-IN')}</td>
            <td class="py-3 px-4"><span class="px-2 py-1 text-xs rounded-full font-medium capitalize ${badge}">${t.status}</span></td>
            <td class="py-3 px-4">${actionCell}</td>
          </tr>`;
        }).join('');

        container.innerHTML = `
          <div class="bg-white rounded-2xl border border-border-light overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-50 border-b border-border-light">
                <tr>
                  <th class="py-3 px-4 text-xs font-medium text-text-secondary text-left">Slot</th>
                  <th class="py-3 px-4 text-xs font-medium text-text-secondary text-left">From Unit</th>
                  <th class="py-3 px-4 text-xs font-medium text-text-secondary text-left">To Unit</th>
                  <th class="py-3 px-4 text-xs font-medium text-text-secondary text-left">Reason</th>
                  <th class="py-3 px-4 text-xs font-medium text-text-secondary text-left">Requested</th>
                  <th class="py-3 px-4 text-xs font-medium text-text-secondary text-left">Status</th>
                  <th class="py-3 px-4 text-xs font-medium text-text-secondary text-left">Action</th>
                </tr>
              </thead>
              <tbody>${rows}</tbody>
            </table>
          </div>`;
      } catch {
        container.innerHTML = `<div class="text-center text-red-600 py-8">Failed to load transfers.</div>`;
      }
    }

    let rejectingTransferId: string = '';
    function openRejectTransfer(id: string) {
      rejectingTransferId = id;
      const note = prompt('Rejection reason (required):');
      if (note === null) return; // cancelled
      if (!note.trim()) { alert('Please provide a rejection reason.'); return; }
      approveTransfer(id, 'reject', note.trim());
    }

    async function approveTransfer(id: string, action: 'approve'|'reject', rejectionNote?: string) {
      try {
        const body: Record<string, string> = { action };
        if (rejectionNote) body.rejection_note = rejectionNote;
        const res  = await fetch(`/api/v1/parking/transfers/${id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (res.ok) {
          showToast(action === 'approve' ? 'Transfer approved.' : 'Transfer rejected.');
          loadTransfers();
        } else {
          showToast(data.message ?? 'Action failed.', 'error');
        }
      } catch {
        showToast('Network error.', 'error');
      }
    }

    async function viewInsuranceDoc(allocId: string) {
      try {
        const res  = await fetch(`/api/v1/parking/allocations/${allocId}/insurance`, { credentials: 'include' });
        const data = await res.json();
        if (res.ok && data.url) { window.open(data.url, '_blank'); }
        else { showToast(data.message ?? 'Document not available.', 'error'); }
      } catch {
        showToast('Network error.', 'error');
      }
    }

    // Insurance file upload — delegated listener on dynamically rendered content
    document.addEventListener('change', async (e) => {
      const input = (e.target as HTMLElement).closest('.insurance-file-input') as HTMLInputElement | null;
      if (!input) return;
      const file = input.files?.[0];
      if (!file) return;
      const allocId  = input.dataset.allocId!;
      const expiryEl = document.getElementById(`insurance-expiry-${allocId}`) as HTMLInputElement | null;
      const statusEl = document.getElementById(`insurance-status-${allocId}`)!;

      statusEl.textContent = 'Uploading…';
      statusEl.className   = 'text-xs mt-1 text-blue-600';
      statusEl.classList.remove('hidden');

      const fd = new FormData();
      fd.append('file', file);
      if (expiryEl?.value) fd.append('insurance_expiry', expiryEl.value);

      try {
        const res  = await fetch(`/api/v1/parking/allocations/${allocId}/insurance`, {
          method: 'POST',
          credentials: 'include',
          body: fd,
        });
        const data = await res.json();
        if (res.ok) {
          statusEl.textContent = 'Insurance document saved.';
          statusEl.className   = 'text-xs mt-1 text-secondary-500';
          showToast('Insurance document uploaded.');
          loadMyAllocation();
        } else {
          statusEl.textContent = data.message ?? 'Upload failed.';
          statusEl.className   = 'text-xs mt-1 text-red-600';
        }
      } catch {
        statusEl.textContent = 'Network error.';
        statusEl.className   = 'text-xs mt-1 text-red-600';
      }
    });

    function showToast(message: string, type = 'success') {
      const t = document.createElement('div');
      t.className = `fixed bottom-6 right-6 z-50 px-4 py-3 rounded-xl shadow-large text-sm font-medium text-white transform translate-y-4 opacity-0 transition-all duration-300 ${type === 'success' ? 'bg-secondary-500' : 'bg-red-500'}`;
      t.textContent = message;
      document.body.appendChild(t);
      requestAnimationFrame(() => t.classList.remove('translate-y-4', 'opacity-0'));
      setTimeout(() => { t.classList.add('translate-y-4', 'opacity-0'); setTimeout(() => t.remove(), 300); }, 3200);
    }

    async function loadSlots() {
      const container = document.getElementById('slots-grid');
      if (!container) return;
      const slotType = document.getElementById('filter-slot-type')?.value || '';
      const vehicleType = document.getElementById('filter-vehicle-type')?.value || '';
      const available = document.getElementById('filter-available')?.value || '';
      const params = new URLSearchParams();
      if (slotType) params.set('slot_type', slotType);
      if (vehicleType) params.set('vehicle_type', vehicleType);
      if (available) params.set('available', available);

      try {
        const res = await fetch(`/api/v1/parking/slots?${params}`, { credentials: 'include' });
        const slots = await res.json();
        allSlots = slots;

        if (!slots.length) {
          container.innerHTML = `<div class="col-span-full text-center text-text-secondary py-12">
            <i class="fas fa-parking text-3xl mb-3 block opacity-30" aria-hidden="true"></i>
            <p>No parking slots found.</p>
            ${isExec ? '<p class="text-xs mt-1">Click "Add Slot" to create your first slot.</p>' : ''}
          </div>`;
          return;
        }

        container.innerHTML = slots.map(s => {
          const occupied = !s.is_available;
          const icon = SLOT_TYPE_ICONS[s.slot_type] || 'fa-parking';
          const vehicleIcon = VEHICLE_ICONS[s.vehicle_type] || 'fa-car';
          const bg = occupied ? 'bg-red-50 border-red-200 hover:border-red-300' : 'bg-green-50 border-green-200 hover:border-green-300';
          const iconColor = occupied ? 'text-red-400' : 'text-green-500';
          const unitText = occupied ? (s.active_allocation?.units?.unit_number ?? 'Occupied') : 'Available';
          const levelText = s.level > 0 ? `L${s.level}` : 'G';
          const chargeText = s.monthly_charge > 0 ? `₹${s.monthly_charge}/mo` : '';
          const allocBtn = isExec && !occupied
            ? `<button onclick="openAllocateModal('${s.id}','${s.slot_number}')" class="mt-2 w-full text-xs bg-primary-600 text-white py-1 rounded-md hover:bg-primary-700">Allocate</button>`
            : '';
          const releaseBtn = isExec && occupied
            ? `<button onclick="releaseSlot('${s.active_allocation?.id}','${s.slot_number}')" class="mt-2 w-full text-xs bg-red-500 text-white py-1 rounded-md hover:bg-red-600">Release</button>`
            : '';
          return `
          <div class="border ${bg} rounded-xl p-3 cursor-pointer transition-all text-center" onclick="showSlotDetail('${s.id}')">
            <div class="text-xs text-text-secondary mb-1">${levelText}</div>
            <i class="fas ${icon} ${iconColor} text-xl mb-1" aria-hidden="true"></i>
            <div class="font-semibold text-sm text-text-primary">${s.slot_number}</div>
            <div class="text-xs ${occupied ? 'text-red-600' : 'text-green-600'} mt-0.5">${unitText}</div>
            ${chargeText ? `<div class="text-xs text-text-secondary mt-0.5">${chargeText}</div>` : ''}
            <div class="text-xs text-text-secondary mt-0.5"><i class="fas ${vehicleIcon}" aria-hidden="true"></i></div>
            ${allocBtn}${releaseBtn}
          </div>`;
        }).join('');
      } catch {
        container.innerHTML = `<div class="col-span-full text-center text-red-600 py-8">Failed to load parking slots.</div>`;
      }
    }

    async function loadMyAllocation() {
      const container = document.getElementById('my-allocation-container');
      if (!container) return;
      try {
        const [allocRes, waitRes] = await Promise.all([
          fetch('/api/v1/parking/allocations', { credentials: 'include' }),
          fetch('/api/v1/parking/waitlist', { credentials: 'include' }),
        ]);
        const allocs = await allocRes.json();
        const waitlist = await waitRes.json();
        const activeAlloc = Array.isArray(allocs) ? allocs.find(a => a.status === 'active') : null;
        const myWaitlist = Array.isArray(waitlist) ? waitlist.find(w => ['waiting','offered'].includes(w.status)) : null;

        let html = '';
        if (activeAlloc) {
          const slot = activeAlloc.parking_slots;
          const allocDate = new Date(activeAlloc.allocated_at).toLocaleDateString('en-IN');
          const expiry = activeAlloc.expires_at ? new Date(activeAlloc.expires_at).toLocaleDateString('en-IN') : 'Indefinite';
          html += `
          <div class="bg-white rounded-2xl border border-green-200 p-6 mb-6">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="text-lg font-semibold text-text-primary">Active Parking Allocation</h3>
                <p class="text-sm text-text-secondary">Your assigned parking slot</p>
              </div>
              <span class="px-3 py-1 text-xs font-medium bg-green-100 text-green-700 rounded-full">Active</span>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4 text-sm">
              <div>
                <p class="text-text-secondary text-xs">Slot Number</p>
                <p class="font-semibold text-primary-600 text-lg">${slot?.slot_number ?? '—'}</p>
              </div>
              <div>
                <p class="text-text-secondary text-xs">Type</p>
                <p class="font-medium capitalize">${slot?.slot_type ?? '—'} / ${slot?.vehicle_type ?? '—'}</p>
              </div>
              <div>
                <p class="text-text-secondary text-xs">Level</p>
                <p class="font-medium">${slot?.level != null ? (slot.level === 0 ? 'Ground' : `Level ${slot.level}`) : '—'}</p>
              </div>
              <div>
                <p class="text-text-secondary text-xs">Vehicle Reg. No.</p>
                <p class="font-medium">${activeAlloc.vehicle_number ?? '—'}</p>
              </div>
              <div>
                <p class="text-text-secondary text-xs">Make / Model</p>
                <p class="font-medium">${[activeAlloc.vehicle_make, slot?.vehicle_model].filter(Boolean).join(' ') || '—'}</p>
              </div>
              <div>
                <p class="text-text-secondary text-xs">Colour</p>
                <p class="font-medium">${slot?.vehicle_colour ?? '—'}</p>
              </div>
              <div>
                <p class="text-text-secondary text-xs">Allocated On</p>
                <p class="font-medium">${allocDate}</p>
              </div>
              <div>
                <p class="text-text-secondary text-xs">Valid Until</p>
                <p class="font-medium">${expiry}</p>
              </div>
            </div>
            ${activeAlloc.notes ? `<p class="text-xs text-text-secondary mt-4 bg-gray-50 rounded-lg p-3">${activeAlloc.notes}</p>` : ''}
            <div class="mt-4 pt-4 border-t border-border-light space-y-4">
              <!-- Insurance document -->
              <div>
                <div class="flex items-center justify-between mb-2">
                  <span class="text-sm font-medium text-text-primary">Vehicle Insurance</span>
                  ${activeAlloc.insurance_expiry
                    ? `<span class="text-xs px-2 py-0.5 rounded-full ${new Date(activeAlloc.insurance_expiry) < new Date() ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700'}">
                        ${new Date(activeAlloc.insurance_expiry) < new Date() ? 'Expired' : 'Valid'} · Expiry: ${new Date(activeAlloc.insurance_expiry).toLocaleDateString('en-IN')}</span>`
                    : '<span class="text-xs text-amber-600 bg-amber-50 px-2 py-0.5 rounded-full">Not uploaded</span>'}
                </div>
                <div class="flex gap-2 flex-wrap">
                  ${activeAlloc.insurance_key ? `<button onclick="viewInsuranceDoc('${activeAlloc.id}')" class="btn-ghost text-sm px-3 py-1.5"><i class="fas fa-file-alt mr-1" aria-hidden="true"></i>View</button>` : ''}
                  <label class="btn-outline text-sm px-3 py-1.5 cursor-pointer">
                    <i class="fas fa-upload mr-1" aria-hidden="true"></i>${activeAlloc.insurance_key ? 'Replace' : 'Upload Insurance'}
                    <input type="file" class="hidden insurance-file-input" data-alloc-id="${activeAlloc.id}" accept="image/jpeg,image/png,application/pdf" />
                  </label>
                  <input type="date" id="insurance-expiry-${activeAlloc.id}" placeholder="Expiry date"
                    value="${activeAlloc.insurance_expiry ?? ''}"

            </button>
          </div>`;
        }

        if (!activeAlloc && !myWaitlist) {
          html = `
          <div class="text-center py-12">
            <i class="fas fa-parking text-4xl text-gray-300 mb-4 block" aria-hidden="true"></i>
            <h3 class="text-lg font-medium text-text-primary mb-2">No Active Parking Allocation</h3>
            <p class="text-sm text-text-secondary mb-6">You don't have a parking slot assigned. Join the waitlist to request one.</p>

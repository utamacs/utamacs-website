---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const canCreate = ['executive','secretary','president'].includes(user.portalRole) || user.isAdmin;
---

<PortalLayout title="Snag List" user={user} activeModule="snags">
  <!-- Process info panel -->
  <details open class="mb-6 group rounded-xl border border-primary-100 bg-gradient-to-r from-primary-50/50 to-blue-50/20 overflow-hidden">
    <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer list-none select-none hover:bg-primary-50/60 transition-colors">
      <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-project-diagram text-white text-xs" aria-hidden="true"></i>
      </div>
      <span class="text-sm font-medium text-text-primary flex-1">Snags are construction defects logged against the builder — each follows a track-and-verify closure process.</span>
      <span class="text-xs text-primary-600 flex items-center gap-1.5 flex-shrink-0 font-medium">
        How it works
        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200 group-open:rotate-180" aria-hidden="true"></i>
      </span>
    </summary>
    <div class="px-5 pb-5">
      <div class="pt-4 border-t border-primary-100 space-y-4">
        <!-- Main flow -->
        <div class="process-snake-flow -mx-1 px-1">
          <div class="flex-shrink-0 w-52 rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Reported</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">Defect logged</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-amber-300 bg-amber-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-amber-800 whitespace-nowrap">Notified</p>
            <p class="text-[11px] text-amber-700 mt-0.5 whitespace-nowrap">Builder informed</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">In Progress</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">Rectification underway</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-amber-300 bg-amber-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-amber-800 whitespace-nowrap">Pending Verify</p>
            <p class="text-[11px] text-amber-700 mt-0.5 whitespace-nowrap">Awaiting inspection</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-green-300 bg-green-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-green-800 whitespace-nowrap">Verified</p>
            <p class="text-[11px] text-green-700 mt-0.5 whitespace-nowrap">Rectification confirmed</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-gray-300 bg-gray-100 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Closed</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">Sign-off complete</p>
          </div>
        </div>
        <!-- Exception row -->
        <div class="flex items-center gap-2 text-xs text-red-600">
          <i class="fas fa-arrow-turn-down text-red-400 text-[10px]" aria-hidden="true"></i>
          <span class="font-medium">Re-opened</span>
          <span class="text-red-500">— If verification fails, snag returns to In Progress for further rectification</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mt-1">
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Only Secretary or President can mark a snag as Verified — members can report</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-exclamation-circle text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Critical snags trigger an automatic builder notification email</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Snags linked to HOTO items update the parent item's documentation status</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Builder reference numbers (Builder Ref) can be added to cross-reference builder's own tracker</span>
          </div>
        </div>
      </div>
    </div>
  </details>

  <div class="mb-6 flex items-center justify-between flex-wrap gap-3">
    <div>
      <h1 class="text-2xl font-bold text-text-primary">Snag List</h1>
      <p class="text-sm text-text-secondary mt-1">Track defects and builder rectification status.</p>
    </div>
    {canCreate && (
      <button id="create-btn" class="btn-primary text-sm flex items-center gap-2">
        <i class="fas fa-plus" aria-hidden="true"></i> New Snag
      </button>
    )}
  </div>

  <!-- Stats bar -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
    {[
      { id:'stat-total',    label:'Total',           cls:'bg-gray-50 border-border-light' },
      { id:'stat-open',     label:'Open',            cls:'bg-red-50 border-red-200' },
      { id:'stat-progress', label:'In Progress',     cls:'bg-blue-50 border-blue-200' },
      { id:'stat-closed',   label:'Verified Closed', cls:'bg-green-50 border-green-200' },
    ].map(s => (
      <div class={`rounded-xl border p-4 ${s.cls}`}>
        <div id={s.id} class="text-2xl font-bold text-text-primary">—</div>
        <div class="text-xs text-text-secondary mt-0.5">{s.label}</div>
      </div>
    ))}
  </div>

  <!-- Filters -->
  <div class="mb-5 flex flex-wrap gap-3">
    <div class="relative flex-1 min-w-[180px] max-w-xs">
      <i class="fas fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-text-secondary text-sm" aria-hidden="true"></i>
      <input type="search" id="search-input" placeholder="Search snags…"
        class="w-full pl-10 pr-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
    </div>
    <select id="status-filter" class="px-4 py-2.5 border border-border-light rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-600">
      <option value="">All statuses</option>
      <option value="OPEN">Open</option>
      <option value="IN_PROGRESS">In Progress</option>
      <option value="RESOLVED">Resolved</option>
      <option value="VERIFIED_CLOSED">Verified Closed</option>
      <option value="REOPENED">Reopened</option>
    </select>
    <select id="severity-filter" class="px-4 py-2.5 border border-border-light rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-600">
      <option value="">All severities</option>
      <option value="CRITICAL">Critical</option>
      <option value="HIGH">High</option>
      <option value="MEDIUM">Medium</option>
      <option value="LOW">Low</option>
    </select>
    <select id="scope-filter" class="px-4 py-2.5 border border-border-light rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-600">
      <option value="">All scopes</option>
      <option value="COMMON_AREA">Common Area</option>
      <option value="APARTMENT">Apartment</option>
    </select>
    <select id="category-filter" class="px-4 py-2.5 border border-border-light rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-600">
      <option value="">All categories</option>
      {['Civil & Structural','Seepage / Water','Electrical','Electrical - HT Infrastructure','Plumbing','Flooring','Painting','Exterior & Facade','Common Area','Lift & Elevator','Fire Safety','Other'].map(c => <option value={c}>{c}</option>)}
    </select>
  </div>

  <!-- Create modal -->
  {canCreate && (
    <div id="create-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
      <div class="bg-white rounded-2xl max-w-lg w-full p-6 shadow-large max-h-[90vh] overflow-y-auto">
        <h2 class="text-lg font-semibold text-text-primary text-lg mb-4">New Snag Item</h2>
        <div id="create-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1.5">Scope <span class="text-red-500">*</span></label>
              <select id="new-scope" class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-600">
                <option value="COMMON_AREA">Common Area</option>
                <option value="APARTMENT">Apartment</option>
              </select>
            </div>
            <div id="flat-number-field" class="hidden">
              <label class="block text-sm font-medium text-text-primary mb-1.5">Flat No. <span class="text-red-500">*</span></label>
              <input type="text" id="new-flat" placeholder="e.g. A-101"
                class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1.5">Category <span class="text-red-500">*</span></label>
              <select id="new-category" class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-600">
                <option value="">Select…</option>
                {['Civil & Structural','Seepage / Water','Electrical','Electrical - HT Infrastructure','Plumbing','Flooring','Painting','Exterior & Facade','Common Area','Lift & Elevator','Fire Safety','Other'].map(c => <option value={c}>{c}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1.5">Severity</label>
              <select id="new-severity" class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-600">
                <option value="LOW">Low</option>
                <option value="MEDIUM" selected>Medium</option>
                <option value="HIGH">High</option>
                <option value="CRITICAL">Critical</option>
              </select>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">Location <span class="text-red-500">*</span></label>
            <input type="text" id="new-location" placeholder="e.g. Ground floor lobby, east wall"
              class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">Description <span class="text-red-500">*</span></label>
            <textarea id="new-description" rows="3" placeholder="Describe the defect…"
              class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none"></textarea>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1.5">Builder Ref</label>
              <input type="text" id="new-builder-ref" placeholder="Optional reference"
                class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1.5">Builder Committed Date</label>
              <input type="date" id="new-committed-date"
                class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
          </div>
          <div class="flex gap-3 pt-1">
            <button id="create-save-btn" class="btn-primary flex-1">Create Snag</button>
            <button id="create-cancel-btn" class="btn-outline flex-1">Cancel</button>
          </div>
        </div>
      </div>
    </div>
  )}

  <div id="item-count" class="text-xs text-text-secondary mb-3">Loading…</div>
  <div id="items-list" class="space-y-3">
    {Array.from({length: 4}).map(() => (
      <div class="bg-white rounded-xl border border-border-light p-4 animate-pulse flex gap-4">
        <div class="flex-1">
          <div class="h-3 bg-gray-200 rounded w-48 mb-2"></div>
          <div class="h-2.5 bg-gray-100 rounded w-32"></div>
        </div>
      </div>
    ))}
  </div>

  <script define:vars={{ canCreate }}>
    const STATUS_LABEL = {
      OPEN: 'Open', IN_PROGRESS: 'In Progress', RESOLVED: 'Resolved',
      VERIFIED_CLOSED: 'Verified Closed', REOPENED: 'Reopened',
    };
    const STATUS_CLS = {
      OPEN: 'bg-red-100 text-red-700',
      IN_PROGRESS: 'bg-blue-100 text-blue-700',
      RESOLVED: 'bg-indigo-100 text-indigo-700',
      VERIFIED_CLOSED: 'bg-green-100 text-green-700',
      REOPENED: 'bg-orange-100 text-orange-700',
    };
    const SEVERITY_CLS = {
      CRITICAL: 'bg-red-600 text-white',
      HIGH: 'bg-orange-100 text-orange-700',
      MEDIUM: 'bg-amber-100 text-amber-700',
      LOW: 'bg-gray-100 text-gray-500',
    };

    let debounceTimer;

    async function loadItems(q = '', status = '', severity = '', scope = '', category = '') {
      const params = new URLSearchParams({ limit: '200' });
      if (q) params.set('q', q);
      if (status) params.set('status', status);
      if (severity) params.set('severity', severity);
      if (scope) params.set('snag_scope', scope);
      if (category) params.set('category', category);

      const res = await fetch(`/api/v1/hoto/snags?${params}`, { credentials: 'include' });
      const items = res.ok ? await res.json() : [];

      document.getElementById('stat-total').textContent = items.length;
      document.getElementById('stat-open').textContent = items.filter(i => i.status === 'OPEN').length;
      document.getElementById('stat-progress').textContent = items.filter(i => i.status === 'IN_PROGRESS').length;
      document.getElementById('stat-closed').textContent = items.filter(i => i.status === 'VERIFIED_CLOSED').length;
      document.getElementById('item-count').textContent = `${items.length} snag${items.length !== 1 ? 's' : ''}`;

      const list = document.getElementById('items-list');
      if (!items.length) {
        list.innerHTML = '<div class="text-center py-10 text-text-secondary text-sm">No snags found.</div>';
        return;
      }

      list.innerHTML = items.map(item => `
        <a href="/portal/snags/${item.id}" class="block bg-white rounded-xl border border-border-light p-4 hover:shadow-soft transition-shadow">
          <div class="flex items-start gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <span class="text-xs px-2 py-0.5 rounded-full font-medium ${SEVERITY_CLS[item.severity] ?? 'bg-gray-100 text-gray-500'}">${item.severity}</span>
                <span class="text-xs px-2 py-0.5 rounded-full font-medium ${STATUS_CLS[item.status] ?? 'bg-gray-100 text-gray-600'}">${STATUS_LABEL[item.status] ?? item.status}</span>
                ${item.snag_source === 'EXTERNAL_AUDIT' ? '<span class="text-xs px-2 py-0.5 rounded-full font-medium bg-purple-100 text-purple-700">Audit</span>' : ''}
                <span class="text-xs text-text-secondary">${item.snag_scope === 'APARTMENT' ? (item.flat_number ?? 'Apt') : 'Common'}</span>
              </div>
              <div class="font-medium text-text-primary text-sm">${item.description.slice(0, 120)}${item.description.length > 120 ? '…' : ''}</div>
              <div class="text-xs text-text-secondary mt-0.5">${item.category}${item.subcategory ? ` › ${item.subcategory}` : ''}${item.location ? ` · ${item.location}` : ''}${item.audit_ref_no ? ` · Ref #${item.audit_ref_no}` : ''}</div>
              ${item.equipment_machinery ? `<div class="text-xs text-text-secondary mt-0.5"><i class="fas fa-cog text-xs mr-1"></i>${item.equipment_machinery}</div>` : ''}
            </div>
            <i class="fas fa-chevron-right text-text-secondary text-xs flex-shrink-0 mt-1" aria-hidden="true"></i>
          </div>
        </a>
      `).join('');
    }

    function getFilters() {
      return {
        q: document.getElementById('search-input').value.trim(),
        status: document.getElementById('status-filter').value,
        severity: document.getElementById('severity-filter').value,
        scope: document.getElementById('scope-filter').value,
        category: document.getElementById('category-filter').value,
      };
    }

    document.getElementById('search-input')?.addEventListener('input', e => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        const f = getFilters();
        loadItems(f.q, f.status, f.severity, f.scope, f.category);
      }, 350);
    });

    ['status-filter','severity-filter','scope-filter','category-filter'].forEach(id => {
      document.getElementById(id)?.addEventListener('change', () => {
        const f = getFilters();
        loadItems(f.q, f.status, f.severity, f.scope, f.category);
      });
    });

    // Show/hide flat number field based on scope
    document.getElementById('new-scope')?.addEventListener('change', e => {
      const flatField = document.getElementById('flat-number-field');
      if (e.target.value === 'APARTMENT') flatField.classList.remove('hidden');
      else flatField.classList.add('hidden');
    });

    if (canCreate) {
      document.getElementById('create-btn')?.addEventListener('click', () => {
        document.getElementById('create-error').classList.add('hidden');
        document.getElementById('create-modal').classList.remove('hidden');
      });
      document.getElementById('create-cancel-btn')?.addEventListener('click', () => {
        document.getElementById('create-modal').classList.add('hidden');
      });
      document.getElementById('create-save-btn')?.addEventListener('click', async () => {
        const scope = document.getElementById('new-scope').value;
        const category = document.getElementById('new-category').value;
        const location = document.getElementById('new-location').value.trim();
        const description = document.getElementById('new-description').value.trim();
        const errEl = document.getElementById('create-error');
        errEl.classList.add('hidden');

        if (!category) { errEl.textContent = 'Category is required.'; errEl.classList.remove('hidden'); return; }
        if (!location) { errEl.textContent = 'Location is required.'; errEl.classList.remove('hidden'); return; }
        if (!description) { errEl.textContent = 'Description is required.'; errEl.classList.remove('hidden'); return; }
        if (scope === 'APARTMENT' && !document.getElementById('new-flat').value.trim()) {
          errEl.textContent = 'Flat number is required for apartment snags.'; errEl.classList.remove('hidden'); return;
        }

        const btn = document.getElementById('create-save-btn');
        btn.disabled = true; btn.textContent = 'Creating…';

        const res = await fetch('/api/v1/hoto/snags', {
          method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            snag_scope: scope,
            category,
            location,
            description,
            flat_number: scope === 'APARTMENT' ? document.getElementById('new-flat').value.trim() : undefined,
            severity: document.getElementById('new-severity').value,
            builder_ref: document.getElementById('new-builder-ref').value.trim() || undefined,
            builder_committed_date: document.getElementById('new-committed-date').value || undefined,
          }),
        });

        btn.disabled = false; btn.textContent = 'Create Snag';

        if (res.ok) {
          const item = await res.json();
          window.location.href = `/portal/snags/${item.id}`;
        } else {
          const d = await res.json().catch(() => ({}));
          errEl.textContent = d.message ?? d.error ?? 'Failed to create snag.';
          errEl.classList.remove('hidden');
        }
      });
    }

    loadItems();
  </script>
</PortalLayout>

---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const snagId = Astro.params.id!;

const canEdit   = ['executive','secretary','president'].includes(user.portalRole) || user.isAdmin;
const canVerify = ['secretary','president'].includes(user.portalRole) || user.isAdmin;
const canDelete = user.portalRole === 'president' || user.isAdmin;
const canUpload = canEdit;
---

<PortalLayout title="Snag Detail" user={user} activeModule="snags">
  <div class="mb-5">
    <a href="/portal/snags" class="text-sm text-text-secondary hover:text-primary-600 flex items-center gap-1.5">
      <i class="fas fa-arrow-left text-xs" aria-hidden="true"></i> Back to Snag List
    </a>
  </div>

  <!-- SLA overdue banner (injected by JS when applicable) -->
  <div id="sla-banner" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-800 flex items-center gap-2">
    <i class="fas fa-exclamation-triangle text-red-500"></i>
    <span id="sla-banner-text"></span>
  </div>

  <div id="snag-header" class="mb-6 animate-pulse">
    <div class="h-4 bg-gray-200 rounded w-24 mb-2"></div>
    <div class="h-6 bg-gray-300 rounded w-3/4"></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Description card -->
      <div class="bg-white rounded-2xl border border-border-light p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-lg font-semibold text-text-primary">Description</h2>
          {canEdit && (
            <button id="edit-btn" class="text-xs text-primary-600 hover:text-primary-700 font-medium">
              <i class="fas fa-pen mr-1"></i> Edit
            </button>
          )}
        </div>
        <div id="snag-description" class="text-sm text-text-primary whitespace-pre-wrap animate-pulse bg-gray-100 h-12 rounded"></div>
      </div>

      <!-- Files -->
      <div class="bg-white rounded-2xl border border-border-light overflow-hidden">
        <div class="px-5 py-4 border-b border-border-light flex items-center justify-between">
          <h2 class="text-lg font-semibold text-text-primary">Documents</h2>
          {canUpload && (
            <button id="upload-btn" class="text-xs text-primary-600 hover:text-primary-700 font-medium">
              + Upload file
            </button>
          )}
        </div>
        <div id="files-list" class="divide-y divide-border-light">
          <div class="px-5 py-3 text-sm text-text-secondary">Loading…</div>
        </div>
        {canUpload && (
          <div id="upload-form-wrapper" class="hidden px-5 py-4 bg-gray-50 border-t border-border-light">
            <div id="upload-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
            <div id="upload-success" class="hidden mb-3 p-3 bg-green-50 border border-green-200 rounded-xl text-sm text-green-700"></div>
            <div class="space-y-3">
              <div>
                <label class="block text-xs font-medium text-text-primary mb-1">File <span class="text-red-500">*</span></label>
                <input type="file" id="upload-file" accept=".pdf,.jpg,.jpeg,.png,.xlsx,.csv,.docx"
                  class="w-full text-sm text-text-secondary file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-primary-600 file:text-white hover:file:bg-primary-700" />
              </div>
              <div>
                <label class="block text-xs font-medium text-text-primary mb-1">Source Description</label>
                <input type="text" id="upload-desc" placeholder="e.g. Received from builder on 15 Jan 2025"
                  class="w-full px-3 py-2 border border-border-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
              </div>
              <div class="flex gap-2">
                <button id="upload-submit-btn" class="btn-primary text-xs py-2 px-4">Upload</button>
                <button id="upload-cancel-btn" class="btn-outline text-xs py-2 px-4">Cancel</button>
              </div>
            </div>
          </div>
        )}
      </div>

      <!-- Photo Attachments -->
      <div class="bg-white rounded-2xl border border-border-light overflow-hidden">
        <div class="px-5 py-4 border-b border-border-light flex items-center justify-between">
          <h2 class="text-lg font-semibold text-text-primary">
            Photos
            <span id="photo-count-badge" class="hidden ml-2 text-xs px-2 py-0.5 rounded-full bg-primary-50 text-primary-700 font-medium"></span>
          </h2>
          {canUpload && (
            <label for="photo-file-input" class="text-xs text-primary-600 hover:text-primary-700 font-medium cursor-pointer flex items-center gap-1">
              <i class="fas fa-camera text-xs" aria-hidden="true"></i> Add Photos
            </label>
          )}
        </div>

        <!-- Photo grid -->
        <div id="photo-grid" class="p-4 grid grid-cols-2 sm:grid-cols-3 gap-3">
          <div class="col-span-full text-sm text-text-secondary text-center py-4">Loading…</div>
        </div>

        {canUpload && (
          <>
            <input type="file" id="photo-file-input" multiple accept="image/jpeg,image/png,image/webp,image/heic,video/mp4" class="hidden" />
            <!-- Drop zone (shown when no photos yet or always below grid) -->
            <div id="photo-drop-zone"
              class="mx-4 mb-4 border-2 border-dashed border-border-light rounded-xl p-6 text-center text-sm text-text-secondary hover:border-primary-400 hover:bg-primary-50/30 transition-colors cursor-pointer">
              <i class="fas fa-cloud-upload-alt text-2xl text-primary-300 mb-2 block" aria-hidden="true"></i>
              Drop photos here or <span class="text-primary-600 font-medium">click to select</span>
              <div class="text-xs mt-1 text-text-secondary">JPEG, PNG, WebP, HEIC, MP4 — up to 50 MB each</div>
            </div>
            <div id="photo-upload-status" class="hidden px-5 pb-4 text-xs text-text-secondary"></div>
          </>
        )}
      </div>

      <!-- Photo Lightbox -->
      <div id="photo-lightbox" class="hidden fixed inset-0 bg-black/90 z-50 flex items-center justify-center p-4">
        <button id="lb-close" class="absolute top-4 right-4 text-white/70 hover:text-white text-2xl" aria-label="Close">
          <i class="fas fa-times" aria-hidden="true"></i>
        </button>
        <button id="lb-prev" class="absolute left-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-2xl px-3 py-6" aria-label="Previous">
          <i class="fas fa-chevron-left" aria-hidden="true"></i>
        </button>
        <img id="lb-img" src="" alt="Photo" class="max-w-full max-h-full object-contain rounded-lg" />
        <div id="lb-caption" class="absolute bottom-6 left-0 right-0 text-center text-white/80 text-sm px-8"></div>
        <button id="lb-next" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-2xl px-3 py-6" aria-label="Next">
          <i class="fas fa-chevron-right" aria-hidden="true"></i>
        </button>
      </div>

      <!-- Comments -->
      <div class="bg-white rounded-2xl border border-border-light overflow-hidden">
        <div class="px-5 py-4 border-b border-border-light">
          <h2 class="text-lg font-semibold text-text-primary">Comments</h2>
        </div>
        <div id="comments-list" class="p-5 space-y-3">
          <div class="text-sm text-text-secondary">Loading…</div>
        </div>
        {canEdit && (
          <div class="px-5 pb-5">
            <textarea id="comment-input" rows="2" placeholder="Add a comment… (Enter to post, Shift+Enter for newline)"
              class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none"></textarea>
            <div id="comment-error" class="hidden mt-1 text-xs text-red-600"></div>
          </div>
        )}
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Status & Actions -->
      <div class="bg-white rounded-2xl border border-border-light overflow-hidden">
        <div class="px-5 py-4 border-b border-border-light">
          <h2 class="text-lg font-semibold text-text-primary">Status &amp; Actions</h2>
        </div>
        <div id="actions-content" class="p-5 space-y-3 animate-pulse">
          <div class="h-8 bg-gray-100 rounded"></div>
        </div>
      </div>

      <!-- Assignee (exec only) -->
    {canEdit && (
      <div class="bg-white rounded-2xl border border-border-light overflow-hidden">
        <div class="px-5 py-4 border-b border-border-light">
          <h2 class="text-base font-semibold text-text-primary">Assigned To</h2>
        </div>
        <div class="p-4">
          <select id="assignee-select"
            class="w-full px-3 py-2 border border-border-light rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-600">
            <option value="">— Unassigned —</option>
          </select>
          <p id="assignee-status" class="text-xs text-text-secondary mt-1.5 hidden"></p>
        </div>
      </div>
    )}

    <!-- Create Work Order (exec only) -->
    {canEdit && (
      <div class="bg-white rounded-2xl border border-border-light overflow-hidden">
        <div class="px-5 py-4 border-b border-border-light">
          <h2 class="text-base font-semibold text-text-primary">Vendor Work Order</h2>
        </div>
        <div class="p-4">
          <div id="linked-wo" class="text-xs text-text-secondary mb-3 hidden"></div>
          <button id="create-wo-btn" class="btn-outline w-full text-sm flex items-center justify-center gap-2">
            <i class="fas fa-tools" aria-hidden="true"></i>Create Work Order
          </button>
        </div>
      </div>
    )}

    <!-- Create Work Order Modal -->
    {canEdit && (
      <div id="wo-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl p-6 w-full max-w-md">
          <h3 class="font-semibold text-text-primary mb-4 flex justify-between">
            Create Work Order from Snag
            <button id="wo-modal-close" class="text-text-secondary"><i class="fas fa-times"></i></button>
          </h3>
          <div id="wo-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>
          <form id="wo-form" class="space-y-3">
            <div>
              <label class="form-label text-xs">Vendor <span class="text-red-500">*</span></label>
              <select id="wo-vendor" required class="form-input text-sm">
                <option value="">Loading vendors…</option>
              </select>
            </div>
            <div>
              <label class="form-label text-xs">Work Order Title <span class="text-red-500">*</span></label>
              <input type="text" id="wo-title" required maxlength="200" class="form-input text-sm" />
            </div>
            <div>
              <label class="form-label text-xs">Description</label>
              <textarea id="wo-desc" rows="2" maxlength="1000" class="form-input text-sm resize-none"></textarea>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="form-label text-xs">Deadline</label>
                <input type="date" id="wo-deadline" class="form-input text-sm" />
              </div>
              <div>
                <label class="form-label text-xs">Quoted Amount (₹)</label>
                <input type="number" id="wo-amount" min="0" step="0.01" class="form-input text-sm" />
              </div>
            </div>
            <div class="flex gap-3 pt-2">
              <button type="submit" class="btn-primary flex-1 text-sm">Create</button>
              <button type="button" id="wo-cancel" class="btn-outline flex-1 text-sm">Cancel</button>
            </div>
          </form>
        </div>
      </div>
    )}

    <!-- Metadata -->
      <div class="bg-white rounded-2xl border border-border-light overflow-hidden">
        <div class="px-5 py-4 border-b border-border-light">
          <h2 class="text-lg font-semibold text-text-primary">Details</h2>
        </div>
        <div id="metadata-content" class="p-5 animate-pulse">
          <div class="space-y-2">
            <div class="h-3 bg-gray-100 rounded w-32"></div>
            <div class="h-3 bg-gray-100 rounded w-24"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit modal -->
  {canEdit && (
    <div id="edit-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
      <div class="bg-white rounded-2xl max-w-lg w-full p-6 shadow-large max-h-[90vh] overflow-y-auto">
        <h2 class="text-lg font-semibold text-text-primary text-lg mb-4">Edit Snag</h2>
        <div id="edit-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1.5">Category <span class="text-red-500">*</span></label>
              <input type="text" id="e-category" class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1.5">Subcategory</label>
              <input type="text" id="e-subcategory" class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">Location <span class="text-red-500">*</span></label>
            <input type="text" id="e-location" class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">Description <span class="text-red-500">*</span></label>
            <textarea id="e-description" rows="3" class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none"></textarea>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1.5">Severity</label>
              <select id="e-severity" class="w-full px-3 py-2 border border-border-light rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-600">
                <option value="LOW">Low</option>
                <option value="MEDIUM">Medium</option>
                <option value="HIGH">High</option>
                <option value="CRITICAL">Critical</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1.5">Builder Committed Date</label>
              <input type="date" id="e-builder-committed-date" class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">Builder Reference</label>
            <input type="text" id="e-builder-ref" placeholder="e.g. BLD-DEFECT-2024-001"
              class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
          </div>
          <div class="flex gap-3 pt-1">
            <button id="edit-save-btn" class="btn-primary flex-1">Save Changes</button>
            <button id="edit-cancel-btn" class="btn-outline flex-1">Cancel</button>
          </div>
        </div>
      </div>
    </div>
  )}

  <!-- Reopen modal -->
  <div id="reopen-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
    <div class="bg-white rounded-2xl max-w-md w-full p-6 shadow-large">
      <h2 class="text-lg font-semibold text-text-primary text-lg mb-4">Reopen Snag</h2>
      <div id="reopen-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text-primary mb-1.5">Reopen Reason <span class="text-red-500">*</span></label>
          <textarea id="reopen-reason" rows="3" placeholder="Why is this snag being reopened?"
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none"></textarea>
        </div>
        <div class="flex gap-3">
          <button id="reopen-submit-btn" class="btn-primary flex-1">Confirm Reopen</button>
          <button id="reopen-cancel-btn" class="btn-outline flex-1">Cancel</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Delete modal -->
  {canDelete && (
    <div id="delete-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
      <div class="bg-white rounded-2xl max-w-md w-full p-6 shadow-large">
        <h2 class="text-lg font-semibold text-text-primary text-lg mb-4">Delete Snag</h2>
        <p class="text-sm text-text-secondary mb-4">This is a permanent soft-delete. The record will be hidden but retained in the audit log.</p>
        <div id="delete-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">Deletion Reason <span class="text-red-500">*</span></label>
            <textarea id="delete-reason" rows="2" placeholder="Why is this snag being deleted?"
              class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none"></textarea>
          </div>
          <div class="flex gap-3">
            <button id="delete-submit-btn" class="btn-primary flex-1 bg-red-600 hover:bg-red-700 border-red-600">Delete</button>
            <button id="delete-cancel-btn" class="btn-outline flex-1">Cancel</button>
          </div>
        </div>
      </div>
    </div>
  )}

  <script define:vars={{ snagId, canEdit, canVerify, canDelete, canUpload }}>
    const STATUS_LABEL = {
      OPEN: 'Open', IN_PROGRESS: 'In Progress', RESOLVED: 'Resolved',
      VERIFIED_CLOSED: 'Verified Closed', REOPENED: 'Reopened',
    };
    const STATUS_CLS = {
      OPEN: 'bg-red-100 text-red-700',
      IN_PROGRESS: 'bg-blue-100 text-blue-700',
      RESOLVED: 'bg-indigo-100 text-indigo-700',
      VERIFIED_CLOSED: 'bg-green-100 text-green-700',
      REOPENED: 'bg-orange-100 text-orange-700',
    };
    const SEVERITY_CLS = {
      CRITICAL: 'bg-red-600 text-white',
      HIGH: 'bg-orange-100 text-orange-700',
      MEDIUM: 'bg-amber-100 text-amber-700',
      LOW: 'bg-gray-100 text-gray-500',
    };

    let state = { snag: null, files: [], comments: [] };

    // ── Assignee dropdown (exec only) ─────────────────────────────────────────
    if (canEdit) {
      const sel = document.getElementById('assignee-select');
      const statusEl = document.getElementById('assignee-status');

      // Load committee members to populate dropdown (filter to exec/secretary/president)
      fetch('/api/v1/members?limit=200', { credentials: 'include' })
        .then(r => r.ok ? r.json() : [])
        .then((members) => {
          if (!sel) return;
          const committee = members.filter((m: any) =>
            ['executive', 'secretary', 'president', 'admin'].includes(m.role ?? ''),
          );
          for (const m of committee) {
            const opt = document.createElement('option');
            opt.value = m.id;
            opt.textContent = m.full_name;
            sel.appendChild(opt);
          }
        }).catch(() => {});

      sel?.addEventListener('change', async () => {
        const userId = (sel as HTMLSelectElement).value;
        if (statusEl) { statusEl.textContent = 'Saving…'; statusEl.classList.remove('hidden', 'text-red-600', 'text-secondary-500'); }
        const res = await fetch(`/api/v1/hoto/snags/${snagId}`, {
          method: 'PATCH', credentials: 'include', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ responsible_user_id: userId || null }),
        });
        if (res.ok) {
          if (statusEl) { statusEl.textContent = 'Saved'; statusEl.classList.add('text-secondary-500'); }
          setTimeout(() => statusEl?.classList.add('hidden'), 2000);
        } else {
          if (statusEl) { statusEl.textContent = 'Failed to save'; statusEl.classList.add('text-red-600'); }
        }
      });
    }

    async function loadData() {
      const res = await fetch(`/api/v1/hoto/snags/${snagId}`, { credentials: 'include' });
      if (!res.ok) {
        document.getElementById('snag-header').innerHTML = '<p class="text-red-600 text-sm">Snag not found or you do not have access.</p>';
        return;
      }
      state = await res.json();
      render();
    }

    function render() {
      const { snag, files, comments } = state;
      if (!snag) return;

      // SLA overdue banner
      const today = new Date().toISOString().slice(0, 10);
      if (snag.builder_committed_date && snag.builder_committed_date < today && !['VERIFIED_CLOSED'].includes(snag.status)) {
        const days = Math.floor((Date.now() - new Date(snag.builder_committed_date).getTime()) / 86_400_000);
        document.getElementById('sla-banner-text').textContent = `Builder committed date passed ${days} day${days !== 1 ? 's' : ''} ago (${new Date(snag.builder_committed_date).toLocaleDateString('en-IN')}). Follow up with builder.`;
        document.getElementById('sla-banner').classList.remove('hidden');
      } else {
        document.getElementById('sla-banner').classList.add('hidden');
      }

      document.getElementById('snag-header').innerHTML = `
        <div class="flex items-start gap-3 flex-wrap">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap mb-1">
              <span class="text-xs px-2 py-0.5 rounded-full font-medium ${SEVERITY_CLS[snag.severity] ?? 'bg-gray-100 text-gray-500'}">${snag.severity}</span>
              <span class="text-xs px-2 py-0.5 rounded-full font-medium ${STATUS_CLS[snag.status] ?? 'bg-gray-100 text-gray-600'}">${STATUS_LABEL[snag.status] ?? snag.status}</span>
              <span class="text-xs text-text-secondary">${snag.snag_scope === 'APARTMENT' ? (snag.flat_number ? `Apt ${snag.flat_number}` : 'Apartment') : 'Common Area'}</span>
            </div>
            <h1 class="text-2xl font-bold text-text-primary">${snag.category}${snag.location ? ` — ${snag.location}` : ''}</h1>
          </div>
        </div>
      `;

      document.getElementById('snag-description').textContent = snag.description;
      document.getElementById('snag-description').classList.remove('animate-pulse', 'bg-gray-100', 'h-12', 'rounded');

      // Sync assignee dropdown with current value
      if (canEdit) {
        const sel = document.getElementById('assignee-select') as HTMLSelectElement | null;
        if (sel) sel.value = snag.responsible_user_id ?? '';
      }

      // Files
      const filesEl = document.getElementById('files-list');
      const fmt = b => b < 1024 ? b + 'B' : b < 1048576 ? (b/1024).toFixed(0)+'KB' : (b/1048576).toFixed(1)+'MB';
      if (!files.length) {
        filesEl.innerHTML = '<div class="px-5 py-4 text-sm text-text-secondary">No documents uploaded yet.</div>';
      } else {
        filesEl.innerHTML = files.map(f => `
          <div class="px-5 py-3 flex items-center gap-3">
            <i class="fas fa-file-alt text-text-secondary flex-shrink-0" aria-hidden="true"></i>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium text-text-primary truncate">${f.name}</div>
              <div class="text-xs text-text-secondary mt-0.5">${fmt(f.file_size_bytes ?? 0)} · ${new Date(f.created_at).toLocaleDateString('en-IN')}</div>
            </div>
          </div>
        `).join('');
      }

      // Comments
      const commentsEl = document.getElementById('comments-list');
      if (!comments.length) {
        commentsEl.innerHTML = '<div class="text-sm text-text-secondary">No comments yet.</div>';
      } else {
        commentsEl.innerHTML = comments.map(c => `
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-full bg-primary-600 flex items-center justify-center text-white text-xs font-medium flex-shrink-0">
              ${(c.profiles?.full_name ?? 'U').charAt(0).toUpperCase()}
            </div>
            <div class="flex-1">
              <div class="text-xs font-medium text-text-primary">${c.profiles?.full_name ?? 'Unknown'}</div>
              <div class="text-sm text-text-primary mt-0.5 whitespace-pre-wrap">${c.body}</div>
              <div class="text-xs text-text-secondary mt-1">${new Date(c.created_at).toLocaleString('en-IN', {day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'})}</div>
            </div>
          </div>
        `).join('');
      }

      // Actions
      renderActions(snag);

      // Metadata
      document.getElementById('metadata-content').innerHTML = `
        <dl class="space-y-3 text-sm">
          <div><dt class="text-xs text-text-secondary uppercase tracking-wide mb-0.5">Category</dt><dd class="text-text-primary">${snag.category}${snag.subcategory ? ` / ${snag.subcategory}` : ''}</dd></div>
          <div><dt class="text-xs text-text-secondary uppercase tracking-wide mb-0.5">Location</dt><dd class="text-text-primary">${snag.location}</dd></div>
          ${snag.equipment_machinery ? `<div><dt class="text-xs text-text-secondary uppercase tracking-wide mb-0.5">Equipment / Asset</dt><dd class="text-text-primary">${snag.equipment_machinery}</dd></div>` : ''}
          ${snag.snag_source === 'EXTERNAL_AUDIT' ? `
            <div class="pt-2 border-t border-border-light">
              <dt class="text-xs font-semibold text-purple-700 uppercase tracking-wide mb-1"><i class="fas fa-clipboard-check mr-1"></i>External Audit</dt>
              ${snag.audit_source ? `<dd class="text-text-primary mb-0.5">Auditor: ${snag.audit_source}</dd>` : ''}
              ${snag.audit_date ? `<dd class="text-text-secondary text-xs">Audit date: ${new Date(snag.audit_date).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'})}</dd>` : ''}
              ${snag.audit_ref_no ? `<dd class="text-text-secondary text-xs">Sr No: ${snag.audit_ref_no}</dd>` : ''}
            </div>` : ''}
          ${snag.compliance_requirement ? `<div><dt class="text-xs text-text-secondary uppercase tracking-wide mb-0.5">Compliance Ref</dt><dd class="text-text-primary text-xs leading-relaxed">${snag.compliance_requirement}</dd></div>` : ''}
          ${snag.builder_ref ? `<div><dt class="text-xs text-text-secondary uppercase tracking-wide mb-0.5">Builder Ref</dt><dd class="text-text-primary">${snag.builder_ref}</dd></div>` : ''}
          ${snag.expected_closure_date ? `<div><dt class="text-xs text-text-secondary uppercase tracking-wide mb-0.5">Expected Closure</dt><dd class="${snag.expected_closure_date < new Date().toISOString().slice(0,10) ? 'text-red-600 font-medium' : 'text-text-primary'}">${new Date(snag.expected_closure_date).toLocaleDateString('en-IN')}</dd></div>` : ''}
          ${snag.builder_committed_date ? `<div><dt class="text-xs text-text-secondary uppercase tracking-wide mb-0.5">Builder Committed</dt><dd class="${snag.builder_committed_date < new Date().toISOString().slice(0,10) ? 'text-red-600 font-medium' : 'text-text-primary'}">${new Date(snag.builder_committed_date).toLocaleDateString('en-IN')}</dd></div>` : ''}
          ${snag.responsible_person_name ? `<div><dt class="text-xs text-text-secondary uppercase tracking-wide mb-0.5">Responsible Person</dt><dd class="text-text-primary">${snag.responsible_person_name}</dd></div>` : ''}
          <div><dt class="text-xs text-text-secondary uppercase tracking-wide mb-0.5">Reported</dt><dd class="text-text-primary">${new Date(snag.reported_date).toLocaleDateString('en-IN')}</dd></div>
          ${snag.verified_at ? `<div><dt class="text-xs text-text-secondary uppercase tracking-wide mb-0.5">Verified</dt><dd class="text-green-600">${new Date(snag.verified_at).toLocaleString('en-IN')}</dd></div>` : ''}
          ${snag.reopen_reason ? `<div><dt class="text-xs text-text-secondary uppercase tracking-wide mb-0.5">Reopen Reason</dt><dd class="text-orange-600">${snag.reopen_reason}</dd></div>` : ''}
        </dl>
      `;
      // Recommendation panel (external audit)
      const recEl = document.getElementById('recommendation-panel');
      if (recEl) {
        if (snag.recommendation) {
          recEl.innerHTML = `
            <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mt-4">
              <h3 class="text-sm font-semibold text-blue-800 mb-1"><i class="fas fa-lightbulb mr-1"></i>Recommendation</h3>
              <p class="text-sm text-blue-900 leading-relaxed">${snag.recommendation}</p>
            </div>`;
        } else {
          recEl.innerHTML = '';
        }
      }
    }

    function renderActions(snag) {
      const el = document.getElementById('actions-content');
      const status = snag.status;

      let html = `
        <div class="text-sm font-medium text-text-secondary mb-2">Current Status</div>
        <span class="text-sm px-2.5 py-1 rounded-full font-medium ${STATUS_CLS[status] ?? 'bg-gray-100 text-gray-600'}">${STATUS_LABEL[status] ?? status}</span>
      `;

      const actionErr = '<div id="action-error" class="hidden mt-3 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>';

      if (canEdit) {
        if (status === 'OPEN' || status === 'REOPENED') {
          html += `<button id="btn-in-progress" class="w-full btn-primary text-sm mt-3" data-to="IN_PROGRESS"><i class="fas fa-play mr-1"></i> Mark In Progress</button>`;
        }
        if (status === 'IN_PROGRESS') {
          html += `<button id="btn-resolved" class="w-full btn-primary text-sm mt-3" data-to="RESOLVED"><i class="fas fa-check mr-1"></i> Mark Resolved</button>`;
        }
      }

      if (canVerify && status === 'RESOLVED') {
        html += `<button id="btn-verify" class="w-full btn-primary text-sm mt-3" data-to="VERIFIED_CLOSED"><i class="fas fa-check-double mr-1"></i> Verify &amp; Close</button>`;
      }

      if (canEdit && status === 'VERIFIED_CLOSED') {
        html += `<button id="btn-reopen" class="w-full btn-outline text-sm mt-3 text-orange-600 border-orange-300"><i class="fas fa-undo mr-1"></i> Reopen</button>`;
      }

      if (canDelete && !['VERIFIED_CLOSED'].includes(status)) {
        html += `<button id="btn-delete" class="w-full btn-outline text-sm text-red-600 border-red-200 hover:bg-red-50 mt-2"><i class="fas fa-trash mr-1"></i> Delete</button>`;
      }

      html += actionErr;
      el.innerHTML = html;

      // Wire up simple advance buttons
      ['btn-in-progress','btn-resolved','btn-verify'].forEach(id => {
        document.getElementById(id)?.addEventListener('click', e => {
          advanceStatus(e.currentTarget.dataset.to);
        });
      });

      // Reopen via modal
      document.getElementById('btn-reopen')?.addEventListener('click', () => {
        document.getElementById('reopen-error').classList.add('hidden');
        document.getElementById('reopen-modal').classList.remove('hidden');
      });

      // Delete via modal
      document.getElementById('btn-delete')?.addEventListener('click', () => {
        document.getElementById('delete-error').classList.add('hidden');
        document.getElementById('delete-modal').classList.remove('hidden');
      });
    }

    async function advanceStatus(toStatus, extra = {}) {
      const res = await fetch(`/api/v1/hoto/snags/${snagId}/status`, {
        method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ to_status: toStatus, ...extra }),
      });
      if (res.ok) {
        await loadData();
      } else {
        const d = await res.json().catch(() => ({}));
        const errEl = document.getElementById('action-error');
        if (errEl) { errEl.textContent = d.message ?? d.error ?? 'Action failed.'; errEl.classList.remove('hidden'); }
      }
    }

    // Edit modal
    if (canEdit) {
      document.getElementById('edit-btn')?.addEventListener('click', () => {
        const s = state.snag;
        if (!s) return;
        (document.getElementById('e-category')).value = s.category ?? '';
        (document.getElementById('e-subcategory')).value = s.subcategory ?? '';
        (document.getElementById('e-location')).value = s.location ?? '';
        (document.getElementById('e-description')).value = s.description ?? '';
        (document.getElementById('e-severity')).value = s.severity ?? 'MEDIUM';
        (document.getElementById('e-builder-committed-date')).value = s.builder_committed_date ?? '';
        (document.getElementById('e-builder-ref')).value = s.builder_ref ?? '';
        document.getElementById('edit-error').classList.add('hidden');
        document.getElementById('edit-modal').classList.remove('hidden');
      });

      document.getElementById('edit-cancel-btn')?.addEventListener('click', () => {
        document.getElementById('edit-modal').classList.add('hidden');
      });

      document.getElementById('edit-save-btn')?.addEventListener('click', async () => {
        const category = (document.getElementById('e-category')).value.trim();
        const location = (document.getElementById('e-location')).value.trim();
        const description = (document.getElementById('e-description')).value.trim();
        const errEl = document.getElementById('edit-error');
        errEl.classList.add('hidden');
        if (!category) { errEl.textContent = 'Category is required.'; errEl.classList.remove('hidden'); return; }
        if (!location) { errEl.textContent = 'Location is required.'; errEl.classList.remove('hidden'); return; }
        if (!description) { errEl.textContent = 'Description is required.'; errEl.classList.remove('hidden'); return; }

        const btn = document.getElementById('edit-save-btn');
        btn.disabled = true; btn.textContent = 'Saving…';

        const res = await fetch(`/api/v1/hoto/snags/${snagId}`, {
          method: 'PATCH', credentials: 'include', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            category,
            subcategory: (document.getElementById('e-subcategory')).value.trim() || null,
            location,
            description,
            severity: (document.getElementById('e-severity')).value,
            builder_committed_date: (document.getElementById('e-builder-committed-date')).value || null,
            builder_ref: (document.getElementById('e-builder-ref')).value.trim() || null,
          }),
        });
        btn.disabled = false; btn.textContent = 'Save Changes';
        if (res.ok) {
          document.getElementById('edit-modal').classList.add('hidden');
          await loadData();
        } else {
          const d = await res.json().catch(() => ({}));
          errEl.textContent = d.message ?? d.error ?? 'Failed to save changes.';
          errEl.classList.remove('hidden');
        }
      });
    }

    // Upload file
    if (canUpload) {
      document.getElementById('upload-btn')?.addEventListener('click', () => {
        document.getElementById('upload-form-wrapper').classList.toggle('hidden');
      });
      document.getElementById('upload-cancel-btn')?.addEventListener('click', () => {
        document.getElementById('upload-form-wrapper').classList.add('hidden');
      });
      document.getElementById('upload-submit-btn')?.addEventListener('click', async () => {
        const fileInput = document.getElementById('upload-file');
        const file = fileInput.files?.[0];
        const errEl = document.getElementById('upload-error');
        const successEl = document.getElementById('upload-success');
        errEl.classList.add('hidden'); successEl.classList.add('hidden');
        if (!file) { errEl.textContent = 'Please select a file.'; errEl.classList.remove('hidden'); return; }

        const safeName = file.name.replace(/[^a-zA-Z0-9._-]/g, '_');
        const targetPath = `snags/${snagId}/${Date.now()}_${safeName}`;
        const fd = new FormData();
        fd.append('file', file);
        fd.append('item_id', snagId);
        fd.append('item_type', 'snag_item');
        fd.append('target_path', targetPath);
        fd.append('source_description', (document.getElementById('upload-desc')).value.trim());

        const btn = document.getElementById('upload-submit-btn');
        btn.disabled = true; btn.textContent = 'Uploading…';
        const res = await fetch('/api/v1/hoto/upload', {
          method: 'POST', credentials: 'include', body: fd,
        });
        btn.disabled = false; btn.textContent = 'Upload';
        if (res.ok) {
          successEl.textContent = 'File uploaded successfully.';
          successEl.classList.remove('hidden');
          fileInput.value = '';
          (document.getElementById('upload-desc')).value = '';
          await loadData();
        } else {
          const d = await res.json().catch(() => ({}));
          errEl.textContent = d.message ?? d.error ?? 'Upload failed.';
          errEl.classList.remove('hidden');
        }
      });
    }

    // Reopen modal
    document.getElementById('reopen-cancel-btn')?.addEventListener('click', () => {
      document.getElementById('reopen-modal').classList.add('hidden');
    });
    document.getElementById('reopen-submit-btn')?.addEventListener('click', async () => {
      const reason = (document.getElementById('reopen-reason')).value.trim();
      const errEl = document.getElementById('reopen-error');
      if (!reason) { errEl.textContent = 'Reopen reason is required.'; errEl.classList.remove('hidden'); return; }
      const btn = document.getElementById('reopen-submit-btn');
      btn.disabled = true; btn.textContent = 'Reopening…';
      const res = await fetch(`/api/v1/hoto/snags/${snagId}/status`, {
        method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ to_status: 'REOPENED', reopen_reason: reason }),
      });
      btn.disabled = false; btn.textContent = 'Confirm Reopen';
      if (res.ok) {
        document.getElementById('reopen-modal').classList.add('hidden');
        await loadData();
      } else {
        const d = await res.json().catch(() => ({}));
        errEl.textContent = d.message ?? d.error ?? 'Failed to reopen.';
        errEl.classList.remove('hidden');
      }
    });

    // Delete modal
    document.getElementById('delete-cancel-btn')?.addEventListener('click', () => {
      document.getElementById('delete-modal').classList.add('hidden');
    });
    document.getElementById('delete-submit-btn')?.addEventListener('click', async () => {
      const reason = (document.getElementById('delete-reason')).value.trim();
      const errEl = document.getElementById('delete-error');
      if (!reason) { errEl.textContent = 'Deletion reason is required.'; errEl.classList.remove('hidden'); return; }
      const btn = document.getElementById('delete-submit-btn');
      btn.disabled = true; btn.textContent = 'Deleting…';
      const res = await fetch(`/api/v1/hoto/snags/${snagId}`, {
        method: 'DELETE', credentials: 'include', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ deletion_reason: reason }),
      });
      btn.disabled = false; btn.textContent = 'Delete';
      if (res.ok || res.status === 204) {
        window.location.href = '/portal/snags';
      } else {
        const d = await res.json().catch(() => ({}));
        errEl.textContent = d.message ?? d.error ?? 'Failed to delete.';
        errEl.classList.remove('hidden');
      }
    });

    // ── Photo Attachments ────────────────────────────────────────────────────────
    let photoData = [];
    let lbIndex = 0;

    async function loadPhotos() {
      const res = await fetch(`/api/v1/hoto/snags/${snagId}/attachments`, { credentials: 'include' });
      if (!res.ok) return;
      photoData = await res.json();
      renderPhotos();
    }

    function renderPhotos() {
      const grid = document.getElementById('photo-grid');
      const badge = document.getElementById('photo-count-badge');
      if (!grid) return;

      if (!photoData.length) {
        grid.innerHTML = '<div class="col-span-full text-sm text-text-secondary text-center py-4">No photos yet.</div>';
        badge?.classList.add('hidden');
        return;
      }

      badge.textContent = String(photoData.length);
      badge.classList.remove('hidden');

      grid.innerHTML = photoData.map((p, i) => {
        const isVideo = p.mime_type === 'video/mp4';
        return `
          <div class="relative group aspect-square bg-gray-100 rounded-xl overflow-hidden cursor-pointer" data-idx="${i}">
            ${isVideo
              ? `<video src="${p.signed_url}" class="w-full h-full object-cover" preload="metadata"></video>`
              : `<img src="${p.signed_url}" alt="${p.caption ?? 'Photo'}" class="w-full h-full object-cover" loading="lazy" />`
            }
            ${p.caption ? `<div class="absolute bottom-0 left-0 right-0 bg-black/50 text-white text-xs px-2 py-1 truncate">${p.caption}</div>` : ''}
            ${canUpload ? `
              <button class="delete-photo-btn hidden group-hover:flex absolute top-2 right-2 w-6 h-6 bg-red-500 text-white rounded-full items-center justify-center text-xs" data-id="${p.id}" title="Delete">
                <i class="fas fa-times"></i>
              </button>` : ''}
            ${isVideo ? `<div class="absolute inset-0 flex items-center justify-center pointer-events-none"><i class="fas fa-play-circle text-white text-3xl opacity-70"></i></div>` : ''}
          </div>
        `;
      }).join('');

      // Lightbox click
      grid.querySelectorAll('[data-idx]').forEach(el => {
        el.addEventListener('click', (e) => {
          if ((e.target as Element).closest('.delete-photo-btn')) return;
          openLightbox(parseInt(el.dataset.idx));
        });
      });

      // Delete clicks
      grid.querySelectorAll('.delete-photo-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          if (!confirm('Delete this photo?')) return;
          const id = (btn as HTMLElement).dataset.id;
          const res = await fetch(`/api/v1/hoto/snags/${snagId}/attachments?attachment_id=${id}`, {
            method: 'DELETE', credentials: 'include',
          });
          if (res.ok) await loadPhotos();
        });
      });
    }

    function openLightbox(idx: number) {
      const lb = document.getElementById('photo-lightbox')!;
      lbIndex = idx;
      lb.classList.remove('hidden');
      showLbPhoto();
      document.addEventListener('keydown', lbKeyHandler);
    }

    function closeLightbox() {
      document.getElementById('photo-lightbox')!.classList.add('hidden');
      document.removeEventListener('keydown', lbKeyHandler);
    }

    function showLbPhoto() {
      const p = photoData[lbIndex];
      if (!p) return;
      const img = document.getElementById('lb-img') as HTMLImageElement;
      img.src = p.signed_url ?? '';
      document.getElementById('lb-caption')!.textContent = p.caption ?? '';
    }

    function lbKeyHandler(e: KeyboardEvent) {
      if (e.key === 'Escape')     closeLightbox();
      if (e.key === 'ArrowLeft')  { lbIndex = (lbIndex - 1 + photoData.length) % photoData.length; showLbPhoto(); }
      if (e.key === 'ArrowRight') { lbIndex = (lbIndex + 1) % photoData.length; showLbPhoto(); }
    }

    document.getElementById('lb-close')?.addEventListener('click', closeLightbox);
    document.getElementById('lb-prev')?.addEventListener('click',  () => { lbIndex = (lbIndex - 1 + photoData.length) % photoData.length; showLbPhoto(); });
    document.getElementById('lb-next')?.addEventListener('click',  () => { lbIndex = (lbIndex + 1) % photoData.length; showLbPhoto(); });
    document.getElementById('photo-lightbox')?.addEventListener('click', (e) => { if (e.target === e.currentTarget) closeLightbox(); });

    if (canUpload) {
      async function uploadPhotoFiles(files: FileList | File[]) {
        const statusEl = document.getElementById('photo-upload-status')!;
        statusEl.classList.remove('hidden');
        let uploaded = 0;
        for (const file of Array.from(files)) {
          statusEl.textContent = `Uploading ${file.name}…`;
          const fd = new FormData();
          fd.append('file', file);
          const res = await fetch(`/api/v1/hoto/snags/${snagId}/attachments`, {
            method: 'POST', credentials: 'include', body: fd,
          });
          if (res.ok) uploaded++;
        }
        statusEl.textContent = `${uploaded} of ${files.length} photo(s) uploaded.`;
        setTimeout(() => statusEl.classList.add('hidden'), 3000);
        await loadPhotos();
      }

      const photoInput = document.getElementById('photo-file-input') as HTMLInputElement;
      const dropZone   = document.getElementById('photo-drop-zone')!;

      photoInput?.addEventListener('change', () => {
        if (photoInput.files?.length) uploadPhotoFiles(photoInput.files);
      });
      dropZone?.addEventListener('click', () => photoInput?.click());
      dropZone?.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-primary-400', 'bg-primary-50/50'); });
      dropZone?.addEventListener('dragleave', ()  => { dropZone.classList.remove('border-primary-400', 'bg-primary-50/50'); });
      dropZone?.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('border-primary-400', 'bg-primary-50/50');
        if (e.dataTransfer?.files.length) uploadPhotoFiles(e.dataTransfer.files);
      });
    }

    loadPhotos();

    // Comment input
    document.getElementById('comment-input')?.addEventListener('keydown', async e => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        const body = e.target.value.trim();
        const errEl = document.getElementById('comment-error');
        if (!body) return;
        e.target.disabled = true;
        const res = await fetch(`/api/v1/hoto/items/${snagId}/comments`, {
          method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ item_type: 'snag_item', body }),
        });
        e.target.disabled = false;
        if (res.ok) {
          e.target.value = '';
          errEl.classList.add('hidden');
          await loadData();
        } else {
          const d = await res.json().catch(() => ({}));
          errEl.textContent = d.message ?? 'Failed to post comment.';
          errEl.classList.remove('hidden');
        }
      }
    });

    loadData();

    // ── Work Order from Snag ──────────────────────────────────────────────────
    if (canEdit) {
      const woBtn    = document.getElementById('create-wo-btn');
      const woModal  = document.getElementById('wo-modal');
      const woClose  = document.getElementById('wo-modal-close');
      const woCancel = document.getElementById('wo-cancel');
      const woError  = document.getElementById('wo-error')!;

      async function openWoModal() {
        // Load vendors
        const vRes = await fetch('/api/v1/vendors', { credentials: 'include' });
        const vendors = vRes.ok ? await vRes.json() : [];
        const sel = document.getElementById('wo-vendor') as HTMLSelectElement;
        sel.innerHTML = '<option value="">— Select vendor —</option>' +
          vendors.map((v: any) => `<option value="${v.id}">${v.name} (${v.category})</option>`).join('');

        // Pre-fill title from snag
        const snag = await (await fetch(`/api/v1/hoto/snags/${snagId}`, { credentials: 'include' })).json();
        (document.getElementById('wo-title') as HTMLInputElement).value =
          `Fix snag: ${snag.description?.slice(0, 80) ?? snag.id}`;
        (document.getElementById('wo-desc') as HTMLTextAreaElement).value =
          `Location: ${snag.location}\nCategory: ${snag.category}\n\n${snag.description ?? ''}`.trim();

        woError.classList.add('hidden');
        woModal!.classList.remove('hidden');
      }

      woBtn?.addEventListener('click', openWoModal);
      woClose?.addEventListener('click', () => woModal!.classList.add('hidden'));
      woCancel?.addEventListener('click', () => woModal!.classList.add('hidden'));

      document.getElementById('wo-form')!.addEventListener('submit', async (e) => {
        e.preventDefault();
        woError.classList.add('hidden');
        const body = {
          vendor_id:    (document.getElementById('wo-vendor') as HTMLSelectElement).value,
          title:        (document.getElementById('wo-title') as HTMLInputElement).value.trim(),
          description:  (document.getElementById('wo-desc') as HTMLTextAreaElement).value.trim() || undefined,
          snag_id:      snagId,
          deadline:     (document.getElementById('wo-deadline') as HTMLInputElement).value || undefined,
          quoted_amount: (document.getElementById('wo-amount') as HTMLInputElement).value
            ? Number((document.getElementById('wo-amount') as HTMLInputElement).value) : undefined,
        };
        const res = await fetch('/api/v1/vendors/work-orders', {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (res.ok) {
          const wo = await res.json();
          woModal!.classList.add('hidden');
          document.getElementById('linked-wo')!.innerHTML =
            `<i class="fas fa-check-circle text-green-500 mr-1"></i>Linked to work order — <a href="/portal/vendors" class="text-primary-600 underline">view</a>`;
          document.getElementById('linked-wo')!.classList.remove('hidden');
          (woBtn as HTMLButtonElement).disabled = true;
          (woBtn as HTMLButtonElement).textContent = 'Work Order Created';
        } else {
          const err = await res.json().catch(() => ({}));
          woError.textContent = err.message ?? 'Failed to create work order.';
          woError.classList.remove('hidden');
        }
      });
    }
  </script>
</PortalLayout>

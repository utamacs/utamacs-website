        </div>
        <form id="refund-form" class="space-y-4">
          <input type="hidden" id="refund-credit-id" />
          <div>
            <label class="form-label" for="refund-mode">Refund Mode <span class="text-red-500">*</span></label>
            <select id="refund-mode" class="form-input" required>
              <option value="">Select mode…</option>
              <option value="bank_transfer">Bank Transfer</option>
              <option value="upi">UPI</option>
              <option value="cheque">Cheque</option>
              <option value="cash">Cash</option>
            </select>
          </div>
          <div>
            <label class="form-label" for="refund-ref">Transaction Reference</label>
            <input type="text" id="refund-ref" class="form-input" maxlength="100"
                   placeholder="UTR, cheque no., reference…" />
          </div>
          <div>
            <label class="form-label" for="refund-notes">Notes</label>
            <textarea id="refund-notes" class="form-input" rows="2" maxlength="500"
                      placeholder="Reason or additional details…"></textarea>
          </div>
          <div class="flex gap-3 pt-2">
            <button type="submit" id="refund-submit-btn" class="btn-primary flex-1">Confirm Refund</button>
            <button type="button" id="cancel-refund-btn" class="btn-outline flex-1">Cancel</button>
          </div>
        </form>
      </div>
    </div>
  )}

  <!-- Aging Report panel (exec only) -->
  {isExec && (
    <div id="panel-aging" class="hidden">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-lg font-semibold text-text-primary">Overdue Aging Report</h2>
          <p id="aging-as-of" class="text-xs text-text-secondary mt-0.5"></p>
        </div>
        <button id="send-reminders-btn" class="btn-primary text-sm flex items-center gap-2">
          <i class="fas fa-bell" aria-hidden="true"></i> Send Reminders
        </button>
      </div>

      <!-- Bucket summary cards -->
      <div id="aging-buckets" class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6"></div>

      <!-- Dry-run preview -->
      <div id="reminder-preview" class="hidden mb-4 card-premium p-4 border border-accent-500">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-sm font-semibold text-text-primary flex items-center gap-2">
            <i class="fas fa-eye text-accent-500" aria-hidden="true"></i>
            Reminder Preview — <span id="reminder-eligible-count">0</span> eligible units
          </h3>
          <div class="flex gap-2">
            <button id="confirm-reminders-btn" class="btn-primary text-xs px-3 py-1.5">Confirm &amp; Send</button>
            <button id="cancel-reminders-btn" class="btn-ghost text-xs px-3 py-1.5">Cancel</button>
          </div>
        </div>
        <p class="text-xs text-text-secondary mb-2">
          <span id="reminder-skipped-count">0</span> units skipped (cooldown / max sends reached).
          Sending to <span id="reminder-send-count">0</span> units now.
        </p>
        <div id="reminder-eligible-list" class="max-h-48 overflow-y-auto space-y-1 text-xs"></div>
      </div>

      <!-- Aging rows table -->
      <div class="card-premium overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border-light bg-section-alt text-xs font-medium text-text-secondary">
                <th class="px-4 py-2 text-left">Unit</th>
                <th class="px-4 py-2 text-left">Billing Period</th>
                <th class="px-4 py-2 text-left">Due Date</th>
                <th class="px-4 py-2 text-right">Outstanding (₹)</th>
                <th class="px-4 py-2 text-center">Days Overdue</th>
                <th class="px-4 py-2 text-center">Reminders Sent</th>
                <th class="px-4 py-2 text-center">Bucket</th>
              </tr>
            </thead>
            <tbody id="aging-rows">
              <tr><td colspan="7" class="py-10 text-center text-text-secondary text-sm">
                <i class="fas fa-spinner fa-spin mr-2" aria-hidden="true"></i>Loading…
              </td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  )}

  <!-- Reconcile panel (exec only) -->
  {isExec && (
    <div id="panel-reconcile" class="hidden">
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-text-primary">Bulk Payment Reconciliation</h2>
        <p class="text-xs text-text-secondary mt-0.5">Paste a JSON array of payment entries to match and record against pending dues.</p>
      </div>

      <div class="card-premium p-5 mb-4">
        <label class="form-label" for="reconcile-json">
          JSON Array of Payment Entries
        </label>
        <p class="text-xs text-text-secondary mb-2">
          Each entry: <code class="bg-gray-100 px-1 rounded">&#123;"unit_number","amount","payment_date","payment_mode","reference_no?"&#125;</code>
        </p>
        <textarea id="reconcile-json" class="form-input font-mono text-xs" rows="8"
          placeholder='[
  {"unit_number":"A101","amount":3500,"payment_date":"2025-05-10","payment_mode":"upi","reference_no":"UPI12345"},
  {"unit_number":"B204","amount":3500,"payment_date":"2025-05-11","payment_mode":"neft","reference_no":"NEFT98765"}
]'></textarea>

        <div class="flex gap-3 mt-3">
          <button id="reconcile-preview-btn" class="btn-outline text-sm flex items-center gap-1.5 px-4 py-2">
            <i class="fas fa-search text-xs" aria-hidden="true"></i> Preview (Dry Run)
          </button>
          <button id="reconcile-commit-btn" class="btn-primary text-sm flex items-center gap-1.5 px-4 py-2 hidden">
            <i class="fas fa-check text-xs" aria-hidden="true"></i> Confirm &amp; Commit
          </button>
          <button id="reconcile-reset-btn" class="btn-ghost text-sm hidden">Reset</button>
        </div>
      </div>

      <!-- Preview result -->
      <div id="reconcile-preview-result" class="hidden card-premium p-5">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-sm font-semibold text-text-primary">Preview Results</h3>
          <div id="reconcile-summary-chips" class="flex gap-2 text-xs"></div>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-border-light text-text-secondary font-medium">
                <th class="px-3 py-2 text-left">#</th>
                <th class="px-3 py-2 text-left">Unit</th>
                <th class="px-3 py-2 text-left">Billing Period</th>
                <th class="px-3 py-2 text-right">Amount (₹)</th>
                <th class="px-3 py-2 text-center">Mode</th>
                <th class="px-3 py-2 text-left">Reference</th>
                <th class="px-3 py-2 text-center">Status</th>
                <th class="px-3 py-2 text-left">Note</th>
              </tr>
            </thead>
            <tbody id="reconcile-rows-body"></tbody>
          </table>
        </div>
      </div>
    </div>
  )}

  <!-- Record Payment modal (all authenticated users) -->
  <div id="payment-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl max-w-lg w-full p-6 shadow-large">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-lg font-semibold text-text-primary">Record Payment</h2>
        <button id="close-payment-modal" class="text-text-secondary hover:text-text-primary text-lg" aria-label="Close">
          <i class="fas fa-times" aria-hidden="true"></i>
        </button>
      </div>
      <div id="payment-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>

      <div class="bg-gray-50 rounded-xl p-3 mb-4">
        <div class="grid grid-cols-3 gap-2 text-center">
          <div>
            <div class="text-xs text-text-secondary">Total Due</div>
            <div class="text-sm font-semibold text-text-primary" id="pay-total-due">—</div>
          </div>
          <div>
            <div class="text-xs text-text-secondary">Already Paid</div>
            <div class="text-sm font-semibold text-secondary-500" id="pay-already-paid">—</div>
          </div>
          <div>
            <div class="text-xs text-text-secondary">Outstanding</div>
            <div class="text-sm font-bold text-red-600" id="pay-outstanding">—</div>
          </div>
        </div>
      </div>

      <form id="payment-form" class="space-y-4">
        <input type="hidden" id="pay-dues-id" name="dues_id" />

        <div>
          <label class="form-label">Amount Being Paid (₹) <span class="text-red-500">*</span></label>
          <div class="flex gap-2">
            <input type="number" id="pay-amount" name="amount" class="form-input" required
                   placeholder="Enter amount" step="0.01" min="0.01" />
            <button type="button" id="pay-full-btn"
                    class="btn-outline text-sm whitespace-nowrap px-3 flex-shrink-0">
              Pay Full
            </button>
          </div>
          <div id="partial-notice" class="hidden mt-2 p-2 bg-amber-50 border border-amber-200 rounded-lg text-sm text-amber-700">
            <i class="fas fa-info-circle mr-1" aria-hidden="true"></i>
            Partial payment — ₹<span id="remaining-amount">0</span> will remain outstanding.
            Status will be set to <strong>Partially Paid</strong>.
          </div>
          <div id="excess-notice" class="hidden mt-2 p-2 bg-blue-50 border border-blue-200 rounded-lg text-sm text-blue-700">
            <i class="fas fa-coins mr-1" aria-hidden="true"></i>
            ₹<span id="excess-amount">0</span> excess will be saved as advance credit.
          </div>
        </div>

        <div>
          <label class="form-label" for="pay-mode">Payment Mode <span class="text-red-500">*</span></label>
          <select id="pay-mode" name="payment_mode" class="form-input" required>
            <option value="">Select mode…</option>
            <option value="cash">Cash</option>
            <option value="upi">UPI</option>
            <option value="cheque">Cheque</option>
            <option value="neft">NEFT</option>
            <option value="rtgs">RTGS</option>
            <option value="online">Online</option>
          </select>
        </div>

        <div>
          <label class="form-label" for="pay-ref">Transaction Reference</label>
          <input type="text" id="pay-ref" name="transaction_ref" class="form-input"
                 placeholder="UPI ID, cheque no., reference no." maxlength="100" />
        </div>

        <div>
          <label class="form-label" for="pay-date">Payment Date</label>
          <input type="date" id="pay-date" name="paid_at" class="form-input" />
        </div>

        <div class="flex gap-3 pt-2">
          <button type="submit" id="payment-submit-btn" class="btn-primary flex-1">Record Payment</button>
          <button type="button" id="cancel-payment-btn" class="btn-outline flex-1">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <script define:vars={{ isExec, razorpayEnabled }}>
    const STATUS_STYLES = {
      pending:        { badge: 'bg-yellow-100 text-yellow-700', border: 'border-yellow-300' },
      overdue:        { badge: 'bg-red-100 text-red-700',       border: 'border-red-400' },
      paid:           { badge: 'bg-green-100 text-green-700',   border: 'border-green-300' },
      partially_paid: { badge: 'bg-blue-100 text-blue-700',     border: 'border-blue-300' },
      waived:         { badge: 'bg-gray-100 text-gray-600',     border: 'border-gray-300' },
    };

    async function loadDues() {
      const container = document.getElementById('dues-list');
      if (!container) return;
      try {
        const res = await fetch('/api/v1/finance/dues', { credentials: 'include' });
        const dues = await res.json();
        if (!dues.length) {
          container.innerHTML = '<div class="bg-white rounded-xl border border-border-light p-12 text-center"><i class="fas fa-check-circle text-4xl text-green-500 mb-3 block"></i><p class="text-text-secondary">No dues found.</p></div>';
          return;
        }
        container.innerHTML = dues.map((d) => {
          const style = STATUS_STYLES[d.status] ?? { badge: 'bg-gray-100 text-gray-600', border: 'border-gray-300' };
          return `
            <div class="bg-white rounded-xl border-l-4 border ${style.border} p-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h2 class="text-lg font-semibold text-text-primary">${d.billing_periods?.name ?? 'Maintenance Due'}</h2>
                  <p class="text-sm text-text-secondary mt-1">Unit: ${d.units?.unit_number ?? '—'} · Due: ${new Date(d.due_date).toLocaleDateString('en-IN')}</p>
                </div>
                <span class="flex-shrink-0 text-xs px-2 py-1 rounded-full font-medium ${style.badge}">${d.status.replace('_', ' ')}</span>
              </div>
              <div class="mt-4 grid grid-cols-3 gap-4 text-sm">
                <div>
                  <div class="text-text-secondary text-xs">Base Amount</div>
                  <div class="font-semibold">₹${Number(d.base_amount).toLocaleString('en-IN')}</div>
                </div>
                <div>
                  <div class="text-text-secondary text-xs">Penalty</div>
                  <div class="font-semibold ${d.penalty_amount > 0 ? 'text-red-600' : ''}">₹${Number(d.penalty_amount).toLocaleString('en-IN')}</div>
                </div>
                <div>
                  <div class="text-text-secondary text-xs">Total Due</div>
                  <div class="font-bold text-lg">₹${Number(d.total_amount).toLocaleString('en-IN')}</div>
                </div>
              </div>
              <div class="mt-4 pt-4 border-t border-border-light flex items-center gap-3 flex-wrap">
                ${d.status !== 'paid' && d.status !== 'waived' ? `
                  <button onclick="handlePay('${d.id}', ${d.total_amount}, ${d.amount_paid ?? 0})" class="btn-primary text-sm">
                    ${d.amount_paid > 0 ? `Pay ₹${Number(d.total_amount - d.amount_paid).toLocaleString('en-IN')} (Partial)` : `Pay ₹${Number(d.total_amount).toLocaleString('en-IN')}`}
                  </button>
                  ${razorpayEnabled ? `
                  <button onclick="handlePayOnline('${d.id}')" class="btn-outline text-sm flex items-center gap-1.5">
                    <i class="fas fa-credit-card text-xs" aria-hidden="true"></i>Pay Online
                  </button>` : ''}
                ` : ''}
                ${d.status === 'paid' && d.payment_id ? `
                  <a href="/api/v1/finance/payments/${d.payment_id}/receipt" target="_blank"
                    class="btn-outline text-sm flex items-center gap-1.5">
                    <i class="fas fa-receipt" aria-hidden="true"></i> Receipt
                  </a>
                  <button onclick="generateGstInvoice('${d.payment_id}')"
                    class="btn-outline text-sm flex items-center gap-1.5">
                    <i class="fas fa-file-invoice" aria-hidden="true"></i> GST Invoice
                  </button>
                ` : ''}
                ${d.status === 'paid' && !d.payment_id ? `
                  <span class="text-xs text-green-600 font-medium"><i class="fas fa-check-circle"></i> Paid</span>
                ` : ''}
              </div>
            </div>
          `;
        }).join('');
      } catch {
        container.innerHTML = '<p class="text-center text-red-600 py-12">Failed to load dues.</p>';
      }
    }

    // ── Payment modal ─────────────────────────────────────────────────────────
    let currentDuesId = null;
    const payModal      = document.getElementById('payment-modal');
    const payErrEl      = document.getElementById('payment-error');
    const payAmountEl   = document.getElementById('pay-amount');
    const payOutstandEl = document.getElementById('pay-outstanding');

    function handlePay(duesId, totalAmount, alreadyPaid = 0) {
      currentDuesId = duesId;
      const outstanding = Math.max(0, totalAmount - alreadyPaid);
      document.getElementById('pay-dues-id').value = duesId;
      document.getElementById('pay-total-due').textContent = `₹${Number(totalAmount).toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;
      document.getElementById('pay-already-paid').textContent = `₹${Number(alreadyPaid).toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;
      payOutstandEl.textContent = `₹${Number(outstanding).toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;
      payAmountEl.value = String(outstanding.toFixed(2));
      payAmountEl.max = String(totalAmount * 2);
      document.getElementById('pay-date').value = new Date().toISOString().slice(0, 10);
      document.getElementById('pay-mode').value = '';
      document.getElementById('pay-ref').value = '';
      document.getElementById('partial-notice').classList.add('hidden');
      document.getElementById('excess-notice').classList.add('hidden');
      payErrEl.classList.add('hidden');
      payModal.classList.remove('hidden');
    }

    window.handlePay = handlePay;

    document.getElementById('pay-full-btn')?.addEventListener('click', () => {
      const outstanding = parseFloat(payOutstandEl.textContent.replace(/[₹,]/g, '')) || 0;
      payAmountEl.value = String(outstanding.toFixed(2));
      document.getElementById('partial-notice').classList.add('hidden');
      document.getElementById('excess-notice').classList.add('hidden');
    });

    payAmountEl?.addEventListener('input', () => {
      const amount      = parseFloat(payAmountEl.value) || 0;
      const outstanding = parseFloat(payOutstandEl.textContent.replace(/[₹,]/g, '')) || 0;
      const partial = document.getElementById('partial-notice');
      const excess  = document.getElementById('excess-notice');
      if (amount > 0 && amount < outstanding) {
        document.getElementById('remaining-amount').textContent = (outstanding - amount).toFixed(2);
        partial.classList.remove('hidden');
        excess.classList.add('hidden');
      } else if (amount > outstanding) {
        document.getElementById('excess-amount').textContent = (amount - outstanding).toFixed(2);
        excess.classList.remove('hidden');
        partial.classList.add('hidden');
      } else {
        partial.classList.add('hidden');
        excess.classList.add('hidden');
      }
    });

    document.getElementById('close-payment-modal')?.addEventListener('click', () => payModal.classList.add('hidden'));
    document.getElementById('cancel-payment-btn')?.addEventListener('click', () => payModal.classList.add('hidden'));

    document.getElementById('payment-form')?.addEventListener('submit', async e => {
      e.preventDefault();
      if (!currentDuesId) return;
      payErrEl.classList.add('hidden');
      const btn = document.getElementById('payment-submit-btn');
      btn.disabled = true; btn.textContent = 'Recording…';

      const body = {
        amount:          parseFloat(payAmountEl.value),
        payment_mode:    document.getElementById('pay-mode').value,
        transaction_ref: document.getElementById('pay-ref').value.trim() || undefined,
        paid_at:         document.getElementById('pay-date').value || undefined,
      };

      try {
        const res = await fetch(`/api/v1/finance/dues/${currentDuesId}/pay`, {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.message ?? data.error ?? 'Payment failed');
        payModal.classList.add('hidden');
        showToast(`Payment recorded — status: ${String(data.dues_status ?? 'updated').replace('_', ' ')}.`);
        loadDues();
      } catch (err) {
        payErrEl.textContent = err.message;
        payErrEl.classList.remove('hidden');
      } finally {
        btn.disabled = false; btn.textContent = 'Record Payment';
      }
    });

    // Billing period modal (exec/admin only)
    if (isExec) {
      const modal = document.getElementById('period-modal');
      const openBtn = document.getElementById('create-period-btn');
      const closeBtn = document.getElementById('close-modal-btn');
      const cancelBtn = document.getElementById('cancel-modal-btn');
      const form = document.getElementById('period-form');
      const errEl = document.getElementById('period-error');

      openBtn?.addEventListener('click', () => modal?.classList.remove('hidden'));
      closeBtn?.addEventListener('click', () => modal?.classList.add('hidden'));
      cancelBtn?.addEventListener('click', () => modal?.classList.add('hidden'));

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        errEl.classList.add('hidden');
        const btn = document.getElementById('period-submit-btn');
        btn.disabled = true;
        btn.textContent = 'Creating…';

        const fd = new FormData(form);
        const gstRate = fd.get('gst_rate');
        const penalty = fd.get('penalty_amount');

        const res = await fetch('/api/v1/finance/dues', {
          method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: fd.get('name'),
            start_date: fd.get('start_date'),
            end_date: fd.get('end_date'),
            due_date: fd.get('due_date'),
            base_amount: parseFloat(fd.get('base_amount')),
            gst_rate: gstRate ? parseFloat(gstRate) : 0,
            penalty_amount: penalty ? parseFloat(penalty) : 0,
          }),
        });

        const data = await res.json();
        if (res.ok) {
          modal?.classList.add('hidden');
          form.reset();
          alert(`Billing period created! ${data.dues_created} dues generated.`);
          loadDues();
        } else {
          errEl.textContent = data.detail ?? data.error ?? 'Failed to create billing period.';
          errEl.classList.remove('hidden');
        }

        btn.disabled = false;
        btn.textContent = 'Generate Dues';
      });
    }

    async function generateGstInvoice(paymentId) {
      try {
        const res = await fetch('/api/v1/finance/invoices/generate', {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ payment_id: paymentId }),
        });
        const data = await res.json();
        if (!res.ok) { alert(data.error || 'Failed to generate invoice.'); return; }
        // Open invoice HTML in new tab
        const win = window.open('', '_blank');
        if (win) { win.document.write(data.html); win.document.close(); }
      } catch { alert('Network error generating invoice.'); }
    }

    window.handlePay = handlePay;
    window.generateGstInvoice = generateGstInvoice;

    // ── Tab switching ─────────────────────────────────────────────────────────
    let expensesLoaded  = false;
    let ledgerLoaded    = false;
    let agingLoaded     = false;
    let reconcileLoaded = false;
    const tabDues       = document.getElementById('tab-dues');
    const tabLedger     = document.getElementById('tab-ledger');
    const tabExpenses   = document.getElementById('tab-expenses');
    const panelDues     = document.getElementById('panel-dues');
    const panelLedger   = document.getElementById('panel-ledger');
    const panelExp      = document.getElementById('panel-expenses');

    const ACTIVE_CLS   = 'main-fin-tab px-4 py-2 text-sm font-medium text-primary-600 border-b-2 border-primary-600 -mb-px';
    const INACTIVE_CLS = 'main-fin-tab px-4 py-2 text-sm font-medium text-text-secondary hover:text-primary-600 border-b-2 border-transparent';

    const tabCredits   = document.getElementById('tab-credits');
    const panelCredits = document.getElementById('panel-credits');
    let creditsLoaded  = false;

    function activateTab(which) {
      [tabDues, tabLedger, tabExpenses, tabCredits,
       document.getElementById('tab-approvals'),
       document.getElementById('tab-aging'),
       document.getElementById('tab-reconcile')]
        .forEach(t => t?.setAttribute('class', INACTIVE_CLS));
      [panelDues, panelLedger, panelExp, panelCredits,
       document.getElementById('panel-approvals'),
       document.getElementById('panel-aging'),
       document.getElementById('panel-reconcile')]
        .forEach(p => p?.classList.add('hidden'));
      if (which === 'dues')      { tabDues?.setAttribute('class', ACTIVE_CLS);     panelDues?.classList.remove('hidden'); }
      if (which === 'ledger')    { tabLedger?.setAttribute('class', ACTIVE_CLS);   panelLedger?.classList.remove('hidden');  if (!ledgerLoaded)    { ledgerLoaded    = true; loadLedger();      } }
      if (which === 'expenses')  { tabExpenses?.setAttribute('class', ACTIVE_CLS); panelExp?.classList.remove('hidden');      if (!expensesLoaded)  { expensesLoaded  = true; loadExpenses();    } }
      if (which === 'credits')   { tabCredits?.setAttribute('class', ACTIVE_CLS);  panelCredits?.classList.remove('hidden');  if (!creditsLoaded)   { creditsLoaded   = true; loadCredits();     } }
      if (which === 'aging')     { document.getElementById('tab-aging')?.setAttribute('class', ACTIVE_CLS);     document.getElementById('panel-aging')?.classList.remove('hidden');     if (!agingLoaded)     { agingLoaded     = true; loadAging();       } }
      if (which === 'reconcile') { document.getElementById('tab-reconcile')?.setAttribute('class', ACTIVE_CLS); document.getElementById('panel-reconcile')?.classList.remove('hidden'); if (!reconcileLoaded) { reconcileLoaded  = true; initReconcile();   } }
    }

    tabDues?.addEventListener('click', () => activateTab('dues'));
    tabLedger?.addEventListener('click', () => activateTab('ledger'));
    tabExpenses?.addEventListener('click', () => activateTab('expenses'));
    tabCredits?.addEventListener('click', () => activateTab('credits'));
    document.getElementById('tab-aging')?.addEventListener('click', () => activateTab('aging'));
    document.getElementById('tab-reconcile')?.addEventListener('click', () => activateTab('reconcile'));

    // ── Member Ledger ─────────────────────────────────────────────────────────
    async function loadLedger() {
      const rowsEl = document.getElementById('ledger-rows');
      if (!rowsEl) return;
      try {
        const res = await fetch('/api/v1/finance/ledger', { credentials: 'include' });
        if (!res.ok) throw new Error('Failed to load');
        const { ledger, summary } = await res.json();

        const fmt = (n) => `₹${Math.abs(n).toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;
        const balColor = (b) => b > 0 ? 'text-red-600' : b < 0 ? 'text-secondary-500' : 'text-text-secondary';

        document.getElementById('ledger-total-dues').textContent  = fmt(summary.total_dues);
        document.getElementById('ledger-total-paid').textContent  = fmt(summary.total_paid);
        const outEl = document.getElementById('ledger-outstanding');
        outEl.textContent = fmt(summary.outstanding);
        outEl.className = `text-xl font-bold ${summary.outstanding > 0 ? 'text-red-600' : 'text-secondary-500'}`;

        if (!ledger.length) {
          rowsEl.innerHTML = '<div class="text-center py-10 text-text-secondary text-sm">No transactions yet.</div>';
          return;
        }

        rowsEl.innerHTML = ledger.map((e) => `
          <div class="grid grid-cols-12 gap-2 px-5 py-3 border-b border-border-light last:border-0 hover:bg-gray-50 text-sm">
            <div class="col-span-2 text-xs text-text-secondary">${e.date}</div>
            <div class="col-span-5 text-text-primary">
              ${e.label}
              ${e.status && e.type === 'debit' ? `<span class="ml-1 text-xs px-1.5 py-0.5 rounded-full font-medium ${e.status === 'paid' ? 'bg-green-100 text-green-700' : e.status === 'overdue' ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700'}">${e.status}</span>` : ''}
              ${e.reference ? `<div class="text-xs text-text-secondary mt-0.5">${e.reference}</div>` : ''}
            </div>
            <div class="col-span-2 text-right font-medium ${e.type === 'debit' ? 'text-red-600' : 'text-text-secondary'}">${e.type === 'debit' ? fmt(e.amount) : '—'}</div>
            <div class="col-span-2 text-right font-medium ${e.type === 'credit' ? 'text-secondary-500' : 'text-text-secondary'}">${e.type === 'credit' ? fmt(e.amount) : '—'}</div>
            <div class="col-span-1 text-right text-xs font-semibold ${balColor(e.running_balance)}">${fmt(e.running_balance)}</div>
          </div>
        `).join('');
      } catch {
        rowsEl.innerHTML = '<div class="text-center py-8 text-red-600 text-sm">Failed to load ledger.</div>';
      }
    }

    // ── Expenses ──────────────────────────────────────────────────────────────
    async function loadExpenses() {
      const list = document.getElementById('expenses-list');
      if (!list) return;
      list.innerHTML = '<div class="text-center py-8 text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';

      const from = document.getElementById('exp-from')?.value ?? '';
      const to   = document.getElementById('exp-to')?.value ?? '';
      const params = new URLSearchParams({ limit: '50' });
      if (from) params.set('from', from);
      if (to)   params.set('to', to);

      try {
        const res = await fetch(`/api/v1/finance/expenses?${params}`, { credentials: 'include' });
        const data = res.ok ? await res.json() : [];

        if (!data.length) {
          list.innerHTML = '<div class="text-center py-12 text-text-secondary"><i class="fas fa-receipt text-4xl text-primary-200 mb-3 block" aria-hidden="true"></i><p class="text-sm">No expenses recorded yet.</p></div>';
          return;
        }

        const totalNet = data.reduce((s, e) => s + Number(e.net_payable ?? 0), 0);
        list.innerHTML = `
          <div class="bg-primary-50 border border-primary-100 rounded-xl px-5 py-3 mb-4 flex items-center justify-between">
            <span class="text-sm font-medium text-primary-700">${data.length} expense${data.length !== 1 ? 's' : ''} found</span>
            <span class="text-base font-bold text-primary-700">Total Net: ₹${totalNet.toLocaleString('en-IN', { minimumFractionDigits: 2 })}</span>
          </div>
          ${data.map((e) => `
            <div class="card-premium p-4">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <h3 class="text-sm font-semibold text-text-primary truncate">${e.description}</h3>
                  <p class="text-xs text-text-secondary mt-0.5">
                    ${e.expense_categories?.name ? `<span class="font-medium">${e.expense_categories.name}</span> · ` : ''}
                    ${e.vendors?.name ? `Vendor: ${e.vendors.name} · ` : ''}
                    ${e.payment_date ? `Paid: ${new Date(e.payment_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}` : 'No payment date'}
                    ${e.bill_number ? ` · Bill: ${e.bill_number}` : ''}
                  </p>
                </div>
                <div class="text-right flex-shrink-0">
                  <p class="text-base font-bold text-text-primary">₹${Number(e.net_payable ?? e.amount).toLocaleString('en-IN', { minimumFractionDigits: 2 })}</p>
                  <p class="text-[10px] text-text-secondary">
                    ${Number(e.gst_amount ?? 0) > 0 ? `+GST ₹${Number(e.gst_amount).toFixed(2)} ` : ''}
                    ${Number(e.tds_deducted ?? 0) > 0 ? `-TDS ₹${Number(e.tds_deducted).toFixed(2)}` : ''}
                  </p>
                </div>
              </div>
            </div>
          `).join('')}
        `;
      } catch {
        list.innerHTML = '<p class="text-center text-red-600 py-8 text-sm">Failed to load expenses.</p>';
      }
    }

    if (isExec) {
      const expModal     = document.getElementById('expense-modal');
      const addExpBtn    = document.getElementById('add-expense-btn');
      const closeExpBtn  = document.getElementById('close-expense-modal');
      const cancelExpBtn = document.getElementById('cancel-expense-btn');
      const expForm      = document.getElementById('expense-form');
      const expErrEl     = document.getElementById('expense-error');

      addExpBtn?.addEventListener('click', () => expModal?.classList.remove('hidden'));
      closeExpBtn?.addEventListener('click', () => expModal?.classList.add('hidden'));
      cancelExpBtn?.addEventListener('click', () => expModal?.classList.add('hidden'));

      expForm?.addEventListener('submit', async (ev) => {
        ev.preventDefault();
        expErrEl?.classList.add('hidden');
        const btn = document.getElementById('expense-submit-btn');
        btn.disabled = true;
        btn.textContent = 'Saving…';

        const fd = new FormData(expForm);
        const body = {
          description:   fd.get('description'),
          amount:        parseFloat(String(fd.get('amount'))),
          gst_amount:    parseFloat(String(fd.get('gst_amount') ?? '0')) || 0,
          tds_deducted:  parseFloat(String(fd.get('tds_deducted') ?? '0')) || 0,
          bill_number:   fd.get('bill_number') || null,
          bill_date:     fd.get('bill_date') || null,
          payment_date:  fd.get('payment_date') || null,
        };

        const res = await fetch('/api/v1/finance/expenses', {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        const data = await res.json();
        if (res.ok) {
          expModal?.classList.add('hidden');
          expForm.reset();
          loadExpenses();
        } else {
          if (expErrEl) { expErrEl.textContent = data.message ?? data.error ?? 'Failed to save.'; expErrEl.classList.remove('hidden'); }
        }

        btn.disabled = false;
        btn.textContent = 'Save Expense';
      });
    }

    window.loadExpenses = loadExpenses;

    // ── Pay Online (Razorpay) ─────────────────────────────────────────────────
    async function handlePayOnline(duesId) {
      const btn = event?.target;
      if (btn) { btn.disabled = true; btn.textContent = 'Creating order…'; }
      try {
        const res = await fetch(`/api/v1/finance/dues/${duesId}/order`, {
          method: 'POST', credentials: 'include',
        });
        const data = await res.json();
        if (!res.ok) {
          showToast(data.message ?? data.error ?? 'Could not create order.', 'error');
          return;
        }

        // Dynamically load Razorpay script if needed
        if (!window.Razorpay) {
          await new Promise((resolve, reject) => {
            const s = document.createElement('script');
            s.src = 'https://checkout.razorpay.com/v1/checkout.js';
            s.onload = resolve;
            s.onerror = reject;
            document.head.appendChild(s);
          });
        }

        const rzp = new window.Razorpay({
          key: data.key_id,
          amount: data.amount_paise,
          currency: data.currency,
          order_id: data.order_id,
          name: 'UTA MACS',
          description: 'Maintenance Dues Payment',
          theme: { color: '#1E3A8A' },
          handler: async (response) => {
            const verRes = await fetch('/api/v1/finance/payments/razorpay-verify', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ ...response, dues_id: duesId }),
            });
            const verData = await verRes.json();
            if (verRes.ok) {
              showToast(`Payment successful! Status: ${String(verData.dues_status).replace('_', ' ')}.`, 'success');
              loadDues();
            } else {
              showToast(verData.message ?? 'Payment verification failed.', 'error');
            }
          },
        });
        rzp.open();
      } catch {
        showToast('Online payment unavailable. Please try manual payment.', 'error');
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Pay Online'; }
      }
    }

    window.handlePayOnline = handlePayOnline;

    // ── Statement Download ────────────────────────────────────────────────────
    document.getElementById('download-statement-btn')?.addEventListener('click', async function () {
      const btn = this;
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin text-xs mr-1"></i>Generating…';

      const from = document.getElementById('stmt-from')?.value ?? '';
      const to   = document.getElementById('stmt-to')?.value ?? '';
      const qs   = new URLSearchParams();
      if (from) qs.set('from', from);
      if (to)   qs.set('to', to);

      const res = await fetch(`/api/v1/finance/ledger/statement?${qs}`, { credentials: 'include' });
      const data = await res.json();
      if (res.ok && data.download_url) {
        window.open(data.download_url, '_blank');
        showToast('Statement downloaded.', 'success');
      } else {
        showToast(data.message ?? 'Failed to generate statement.', 'error');
      }
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-download text-xs mr-1"></i>Download Statement';
    });

    // ── Expense Approvals ─────────────────────────────────────────────────────
    async function loadApprovals() {
      const list = document.getElementById('approvals-list');
      if (!list) return;
      list.innerHTML = '<div class="text-center py-8 text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';
      try {
        const res = await fetch('/api/v1/finance/expenses/pending', { credentials: 'include' });
        const data = res.ok ? await res.json() : null;
        const expenses = data?.expenses ?? [];

        // Update badge
        const badge = document.getElementById('approvals-badge');
        if (badge) {
          if (expenses.length > 0) {
            badge.textContent = String(expenses.length);
            badge.classList.remove('hidden');
          } else {
            badge.classList.add('hidden');
          }
        }

        if (!expenses.length) {
          list.innerHTML = '<div class="text-center py-12 text-text-secondary"><i class="fas fa-check-circle text-4xl text-green-400 mb-3 block"></i><p class="text-sm">No pending expense approvals.</p></div>';
          return;
        }

        const fmt = (n) => `₹${Number(n).toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;
        list.innerHTML = expenses.map((e) => `
          <div class="card-premium p-4" id="exp-row-${e.id}">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold text-text-primary">${e.description}</h3>
                <p class="text-xs text-text-secondary mt-0.5">
                  ${e.expense_categories?.name ? `${e.expense_categories.name} · ` : ''}
                  ${e.bill_number ? `Bill: ${e.bill_number} · ` : ''}
                  ${e.payment_date ? new Date(e.payment_date).toLocaleDateString('en-IN') : ''}
                </p>
              </div>
              <div class="text-right flex-shrink-0">
                <p class="text-base font-bold text-text-primary">${fmt(e.net_payable ?? e.amount)}</p>
                ${Number(e.gst_amount) > 0 ? `<p class="text-[10px] text-text-secondary">incl. GST ${fmt(e.gst_amount)}</p>` : ''}
              </div>
            </div>
            ${e.can_action ? `
            <div class="mt-3 pt-3 border-t border-border-light flex items-center gap-2">
              <input type="text" id="notes-${e.id}" class="form-input text-sm flex-1" placeholder="Notes (optional)" />
              <button onclick="submitDecision('${e.id}', 'approved')" class="btn-primary text-xs px-3 py-2 flex items-center gap-1">
                <i class="fas fa-check" aria-hidden="true"></i>Approve
              </button>
              <button onclick="submitDecision('${e.id}', 'rejected')" class="bg-red-100 text-red-700 hover:bg-red-200 text-xs px-3 py-2 rounded-lg font-medium flex items-center gap-1">
                <i class="fas fa-times" aria-hidden="true"></i>Reject
              </button>
            </div>` : `
            <div class="mt-2 text-xs text-text-secondary">
              <i class="fas fa-lock mr-1" aria-hidden="true"></i>Insufficient role to action this amount tier.
            </div>`}
          </div>
        `).join('');
      } catch {
        list.innerHTML = '<p class="text-center text-red-600 py-8 text-sm">Failed to load approvals.</p>';
      }
    }

    async function submitDecision(expenseId, decision) {
      const notesEl = document.getElementById(`notes-${expenseId}`);
      const notes = notesEl?.value?.trim() || null;
      const res = await fetch(`/api/v1/finance/expenses/${expenseId}/decision`, {
        method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ decision, notes }),
      });
      const data = await res.json();
      if (res.ok) {
        showToast(`Expense ${decision}.`, decision === 'approved' ? 'success' : 'error');
        document.getElementById(`exp-row-${expenseId}`)?.remove();
        const badge = document.getElementById('approvals-badge');
        const remaining = document.querySelectorAll('[id^="exp-row-"]').length;
        if (badge && remaining === 0) { badge.classList.add('hidden'); }
      } else {
        showToast(data.message ?? 'Action failed.', 'error');
      }
    }

    window.submitDecision = submitDecision;

    // Wire approvals tab via activateTab
    if (isExec) {
      let approvalsLoaded = false;
      document.getElementById('tab-approvals')?.addEventListener('click', () => {
        activateTab('_none');
        document.getElementById('tab-approvals')?.setAttribute('class', ACTIVE_CLS);
        document.getElementById('panel-approvals')?.classList.remove('hidden');
        if (!approvalsLoaded) { approvalsLoaded = true; loadApprovals(); }
      });

      // Pre-fetch badge count on load
      fetch('/api/v1/finance/expenses/pending', { credentials: 'include' })
        .then(r => r.json())
        .then(data => {
          const n = data?.expenses?.length ?? 0;
          const badge = document.getElementById('approvals-badge');
          if (badge && n > 0) { badge.textContent = String(n); badge.classList.remove('hidden'); }
        }).catch(() => {});
    }

    // ── Credits & Refunds ─────────────────────────────────────────────────────
    async function loadCredits() {
      const list = document.getElementById('credits-list');
      if (!list) return;
      list.innerHTML = '<div class="text-center py-10 text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';

      const statusFilter = isExec ? (document.getElementById('credits-status-filter')?.value ?? '') : '';
      const qs = statusFilter ? `?status=${statusFilter}` : '';

      try {
        const res = await fetch(`/api/v1/finance/credits${qs}`, { credentials: 'include' });
        const data = res.ok ? await res.json() : null;
        const credits = data?.credits ?? [];

        const fmt = (n) => `₹${Number(n).toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;

        // Update summary
        const available = credits.filter((c) => c.status === 'available');
        const refunded  = credits.filter((c) => c.status === 'refunded');
        document.getElementById('credits-available-total').textContent = fmt(data?.available_total ?? 0);
        document.getElementById('credits-total-count').textContent = String(credits.length);
        document.getElementById('credits-refunded-count').textContent = String(refunded.length);

        // Update badge on credits tab
        const badge = document.getElementById('credits-badge');
        if (badge) {
          if (available.length > 0) { badge.textContent = String(available.length); badge.classList.remove('hidden'); }
          else { badge.classList.add('hidden'); }
        }

        if (!credits.length) {
          list.innerHTML = '<div class="text-center py-12 text-text-secondary"><i class="fas fa-coins text-4xl text-primary-200 mb-3 block"></i><p class="text-sm">No credits on record.</p></div>';
          return;
        }

        const statusBadge = (s) => {
          const map = { available: 'bg-green-100 text-green-700', refunded: 'bg-gray-100 text-gray-600', applied: 'bg-blue-100 text-blue-700' };
          return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${map[s] ?? 'bg-gray-100 text-gray-600'}">${s}</span>`;
        };

        list.innerHTML = credits.map((c) => {
          const memberInfo = isExec && c.profiles
            ? `<div class="text-xs text-text-secondary">${c.profiles.full_name}${c.profiles.units?.unit_number ? ` · Flat ${c.profiles.units.unit_number}` : ''}</div>`
            : '';
          return `
            <div class="card-premium p-4 flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-base font-bold text-secondary-500">${fmt(c.amount)}</span>
                  ${statusBadge(c.status)}
                </div>
                ${memberInfo}
                <div class="text-xs text-text-secondary mt-1">
                  ${c.notes ? `${c.notes} · ` : ''}Added ${new Date(c.created_at).toLocaleDateString('en-IN')}
                  ${c.refunded_at ? ` · Refunded ${new Date(c.refunded_at).toLocaleDateString('en-IN')}` : ''}
                </div>
              </div>
              ${isExec && c.status === 'available' ? `
              <button onclick="openRefundModal('${c.id}', '${c.profiles?.full_name ?? 'Member'}', ${c.amount})"
                      class="btn-outline text-xs px-3 py-2 flex-shrink-0 flex items-center gap-1">
                <i class="fas fa-undo text-xs" aria-hidden="true"></i>Refund
              </button>` : ''}
            </div>
          `;
        }).join('');
      } catch {
        list.innerHTML = '<p class="text-center text-red-600 py-8 text-sm">Failed to load credits.</p>';
      }
    }

    window.loadCredits = loadCredits;

    // Pre-fetch credits badge on load
    fetch('/api/v1/finance/credits?status=available', { credentials: 'include' })
      .then(r => r.json())
      .then(data => {
        const n = data?.credits?.length ?? 0;
        const badge = document.getElementById('credits-badge');
        if (badge && n > 0) { badge.textContent = String(n); badge.classList.remove('hidden'); }
      }).catch(() => {});

    // ── Refund modal (exec only) ──────────────────────────────────────────────
    if (isExec) {
      function openRefundModal(creditId, memberName, amount) {
        document.getElementById('refund-credit-id').value = creditId;
        document.getElementById('refund-member-name').textContent = memberName;
        document.getElementById('refund-amount-display').textContent =
          `₹${Number(amount).toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;
        document.getElementById('refund-error')?.classList.add('hidden');
        document.getElementById('refund-form')?.reset();
        document.getElementById('refund-modal')?.classList.remove('hidden');
      }
      window.openRefundModal = openRefundModal;

      document.getElementById('close-refund-modal')?.addEventListener('click', () =>
        document.getElementById('refund-modal')?.classList.add('hidden'));
      document.getElementById('cancel-refund-btn')?.addEventListener('click', () =>
        document.getElementById('refund-modal')?.classList.add('hidden'));

      document.getElementById('refund-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const errEl = document.getElementById('refund-error');
        errEl.classList.add('hidden');
        const btn = document.getElementById('refund-submit-btn');
        btn.disabled = true;
        btn.textContent = 'Processing…';

        const creditId = document.getElementById('refund-credit-id').value;
        const mode     = document.getElementById('refund-mode').value;
        const ref      = document.getElementById('refund-ref').value.trim();
        const notes    = document.getElementById('refund-notes').value.trim();

        const res = await fetch(`/api/v1/finance/credits/${creditId}/refund`, {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ refund_mode: mode, transaction_ref: ref || null, notes: notes || null }),
        });
        const data = await res.json();

        if (res.ok) {
          document.getElementById('refund-modal')?.classList.add('hidden');
          showToast('Refund processed successfully.', 'success');
          creditsLoaded = false;
          loadCredits();
        } else {
          errEl.textContent = data.message ?? data.error ?? 'Refund failed.';
          errEl.classList.remove('hidden');
        }
        btn.disabled = false;
        btn.textContent = 'Confirm Refund';
      });
    }

    // ── Aging Report ──────────────────────────────────────────────────────────
    async function loadAging() {
      document.getElementById('aging-rows').innerHTML =
        '<tr><td colspan="7" class="py-10 text-center text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</td></tr>';

      const res = await fetch('/api/v1/finance/dues/aging', { credentials: 'include' });
      if (!res.ok) {
        document.getElementById('aging-rows').innerHTML =
          '<tr><td colspan="7" class="py-10 text-center text-red-600 text-sm">Failed to load aging report.</td></tr>';
        return;
      }
      const data = await res.json();
      document.getElementById('aging-as-of').textContent = `As of ${data.as_of}`;

      const fmt = n => `₹${Number(n).toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;
      const buckets = data.summary.buckets;
      const b1 = data.bucket_labels.b1, b2 = data.bucket_labels.b2, b3 = data.bucket_labels.b3;

      const bucketCfg = [
        { key: '1_30',    label: `1–${b1} days`,   color: 'text-amber-600',  bg: 'bg-amber-50'  },
        { key: '31_60',   label: `${b1+1}–${b2} days`, color: 'text-orange-600', bg: 'bg-orange-50' },
        { key: '61_90',   label: `${b2+1}–${b3} days`, color: 'text-red-600',    bg: 'bg-red-50'    },
        { key: '90_plus', label: `${b3}+ days`,   color: 'text-red-800',    bg: 'bg-red-100'   },
      ];

      document.getElementById('aging-buckets').innerHTML = bucketCfg.map(b => `
        <div class="card-premium p-4">
          <p class="text-xs text-text-secondary">${b.label}</p>
          <p class="text-xl font-bold ${b.color} mt-1">${fmt(buckets[b.key]?.total ?? 0)}</p>
          <p class="text-xs text-text-secondary mt-0.5">${buckets[b.key]?.count ?? 0} unit${(buckets[b.key]?.count ?? 0) !== 1 ? 's' : ''}</p>
        </div>
      `).join('');

      const badge = document.getElementById('aging-badge');
      if (data.summary.total_overdue_units > 0) {
        badge?.classList.remove('hidden');
        if (badge) badge.textContent = String(data.summary.total_overdue_units);
      }

      const bucketColor = { '1_30': 'text-amber-600', '31_60': 'text-orange-600', '61_90': 'text-red-600', '90_plus': 'text-red-800' };
      const bucketLabel = (key) => ({ '1_30': '1–30d', '31_60': '31–60d', '61_90': '61–90d', '90_plus': '90d+' }[key] ?? key);

      if (!data.rows.length) {
        document.getElementById('aging-rows').innerHTML =
          '<tr><td colspan="7" class="py-10 text-center text-text-secondary text-sm">No overdue dues. All units are up to date.</td></tr>';
        return;
      }

      document.getElementById('aging-rows').innerHTML = data.rows.map(r => `
        <tr class="border-b border-border-light hover:bg-section-alt">
          <td class="px-4 py-2 font-medium text-text-primary">${r.block ? `${r.block} ` : ''}${r.unit_number}</td>
          <td class="px-4 py-2 text-text-secondary">${r.billing_period || '—'}</td>
          <td class="px-4 py-2 text-text-secondary">${r.due_date}</td>
          <td class="px-4 py-2 text-right font-semibold text-red-600">${fmt(r.outstanding)}</td>
          <td class="px-4 py-2 text-center font-medium ${bucketColor[r.bucket]}">${r.days_overdue}</td>
          <td class="px-4 py-2 text-center text-text-secondary">${r.reminder_sent_count}</td>
          <td class="px-4 py-2 text-center">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-red-100 ${bucketColor[r.bucket]}">${bucketLabel(r.bucket)}</span>
          </td>
        </tr>
      `).join('');
    }

    // Send reminders flow (dry-run preview → confirm)
    let _reminderDryRunData = null;
    document.getElementById('send-reminders-btn')?.addEventListener('click', async () => {
      const btn = document.getElementById('send-reminders-btn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Previewing…';
      const res = await fetch('/api/v1/finance/dues/reminders', {
        method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ dry_run: true }),
      });
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-bell mr-2"></i>Send Reminders';
      if (!res.ok) { showToast('Failed to preview reminders.', 'error'); return; }
      _reminderDryRunData = await res.json();
      document.getElementById('reminder-eligible-count').textContent = _reminderDryRunData.eligible_count;
      document.getElementById('reminder-skipped-count').textContent  = _reminderDryRunData.skipped_count;
      document.getElementById('reminder-send-count').textContent     = _reminderDryRunData.eligible_count;
      document.getElementById('reminder-eligible-list').innerHTML = (_reminderDryRunData.eligible ?? []).slice(0, 20).map(e =>
        `<div class="flex justify-between px-2 py-1 rounded bg-section-alt">
          <span class="font-medium">${e.unit_number}${e.block ? ` (${e.block})` : ''}</span>
          <span class="text-text-secondary">${e.billing_period}</span>
          <span class="text-red-600 font-semibold">₹${Number(e.outstanding).toLocaleString('en-IN', { minimumFractionDigits: 2 })}</span>
        </div>`
      ).join('') + (_reminderDryRunData.eligible?.length > 20 ? `<p class="text-center text-text-secondary py-1">…and ${_reminderDryRunData.eligible.length - 20} more</p>` : '');
      document.getElementById('reminder-preview').classList.remove('hidden');
    });

    document.getElementById('cancel-reminders-btn')?.addEventListener('click', () =>
      document.getElementById('reminder-preview').classList.add('hidden'));

    document.getElementById('confirm-reminders-btn')?.addEventListener('click', async () => {
      const btn = document.getElementById('confirm-reminders-btn');
      btn.disabled = true; btn.textContent = 'Sending…';
      const res = await fetch('/api/v1/finance/dues/reminders', {
        method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ dry_run: false }),
      });
      btn.disabled = false; btn.textContent = 'Confirm & Send';
      const data = await res.json();
      document.getElementById('reminder-preview').classList.add('hidden');
      if (res.ok) {
        showToast(`Reminders sent to ${data.sent} unit${data.sent !== 1 ? 's' : ''}.`, 'success');
        agingLoaded = false;
        loadAging();
      } else {
        showToast(data.message ?? 'Failed to send reminders.', 'error');
      }
    });

    // ── Reconcile ─────────────────────────────────────────────────────────────
    function initReconcile() {
      // Nothing to preload
    }

    document.getElementById('reconcile-preview-btn')?.addEventListener('click', async () => {
      const jsonEl = document.getElementById('reconcile-json');
      let entries;
      try { entries = JSON.parse(jsonEl.value.trim()); }
      catch { showToast('Invalid JSON — please check your input.', 'error'); return; }
      const btn = document.getElementById('reconcile-preview-btn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Previewing…';
      const res = await fetch('/api/v1/finance/payments/bulk-reconcile', {
        method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ entries, dry_run: true }),
      });
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-search mr-2"></i>Preview (Dry Run)';
      if (!res.ok) { showToast('Preview failed.', 'error'); return; }
      const data = await res.json();
      renderReconcilePreview(data, true);
    });

    document.getElementById('reconcile-commit-btn')?.addEventListener('click', async () => {
      const jsonEl = document.getElementById('reconcile-json');
      let entries;
      try { entries = JSON.parse(jsonEl.value.trim()); }
      catch { showToast('Invalid JSON.', 'error'); return; }
      const btn = document.getElementById('reconcile-commit-btn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Committing…';
      const res = await fetch('/api/v1/finance/payments/bulk-reconcile', {
        method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ entries, dry_run: false }),
      });
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-check mr-2"></i>Confirm & Commit';
      const data = await res.json();
      if (res.ok) {
        renderReconcilePreview(data, false);
        showToast(`Committed ${data.summary.committed} payment${data.summary.committed !== 1 ? 's' : ''}.`, 'success');
        document.getElementById('reconcile-commit-btn').classList.add('hidden');
        document.getElementById('reconcile-reset-btn').classList.remove('hidden');
      } else {
        showToast(data.message ?? 'Commit failed.', 'error');
      }
    });

    document.getElementById('reconcile-reset-btn')?.addEventListener('click', () => {
      document.getElementById('reconcile-json').value = '';
      document.getElementById('reconcile-preview-result').classList.add('hidden');
      document.getElementById('reconcile-commit-btn').classList.add('hidden');
      document.getElementById('reconcile-reset-btn').classList.add('hidden');
      document.getElementById('reconcile-preview-btn').classList.remove('hidden');
    });

    function renderReconcilePreview(data, showCommitBtn) {
      const s = data.summary;
      document.getElementById('reconcile-summary-chips').innerHTML = [
        `<span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-700">${s.total} total</span>`,
        `<span class="px-2 py-0.5 rounded-full bg-green-100 text-green-700">${s.matched} matched</span>`,
        `<span class="px-2 py-0.5 rounded-full bg-amber-100 text-amber-700">${s.skipped} skipped</span>`,
        `<span class="px-2 py-0.5 rounded-full bg-red-100 text-red-700">${s.failed} failed</span>`,
      ].join('');

      const statusCls = { matched: 'bg-green-100 text-green-700', skipped: 'bg-amber-100 text-amber-700', failed: 'bg-red-100 text-red-700' };
      document.getElementById('reconcile-rows-body').innerHTML = (data.rows ?? []).map(r => `
        <tr class="border-b border-border-light hover:bg-section-alt">
          <td class="px-3 py-2 text-text-secondary">${r.row_index + 1}</td>
          <td class="px-3 py-2 font-medium">${r.unit_number}</td>
          <td class="px-3 py-2 text-text-secondary">${r.billing_period ?? '—'}</td>
          <td class="px-3 py-2 text-right">₹${Number(r.amount).toLocaleString('en-IN', { minimumFractionDigits: 2 })}</td>
          <td class="px-3 py-2 text-center text-text-secondary">${r.payment_mode}</td>
          <td class="px-3 py-2 text-text-secondary">${r.reference_no ?? '—'}</td>
          <td class="px-3 py-2 text-center">
            <span class="inline-flex px-2 py-0.5 rounded-full text-[10px] font-medium ${statusCls[r.status] ?? ''}">${r.status}</span>
          </td>
          <td class="px-3 py-2 text-text-secondary">${r.error_message ?? ''}</td>
        </tr>
      `).join('');

      document.getElementById('reconcile-preview-result').classList.remove('hidden');
      if (showCommitBtn && s.matched > 0) {
        document.getElementById('reconcile-commit-btn').classList.remove('hidden');
      }
    }

    // ── TDS Certificate download ──────────────────────────────────────────────
    async function loadVendorsForTdsCert() {
      const sel = document.getElementById('tds-cert-vendor');
      if (!sel) return;
      try {
        const res = await fetch('/api/v1/finance/expenses?vendors=1', { credentials: 'include' });
        if (!res.ok) return;
        const data = await res.json();
        const vendors = (data.vendors ?? []);
        if (!vendors.length) return;
        sel.innerHTML = '<option value="">Select vendor…</option>' +
          vendors.map(v => `<option value="${v.id}">${v.name}${v.pan ? ` (${v.pan})` : ''}</option>`).join('');
      } catch { /* non-fatal */ }
    }
    loadVendorsForTdsCert();

    // Populate FY select dynamically
    (function() {
      const fyEl = document.getElementById('tds-cert-fy');
      if (!fyEl) return;
      const now = new Date();
      const cur = now.getMonth() >= 3 ? now.getFullYear() : now.getFullYear() - 1;
      fyEl.innerHTML = [cur, cur - 1, cur - 2].map(y =>
        `<option value="${y}">${y}-${String(y + 1).slice(2)}</option>`
      ).join('');
    })();

    document.getElementById('tds-cert-download-btn')?.addEventListener('click', async () => {
      const vendorId = document.getElementById('tds-cert-vendor')?.value;
      const fy       = document.getElementById('tds-cert-fy')?.value;
      const statusEl = document.getElementById('tds-cert-status');
      if (!vendorId) { showToast('Please select a vendor.', 'error'); return; }
      const btn = document.getElementById('tds-cert-download-btn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Generating…';
      if (statusEl) { statusEl.textContent = 'Generating certificate…'; statusEl.classList.remove('hidden'); }
      try {
        const res = await fetch(`/api/v1/finance/tds-report/certificate?vendor_id=${vendorId}&fy=${fy}`, { credentials: 'include' });
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          showToast(err.message ?? 'Failed to generate TDS certificate.', 'error');
          if (statusEl) statusEl.classList.add('hidden');
        } else {
          const blob = await res.blob();
          const url  = URL.createObjectURL(blob);
          const a    = document.createElement('a');
          const vendorName = document.getElementById('tds-cert-vendor')?.selectedOptions[0]?.text ?? 'vendor';
          a.href     = url;
          a.download = `TDS-Certificate-${vendorName.replace(/\s+/g, '-')}-FY${fy}-${parseInt(fy)+1}.pdf`;
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          URL.revokeObjectURL(url);
          showToast('TDS certificate downloaded.', 'success');
          if (statusEl) statusEl.classList.add('hidden');
        }
      } catch { showToast('Network error.', 'error'); if (statusEl) statusEl.classList.add('hidden'); }
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-download mr-2"></i>Download PDF';
    });

    loadDues();
  </script>
</PortalLayout>

---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const isExec = ['executive', 'admin'].includes(user.role);
---

<PortalLayout title="Finance & Dues" user={user} activeModule="finance">
  <!-- Process info panel -->
  <details class="mb-6 group rounded-xl border border-primary-100 bg-gradient-to-r from-primary-50/50 to-blue-50/20 overflow-hidden">
    <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer list-none select-none hover:bg-primary-50/60 transition-colors">
      <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-project-diagram text-white text-xs" aria-hidden="true"></i>
      </div>
      <span class="text-sm font-medium text-text-primary flex-1">Maintenance billing runs in monthly periods — dues are raised, members pay, and overdue accounts are tracked for follow-up.</span>
      <span class="text-xs text-primary-600 flex items-center gap-1.5 flex-shrink-0 font-medium">
        How it works
        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200 group-open:rotate-180" aria-hidden="true"></i>
      </span>
    </summary>
    <div class="px-5 pb-5">
      <div class="pt-4 border-t border-primary-100 space-y-4">
        <!-- Main flow -->
        <div class="process-snake-flow -mx-1 px-1">
          <div class="flex-shrink-0 w-52 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">Period Created</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">Monthly cycle opens</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-amber-300 bg-amber-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-amber-800 whitespace-nowrap">Dues Raised</p>
            <p class="text-[11px] text-amber-700 mt-0.5 whitespace-nowrap">Bills sent to members</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-green-300 bg-green-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-green-800 whitespace-nowrap">Payments Received</p>
            <p class="text-[11px] text-green-700 mt-0.5 whitespace-nowrap">Logged against unit</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-red-300 bg-red-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-red-800 whitespace-nowrap">Overdue Flagged</p>
            <p class="text-[11px] text-red-700 mt-0.5 whitespace-nowrap">Past due date</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-gray-300 bg-gray-100 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Period Closed</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">Accounts reconciled</p>
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mt-1">
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Maintenance amounts can differ by flat category (1BHK / 2BHK / 3BHK)</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-exclamation-circle text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Late payments may attract interest as per society bye-laws</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-exclamation-circle text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Finance entries above ₹10,000 require a second-level approval (see HOTO Finance for approval tiers)</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>All financial records are available in the Document Repository after period close</span>
          </div>
        </div>
      </div>
    </div>
  </details>

  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-text-primary">Finance & Dues</h1>
      <p class="text-sm text-text-secondary mt-1">{isExec ? 'Manage maintenance billing and track collections.' : 'View and pay your maintenance dues.'}</p>
    </div>
    {isExec && (
      <button id="create-period-btn" class="btn-primary text-sm flex items-center gap-2">
        <i class="fas fa-plus" aria-hidden="true"></i>
        Create Billing Period
      </button>
    )}
  </div>

  <!-- Billing period creation modal (exec/admin only) -->
  {isExec && (
    <div id="period-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div class="bg-white rounded-2xl max-w-lg w-full p-6 shadow-large">
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-lg font-semibold text-text-primary text-lg">Create Billing Period</h2>
          <button id="close-modal-btn" class="text-text-secondary hover:text-text-primary text-lg" aria-label="Close">
            <i class="fas fa-times" aria-hidden="true"></i>
          </button>
        </div>
        <div id="period-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
        <form id="period-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1">Period Name <span class="text-red-500">*</span></label>
            <input name="name" type="text" required placeholder="e.g. Q1 FY2025-26"
              class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1">Start Date <span class="text-red-500">*</span></label>
              <input name="start_date" type="date" required class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1">End Date <span class="text-red-500">*</span></label>
              <input name="end_date" type="date" required class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1">Due Date <span class="text-red-500">*</span></label>
              <input name="due_date" type="date" required class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1">Base Amount (₹) <span class="text-red-500">*</span></label>
              <input name="base_amount" type="number" required min="1" step="1" placeholder="e.g. 3000"
                class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1">GST Rate (%)</label>
              <input name="gst_rate" type="number" min="0" max="28" step="0.01" placeholder="0"
                class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1">Default Penalty (₹)</label>
              <input name="penalty_amount" type="number" min="0" step="1" placeholder="0"
                class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
          </div>
          <p class="text-xs text-text-secondary">Dues will be auto-generated for all occupied units immediately.</p>
          <div class="flex gap-3 pt-2">
            <button type="submit" id="period-submit-btn" class="btn-primary flex-1">Generate Dues</button>
            <button type="button" id="cancel-modal-btn" class="btn-outline flex-1">Cancel</button>
          </div>
        </form>
      </div>
    </div>
  )}

  <!-- Main tabs (Dues / Ledger / Expenses) — Expenses visible to exec only -->
  <div class="flex gap-2 mb-5 border-b border-border-light">
    <button id="tab-dues" class="main-fin-tab px-4 py-2 text-sm font-medium text-primary-600 border-b-2 border-primary-600 -mb-px">
      <i class="fas fa-file-invoice-dollar mr-1.5 text-xs" aria-hidden="true"></i>Dues
    </button>
    <button id="tab-ledger" class="main-fin-tab px-4 py-2 text-sm font-medium text-text-secondary hover:text-primary-600 border-b-2 border-transparent">
      <i class="fas fa-book mr-1.5 text-xs" aria-hidden="true"></i>My Ledger
    </button>
    {isExec && (
      <button id="tab-expenses" class="main-fin-tab px-4 py-2 text-sm font-medium text-text-secondary hover:text-primary-600 border-b-2 border-transparent">
        <i class="fas fa-receipt mr-1.5 text-xs" aria-hidden="true"></i>Expenses
      </button>
    )}
  </div>

  <!-- Dues panel -->
  <div id="panel-dues">
    <div id="dues-list" class="space-y-4">
      <div class="flex items-center justify-center h-32 text-text-secondary">
        <i class="fas fa-spinner fa-spin mr-2" aria-hidden="true"></i>
        Loading dues…
      </div>
    </div>
  </div>

  <!-- Ledger panel (all members) -->
  <div id="panel-ledger" class="hidden">
    <div id="ledger-summary" class="grid grid-cols-3 gap-4 mb-5">
      <div class="bg-white rounded-xl border border-border-light p-4 text-center">
        <div class="text-xs text-text-secondary mb-1">Total Billed</div>
        <div id="ledger-total-dues" class="text-xl font-bold text-text-primary">—</div>
      </div>
      <div class="bg-white rounded-xl border border-border-light p-4 text-center">
        <div class="text-xs text-text-secondary mb-1">Total Paid</div>
        <div id="ledger-total-paid" class="text-xl font-bold text-secondary-500">—</div>
      </div>
      <div class="bg-white rounded-xl border border-border-light p-4 text-center">
        <div class="text-xs text-text-secondary mb-1">Outstanding</div>
        <div id="ledger-outstanding" class="text-xl font-bold text-red-600">—</div>
      </div>
    </div>
    <div class="bg-white rounded-xl border border-border-light overflow-hidden">
      <div class="px-5 py-3 border-b border-border-light bg-gray-50 grid grid-cols-12 gap-2 text-xs font-medium text-text-secondary">
        <div class="col-span-2">Date</div>
        <div class="col-span-5">Description</div>
        <div class="col-span-2 text-right">Debit (₹)</div>
        <div class="col-span-2 text-right">Credit (₹)</div>
        <div class="col-span-1 text-right">Balance</div>
      </div>
      <div id="ledger-rows">
        <div class="text-center py-10 text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>
      </div>
    </div>
  </div>

  <!-- Expenses panel (exec only) -->
  {isExec && (
    <div id="panel-expenses" class="hidden">
      <div class="mb-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <input id="exp-from" type="date" class="form-input text-sm" style="width:150px" placeholder="From" />
          <input id="exp-to" type="date" class="form-input text-sm" style="width:150px" placeholder="To" />
          <button onclick="loadExpenses()" class="btn-outline text-sm flex items-center gap-1.5 px-3 py-2">
            <i class="fas fa-filter text-xs" aria-hidden="true"></i> Filter
          </button>
        </div>
        <button id="add-expense-btn" class="btn-primary text-sm flex items-center gap-2">
          <i class="fas fa-plus" aria-hidden="true"></i> Record Expense
        </button>
      </div>

      <div id="expenses-list" class="space-y-3">
        <div class="text-center py-10 text-text-secondary text-sm">
          <i class="fas fa-spinner fa-spin mr-2" aria-hidden="true"></i>Loading…
        </div>
      </div>

      <!-- Add expense modal -->
      <div id="expense-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl max-w-lg w-full p-6 shadow-large">
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-lg font-semibold text-text-primary">Record Expense</h2>
            <button id="close-expense-modal" class="text-text-secondary hover:text-text-primary text-lg" aria-label="Close">
              <i class="fas fa-times" aria-hidden="true"></i>
            </button>
          </div>
          <div id="expense-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
          <form id="expense-form" class="space-y-4">
            <div>
              <label class="form-label" for="exp-description">Description <span class="text-red-500">*</span></label>
              <input id="exp-description" name="description" type="text" required maxlength="500" placeholder="e.g. Lift maintenance service"
                class="form-input text-sm" />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="form-label" for="exp-amount">Amount (₹) <span class="text-red-500">*</span></label>
                <input id="exp-amount" name="amount" type="number" required min="1" step="0.01"
                  class="form-input text-sm" />
              </div>
              <div>
                <label class="form-label" for="exp-gst">GST Amount (₹)</label>
                <input id="exp-gst" name="gst_amount" type="number" min="0" step="0.01" value="0"
                  class="form-input text-sm" />
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="form-label" for="exp-tds">TDS Deducted (₹)</label>
                <input id="exp-tds" name="tds_deducted" type="number" min="0" step="0.01" value="0"
                  class="form-input text-sm" />
              </div>
              <div>
                <label class="form-label" for="exp-bill-no">Bill Number</label>
                <input id="exp-bill-no" name="bill_number" type="text" maxlength="100" placeholder="e.g. INV-2025-001"
                  class="form-input text-sm" />
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="form-label" for="exp-bill-date">Bill Date</label>
                <input id="exp-bill-date" name="bill_date" type="date" class="form-input text-sm" />
              </div>
              <div>
                <label class="form-label" for="exp-payment-date">Payment Date</label>
                <input id="exp-payment-date" name="payment_date" type="date" class="form-input text-sm" />
              </div>
            </div>
            <div class="flex gap-3 pt-2">
              <button type="submit" id="expense-submit-btn" class="btn-primary flex-1">Save Expense</button>
              <button type="button" id="cancel-expense-btn" class="btn-outline flex-1">Cancel</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  )}

  <script define:vars={{ isExec }}>
    const STATUS_STYLES = {
      pending:        { badge: 'bg-yellow-100 text-yellow-700', border: 'border-yellow-300' },
      overdue:        { badge: 'bg-red-100 text-red-700',       border: 'border-red-400' },
      paid:           { badge: 'bg-green-100 text-green-700',   border: 'border-green-300' },
      partially_paid: { badge: 'bg-blue-100 text-blue-700',     border: 'border-blue-300' },
      waived:         { badge: 'bg-gray-100 text-gray-600',     border: 'border-gray-300' },
    };

    async function loadDues() {
      const container = document.getElementById('dues-list');
      if (!container) return;
      try {
        const res = await fetch('/api/v1/finance/dues', { credentials: 'include' });
        const dues = await res.json();
        if (!dues.length) {
          container.innerHTML = '<div class="bg-white rounded-xl border border-border-light p-12 text-center"><i class="fas fa-check-circle text-4xl text-green-500 mb-3 block"></i><p class="text-text-secondary">No dues found.</p></div>';
          return;
        }
        container.innerHTML = dues.map((d) => {
          const style = STATUS_STYLES[d.status] ?? { badge: 'bg-gray-100 text-gray-600', border: 'border-gray-300' };
          return `
            <div class="bg-white rounded-xl border-l-4 border ${style.border} p-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h2 class="text-lg font-semibold text-text-primary">${d.billing_periods?.name ?? 'Maintenance Due'}</h2>
                  <p class="text-sm text-text-secondary mt-1">Unit: ${d.units?.unit_number ?? '—'} · Due: ${new Date(d.due_date).toLocaleDateString('en-IN')}</p>
                </div>
                <span class="flex-shrink-0 text-xs px-2 py-1 rounded-full font-medium ${style.badge}">${d.status.replace('_', ' ')}</span>
              </div>
              <div class="mt-4 grid grid-cols-3 gap-4 text-sm">
                <div>
                  <div class="text-text-secondary text-xs">Base Amount</div>
                  <div class="font-semibold">₹${Number(d.base_amount).toLocaleString('en-IN')}</div>
                </div>
                <div>
                  <div class="text-text-secondary text-xs">Penalty</div>
                  <div class="font-semibold ${d.penalty_amount > 0 ? 'text-red-600' : ''}">₹${Number(d.penalty_amount).toLocaleString('en-IN')}</div>
                </div>
                <div>
                  <div class="text-text-secondary text-xs">Total Due</div>
                  <div class="font-bold text-lg">₹${Number(d.total_amount).toLocaleString('en-IN')}</div>
                </div>
              </div>
              <div class="mt-4 pt-4 border-t border-border-light flex items-center gap-3 flex-wrap">
                ${d.status !== 'paid' && d.status !== 'waived' ? `
                  <button onclick="handlePay('${d.id}', ${d.total_amount})" class="btn-primary text-sm">
                    Pay ₹${Number(d.total_amount).toLocaleString('en-IN')}
                  </button>
                ` : ''}
                ${d.status === 'paid' && d.payment_id ? `
                  <a href="/api/v1/finance/payments/${d.payment_id}/receipt" target="_blank"
                    class="btn-outline text-sm flex items-center gap-1.5">
                    <i class="fas fa-receipt" aria-hidden="true"></i> Receipt
                  </a>
                  <button onclick="generateGstInvoice('${d.payment_id}')"
                    class="btn-outline text-sm flex items-center gap-1.5">
                    <i class="fas fa-file-invoice" aria-hidden="true"></i> GST Invoice
                  </button>
                ` : ''}
                ${d.status === 'paid' && !d.payment_id ? `
                  <span class="text-xs text-green-600 font-medium"><i class="fas fa-check-circle"></i> Paid</span>
                ` : ''}
              </div>
            </div>
          `;
        }).join('');
      } catch {
        container.innerHTML = '<p class="text-center text-red-600 py-12">Failed to load dues.</p>';
      }
    }

    async function handlePay(duesId, amount) {
      const mode = prompt('Payment mode (cash/upi/cheque/neft/rtgs/online):') ?? '';
      if (!mode.trim()) return;
      const ref = prompt('Transaction reference (optional):') ?? undefined;
      const res = await fetch('/api/v1/finance/payments', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
        body: JSON.stringify({ dues_id: duesId, amount, payment_mode: mode.trim(), transaction_ref: ref || undefined }),
      });
      if (res.ok) { loadDues(); }
      else { const err = await res.json(); alert(`Payment failed: ${err.detail ?? err.error}`); }
    }

    // Billing period modal (exec/admin only)
    if (isExec) {
      const modal = document.getElementById('period-modal');
      const openBtn = document.getElementById('create-period-btn');
      const closeBtn = document.getElementById('close-modal-btn');
      const cancelBtn = document.getElementById('cancel-modal-btn');
      const form = document.getElementById('period-form');
      const errEl = document.getElementById('period-error');

      openBtn?.addEventListener('click', () => modal?.classList.remove('hidden'));
      closeBtn?.addEventListener('click', () => modal?.classList.add('hidden'));
      cancelBtn?.addEventListener('click', () => modal?.classList.add('hidden'));

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        errEl.classList.add('hidden');
        const btn = document.getElementById('period-submit-btn');
        btn.disabled = true;
        btn.textContent = 'Creating…';

        const fd = new FormData(form);
        const gstRate = fd.get('gst_rate');
        const penalty = fd.get('penalty_amount');

        const res = await fetch('/api/v1/finance/dues', {
          method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: fd.get('name'),
            start_date: fd.get('start_date'),
            end_date: fd.get('end_date'),
            due_date: fd.get('due_date'),
            base_amount: parseFloat(fd.get('base_amount')),
            gst_rate: gstRate ? parseFloat(gstRate) : 0,
            penalty_amount: penalty ? parseFloat(penalty) : 0,
          }),
        });

        const data = await res.json();
        if (res.ok) {
          modal?.classList.add('hidden');
          form.reset();
          alert(`Billing period created! ${data.dues_created} dues generated.`);
          loadDues();
        } else {
          errEl.textContent = data.detail ?? data.error ?? 'Failed to create billing period.';
          errEl.classList.remove('hidden');
        }

        btn.disabled = false;
        btn.textContent = 'Generate Dues';
      });
    }

    async function generateGstInvoice(paymentId) {
      try {
        const res = await fetch('/api/v1/finance/invoices/generate', {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ payment_id: paymentId }),
        });
        const data = await res.json();
        if (!res.ok) { alert(data.error || 'Failed to generate invoice.'); return; }
        // Open invoice HTML in new tab
        const win = window.open('', '_blank');
        if (win) { win.document.write(data.html); win.document.close(); }
      } catch { alert('Network error generating invoice.'); }
    }

    window.handlePay = handlePay;
    window.generateGstInvoice = generateGstInvoice;

    // ── Tab switching (Dues / Ledger / Expenses) ─────────────────────────────
    let expensesLoaded = false;
    let ledgerLoaded   = false;
    const tabDues     = document.getElementById('tab-dues');
    const tabLedger   = document.getElementById('tab-ledger');
    const tabExpenses = document.getElementById('tab-expenses');
    const panelDues   = document.getElementById('panel-dues');
    const panelLedger = document.getElementById('panel-ledger');
    const panelExp    = document.getElementById('panel-expenses');

    const ACTIVE_CLS   = 'main-fin-tab px-4 py-2 text-sm font-medium text-primary-600 border-b-2 border-primary-600 -mb-px';
    const INACTIVE_CLS = 'main-fin-tab px-4 py-2 text-sm font-medium text-text-secondary hover:text-primary-600 border-b-2 border-transparent';

    function activateTab(which) {
      [tabDues, tabLedger, tabExpenses].forEach(t => t?.setAttribute('class', INACTIVE_CLS));
      [panelDues, panelLedger, panelExp].forEach(p => p?.classList.add('hidden'));
      if (which === 'dues')     { tabDues?.setAttribute('class', ACTIVE_CLS);     panelDues?.classList.remove('hidden'); }
      if (which === 'ledger')   { tabLedger?.setAttribute('class', ACTIVE_CLS);   panelLedger?.classList.remove('hidden'); if (!ledgerLoaded)   { ledgerLoaded   = true; loadLedger();   } }
      if (which === 'expenses') { tabExpenses?.setAttribute('class', ACTIVE_CLS); panelExp?.classList.remove('hidden');    if (!expensesLoaded) { expensesLoaded = true; loadExpenses(); } }
    }

    tabDues?.addEventListener('click', () => activateTab('dues'));
    tabLedger?.addEventListener('click', () => activateTab('ledger'));
    tabExpenses?.addEventListener('click', () => activateTab('expenses'));

    // ── Member Ledger ─────────────────────────────────────────────────────────
    async function loadLedger() {
      const rowsEl = document.getElementById('ledger-rows');
      if (!rowsEl) return;
      try {
        const res = await fetch('/api/v1/finance/ledger', { credentials: 'include' });
        if (!res.ok) throw new Error('Failed to load');
        const { ledger, summary } = await res.json();

        const fmt = (n) => `₹${Math.abs(n).toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;
        const balColor = (b) => b > 0 ? 'text-red-600' : b < 0 ? 'text-secondary-500' : 'text-text-secondary';

        document.getElementById('ledger-total-dues').textContent  = fmt(summary.total_dues);
        document.getElementById('ledger-total-paid').textContent  = fmt(summary.total_paid);
        const outEl = document.getElementById('ledger-outstanding');
        outEl.textContent = fmt(summary.outstanding);
        outEl.className = `text-xl font-bold ${summary.outstanding > 0 ? 'text-red-600' : 'text-secondary-500'}`;

        if (!ledger.length) {
          rowsEl.innerHTML = '<div class="text-center py-10 text-text-secondary text-sm">No transactions yet.</div>';
          return;
        }

        rowsEl.innerHTML = ledger.map((e) => `
          <div class="grid grid-cols-12 gap-2 px-5 py-3 border-b border-border-light last:border-0 hover:bg-gray-50 text-sm">
            <div class="col-span-2 text-xs text-text-secondary">${e.date}</div>
            <div class="col-span-5 text-text-primary">
              ${e.label}
              ${e.status && e.type === 'debit' ? `<span class="ml-1 text-xs px-1.5 py-0.5 rounded-full font-medium ${e.status === 'paid' ? 'bg-green-100 text-green-700' : e.status === 'overdue' ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700'}">${e.status}</span>` : ''}
              ${e.reference ? `<div class="text-xs text-text-secondary mt-0.5">${e.reference}</div>` : ''}
            </div>
            <div class="col-span-2 text-right font-medium ${e.type === 'debit' ? 'text-red-600' : 'text-text-secondary'}">${e.type === 'debit' ? fmt(e.amount) : '—'}</div>
            <div class="col-span-2 text-right font-medium ${e.type === 'credit' ? 'text-secondary-500' : 'text-text-secondary'}">${e.type === 'credit' ? fmt(e.amount) : '—'}</div>
            <div class="col-span-1 text-right text-xs font-semibold ${balColor(e.running_balance)}">${fmt(e.running_balance)}</div>
          </div>
        `).join('');
      } catch {
        rowsEl.innerHTML = '<div class="text-center py-8 text-red-600 text-sm">Failed to load ledger.</div>';
      }
    }

    // ── Expenses ──────────────────────────────────────────────────────────────
    async function loadExpenses() {
      const list = document.getElementById('expenses-list');
      if (!list) return;
      list.innerHTML = '<div class="text-center py-8 text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';

      const from = document.getElementById('exp-from')?.value ?? '';
      const to   = document.getElementById('exp-to')?.value ?? '';
      const params = new URLSearchParams({ limit: '50' });
      if (from) params.set('from', from);
      if (to)   params.set('to', to);

      try {
        const res = await fetch(`/api/v1/finance/expenses?${params}`, { credentials: 'include' });
        const data = res.ok ? await res.json() : [];

        if (!data.length) {
          list.innerHTML = '<div class="text-center py-12 text-text-secondary"><i class="fas fa-receipt text-4xl text-primary-200 mb-3 block" aria-hidden="true"></i><p class="text-sm">No expenses recorded yet.</p></div>';
          return;
        }

        const totalNet = data.reduce((s, e) => s + Number(e.net_payable ?? 0), 0);
        list.innerHTML = `
          <div class="bg-primary-50 border border-primary-100 rounded-xl px-5 py-3 mb-4 flex items-center justify-between">
            <span class="text-sm font-medium text-primary-700">${data.length} expense${data.length !== 1 ? 's' : ''} found</span>
            <span class="text-base font-bold text-primary-700">Total Net: ₹${totalNet.toLocaleString('en-IN', { minimumFractionDigits: 2 })}</span>
          </div>
          ${data.map((e) => `
            <div class="card-premium p-4">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <h3 class="text-sm font-semibold text-text-primary truncate">${e.description}</h3>
                  <p class="text-xs text-text-secondary mt-0.5">
                    ${e.expense_categories?.name ? `<span class="font-medium">${e.expense_categories.name}</span> · ` : ''}
                    ${e.vendors?.name ? `Vendor: ${e.vendors.name} · ` : ''}
                    ${e.payment_date ? `Paid: ${new Date(e.payment_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}` : 'No payment date'}
                    ${e.bill_number ? ` · Bill: ${e.bill_number}` : ''}
                  </p>
                </div>
                <div class="text-right flex-shrink-0">
                  <p class="text-base font-bold text-text-primary">₹${Number(e.net_payable ?? e.amount).toLocaleString('en-IN', { minimumFractionDigits: 2 })}</p>
                  <p class="text-[10px] text-text-secondary">
                    ${Number(e.gst_amount ?? 0) > 0 ? `+GST ₹${Number(e.gst_amount).toFixed(2)} ` : ''}
                    ${Number(e.tds_deducted ?? 0) > 0 ? `-TDS ₹${Number(e.tds_deducted).toFixed(2)}` : ''}
                  </p>
                </div>
              </div>
            </div>
          `).join('')}
        `;
      } catch {
        list.innerHTML = '<p class="text-center text-red-600 py-8 text-sm">Failed to load expenses.</p>';
      }
    }

    if (isExec) {
      const expModal     = document.getElementById('expense-modal');
      const addExpBtn    = document.getElementById('add-expense-btn');
      const closeExpBtn  = document.getElementById('close-expense-modal');
      const cancelExpBtn = document.getElementById('cancel-expense-btn');
      const expForm      = document.getElementById('expense-form');
      const expErrEl     = document.getElementById('expense-error');

      addExpBtn?.addEventListener('click', () => expModal?.classList.remove('hidden'));
      closeExpBtn?.addEventListener('click', () => expModal?.classList.add('hidden'));
      cancelExpBtn?.addEventListener('click', () => expModal?.classList.add('hidden'));

      expForm?.addEventListener('submit', async (ev) => {
        ev.preventDefault();
        expErrEl?.classList.add('hidden');
        const btn = document.getElementById('expense-submit-btn');
        btn.disabled = true;
        btn.textContent = 'Saving…';

        const fd = new FormData(expForm);
        const body = {
          description:   fd.get('description'),
          amount:        parseFloat(String(fd.get('amount'))),
          gst_amount:    parseFloat(String(fd.get('gst_amount') ?? '0')) || 0,
          tds_deducted:  parseFloat(String(fd.get('tds_deducted') ?? '0')) || 0,
          bill_number:   fd.get('bill_number') || null,
          bill_date:     fd.get('bill_date') || null,
          payment_date:  fd.get('payment_date') || null,
        };

        const res = await fetch('/api/v1/finance/expenses', {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        const data = await res.json();
        if (res.ok) {
          expModal?.classList.add('hidden');
          expForm.reset();
          loadExpenses();
        } else {
          if (expErrEl) { expErrEl.textContent = data.message ?? data.error ?? 'Failed to save.'; expErrEl.classList.remove('hidden'); }
        }

        btn.disabled = false;
        btn.textContent = 'Save Expense';
      });
    }

    window.loadExpenses = loadExpenses;
    loadDues();
  </script>
</PortalLayout>

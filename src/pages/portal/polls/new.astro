---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
const isPrivileged = user && (['executive', 'admin'].includes(user.role) ||
  ['executive', 'secretary', 'president'].includes(user.portalRole ?? '') || user.isAdmin);
if (!isPrivileged) return Astro.redirect('/portal/polls');
---

<PortalLayout title="Create Poll" user={user} activeModule="polls">
  <div class="mb-6">
    <nav class="text-sm text-text-secondary mb-3">
      <a href="/portal/polls" class="hover:text-primary-600">Polls</a>
      <span class="mx-2">›</span><span class="text-text-primary">New Poll</span>
    </nav>
    <h1 class="text-2xl font-bold text-text-primary">Create Poll</h1>
  </div>

  <div class="max-w-2xl">
    <div id="error-banner" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>

    <form id="poll-form" class="bg-white rounded-xl border border-border-light p-6 space-y-5">
      <div>
        <label for="title" class="block text-sm font-medium text-text-primary mb-1.5">Question <span class="text-red-500">*</span></label>
        <input type="text" id="title" name="title" required maxlength="300"
          placeholder="e.g. What is your preferred timing for yoga sessions?"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <div>
        <label for="description" class="block text-sm font-medium text-text-primary mb-1.5">Description</label>
        <textarea id="description" name="description" rows="2"
          placeholder="Additional context (optional)"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none"></textarea>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="poll_type" class="block text-sm font-medium text-text-primary mb-1.5">Poll Type</label>
          <select id="poll_type" name="poll_type"
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
            <option value="single_choice">Single Choice</option>
            <option value="multiple_choice">Multiple Choice</option>
            <option value="yes_no">Yes / No</option>
            <option value="rating">Rating (1–5 stars)</option>
          </select>
        </div>
        <div>
          <label for="result_visibility" class="block text-sm font-medium text-text-primary mb-1.5">Show Results</label>
          <select id="result_visibility" name="result_visibility"
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
            <option value="after_close">After poll closes</option>
            <option value="after_vote">After member votes</option>
            <option value="executive_only">Exec only</option>
          </select>
        </div>
      </div>

      <!-- max_choices — only shown for multiple_choice -->
      <div id="max-choices-row" class="hidden">
        <label for="max_choices" class="block text-sm font-medium text-text-primary mb-1.5">Max choices per member</label>
        <input type="number" id="max_choices" name="max_choices" min="2" max="20" value="2"
          class="w-40 px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
        <p class="text-xs text-text-secondary mt-1">Members may select up to this many options.</p>
      </div>

      <div>
        <label for="ends_at" class="block text-sm font-medium text-text-primary mb-1.5">Closing Date & Time</label>
        <input type="datetime-local" id="ends_at" name="ends_at"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <!-- Options builder — hidden for rating type -->
      <div id="options-section">
        <div class="flex items-center justify-between mb-2">
          <label class="text-sm font-medium text-text-primary">Options <span class="text-red-500">*</span></label>
          <button type="button" id="add-option" class="text-xs text-primary-600 hover:underline flex items-center gap-1">
            <i class="fas fa-plus" aria-hidden="true"></i> Add option
          </button>
        </div>
        <div id="options-list" class="space-y-2">
          <div class="flex items-center gap-2">
            <input type="text" name="option" placeholder="Option 1" required
              class="flex-1 px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            <button type="button" onclick="this.parentElement.remove()" class="text-red-400 hover:text-red-600 px-2" aria-label="Remove option">
              <i class="fas fa-times" aria-hidden="true"></i>
            </button>
          </div>
          <div class="flex items-center gap-2">
            <input type="text" name="option" placeholder="Option 2" required
              class="flex-1 px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            <button type="button" onclick="this.parentElement.remove()" class="text-red-400 hover:text-red-600 px-2" aria-label="Remove option">
              <i class="fas fa-times" aria-hidden="true"></i>
            </button>
          </div>
        </div>
      </div>

      <!-- Rating type hint — shown instead of options builder -->
      <div id="rating-hint" class="hidden p-4 bg-blue-50 border border-primary-100 rounded-xl text-sm text-primary-700">
        <i class="fas fa-star mr-2 text-amber-400" aria-hidden="true"></i>
        Rating options 1–5 will be auto-generated. Members select one star value.
      </div>

      <div class="flex items-center gap-6">
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="is_anonymous" class="rounded border-border-light text-primary-600" />
          <span>Anonymous voting</span>
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="one_vote_per_unit" class="rounded border-border-light text-primary-600" />
          <span>One vote per unit</span>
        </label>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <button type="submit" id="submit-btn" class="btn-primary flex items-center gap-2">
          <i class="fas fa-vote-yea" aria-hidden="true"></i>
          <span id="btn-text">Launch Poll</span>
          <span id="btn-spinner" class="hidden"><i class="fas fa-spinner fa-spin" aria-hidden="true"></i></span>
        </button>
        <a href="/portal/polls" class="btn-outline">Cancel</a>
      </div>
    </form>
  </div>

  <script>
    const pollTypeEl = document.getElementById('poll_type') as HTMLSelectElement;
    const optionsSection = document.getElementById('options-section')!;
    const ratingHint = document.getElementById('rating-hint')!;
    const maxChoicesRow = document.getElementById('max-choices-row')!;

    function onTypeChange() {
      const type = pollTypeEl.value;
      const isRating = type === 'rating';
      const isMulti = type === 'multiple_choice';
      const isYesNo = type === 'yes_no';

      optionsSection.classList.toggle('hidden', isRating);
      ratingHint.classList.toggle('hidden', !isRating);
      maxChoicesRow.classList.toggle('hidden', !isMulti);

      if (isYesNo) {
        const inputs = document.querySelectorAll<HTMLInputElement>('input[name="option"]');
        if (inputs[0]) inputs[0].value = 'Yes';
        if (inputs[1]) inputs[1].value = 'No';
      }
    }

    pollTypeEl?.addEventListener('change', onTypeChange);

    document.getElementById('add-option')?.addEventListener('click', () => {
      const list = document.getElementById('options-list')!;
      const count = list.querySelectorAll('input[name="option"]').length + 1;
      const div = document.createElement('div');
      div.className = 'flex items-center gap-2';
      div.innerHTML = `
        <input type="text" name="option" placeholder="Option ${count}"
          class="flex-1 px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
        <button type="button" onclick="this.parentElement.remove()" class="text-red-400 hover:text-red-600 px-2" aria-label="Remove option">
          <i class="fas fa-times" aria-hidden="true"></i>
        </button>`;
      list.appendChild(div);
    });

    const form = document.getElementById('poll-form') as HTMLFormElement;
    const errorBanner = document.getElementById('error-banner')!;
    const btnText = document.getElementById('btn-text')!;
    const btnSpinner = document.getElementById('btn-spinner')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const pollType = fd.get('poll_type') as string;
      const isRating = pollType === 'rating';

      let options: string[] = [];
      if (!isRating) {
        options = Array.from(document.querySelectorAll<HTMLInputElement>('input[name="option"]'))
          .map(i => i.value.trim()).filter(Boolean);
        if (options.length < 2) {
          errorBanner.textContent = 'Please provide at least 2 options.';
          errorBanner.classList.remove('hidden');
          return;
        }
      }

      errorBanner.classList.add('hidden');
      btnText.classList.add('hidden');
      btnSpinner.classList.remove('hidden');
      submitBtn.disabled = true;

      const endsAt = fd.get('ends_at') as string;
      const maxChoicesRaw = fd.get('max_choices');
      const maxChoices = maxChoicesRaw ? parseInt(String(maxChoicesRaw)) : 1;

      const res = await fetch('/api/v1/polls', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
        body: JSON.stringify({
          title: fd.get('title'),
          description: fd.get('description') || null,
          poll_type: pollType,
          options: isRating ? [] : options,
          result_visibility: fd.get('result_visibility'),
          max_choices: pollType === 'multiple_choice' ? maxChoices : 1,
          is_anonymous: (document.getElementById('is_anonymous') as HTMLInputElement).checked,
          one_vote_per_unit: (document.getElementById('one_vote_per_unit') as HTMLInputElement).checked,
          ends_at: endsAt ? new Date(endsAt).toISOString() : null,
        }),
      });

      const data = await res.json();
      if (res.ok) {
        window.location.href = '/portal/polls';
      } else {
        errorBanner.textContent = data.detail ?? data.error ?? 'Failed to create poll.';
        errorBanner.classList.remove('hidden');
        btnText.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
        submitBtn.disabled = false;
      }
    });
  </script>
</PortalLayout>

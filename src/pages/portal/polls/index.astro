---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
---

<PortalLayout title="Polls & Voting" user={user} activeModule="polls">
  <!-- Process info panel -->
  <details class="mb-6 group rounded-xl border border-primary-100 bg-gradient-to-r from-primary-50/50 to-blue-50/20 overflow-hidden">
    <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer list-none select-none hover:bg-primary-50/60 transition-colors">
      <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-project-diagram text-white text-xs" aria-hidden="true"></i>
      </div>
      <span class="text-sm font-medium text-text-primary flex-1">Polls allow the committee to gather resident opinion — results are non-binding advisory votes unless designated as a formal resolution.</span>
      <span class="text-xs text-primary-600 flex items-center gap-1.5 flex-shrink-0 font-medium">
        How it works
        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200 group-open:rotate-180" aria-hidden="true"></i>
      </span>
    </summary>
    <div class="px-5 pb-5">
      <div class="pt-4 border-t border-primary-100 space-y-4">
        <div class="process-snake-flow -mx-1 px-1">
          <div class="flex-shrink-0 w-52 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">Created</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">Options defined</p>
          </div>
          <div class="flex-shrink-0 w-52 rounded-lg border border-amber-300 bg-amber-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-amber-800 whitespace-nowrap">Open</p>
            <p class="text-[11px] text-amber-700 mt-0.5 whitespace-nowrap">Voting window active</p>
          </div>
          <div class="flex-shrink-0 w-52 rounded-lg border border-green-300 bg-green-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-green-800 whitespace-nowrap">Closed</p>
            <p class="text-[11px] text-green-700 mt-0.5 whitespace-nowrap">Window ends</p>
          </div>
          <div class="flex-shrink-0 w-52 rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Tallied</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">Results computed</p>
          </div>
          <div class="flex-shrink-0 w-52 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">Published</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">Outcome shared</p>
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mt-1">
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>All active members are eligible to vote — one vote per registered unit</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Anonymous voting is configurable at poll creation time</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-exclamation-circle text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Formal resolutions (binding votes) require the Board Resolution workflow in HOTO Finance</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Poll results are stored and linked to the relevant AGM or meeting minutes</span>
          </div>
        </div>
      </div>
    </div>
  </details>

  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-text-primary">Polls & Voting</h1>
      <p class="text-sm text-text-secondary mt-1">Participate in community decisions.</p>
    </div>
    {['executive','admin'].includes(user.role) && (
      <a href="/portal/polls/new" class="btn-primary text-sm flex items-center gap-2">
        <i class="fas fa-plus" aria-hidden="true"></i>
        Create Poll
      </a>
    )}
  </div>

  <div id="polls-list" class="space-y-6">
    <div class="flex items-center justify-center h-32 text-text-secondary">
      <i class="fas fa-spinner fa-spin mr-2" aria-hidden="true"></i>
      Loading polls…
    </div>
  </div>

  <script define:vars={{ userId: user.id, isExec: ['executive','admin'].includes(user.role) || user.isAdmin }}>
    // Preserve poll data for re-rendering after votes
    const pollsStore = {};

    function showToast(message, type = 'success') {
      const toast = document.createElement('div');
      const color = type === 'success' ? 'bg-secondary-500' : 'bg-red-500';
      toast.className = `fixed bottom-6 right-6 z-50 px-4 py-3 rounded-xl shadow-large text-sm font-medium text-white transform translate-y-4 opacity-0 transition-all duration-300 ${color}`;
      toast.textContent = message;
      document.body.appendChild(toast);
      requestAnimationFrame(() => toast.classList.remove('translate-y-4', 'opacity-0'));
      setTimeout(() => {
        toast.classList.add('translate-y-4', 'opacity-0');
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    function renderResultBars(options, results) {
      return options
        .slice()
        .sort((a, b) => a.order_index - b.order_index)
        .map((opt) => {
          const r = (results.options ?? []).find((o) => o.id === opt.id) ?? { vote_count: 0, percentage: 0 };
          const isMyVote = opt.id === results.voted_option_id;
          return `
            <div class="mb-3">
              <div class="flex items-center justify-between text-sm mb-1.5">
                <span class="font-medium ${isMyVote ? 'text-primary-600' : 'text-text-primary'} flex items-center gap-1.5">
                  ${isMyVote ? '<i class="fas fa-check-circle text-primary-600 text-xs"></i>' : ''}
                  ${opt.option_text}
                </span>
                <span class="text-xs text-text-secondary ml-2 flex-shrink-0">${r.vote_count} (${r.percentage}%)</span>
              </div>
              <div class="w-full bg-gray-100 rounded-full h-2">
                <div class="h-2 rounded-full transition-all duration-500 ${isMyVote ? 'bg-primary-600' : 'bg-primary-300'}" style="width:${r.percentage}%"></div>
              </div>
            </div>
          `;
        })
        .join('');
    }

    function renderVoteButtons(options, pollId, isOpen) {
      return options
        .slice()
        .sort((a, b) => a.order_index - b.order_index)
        .map((opt) => `
          <button
            onclick="castVote('${pollId}', '${opt.id}')"
            class="w-full text-left px-4 py-3 rounded-lg border border-border-light hover:border-primary-600 hover:bg-primary-50 transition-colors text-sm font-medium text-text-primary mb-2 last:mb-0"
            ${!isOpen ? 'disabled' : ''}
          >
            ${opt.option_text}
          </button>
        `)
        .join('');
    }

    function renderPollCard(p, results) {
      const isOpen = !p.ends_at || new Date(p.ends_at) > new Date();
      const options = p.poll_options ?? [];
      const hasVoted = results?.has_voted;
      const resultsAvailable = results?.results_available;

      const optionsHTML = hasVoted && resultsAvailable
        ? renderResultBars(options, results)
        : renderVoteButtons(options, p.id, isOpen);

      return `
        <div class="bg-white rounded-xl border border-border-light p-5" id="poll-${p.id}">
          <div class="flex items-start justify-between gap-4 mb-3">
            <div class="flex-1 min-w-0">
              <h2 class="text-lg font-semibold text-text-primary">${p.title}</h2>
              ${p.description ? `<p class="text-sm text-text-secondary mt-1">${p.description}</p>` : ''}
            </div>
            <div class="flex items-center gap-2 flex-shrink-0">
              <span class="text-xs px-2 py-1 rounded-full font-medium ${isOpen ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600'}">
                ${isOpen ? 'Active' : 'Closed'}
              </span>
              ${isExec ? `<button onclick="exportPoll('${p.id}', event)" class="text-xs btn-ghost px-2 py-1 flex items-center gap-1 text-text-secondary hover:text-primary-600" title="Export PDF results"><i class="fas fa-file-pdf text-xs"></i></button>` : ''}
            </div>
          </div>
          ${p.ends_at ? `<p class="text-xs text-text-secondary mb-4">Closes: ${new Date(p.ends_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}</p>` : ''}
          <div class="poll-options" id="poll-options-${p.id}">
            ${optionsHTML}
          </div>
          ${hasVoted && resultsAvailable
            ? `<p class="text-xs text-text-secondary mt-3 text-center">${results.total_votes} vote${results.total_votes !== 1 ? 's' : ''} total</p>`
            : ''}
          ${hasVoted && !isOpen
            ? `<p class="text-xs text-amber-600 mt-2 text-center"><i class="fas fa-lock mr-1"></i>Poll closed</p>`
            : ''}
          ${isExec && isOpen
            ? `<div class="mt-3 pt-3 border-t border-border-light flex justify-end">
                 <button onclick="closePoll('${p.id}')" class="text-xs text-red-500 hover:text-red-700 flex items-center gap-1.5 transition-colors">
                   <i class="fas fa-stop-circle"></i> Close poll
                 </button>
               </div>`
            : ''}
        </div>
      `;
    }

    async function loadPolls() {
      const container = document.getElementById('polls-list');
      if (!container) return;
      try {
        const res = await fetch('/api/v1/polls', { credentials: 'include' });
        const polls = await res.json();

        if (!polls.length) {
          container.innerHTML = '<p class="text-center text-text-secondary py-12">No active polls at this time.</p>';
          return;
        }

        polls.forEach((p) => { pollsStore[p.id] = p; });

        // Fetch results for all polls in parallel
        const resultMap = {};
        await Promise.all(polls.map(async (p) => {
          try {
            const r = await fetch(`/api/v1/polls/${p.id}/results`, { credentials: 'include' });
            if (r.ok) resultMap[p.id] = await r.json();
          } catch {}
        }));

        container.innerHTML = polls.map((p) => renderPollCard(p, resultMap[p.id])).join('');
      } catch {
        container.innerHTML = '<p class="text-center text-red-600 py-12">Failed to load polls.</p>';
      }
    }

    async function castVote(pollId, optionId) {
      // Disable all vote buttons in this poll while submitting
      const pollEl = document.getElementById(`poll-${pollId}`);
      pollEl?.querySelectorAll('button[onclick^="castVote"]').forEach((b) => { b.disabled = true; });

      const res = await fetch(`/api/v1/polls/${pollId}/vote`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ option_id: optionId }),
      });
      const data = await res.json();

      if (res.ok) {
        showToast('Your vote has been recorded. Thank you!');
        // Fetch results and show bars
        try {
          const rRes = await fetch(`/api/v1/polls/${pollId}/results`, { credentials: 'include' });
          if (rRes.ok) {
            const results = await rRes.json();
            const optionsEl = document.getElementById(`poll-options-${pollId}`);
            if (optionsEl && results.results_available) {
              const poll = pollsStore[pollId];
              optionsEl.innerHTML = renderResultBars(poll?.poll_options ?? [], results);
              // Append vote total below options
              const totalEl = document.createElement('p');
              totalEl.className = 'text-xs text-text-secondary mt-3 text-center';
              totalEl.textContent = `${results.total_votes} vote${results.total_votes !== 1 ? 's' : ''} total`;
              optionsEl.after(totalEl);
            }
          }
        } catch {}
      } else {
        showToast(data.detail ?? data.error ?? 'Voting failed.', 'error');
        pollEl?.querySelectorAll('button[onclick^="castVote"]').forEach((b) => { b.disabled = false; });
      }
    }

    async function closePoll(pollId) {
      if (!confirm('Close this poll now? Members will no longer be able to vote.')) return;
      const res = await fetch(`/api/v1/polls/${pollId}/close`, {
        method: 'POST', credentials: 'include',
      });
      if (res.ok) {
        showToast('Poll closed successfully.');
        loadPolls();
      } else {
        const d = await res.json().catch(() => ({}));
        showToast(d.message ?? 'Failed to close poll.', 'error');
      }
    }

    async function exportPoll(pollId, event) {
      const btn = event?.currentTarget;
      if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin text-xs"></i>'; }
      try {
        const res = await fetch(`/api/v1/polls/${pollId}/export`, { credentials: 'include' });
        const data = await res.json();
        if (!res.ok) throw new Error(data.message ?? 'Export failed');
        window.open(data.signed_url, '_blank');
      } catch (err) {
        showToast(err.message ?? 'Failed to export poll results.', 'error');
      } finally {
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-file-pdf text-xs"></i>'; }
      }
    }

    window.castVote = castVote;
    window.closePoll = closePoll;
    window.exportPoll = exportPoll;
    loadPolls();
  </script>
</PortalLayout>

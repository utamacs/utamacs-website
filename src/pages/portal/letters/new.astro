---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
if (!['executive', 'admin'].includes(user.role)) return Astro.redirect('/portal/letters');

const preselectedTemplate = Astro.url.searchParams.get('template') ?? '';
---

<PortalLayout title="Generate Letter" user={user} activeModule="letters">

  <!-- Carlito font for live preview -->
  <style>
    @font-face {
      font-family: 'Carlito';
      src: url('/fonts/Carlito-Regular.ttf') format('truetype');
      font-weight: 400;
    }
    @font-face {
      font-family: 'Carlito';
      src: url('/fonts/Carlito-Bold.ttf') format('truetype');
      font-weight: 700;
    }
    @font-face {
      font-family: 'Carlito';
      src: url('/fonts/Carlito-Italic.ttf') format('truetype');
      font-style: italic;
    }
    @font-face {
      font-family: 'Carlito';
      src: url('/fonts/Carlito-BoldItalic.ttf') format('truetype');
      font-weight: 700;
      font-style: italic;
    }

    /* Letter preview styles mirroring exact A4 letterhead layout */
    #letter-preview {
      font-family: 'Carlito', 'Calibri', sans-serif;
      font-size: 11pt;
      line-height: 1.45;
      color: #111827;
      background: white;
    }
    .lh-header { display: flex; align-items: flex-start; gap: 0; border-bottom: 2px solid #1a2a6c; padding-bottom: 10px; margin-bottom: 16px; }
    .lh-logo-block { flex: 0 0 auto; max-width: 220px; }
    .lh-logo-block img { max-height: 95px; width: auto; }
    .lh-divider { width: 2px; background: #c8a84b; margin: 0 18px; align-self: stretch; }
    .lh-center-block { flex: 1; }
    .lh-center-block .society-name { font-size: 20pt; font-weight: 700; color: #1a2a6c; letter-spacing: 1px; }
    .lh-center-block .tagline { font-size: 8pt; letter-spacing: 3px; color: #1a2a6c; margin-top: 2px; }
    .lh-center-block .reg-no { font-size: 8pt; color: #c8a84b; margin-top: 6px; display: flex; align-items: center; gap: 6px; }
    .lh-center-block .reg-no::before, .lh-center-block .reg-no::after { content: ''; flex: 1; height: 1px; background: #c8a84b; }
    .lh-right-block { flex: 0 0 220px; text-align: right; }
    .lh-right-block .address { font-size: 8.5pt; font-weight: 700; line-height: 1.4; color: #1a2a6c; }
    .lh-right-block .committee { margin-top: 8px; }
    .lh-right-block .committee-row { display: flex; justify-content: flex-end; align-items: baseline; gap: 6px; font-size: 8.5pt; margin-top: 3px; }
    .lh-right-block .committee-role { color: #c8a84b; font-weight: 700; }
    .lh-right-block .committee-name { font-weight: 700; color: #1a2a6c; }
    .lh-body { padding: 0; }
    .lh-date { margin-bottom: 18px; }
    .lh-to { margin-bottom: 14px; white-space: pre-line; }
    .lh-subject { margin-bottom: 14px; }
    .lh-subject strong { font-weight: 700; }
    .lh-salutation { margin-bottom: 18px; }
    .lh-message { margin-bottom: 28px; white-space: pre-wrap; text-align: justify; }
    .lh-closing { margin-bottom: 60px; }
    .lh-signatures { display: flex; gap: 20px; margin-bottom: 20px; }
    .lh-sig-block { flex: 1; }
    .lh-sig-role { color: #c8a84b; font-weight: 700; font-size: 10pt; }
    .lh-sig-society { font-size: 10pt; color: #1a2a6c; }
    .lh-footer { border-top: 2px solid #1a2a6c; padding-top: 8px; display: flex; justify-content: space-between; font-size: 8pt; color: #374151; }
    .lh-footer-item { display: flex; align-items: center; gap: 5px; }
    .lh-subseq-header { font-size: 11pt; font-weight: 700; color: #1a2a6c; border-bottom: 1px solid #e5e7eb; padding-bottom: 6px; margin-bottom: 14px; }
    .lh-page-num { text-align: right; font-size: 8pt; color: #6b7280; margin-top: 4px; }
  </style>

  <div class="mb-5">
    <nav class="text-sm text-text-secondary mb-2">
      <a href="/portal/letters" class="hover:text-primary-600">Letters</a>
      <span class="mx-2">›</span>
      <span class="text-text-primary">Generate Letter</span>
    </nav>
    <h1 class="text-2xl font-bold text-text-primary">Generate Letter</h1>
    <p class="text-sm text-text-secondary mt-1">Fill in the details below. The preview updates live.</p>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">

    <!-- ── LEFT: Form ── -->
    <div class="space-y-5">

      <!-- Template selector -->
      <div class="bg-white rounded-xl border border-border-light p-5">
        <label class="block text-sm font-semibold text-text-primary mb-2">
          <i class="fas fa-file-alt text-primary-600 mr-1"></i> Letterhead Template
        </label>
        <select id="template-select" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-600">
          <option value="">Loading templates…</option>
        </select>
      </div>

      <!-- Internal title (for archive only) -->
      <div class="bg-white rounded-xl border border-border-light p-5">
        <label class="block text-sm font-semibold text-text-primary mb-2">
          <i class="fas fa-tag text-primary-600 mr-1"></i> Internal Title <span class="text-red-500">*</span>
          <span class="text-xs font-normal text-text-secondary ml-1">(used for file name in archive)</span>
        </label>
        <input id="f-title" type="text" required placeholder="e.g. Notice to GHMC regarding road repair"
          class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <!-- Dynamic fields (rendered based on template) -->
      <div class="bg-white rounded-xl border border-border-light p-5" id="dynamic-fields-section">
        <h3 class="text-sm font-semibold text-text-primary mb-3">
          <i class="fas fa-edit text-primary-600 mr-1"></i> Letter Content
        </h3>
        <div id="dynamic-fields" class="space-y-4">
          <div class="text-sm text-text-secondary">Select a template to see fields.</div>
        </div>
      </div>

      <!-- Signature selection -->
      <div class="bg-white rounded-xl border border-border-light p-5">
        <h3 class="text-sm font-semibold text-text-primary mb-3">
          <i class="fas fa-pen-nib text-primary-600 mr-1"></i> Signatories
        </h3>
        <p class="text-xs text-text-secondary mb-3">Select who should appear in the signature block. Columns reflow automatically.</p>
        <div id="signature-options" class="space-y-2">
          <div class="text-sm text-text-secondary">Select a template to see signatories.</div>
        </div>
      </div>

      <!-- Action buttons -->
      <div class="bg-white rounded-xl border border-border-light p-5 space-y-3">
        <div class="grid grid-cols-2 gap-3">
          <button id="btn-pdf" class="btn-primary text-sm py-2.5 flex items-center justify-center gap-2" disabled>
            <i class="fas fa-file-pdf"></i> Download PDF
          </button>
          <button id="btn-docx" class="btn-outline text-sm py-2.5 flex items-center justify-center gap-2" disabled>
            <i class="fas fa-file-word"></i> Download DOCX
          </button>
        </div>
        <button id="btn-save" class="w-full btn-primary text-sm py-2.5 flex items-center justify-center gap-2 bg-green-600 hover:bg-green-700 border-green-600" disabled>
          <i class="fas fa-cloud-upload-alt"></i> Save to Archive (GitHub)
        </button>
        <p class="text-xs text-text-secondary text-center">Saving commits both PDF and DOCX to the private letters repository.</p>
      </div>
    </div>

    <!-- ── RIGHT: Live Preview ── -->
    <div>
      <div class="sticky top-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-semibold text-text-primary">Live Preview</span>
          <span class="text-xs text-text-secondary bg-gray-100 px-2 py-1 rounded">A4 · Carlito 11pt</span>
        </div>
        <!-- A4 aspect ratio container -->
        <div class="bg-gray-200 rounded-xl p-3 overflow-auto max-h-[85vh]">
          <div id="letter-preview-wrap"
            style="width:794px; min-height:1123px; background:white; padding:72px 57px 57px; box-shadow:0 2px 16px rgba(0,0,0,0.15); transform-origin:top left;"
            class="rounded-sm">
            <div id="letter-preview">
              <p class="text-text-secondary text-sm text-center mt-40">Select a template and fill in the fields to see a live preview.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="toast" class="hidden fixed bottom-6 right-6 px-4 py-2.5 rounded-lg shadow-large text-sm z-50 text-white max-w-sm"></div>

  <!-- pdfmake + docx loaded via CDN to avoid complex bundling with fonts -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js" crossorigin="anonymous"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.min.js" crossorigin="anonymous"></script>

  <script define:vars={{ preselectedTemplate }}>
    // ── State ─────────────────────────────────────────────────────────────────
    let currentTemplate = null;
    let carlitoBoldB64 = null;
    let carlitoRegB64 = null;
    let carlitoItalicB64 = null;
    let carlitoBoldItalicB64 = null;
    let logoB64 = null;

    // ── Font loading ──────────────────────────────────────────────────────────
    async function loadFontB64(url) {
      try {
        const res = await fetch(url);
        if (!res.ok) return null;
        const buf = await res.arrayBuffer();
        const bytes = new Uint8Array(buf);
        let binary = '';
        for (let i = 0; i < bytes.byteLength; i++) binary += String.fromCharCode(bytes[i]);
        return btoa(binary);
      } catch { return null; }
    }

    async function loadLogoB64() {
      try {
        const res = await fetch('/UTA-MACS-Logo.png');
        if (!res.ok) return null;
        const buf = await res.arrayBuffer();
        const bytes = new Uint8Array(buf);
        let binary = '';
        for (let i = 0; i < bytes.byteLength; i++) binary += String.fromCharCode(bytes[i]);
        return 'data:image/png;base64,' + btoa(binary);
      } catch { return null; }
    }

    async function initFonts() {
      [carlitoRegB64, carlitoBoldB64, carlitoItalicB64, carlitoBoldItalicB64, logoB64] = await Promise.all([
        loadFontB64('/fonts/Carlito-Regular.ttf'),
        loadFontB64('/fonts/Carlito-Bold.ttf'),
        loadFontB64('/fonts/Carlito-Italic.ttf'),
        loadFontB64('/fonts/Carlito-BoldItalic.ttf'),
        loadLogoB64(),
      ]);

      if (carlitoRegB64 && carlitoBoldB64) {
        pdfMake.vfs['Carlito-Regular.ttf'] = carlitoRegB64;
        pdfMake.vfs['Carlito-Bold.ttf'] = carlitoBoldB64;
        if (carlitoItalicB64) pdfMake.vfs['Carlito-Italic.ttf'] = carlitoItalicB64;
        if (carlitoBoldItalicB64) pdfMake.vfs['Carlito-BoldItalic.ttf'] = carlitoBoldItalicB64;
        pdfMake.fonts = pdfMake.fonts ?? {};
        pdfMake.fonts.Carlito = {
          normal: 'Carlito-Regular.ttf',
          bold: 'Carlito-Bold.ttf',
          italics: carlitoItalicB64 ? 'Carlito-Italic.ttf' : 'Carlito-Regular.ttf',
          bolditalics: carlitoBoldItalicB64 ? 'Carlito-BoldItalic.ttf' : 'Carlito-Bold.ttf',
        };
      }
    }

    // ── Template loading ──────────────────────────────────────────────────────
    async function loadTemplates() {
      const sel = document.getElementById('template-select');
      const res = await fetch('/api/v1/letters/templates', { credentials: 'include' });
      const templates = res.ok ? await res.json() : [];
      sel.innerHTML = templates.map(t =>
        `<option value="${t.id}" ${t.id === preselectedTemplate || t.is_default ? 'selected' : ''}>${t.name}${t.is_default ? ' (Default)' : ''}</option>`
      ).join('');
      if (templates.length) loadTemplateDetails(sel.value);
    }

    async function loadTemplateDetails(id) {
      if (!id) return;
      const res = await fetch(`/api/v1/letters/templates/${id}`, { credentials: 'include' });
      if (!res.ok) return;
      currentTemplate = await res.json();
      renderDynamicFields();
      renderSignatureOptions();
      updatePreview();
      enableButtons();
    }

    // ── Dynamic fields rendering ──────────────────────────────────────────────
    function renderDynamicFields() {
      const container = document.getElementById('dynamic-fields');
      if (!currentTemplate) { container.innerHTML = '<div class="text-sm text-text-secondary">Select a template.</div>'; return; }

      const fields = (currentTemplate.letterhead_dynamic_fields ?? []).sort((a, b) => a.display_order - b.display_order);
      container.innerHTML = fields.map(f => {
        const id = `df-${f.field_key}`;
        const req = f.is_required ? '<span class="text-red-500">*</span>' : '';
        let input;
        if (f.field_type === 'date') {
          input = `<input id="${id}" type="date" ${f.is_required ? 'required' : ''}
            class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 font-[Carlito,Calibri,sans-serif]" />`;
        } else if (f.field_type === 'textarea' || f.field_type === 'richtext') {
          input = `<textarea id="${id}" rows="4" placeholder="${f.placeholder ?? ''}" ${f.is_required ? 'required' : ''}
            class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 font-[Carlito,Calibri,sans-serif] resize-y"></textarea>`;
        } else {
          input = `<input id="${id}" type="text" placeholder="${f.placeholder ?? ''}" ${f.is_required ? 'required' : ''}
            class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 font-[Carlito,Calibri,sans-serif]" />`;
        }
        return `<div>
          <label class="block text-sm font-medium text-text-primary mb-1">${f.display_label} ${req}</label>
          ${input}
        </div>`;
      }).join('');

      // Set today's date for date fields
      document.querySelectorAll('input[type="date"][id^="df-"]').forEach(el => {
        if (!el.value) el.value = new Date().toISOString().slice(0, 10);
      });

      // Live preview on any input change
      container.querySelectorAll('input,textarea,select').forEach(el => {
        el.addEventListener('input', updatePreview);
      });
    }

    // ── Signature options ─────────────────────────────────────────────────────
    function renderSignatureOptions() {
      const container = document.getElementById('signature-options');
      if (!currentTemplate) { container.innerHTML = '<div class="text-sm text-text-secondary">Select a template.</div>'; return; }

      const signatories = (currentTemplate.letterhead_committee_members ?? [])
        .filter(m => m.show_in_signature)
        .sort((a, b) => a.display_order - b.display_order);

      container.innerHTML = signatories.map(m => `
        <label class="flex items-center gap-3 p-2.5 rounded-lg border border-border-light hover:bg-gray-50 cursor-pointer">
          <input type="checkbox" class="sig-check rounded text-primary-600" value="${m.id}"
            data-name="${m.name}" data-designation="${m.designation}" checked />
          <div>
            <div class="text-sm font-medium text-text-primary">${m.name}</div>
            <div class="text-xs text-text-secondary">${m.designation}</div>
          </div>
        </label>
      `).join('');

      container.querySelectorAll('.sig-check').forEach(el => el.addEventListener('change', updatePreview));
    }

    // ── Collect current field values ──────────────────────────────────────────
    function getFieldValues() {
      const values = {};
      if (!currentTemplate) return values;
      (currentTemplate.letterhead_dynamic_fields ?? []).forEach(f => {
        const el = document.getElementById(`df-${f.field_key}`);
        if (el) values[f.field_key] = el.value;
      });
      return values;
    }

    function getSelectedSignatories() {
      return Array.from(document.querySelectorAll('.sig-check:checked')).map(el => ({
        id: el.value,
        name: el.dataset.name,
        designation: el.dataset.designation,
      }));
    }

    // ── Live HTML preview ─────────────────────────────────────────────────────
    function formatDate(iso) {
      if (!iso) return '';
      const d = new Date(iso);
      return d.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
    }

    function updatePreview() {
      if (!currentTemplate) return;
      const t = currentTemplate;
      const vals = getFieldValues();
      const sigs = getSelectedSignatories();
      const headerMembers = (t.letterhead_committee_members ?? [])
        .filter(m => m.show_in_header)
        .sort((a, b) => a.display_order - b.display_order);

      const sigCols = sigs.length === 1 ? 'justify-start' : sigs.length === 2 ? 'gap-16' : '';
      const dateStr = vals.date ? formatDate(vals.date) : formatDate(new Date().toISOString());

      document.getElementById('letter-preview').innerHTML = `
        <!-- Header -->
        <div class="lh-header">
          <div class="lh-logo-block">
            <img src="/UTA-MACS-Logo.png" alt="Logo" onerror="this.style.display='none'" />
          </div>
          <div class="lh-divider"></div>
          <div class="lh-center-block">
            <div class="society-name">${t.society_name}</div>
            <div class="tagline">M A C S</div>
            <div class="tagline">${t.society_tagline}</div>
            <div class="reg-no">Reg No: ${t.society_reg_no}</div>
          </div>
          <div class="lh-right-block">
            <div class="address">${t.society_address_line1}<br>${t.society_address_line2}<br>${t.society_address_line3}</div>
            <div class="committee">
              ${headerMembers.map(m => `
                <div class="committee-row">
                  <span class="committee-role">${m.designation}</span>
                  <span class="committee-name">${m.name}</span>
                </div>`).join('')}
            </div>
          </div>
        </div>

        <!-- Body -->
        <div class="lh-body">
          <div class="lh-date">${dateStr}</div>
          ${vals.to ? `<div class="lh-to"><strong>To</strong><br>${vals.to.replace(/\n/g,'<br>')}</div>` : ''}
          ${vals.subject ? `<div class="lh-subject"><strong>Subject:</strong> ${vals.subject}</div>` : ''}
          ${vals.tosalutation ? `<div class="lh-salutation">Dear ${vals.tosalutation}</div>` : ''}
          <div class="lh-message">${(vals.message ?? '').replace(/\n/g,'<br>') || '<span style="color:#9ca3af">[Message body will appear here]</span>'}</div>
          <div class="lh-closing">
            <div>${t.closing_line1}</div>
            <div>${t.closing_line2}</div>
          </div>

          <!-- Signature block -->
          <div class="lh-signatures ${sigCols}">
            ${sigs.map(s => `
              <div class="lh-sig-block">
                <div style="height:40px; border-bottom:1px solid #d1d5db; margin-bottom:4px;"></div>
                <div class="lh-sig-role">${s.designation}</div>
                <div class="lh-sig-society">${t.society_name}</div>
              </div>`).join('')}
          </div>
        </div>

        <!-- Footer -->
        <div class="lh-footer">
          <div class="lh-footer-item">🌐 ${t.footer_website}</div>
          <div class="lh-footer-item">📞 ${t.footer_phone}</div>
          <div class="lh-footer-item">✉ ${t.footer_email}</div>
        </div>
        <div class="lh-page-num">1</div>
      `;
    }

    // ── Enable/disable action buttons ─────────────────────────────────────────
    function enableButtons() {
      ['btn-pdf','btn-docx','btn-save'].forEach(id => {
        const btn = document.getElementById(id);
        if (btn) btn.disabled = false;
      });
    }

    // ── PDF generation (pdfmake) ──────────────────────────────────────────────
    function buildPdfDefinition(asBase64) {
      const t = currentTemplate;
      const vals = getFieldValues();
      const sigs = getSelectedSignatories();
      const headerMembers = (t.letterhead_committee_members ?? []).filter(m => m.show_in_header).sort((a, b) => a.display_order - b.display_order);
      const dateStr = vals.date ? formatDate(vals.date) : formatDate(new Date().toISOString());
      const fontName = (carlitoRegB64 && carlitoBoldB64) ? 'Carlito' : 'Roboto';

      // Signature columns — reflow
      const sigCount = sigs.length;
      const sigTableBody = [sigs.map(() => ({ text: '', border:[false,false,false,true], borderColor:['','','','#d1d5db'], margin:[0,0,0,4] }))];
      const sigRoleRow = sigs.map(s => ({ text: s.designation, color:'#c8a84b', bold:true, fontSize:9, border:[false,false,false,false] }));
      const sigNameRow = sigs.map(s => ({ text: t.society_name, fontSize:9, color:'#1a2a6c', border:[false,false,false,false] }));
      sigTableBody.push(sigRoleRow, sigNameRow);

      function buildHeader(currentPage) {
        if (currentPage === 1) {
          return {
            margin: [57,36,57,0],
            stack: [
              {
                columns: [
                  logoB64 ? { image: logoB64, width:120, margin:[0,0,0,0] } : { text: t.society_name, fontSize:14, bold:true, color:'#1a2a6c' },
                  { canvas:[{ type:'line', x1:0, y1:0, x2:0, y2:85, lineWidth:2, lineColor:'#c8a84b' }], width:12 },
                  {
                    stack: [
                      { text:'URBAN TRILLA', fontSize:18, bold:true, color:'#1a2a6c', characterSpacing:1 },
                      { text:'M A C S', fontSize:18, bold:true, color:'#1a2a6c', characterSpacing:4 },
                      { text: t.society_tagline, fontSize:7.5, color:'#1a2a6c', characterSpacing:2 },
                      { canvas:[{ type:'line', x1:0, y1:4, x2:180, y2:4, lineWidth:0.5, lineColor:'#c8a84b' }], margin:[0,4,0,2] },
                      { text:`Reg No: ${t.society_reg_no}`, fontSize:7.5, color:'#c8a84b' },
                    ],
                    width:'*',
                  },
                  {
                    stack: [
                      { text: t.society_address_line1, bold:true, color:'#1a2a6c', fontSize:8.5, alignment:'right' },
                      { text: t.society_address_line2, bold:true, color:'#1a2a6c', fontSize:8.5, alignment:'right' },
                      { text: t.society_address_line3, bold:true, color:'#1a2a6c', fontSize:8.5, alignment:'right' },
                      ...headerMembers.map(m => ({
                        columns: [
                          { text: m.designation, color:'#c8a84b', bold:true, fontSize:8, alignment:'right', width:'*' },
                          { text: `  ${m.name}`, bold:true, color:'#1a2a6c', fontSize:8, alignment:'right', width:'auto' },
                        ],
                        columnGap: 4,
                        margin:[0,2,0,0],
                      })),
                    ],
                    width:180,
                    alignment:'right',
                  },
                ],
                columnGap: 6,
              },
              { canvas:[{ type:'line', x1:0, y1:4, x2:680, y2:4, lineWidth:2, lineColor:'#1a2a6c' }], margin:[0,6,0,0] },
            ],
          };
        } else {
          return {
            margin: [57,28,57,0],
            stack: [
              { text: t.subsequent_page_header, bold:true, color:'#1a2a6c', fontSize:10 },
              { canvas:[{ type:'line', x1:0, y1:4, x2:680, y2:4, lineWidth:1, lineColor:'#e5e7eb' }], margin:[0,4,0,0] },
            ],
          };
        }
      }

      function buildFooter(currentPage) {
        return {
          margin: [57,0,57,18],
          stack: [
            { canvas:[{ type:'line', x1:0, y1:0, x2:680, y2:0, lineWidth:2, lineColor:'#1a2a6c' }], margin:[0,0,0,4] },
            {
              columns: [
                { text:`🌐 ${t.footer_website}`, fontSize:8 },
                { text:`📞 ${t.footer_phone}`, fontSize:8, alignment:'center' },
                { text:`✉ ${t.footer_email}`, fontSize:8, alignment:'right' },
              ],
            },
            { text: String(currentPage), fontSize:7.5, color:'#6b7280', alignment:'right', margin:[0,2,0,0] },
          ],
        };
      }

      return {
        pageSize: 'A4',
        pageMargins: [57, 155, 57, 72],
        defaultStyle: { font: fontName, fontSize: 11, lineHeight: 1.45, color: '#111827' },
        header: buildHeader,
        footer: buildFooter,
        content: [
          { text: dateStr, margin:[0,0,0,16] },
          vals.to ? { stack:[ { text:'To', bold:true }, { text: vals.to, margin:[0,2,0,0] } ], margin:[0,0,0,14] } : null,
          vals.subject ? { text:[{ text:'Subject: ', bold:true }, vals.subject], margin:[0,0,0,14] } : null,
          vals.tosalutation ? { text:`Dear ${vals.tosalutation}`, margin:[0,0,0,18] } : null,
          { text: vals.message ?? '', margin:[0,0,0,28], alignment:'justify' },
          { text: t.closing_line1, margin:[0,0,0,4] },
          { text: t.closing_line2, margin:[0,0,0,56] },
          sigCount > 0 ? {
            table: {
              widths: Array(sigCount).fill('*'),
              body: sigTableBody,
            },
            layout: 'noBorders',
            margin:[0,0,0,20],
          } : null,
        ].filter(Boolean),
      };
    }

    async function generatePdfBase64() {
      return new Promise((resolve, reject) => {
        try {
          const docDef = buildPdfDefinition(true);
          pdfMake.createPdf(docDef).getBase64(resolve);
        } catch (e) { reject(e); }
      });
    }

    async function downloadPdf() {
      const title = document.getElementById('f-title').value.trim() || 'letter';
      const docDef = buildPdfDefinition(false);
      pdfMake.createPdf(docDef).download(`${title}.pdf`);
    }

    // ── DOCX generation ────────────────────────────────────────────────────────
    async function generateDocxBase64() {
      const t = currentTemplate;
      const vals = getFieldValues();
      const sigs = getSelectedSignatories();
      const headerMembers = (t.letterhead_committee_members ?? []).filter(m => m.show_in_header).sort((a, b) => a.display_order - b.display_order);
      const dateStr = vals.date ? formatDate(vals.date) : formatDate(new Date().toISOString());

      const { Document, Paragraph, TextRun, Table, TableRow, TableCell, AlignmentType,
              HeadingLevel, BorderStyle, WidthType, Packer, Header, Footer,
              PageNumber, NumberOfPages, ImageRun, ShadingType } = await import('docx');

      const NAVY = '1a2a6c';
      const GOLD = 'c8a84b';
      const BORDER_NONE = { style: BorderStyle.NONE, size: 0, color: 'FFFFFF' };

      function textRun(text, opts) {
        return new TextRun({ text: String(text ?? ''), font: 'Carlito', size: 22, ...opts });
      }
      function para(runs, alignment, spacing) {
        return new Paragraph({ children: Array.isArray(runs) ? runs : [runs], alignment, spacing: spacing ?? { after: 0 } });
      }

      const bodyContent = [];

      // Date
      bodyContent.push(para(textRun(dateStr), AlignmentType.LEFT, { after: 200 }));

      // To
      if (vals.to) {
        bodyContent.push(para(textRun('To', { bold: true }), AlignmentType.LEFT, { after: 40 }));
        vals.to.split('\n').forEach(line => bodyContent.push(para(textRun(line), AlignmentType.LEFT, { after: 40 })));
        bodyContent.push(para(textRun(''), AlignmentType.LEFT, { after: 120 }));
      }

      // Subject
      if (vals.subject) {
        bodyContent.push(new Paragraph({
          children: [textRun('Subject: ', { bold: true }), textRun(vals.subject)],
          spacing: { after: 200 },
        }));
      }

      // Salutation
      if (vals.tosalutation) {
        bodyContent.push(para(textRun(`Dear ${vals.tosalutation}`), AlignmentType.LEFT, { after: 200 }));
      }

      // Message
      (vals.message ?? '').split('\n').forEach(line => {
        bodyContent.push(para(textRun(line), AlignmentType.JUSTIFIED, { after: 100 }));
      });
      bodyContent.push(para(textRun(''), AlignmentType.LEFT, { after: 200 }));

      // Closing
      bodyContent.push(para(textRun(t.closing_line1), AlignmentType.LEFT, { after: 80 }));
      bodyContent.push(para(textRun(t.closing_line2), AlignmentType.LEFT, { after: 800 }));

      // Signatures
      if (sigs.length > 0) {
        const sigCols = Array(sigs.length).fill(Math.floor(9360 / sigs.length));
        const sigTable = new Table({
          width: { size: 100, type: WidthType.PERCENTAGE },
          rows: [
            new TableRow({ children: sigs.map(() => new TableCell({
              borders: { top: BORDER_NONE, left: BORDER_NONE, right: BORDER_NONE, bottom: { style: BorderStyle.SINGLE, size: 4, color: 'd1d5db' } },
              children: [para(textRun(''), AlignmentType.LEFT, { before: 560 })],
              width: { size: sigCols[0], type: WidthType.DXA },
            })) }),
            new TableRow({ children: sigs.map(s => new TableCell({
              borders: { top: BORDER_NONE, left: BORDER_NONE, right: BORDER_NONE, bottom: BORDER_NONE },
              children: [para(textRun(s.designation, { bold: true, color: GOLD, size: 18 }), AlignmentType.LEFT, { after: 40 })],
            })) }),
            new TableRow({ children: sigs.map(() => new TableCell({
              borders: { top: BORDER_NONE, left: BORDER_NONE, right: BORDER_NONE, bottom: BORDER_NONE },
              children: [para(textRun(t.society_name, { color: NAVY, size: 18 }), AlignmentType.LEFT)],
            })) }),
          ],
        });
        bodyContent.push(sigTable);
      }

      const footerPara = new Footer({
        children: [
          new Paragraph({
            border: { top: { style: BorderStyle.SINGLE, size: 6, color: NAVY, space: 4 } },
            children: [
              textRun(`🌐 ${t.footer_website}    📞 ${t.footer_phone}    ✉ ${t.footer_email}`, { size: 16, color: '374151' }),
            ],
            spacing: { after: 40 },
          }),
          new Paragraph({
            children: [textRun('Page ', { size: 14, color: '6b7280' }), new PageNumber(), textRun(' of ', { size: 14, color: '6b7280' }), new NumberOfPages()],
            alignment: AlignmentType.RIGHT,
          }),
        ],
      });

      const doc = new Document({
        sections: [{
          properties: {
            page: {
              margin: { top: 2200, bottom: 1100, left: 910, right: 910 },
            },
          },
          headers: {
            default: new Header({
              children: [
                new Paragraph({
                  border: { bottom: { style: BorderStyle.SINGLE, size: 6, color: NAVY, space: 4 } },
                  children: [textRun(`${t.society_name} — ${t.society_tagline}`, { bold: true, color: NAVY, size: 24 })],
                  spacing: { after: 80 },
                }),
                new Paragraph({
                  children: [textRun(`Reg No: ${t.society_reg_no} | ${t.society_address_line1} ${t.society_address_line2} ${t.society_address_line3}`, { size: 16, color: '374151' })],
                  spacing: { after: 80 },
                }),
                new Paragraph({
                  children: headerMembers.map(m => textRun(`${m.designation}: ${m.name}   `, { size: 16, color: NAVY, bold: true })),
                  spacing: { after: 60 },
                }),
              ],
            }),
          },
          footers: { default: footerPara },
          children: bodyContent,
        }],
      });

      const buffer = await Packer.toBuffer(doc);
      const bytes = new Uint8Array(buffer);
      let binary = '';
      for (let i = 0; i < bytes.byteLength; i++) binary += String.fromCharCode(bytes[i]);
      return btoa(binary);
    }

    async function downloadDocx() {
      const { Packer } = await import('docx');
      const title = document.getElementById('f-title').value.trim() || 'letter';
      const b64 = await generateDocxBase64();
      const binary = atob(b64);
      const bytes = new Uint8Array(binary.length);
      for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
      const blob = new Blob([bytes], { type: 'application/vnd.openxmlformats-officedocument.wordprocessingml.document' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = `${title}.docx`;
      document.body.appendChild(a); a.click();
      document.body.removeChild(a); URL.revokeObjectURL(url);
    }

    // ── Save to GitHub ────────────────────────────────────────────────────────
    async function saveToArchive() {
      const title = document.getElementById('f-title').value.trim();
      if (!title) { showToast('Enter an internal title before saving', true); return; }
      if (!currentTemplate) { showToast('Select a template first', true); return; }

      const btn = document.getElementById('btn-save');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generating & Saving…';

      try {
        const [pdf_base64, docx_base64] = await Promise.all([generatePdfBase64(), generateDocxBase64()]);
        const vals = getFieldValues();
        const sigs = getSelectedSignatories();

        const res = await fetch('/api/v1/letters', {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            template_id: currentTemplate.id,
            title,
            subject: vals.subject ?? null,
            recipient: vals.to ?? null,
            field_values: vals,
            signatures_used: sigs.map(s => s.designation),
            pdf_base64,
            docx_base64,
          }),
        });

        if (res.ok) {
          showToast('Letter saved to GitHub archive!', false);
          setTimeout(() => window.location.href = '/portal/letters', 1800);
        } else {
          const d = await res.json();
          showToast(d.error ?? 'Save failed', true);
          btn.disabled = false;
          btn.innerHTML = '<i class="fas fa-cloud-upload-alt"></i> Save to Archive (GitHub)';
        }
      } catch (e) {
        showToast('Error generating files: ' + e.message, true);
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-cloud-upload-alt"></i> Save to Archive (GitHub)';
      }
    }

    function showToast(msg, isError) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = `fixed bottom-6 right-6 px-4 py-2.5 rounded-lg shadow-large text-sm z-50 text-white max-w-sm ${isError ? 'bg-red-600' : 'bg-green-600'}`;
      setTimeout(() => t.classList.add('hidden'), 4000);
    }

    // ── Wire up events ────────────────────────────────────────────────────────
    document.getElementById('template-select').addEventListener('change', e => loadTemplateDetails(e.target.value));
    document.getElementById('f-title').addEventListener('input', updatePreview);
    document.getElementById('btn-pdf').addEventListener('click', downloadPdf);
    document.getElementById('btn-docx').addEventListener('click', downloadDocx);
    document.getElementById('btn-save').addEventListener('click', saveToArchive);

    // ── Init ──────────────────────────────────────────────────────────────────
    initFonts();
    loadTemplates();
  </script>
</PortalLayout>

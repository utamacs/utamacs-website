---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
if (!['executive', 'admin'].includes(user.role)) return Astro.redirect('/portal/letters');

const preselectedTemplate = Astro.url.searchParams.get('template') ?? '';
---

<PortalLayout title="Generate Letter" user={user} activeModule="letters">

  <!-- Carlito font for live preview -->
  <style is:global>
    @font-face { font-family:'Carlito'; src:url('/fonts/Carlito-Regular.ttf') format('truetype'); font-weight:400; }
    @font-face { font-family:'Carlito'; src:url('/fonts/Carlito-Bold.ttf') format('truetype'); font-weight:700; }
    @font-face { font-family:'Carlito'; src:url('/fonts/Carlito-Italic.ttf') format('truetype'); font-style:italic; }
    @font-face { font-family:'Carlito'; src:url('/fonts/Carlito-BoldItalic.ttf') format('truetype'); font-weight:700; font-style:italic; }

    /* ─── A4 letter preview — exact replica of the UTA MACS letterhead ─── */
    #letter-preview {
      font-family: 'Carlito', 'Calibri', sans-serif;
      font-size: 11pt;
      line-height: 1.45;
      color: #111827;
    }

    /* HEADER: logo image (left) + address/committee (right) */
    .lh-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 0;
    }

    /* Logo — full branded image, height sized to match right-column content */
    .lh-logo-col {
      flex: 0 0 auto;
    }
    .lh-logo-col img {
      height: 160px;
      width: auto;
      display: block;
    }

    /* Right column: address + committee */
    .lh-right-col {
      flex: 0 0 210px;
      padding-top: 2px;
    }
    .lh-addr {
      font-weight: 700;
      color: #1a2a6c;
      font-size: 8.5pt;
      line-height: 1.55;
    }
    .lh-cmtee { margin-top: 10px; }
    .lh-cmtee-row {
      display: flex;
      align-items: baseline;
      gap: 8px;
      margin-top: 3px;
    }
    .lh-cmtee-role { color: #c8a84b; font-weight: 700; font-size: 8.5pt; min-width: 62px; }
    .lh-cmtee-name { font-weight: 700; color: #1a2a6c; font-size: 8.5pt; }

    /* Thick navy line under header */
    .lh-header-line {
      height: 3px;
      background: #1a2a6c;
      margin-top: 8px;
      margin-bottom: 20px;
    }

    /* BODY ──────────────────────────────────────────────── */
    .lh-date        { margin-bottom: 18px; }
    .lh-to-block    { margin-bottom: 14px; }
    .lh-to-block .to-label { font-weight: 700; }
    .lh-subject     { margin-bottom: 14px; }
    .lh-salutation  { margin-bottom: 18px; }
    .lh-message     { margin-bottom: 30px; white-space: pre-wrap; text-align: justify; }
    .lh-closing     { margin-bottom: 10px; }

    /* SIGNATURE BLOCK ───────────────────────────────────── */
    /* No underline within cells — signing space comes from flex layout pushing block down */
    .lh-sig-row      { display: flex; gap: 20px; padding-top: 8px; }
    .lh-sig-cell     { flex: 1; }
    .lh-sig-role     { font-weight: 700; color: #c8a84b; font-size: 10pt; }
    .lh-sig-society  { color: #1a2a6c; font-size: 10pt; }

    /* FOOTER ────────────────────────────────────────────── */
    .lh-footer-line  { height: 3px; background: #1a2a6c; margin-top: 10px; margin-bottom: 6px; }
    .lh-footer       { display: flex; flex-direction: row; justify-content: space-between; flex-wrap: nowrap; font-size: 8pt; color: #374151; }
    .lh-footer-item  { display: flex; flex-direction: row; align-items: center; gap: 5px; white-space: nowrap; }
  </style>

  <div class="mb-5">
    <nav class="text-sm text-text-secondary mb-2">
      <a href="/portal/letters" class="hover:text-primary-600">Letters</a>
      <span class="mx-2">›</span>
      <span class="text-text-primary">Generate Letter</span>
    </nav>
    <h1 class="text-2xl font-bold text-text-primary">Generate Letter</h1>
    <p class="text-sm text-text-secondary mt-1">Fill in the details. The preview updates live as you type.</p>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">

    <!-- ── LEFT: Form ── -->
    <div class="space-y-5">

      <!-- Template selector -->
      <div class="bg-white rounded-xl border border-border-light p-5">
        <label class="block text-sm font-semibold text-text-primary mb-2">
          <i class="fas fa-file-alt text-primary-600 mr-1"></i> Letterhead Template
        </label>
        <select id="template-select" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-600">
          <option value="">Loading templates…</option>
        </select>
      </div>

      <!-- Internal title -->
      <div class="bg-white rounded-xl border border-border-light p-5">
        <label class="block text-sm font-semibold text-text-primary mb-1">
          <i class="fas fa-tag text-primary-600 mr-1"></i> Internal Title <span class="text-red-500">*</span>
        </label>
        <p class="text-xs text-text-secondary mb-2">Used as the file name in the GitHub archive (e.g. "Notice to GHMC – road repair")</p>
        <input id="f-title" type="text" required placeholder="e.g. Notice to GHMC regarding road repair"
          class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <!-- Dynamic fields -->
      <div class="bg-white rounded-xl border border-border-light p-5">
        <h3 class="text-sm font-semibold text-text-primary mb-3">
          <i class="fas fa-edit text-primary-600 mr-1"></i> Letter Content
        </h3>
        <div id="dynamic-fields" class="space-y-4">
          <div class="text-sm text-text-secondary">Select a template to see fields.</div>
        </div>
      </div>

      <!-- Signature selection -->
      <div class="bg-white rounded-xl border border-border-light p-5">
        <h3 class="text-sm font-semibold text-text-primary mb-1">
          <i class="fas fa-pen-nib text-primary-600 mr-1"></i> Signatories
        </h3>
        <p class="text-xs text-text-secondary mb-3">Select who signs. Columns reflow when fewer than 3 are chosen.</p>
        <div id="signature-options" class="space-y-2">
          <div class="text-sm text-text-secondary">Select a template to see signatories.</div>
        </div>
      </div>

      <!-- Actions -->
      <div class="bg-white rounded-xl border border-border-light p-5 space-y-3">
        <div class="grid grid-cols-2 gap-3">
          <button id="btn-pdf" class="btn-primary text-sm py-2.5 flex items-center justify-center gap-2" disabled>
            <i class="fas fa-file-pdf"></i> Download PDF
          </button>
          <button id="btn-docx" class="btn-outline text-sm py-2.5 flex items-center justify-center gap-2" disabled>
            <i class="fas fa-file-word"></i> Download DOCX
          </button>
        </div>
        <button id="btn-save" class="w-full text-sm py-2.5 flex items-center justify-center gap-2 rounded-lg font-medium text-white bg-green-600 hover:bg-green-700 transition-colors" disabled>
          <i class="fas fa-cloud-upload-alt"></i> Save to Archive (GitHub)
        </button>
        <p class="text-xs text-text-secondary text-center">Save commits both PDF and DOCX to the private letters repository.</p>
      </div>
    </div>

    <!-- ── RIGHT: Live Preview ── -->
    <div>
      <div class="sticky top-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-semibold text-text-primary">Live Preview — A4</span>
          <span class="text-xs bg-gray-100 text-text-secondary px-2 py-1 rounded">Carlito 11pt</span>
        </div>
        <!-- Scale A4 (794px) to fit container (~560px) -->
        <div class="bg-gray-300 rounded-xl p-3 overflow-auto" style="max-height:85vh;">
          <div style="width:794px; transform-origin:top left; transform:scale(0.68); margin-bottom:-360px;">
            <div id="letter-preview"
              style="width:794px; min-height:1123px; background:white; padding:50px 57px 50px; box-shadow:0 2px 20px rgba(0,0,0,0.18); font-family:'Carlito','Calibri',sans-serif; font-size:11pt; line-height:1.45; color:#111827; display:flex; flex-direction:column;">
              <p style="color:#9ca3af; text-align:center; margin-top:200px; font-size:11pt;">
                Select a template and fill in the fields to see a live preview.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="toast" class="hidden fixed bottom-6 right-6 px-4 py-2.5 rounded-lg shadow-large text-sm z-50 text-white max-w-sm"></div>

  <!-- pdfmake from CDN -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js" crossorigin="anonymous"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.min.js" crossorigin="anonymous"></script>

  <script define:vars={{ preselectedTemplate }}>
    // ── State ─────────────────────────────────────────────────────────────────
    let currentTemplate = null;
    let carlitoRegB64 = null;
    let carlitoBoldB64 = null;
    let carlitoItalicB64 = null;
    let carlitoBoldItalicB64 = null;
    let logoB64 = null; // data:image/png;base64,…

    // ── Utilities ─────────────────────────────────────────────────────────────
    async function toBase64(url) {
      try {
        const res = await fetch(url);
        if (!res.ok) return null;
        const buf = await res.arrayBuffer();
        const bytes = new Uint8Array(buf);
        let s = '';
        for (let i = 0; i < bytes.byteLength; i++) s += String.fromCharCode(bytes[i]);
        return btoa(s);
      } catch { return null; }
    }

    function formatDate(iso) {
      if (!iso) return '';
      const d = new Date(iso + 'T00:00:00');
      return d.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
    }

    function esc(s) {
      return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // ── Font + Logo preload ───────────────────────────────────────────────────
    async function initAssets() {
      [carlitoRegB64, carlitoBoldB64, carlitoItalicB64, carlitoBoldItalicB64, logoB64] = await Promise.all([
        toBase64('/fonts/Carlito-Regular.ttf'),
        toBase64('/fonts/Carlito-Bold.ttf'),
        toBase64('/fonts/Carlito-Italic.ttf'),
        toBase64('/fonts/Carlito-BoldItalic.ttf'),
        toBase64('/UTA-MACS-Logo.png'),
      ]);

      if (carlitoRegB64 && carlitoBoldB64) {
        pdfMake.vfs['Carlito-Regular.ttf']   = carlitoRegB64;
        pdfMake.vfs['Carlito-Bold.ttf']      = carlitoBoldB64;
        if (carlitoItalicB64)     pdfMake.vfs['Carlito-Italic.ttf']     = carlitoItalicB64;
        if (carlitoBoldItalicB64) pdfMake.vfs['Carlito-BoldItalic.ttf'] = carlitoBoldItalicB64;
        pdfMake.fonts = pdfMake.fonts ?? {};
        pdfMake.fonts.Carlito = {
          normal:     'Carlito-Regular.ttf',
          bold:       'Carlito-Bold.ttf',
          italics:    carlitoItalicB64     ? 'Carlito-Italic.ttf'     : 'Carlito-Regular.ttf',
          bolditalics:carlitoBoldItalicB64 ? 'Carlito-BoldItalic.ttf' : 'Carlito-Bold.ttf',
        };
      }
    }

    // ── Template loading ──────────────────────────────────────────────────────
    async function loadTemplates() {
      const sel = document.getElementById('template-select');
      const res = await fetch('/api/v1/letters/templates', { credentials: 'include' });
      const templates = res.ok ? await res.json() : [];
      if (!templates.length) {
        sel.innerHTML = '<option value="">No templates found — create one first</option>';
        return;
      }
      sel.innerHTML = templates.map(t =>
        `<option value="${t.id}" ${(t.id === preselectedTemplate) || (!preselectedTemplate && t.is_default) ? 'selected' : ''}>
          ${esc(t.name)}${t.is_default ? ' (Default)' : ''}</option>`
      ).join('');
      loadTemplateDetails(sel.value);
    }

    async function loadTemplateDetails(id) {
      if (!id) return;
      const res = await fetch(`/api/v1/letters/templates/${id}`, { credentials: 'include' });
      if (!res.ok) return;
      currentTemplate = await res.json();
      currentTemplate.letterhead_committee_members =
        (currentTemplate.letterhead_committee_members ?? []).sort((a, b) => a.display_order - b.display_order);
      currentTemplate.letterhead_dynamic_fields =
        (currentTemplate.letterhead_dynamic_fields ?? []).sort((a, b) => a.display_order - b.display_order);
      renderDynamicFields();
      renderSignatureOptions();
      updatePreview();
      enableButtons();
    }

    // ── Dynamic fields ────────────────────────────────────────────────────────
    function renderDynamicFields() {
      const container = document.getElementById('dynamic-fields');
      if (!currentTemplate) { container.innerHTML = '<div class="text-sm text-text-secondary">Select a template.</div>'; return; }
      container.innerHTML = currentTemplate.letterhead_dynamic_fields.map(f => {
        const domId = `df-${f.field_key}`;
        const req = f.is_required ? '<span class="text-red-500">*</span>' : '';
        const base = `class="w-full border border-border-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-600"`;
        let input;
        if (f.field_type === 'date') {
          input = `<input id="${domId}" type="date" ${f.is_required ? 'required' : ''} ${base} />`;
        } else if (f.field_type === 'textarea' || f.field_type === 'richtext') {
          input = `<textarea id="${domId}" rows="4" placeholder="${esc(f.placeholder ?? '')}" ${f.is_required ? 'required' : ''} ${base} style="resize:vertical;"></textarea>`;
        } else {
          input = `<input id="${domId}" type="text" placeholder="${esc(f.placeholder ?? '')}" ${f.is_required ? 'required' : ''} ${base} />`;
        }
        return `<div><label class="block text-sm font-medium text-text-primary mb-1">${esc(f.display_label)} ${req}</label>${input}</div>`;
      }).join('');

      // Auto-fill today for date fields
      document.querySelectorAll('input[type="date"][id^="df-"]').forEach(el => {
        if (!el.value) el.value = new Date().toISOString().slice(0, 10);
      });
      container.querySelectorAll('input,textarea').forEach(el => el.addEventListener('input', updatePreview));
    }

    function renderSignatureOptions() {
      const container = document.getElementById('signature-options');
      if (!currentTemplate) { container.innerHTML = '<div class="text-sm text-text-secondary">Select a template.</div>'; return; }
      const sigs = currentTemplate.letterhead_committee_members.filter(m => m.show_in_signature);
      container.innerHTML = sigs.map(m => `
        <label class="flex items-center gap-3 p-2.5 rounded-lg border border-border-light hover:bg-gray-50 cursor-pointer">
          <input type="checkbox" class="sig-check rounded text-primary-600" value="${m.id}"
            data-name="${esc(m.name)}" data-designation="${esc(m.designation)}" checked />
          <div>
            <div class="text-sm font-medium text-text-primary">${esc(m.name)}</div>
            <div class="text-xs text-text-secondary">${esc(m.designation)}</div>
          </div>
        </label>`).join('');
      container.querySelectorAll('.sig-check').forEach(el => el.addEventListener('change', updatePreview));
    }

    // ── Collect values ────────────────────────────────────────────────────────
    function getFieldValues() {
      const vals = {};
      if (!currentTemplate) return vals;
      currentTemplate.letterhead_dynamic_fields.forEach(f => {
        const el = document.getElementById(`df-${f.field_key}`);
        if (el) vals[f.field_key] = el.value;
      });
      return vals;
    }

    function getSelectedSignatories() {
      return Array.from(document.querySelectorAll('.sig-check:checked')).map(el => ({
        id: el.value, name: el.dataset.name, designation: el.dataset.designation,
      }));
    }

    // ── LIVE PREVIEW — exact match to UTA MACS letterhead template ────────────
    function updatePreview() {
      if (!currentTemplate) return;
      const t = currentTemplate;
      const vals = getFieldValues();
      const sigs = getSelectedSignatories();

      const headerMembers = t.letterhead_committee_members.filter(m => m.show_in_header);
      const dateStr = vals.date ? formatDate(vals.date) : formatDate(new Date().toISOString().slice(0,10));
      const societyName = (t.society_name ?? 'URBAN TRILLA MACS').toUpperCase();
      const macsLine = 'M A C S';

      // Committee rows for right-column header
      const hdrFsPt = `${t.header_font_size_pt ?? 8.5}pt`;
      const cmteeRows = headerMembers.map(m =>
        `<div class="lh-cmtee-row">
          <span class="lh-cmtee-role" style="font-size:${hdrFsPt};">${esc(m.designation)}</span>
          <span class="lh-cmtee-name" style="font-size:${hdrFsPt};">${esc(m.name)}</span>
        </div>`).join('');

      // Signature block — reflows 1, 2 or 3 columns
      // No grey underline per cell: the signing space is the white area above (flex pushes block down)
      const sigHTML = sigs.length === 0 ? '' :
        `<div class="lh-sig-row">
          ${sigs.map(s => `
            <div class="lh-sig-cell">
              <div class="lh-sig-role">${esc(s.designation)}</div>
              <div class="lh-sig-society">${esc(t.society_name)}</div>
            </div>`).join('')}
        </div>`;

      // Message — preserve line breaks
      const messageHTML = (vals.message ?? '')
        ? vals.message.split('\n').map(l => `<p style="margin:0 0 4px 0;">${esc(l) || '&nbsp;'}</p>`).join('')
        : '<p style="color:#9ca3af;margin:0;">[Message body will appear here]</p>';

      const previewEl = document.getElementById('letter-preview');
      previewEl.style.fontSize = `${t.body_font_size_pt ?? 11}pt`;
      const logoAlignItems = t.logo_valign === 'center' ? 'center' : t.logo_valign === 'bottom' ? 'flex-end' : 'flex-start';
      previewEl.innerHTML = `
        <!-- ── HEADER: full logo image (left) + address/committee (right) ── -->
        <div class="lh-header" style="align-items:${logoAlignItems};">

          <!-- Full branded logo — contains building, URBAN TRILLA MACS, tagline, reg no -->
          <div class="lh-logo-col">
            <img src="/UTA-MACS-Logo.png" alt="UTA MACS Logo"
              style="height:${t.logo_height_px ?? 160}px; width:auto; display:block;"
              onerror="this.style.visibility='hidden';" />
          </div>

          <!-- Right: address + committee -->
          <div class="lh-right-col" style="flex:0 0 ${t.addr_col_width_px ?? 210}px;">
            <div class="lh-addr" style="font-size:${t.header_font_size_pt ?? 8.5}pt;">
              ${esc(t.society_address_line1 ?? '')}<br>
              ${esc(t.society_address_line2 ?? '')}<br>
              ${esc(t.society_address_line3 ?? '')}
            </div>
            <div class="lh-cmtee">${cmteeRows}</div>
          </div>
        </div>

        <!-- Thick navy underline -->
        <div class="lh-header-line"></div>

        <!-- ── BODY: flex:1 fills the page; sig block pushed to bottom ─── -->
        <div style="flex:1; display:flex; flex-direction:column;">

          <!-- Letter content -->
          <div style="flex:1;">
            <div class="lh-date">${esc(dateStr)}</div>

            ${vals.to ? `<div class="lh-to-block">
              <div class="to-label">To</div>
              <div>${vals.to.split('\n').map(l => esc(l)).join('<br>')}</div>
            </div>` : ''}

            ${vals.subject ? `<div class="lh-subject">
              Subject: ${esc(vals.subject)}
            </div>` : ''}

            ${vals.tosalutation ? `<div class="lh-salutation">Dear ${esc(vals.tosalutation)}</div>` : ''}

            <div class="lh-message">${messageHTML}</div>

            <div class="lh-closing">
              <div>${esc(t.closing_line1 ?? 'Thanking you!')}</div>
              <div>${esc(t.closing_line2 ?? 'Yours sincerely')}</div>
            </div>
          </div>

          <!-- Signature block: sits at bottom of the body area (signing space is whitespace above) -->
          ${sigHTML}
        </div>

        <!-- ── FOOTER: always at the bottom of the page ──────────────── -->
        <div class="lh-footer-line"></div>
        <div class="lh-footer">
          <div class="lh-footer-item">🌐 <span>${esc(t.footer_website ?? 'www.utamacs.org')}</span></div>
          <div class="lh-footer-item">📞 <span>${esc(t.footer_phone ?? '+91 7032820247')}</span></div>
          <div class="lh-footer-item">✉ <span>${esc(t.footer_email ?? 'urbantrillaresidents@gmail.com')}</span></div>
        </div>
      `;
    }

    function enableButtons() {
      ['btn-pdf','btn-docx','btn-save'].forEach(id => {
        const btn = document.getElementById(id);
        if (btn) btn.disabled = false;
      });
    }

    // ── PDF generation (pdfmake) — matches the exact letterhead ──────────────
    function buildPdfDefinition() {
      const t = currentTemplate;
      const vals = getFieldValues();
      const sigs = getSelectedSignatories();
      const headerMembers = t.letterhead_committee_members.filter(m => m.show_in_header);
      const dateStr = vals.date ? formatDate(vals.date) : formatDate(new Date().toISOString().slice(0,10));
      const fontName = (carlitoRegB64 && carlitoBoldB64) ? 'Carlito' : 'Roboto';
      const NAVY = '#1a2a6c';
      const GOLD = '#c8a84b';
      const logoH  = Math.round((t.logo_height_px ?? 160) * 0.75);
      const bodyFs = Number(t.body_font_size_pt ?? 11);
      const hdrFs  = Number(t.header_font_size_pt ?? 8.5);

      // ── Committee rows for right column ─────────────────────────────
      const cmteeContent = headerMembers.map(m => ({
        columns: [
          { text: m.designation, color: GOLD, bold: true, fontSize: hdrFs, width: 70 },
          { text: m.name, color: NAVY, bold: true, fontSize: hdrFs, width: '*' },
        ],
        columnGap: 4,
        margin: [0, 3, 0, 0],
      }));

      // ── FIRST PAGE HEADER ────────────────────────────────────────────
      // Logo PNG is the full branded image (building + URBAN TRILLA MACS + tagline + reg no).
      // Right column holds address + committee only.
      function firstPageHeader() {
        const logoImg = logoB64
          ? { image: `data:image/png;base64,${logoB64}`, fit: [600, logoH], alignment: 'left' }
          : { text: 'URBAN TRILLA MACS', fontSize: 14, bold: true, color: NAVY };

        return {
          margin: [57, 28, 57, 0],
          stack: [
            {
              columns: [
                // Left: full branded logo image
                { stack: [logoImg], width: 'auto' },
                // Spacer pushes right column to the far right
                { text: '', width: '*' },
                // Right: address + committee
                {
                  width: 185,
                  stack: [
                    { text: t.society_address_line1 ?? '', bold: true, color: NAVY, fontSize: hdrFs, lineHeight: 1.5 },
                    { text: t.society_address_line2 ?? '', bold: true, color: NAVY, fontSize: hdrFs, lineHeight: 1.5 },
                    { text: t.society_address_line3 ?? '', bold: true, color: NAVY, fontSize: hdrFs, lineHeight: 1.5 },
                    ...cmteeContent,
                  ],
                },
              ],
              columnGap: 0,
            },
            // Thick navy underline (A4 content width: 595.28 - 57 - 57 = 481pt)
            { canvas: [{ type: 'line', x1: 0, y1: 6, x2: 481, y2: 6, lineWidth: 3, lineColor: NAVY }], margin: [0, 8, 0, 0] },
          ],
        };
      }

      // ── SUBSEQUENT PAGE HEADER ───────────────────────────────────────
      function subsequentHeader() {
        return {
          margin: [57, 28, 57, 0],
          stack: [
            { text: t.subsequent_page_header ?? 'Urban Trilla MACS — Continued', bold: true, color: NAVY, fontSize: 10 },
            { canvas: [{ type: 'line', x1: 0, y1: 5, x2: 481, y2: 5, lineWidth: 1, lineColor: '#e5e7eb' }], margin: [0, 4, 0, 0] },
          ],
        };
      }

      // ── FOOTER (same on every page) ──────────────────────────────────
      function buildFooter(currentPage, pageCount) {
        return {
          margin: [57, 0, 57, 14],
          stack: [
            { canvas: [{ type: 'line', x1: 0, y1: 0, x2: 481, y2: 0, lineWidth: 3, lineColor: NAVY }], margin: [0, 0, 0, 5] },
            {
              columns: [
                { text: `🌐 ${t.footer_website ?? 'www.utamacs.org'}`, fontSize: 8, color: '#374151' },
                { text: `📞 ${t.footer_phone ?? '+91 7032820247'}`, fontSize: 8, color: '#374151', alignment: 'center' },
                { text: `✉ ${t.footer_email ?? 'urbantrillaresidents@gmail.com'}`, fontSize: 8, color: '#374151', alignment: 'right' },
              ],
            },
            { text: String(currentPage), fontSize: 7.5, color: '#6b7280', alignment: 'right', margin: [0, 2, 0, 0] },
          ],
        };
      }

      // ── Body content ─────────────────────────────────────────────────
      const body = [];

      // Date
      body.push({ text: dateStr, fontSize: bodyFs, margin: [0, 0, 0, 16] });

      // To block
      if (vals.to?.trim()) {
        const toLines = vals.to.trim().split('\n');
        body.push({
          stack: [
            { text: 'To', bold: true, fontSize: bodyFs },
            ...toLines.map(l => ({ text: l, fontSize: bodyFs, margin: [0, 1, 0, 0] })),
          ],
          margin: [0, 0, 0, 14],
        });
      }

      // Subject
      if (vals.subject?.trim()) {
        body.push({
          text: `Subject: ${vals.subject}`,
          fontSize: bodyFs,
          margin: [0, 0, 0, 14],
        });
      }

      // Salutation
      if (vals.tosalutation?.trim()) {
        body.push({ text: `Dear ${vals.tosalutation}`, fontSize: bodyFs, margin: [0, 0, 0, 18] });
      }

      // Message body
      const message = vals.message?.trim() ?? '';
      if (message) {
        const msgParagraphs = message.split('\n').map(l => ({ text: l || ' ', fontSize: bodyFs, alignment: 'justify', margin: [0, 0, 0, 4] }));
        body.push({ stack: msgParagraphs, margin: [0, 0, 0, 28] });
      } else {
        body.push({ text: '', margin: [0, 0, 0, 28] });
      }

      // Closing
      body.push({ text: t.closing_line1 ?? 'Thanking you!', fontSize: bodyFs, margin: [0, 0, 0, 5] });
      // Large bottom margin = physical signing space above the signature block
      body.push({ text: t.closing_line2 ?? 'Yours sincerely', fontSize: bodyFs, margin: [0, 0, 0, 90] });

      // Signature block — equal-width columns that reflow 1→2→3
      // No grey line within cells; signing space is the 90pt gap above
      if (sigs.length > 0) {
        const colWidth = Math.floor(481 / sigs.length);
        body.push({
          columns: sigs.map(s => ({
            width: colWidth,
            stack: [
              { text: s.designation, bold: true, color: GOLD, fontSize: 10 },
              { text: t.society_name ?? 'Urban Trilla MACS', color: NAVY, fontSize: 10 },
            ],
          })),
          columnGap: 20,
          margin: [0, 0, 0, 20],
        });
      }

      return {
        pageSize: 'A4',
        pageMargins: [57, 168, 57, 72],
        defaultStyle: { font: fontName, fontSize: bodyFs, lineHeight: 1.45, color: '#111827' },
        header: (page) => page === 1 ? firstPageHeader() : subsequentHeader(),
        footer: buildFooter,
        content: body,
      };
    }

    // ── Download PDF ──────────────────────────────────────────────────────────
    async function downloadPdf() {
      if (!currentTemplate) { showToast('Select a template first', true); return; }
      const title = document.getElementById('f-title').value.trim() || 'letter';
      pdfMake.createPdf(buildPdfDefinition()).download(`${title}.pdf`);
    }

    // ── Generate PDF as base64 (for GitHub save) ──────────────────────────────
    async function generatePdfBase64() {
      return new Promise((resolve, reject) => {
        try { pdfMake.createPdf(buildPdfDefinition()).getBase64(resolve); }
        catch (e) { reject(e); }
      });
    }

    // ── DOCX generation ───────────────────────────────────────────────────────
    async function generateDocxBase64() {
      const t = currentTemplate;
      const vals = getFieldValues();
      const sigs = getSelectedSignatories();
      const headerMembers = t.letterhead_committee_members.filter(m => m.show_in_header);
      const dateStr = vals.date ? formatDate(vals.date) : formatDate(new Date().toISOString().slice(0,10));

      const { Document, Paragraph, TextRun, Table, TableRow, TableCell,
              AlignmentType, BorderStyle, WidthType, Packer, Header, Footer,
              PageNumber, NumberOfPages } = await import('docx');

      const NAVY = '1a2a6c';
      const GOLD = 'c8a84b';
      const NO_BORDER = { style: BorderStyle.NONE, size: 0, color: 'FFFFFF' };

      function tr(text, opts) {
        return new TextRun({ text: String(text ?? ''), font: 'Carlito', size: 22, ...opts });
      }
      function p(children, opts) {
        return new Paragraph({ children: Array.isArray(children) ? children : [children], ...opts });
      }

      // Header paragraphs
      const headerParas = [
        p(tr(`${t.society_name ?? 'URBAN TRILLA MACS'}  |  ${t.society_tagline ?? 'COMMUNITY • CARE • MAINTENANCE'}`,
          { bold: true, color: NAVY, size: 24 }), { spacing: { after: 60 } }),
        p(tr(`Reg No: ${t.society_reg_no ?? 'TG/RRD/MACS/2026-15/FOW & M'}  |  ${t.society_address_line1 ?? ''} ${t.society_address_line2 ?? ''} ${t.society_address_line3 ?? ''}`,
          { size: 16, color: '374151' }), { spacing: { after: 60 } }),
        p(headerMembers.map(m => tr(`${m.designation}: ${m.name}   `, { bold: true, size: 16, color: NAVY })),
          { spacing: { after: 60 }, border: { bottom: { style: BorderStyle.SINGLE, size: 6, color: NAVY, space: 4 } } }),
      ];

      const footerParas = [
        p(tr(`🌐 ${t.footer_website ?? 'www.utamacs.org'}    📞 ${t.footer_phone ?? '+91 7032820247'}    ✉ ${t.footer_email ?? 'urbantrillaresidents@gmail.com'}`,
          { size: 16, color: '374151' }),
          { border: { top: { style: BorderStyle.SINGLE, size: 6, color: NAVY, space: 4 } }, spacing: { after: 40 } }),
        p([tr('Page ', { size: 14, color: '6b7280' }), new PageNumber(), tr(' of ', { size: 14, color: '6b7280' }), new NumberOfPages()],
          { alignment: AlignmentType.RIGHT }),
      ];

      const bodyContent = [];

      bodyContent.push(p(tr(dateStr), { spacing: { after: 200 } }));

      if (vals.to?.trim()) {
        bodyContent.push(p(tr('To', { bold: true }), { spacing: { after: 40 } }));
        vals.to.trim().split('\n').forEach(line =>
          bodyContent.push(p(tr(line), { spacing: { after: 40 } })));
        bodyContent.push(p(tr(''), { spacing: { after: 120 } }));
      }

      if (vals.subject?.trim()) {
        bodyContent.push(p([tr('Subject: ', { bold: true }), tr(vals.subject)], { spacing: { after: 200 } }));
      }

      if (vals.tosalutation?.trim()) {
        bodyContent.push(p(tr(`Dear ${vals.tosalutation}`), { spacing: { after: 200 } }));
      }

      (vals.message?.trim() ?? '').split('\n').forEach(line =>
        bodyContent.push(p(tr(line || ' '), { alignment: AlignmentType.JUSTIFIED, spacing: { after: 80 } })));

      bodyContent.push(p(tr(''), { spacing: { after: 200 } }));
      bodyContent.push(p(tr(t.closing_line1 ?? 'Thanking you!'), { spacing: { after: 80 } }));
      bodyContent.push(p(tr(t.closing_line2 ?? 'Yours sincerely'), { spacing: { after: 800 } }));

      if (sigs.length > 0) {
        const colW = Math.floor(9360 / sigs.length);
        bodyContent.push(new Table({
          width: { size: 100, type: WidthType.PERCENTAGE },
          rows: [
            new TableRow({ children: sigs.map(() => new TableCell({
              borders: { top: NO_BORDER, left: NO_BORDER, right: NO_BORDER,
                bottom: { style: BorderStyle.SINGLE, size: 4, color: 'd1d5db' } },
              children: [p(tr(''), { spacing: { before: 500 } })],
              width: { size: colW, type: WidthType.DXA },
            })) }),
            new TableRow({ children: sigs.map(s => new TableCell({
              borders: { top: NO_BORDER, left: NO_BORDER, right: NO_BORDER, bottom: NO_BORDER },
              children: [p(tr(s.designation, { bold: true, color: GOLD, size: 18 }), { spacing: { after: 40 } })],
            })) }),
            new TableRow({ children: sigs.map(() => new TableCell({
              borders: { top: NO_BORDER, left: NO_BORDER, right: NO_BORDER, bottom: NO_BORDER },
              children: [p(tr(t.society_name ?? 'Urban Trilla MACS', { color: NAVY, size: 18 }))],
            })) }),
          ],
        }));
      }

      const doc = new Document({
        sections: [{
          properties: { page: { margin: { top: 2200, bottom: 1100, left: 910, right: 910 } } },
          headers: { default: new Header({ children: headerParas }) },
          footers: { default: new Footer({ children: footerParas }) },
          children: bodyContent,
        }],
      });

      const buf = await Packer.toBuffer(doc);
      const bytes = new Uint8Array(buf);
      let s = '';
      for (let i = 0; i < bytes.byteLength; i++) s += String.fromCharCode(bytes[i]);
      return btoa(s);
    }

    async function downloadDocx() {
      if (!currentTemplate) { showToast('Select a template first', true); return; }
      const title = document.getElementById('f-title').value.trim() || 'letter';
      showToast('Generating DOCX…', false);
      try {
        const b64 = await generateDocxBase64();
        const bytes = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
        const blob = new Blob([bytes], { type: 'application/vnd.openxmlformats-officedocument.wordprocessingml.document' });
        const url = URL.createObjectURL(blob);
        const a = Object.assign(document.createElement('a'), { href: url, download: `${title}.docx` });
        document.body.appendChild(a); a.click();
        document.body.removeChild(a); URL.revokeObjectURL(url);
      } catch(e) { showToast('DOCX generation failed: ' + e.message, true); }
    }

    // ── Save to GitHub ─────────────────────────────────────────────────────────
    async function saveToArchive() {
      const title = document.getElementById('f-title').value.trim();
      if (!title) { showToast('Enter an internal title before saving', true); return; }
      if (!currentTemplate) { showToast('Select a template first', true); return; }

      const btn = document.getElementById('btn-save');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generating & Saving…';

      try {
        const [pdf_base64, docx_base64] = await Promise.all([generatePdfBase64(), generateDocxBase64()]);
        const vals = getFieldValues();
        const sigs = getSelectedSignatories();

        const res = await fetch('/api/v1/letters', {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            template_id: currentTemplate.id,
            title,
            subject: vals.subject ?? null,
            recipient: vals.to ?? null,
            field_values: vals,
            signatures_used: sigs.map(s => s.designation),
            pdf_base64,
            docx_base64,
          }),
        });

        if (res.ok) {
          showToast('Letter saved to GitHub archive!', false);
          setTimeout(() => window.location.href = '/portal/letters', 1800);
        } else {
          const d = await res.json();
          showToast(d.error ?? 'Save failed', true);
          btn.disabled = false;
          btn.innerHTML = '<i class="fas fa-cloud-upload-alt"></i> Save to Archive (GitHub)';
        }
      } catch (e) {
        showToast('Error: ' + e.message, true);
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-cloud-upload-alt"></i> Save to Archive (GitHub)';
      }
    }

    function showToast(msg, isError) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = `fixed bottom-6 right-6 px-4 py-2.5 rounded-lg shadow-large text-sm z-50 text-white max-w-sm ${isError ? 'bg-red-600' : 'bg-green-600'}`;
      setTimeout(() => t.classList.add('hidden'), 4000);
    }

    // ── Wire up ────────────────────────────────────────────────────────────────
    document.getElementById('template-select').addEventListener('change', e => loadTemplateDetails(e.target.value));
    document.getElementById('f-title').addEventListener('input', updatePreview);
    document.getElementById('btn-pdf').addEventListener('click', downloadPdf);
    document.getElementById('btn-docx').addEventListener('click', downloadDocx);
    document.getElementById('btn-save').addEventListener('click', saveToArchive);

    // ── Init ───────────────────────────────────────────────────────────────────
    initAssets();
    loadTemplates();
  </script>
</PortalLayout>

---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
const canSeeLetters =
  ['executive', 'admin'].includes(user.role) ||
  ['executive', 'secretary', 'president'].includes(user.portalRole ?? '') ||
  user.isAdmin;
if (!canSeeLetters) return Astro.redirect('/portal');
---

<PortalLayout title="Letters" user={user} activeModule="letters">
  <!-- Process info panel -->
  <details class="mb-6 group rounded-xl border border-primary-100 bg-gradient-to-r from-primary-50/50 to-blue-50/20 overflow-hidden">
    <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer list-none select-none hover:bg-primary-50/60 transition-colors">
      <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-project-diagram text-white text-xs" aria-hidden="true"></i>
      </div>
      <span class="text-sm font-medium text-text-primary flex-1">Official letters are generated from society letterhead templates — draft, review, and download as a signed PDF.</span>
      <span class="text-xs text-primary-600 flex items-center gap-1.5 flex-shrink-0 font-medium">
        How it works
        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200 group-open:rotate-180" aria-hidden="true"></i>
      </span>
    </summary>
    <div class="px-5 pb-5">
      <div class="pt-4 border-t border-primary-100 space-y-4">
        <!-- Main flow -->
        <div class="process-snake-flow -mx-1 px-1">
          <div class="flex-shrink-0 w-52 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">Select Template</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">Choose letter type</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-amber-300 bg-amber-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-amber-800 whitespace-nowrap">Fill Details</p>
            <p class="text-[11px] text-amber-700 mt-0.5 whitespace-nowrap">Edit content &amp; fields</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-green-300 bg-green-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-green-800 whitespace-nowrap">Generate PDF</p>
            <p class="text-[11px] text-green-700 mt-0.5 whitespace-nowrap">Letterhead applied</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-gray-300 bg-gray-100 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Dispatch &amp; File</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">Saved to Documents</p>
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mt-1">
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Templates include Society letterhead, RERA notice, and general correspondence</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Letters are auto-filed in the Document Repository under the 'Letters' category</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-exclamation-circle text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Only Secretary and above can create letters using official society letterhead</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Downloaded PDFs include a document reference number for tracking</span>
          </div>
        </div>
      </div>
    </div>
  </details>

  <div class="mb-6 flex items-center justify-between flex-wrap gap-3">
    <div>
      <h1 class="text-2xl font-bold text-text-primary">Letter Archive</h1>
      <p class="text-sm text-text-secondary mt-1">Official correspondence generated using the letterhead system.</p>
    </div>
    <div class="flex items-center gap-2">
      <a href="/portal/letters/templates" class="btn-outline text-sm flex items-center gap-2">
        <i class="fas fa-cog" aria-hidden="true"></i>
        Manage Templates
      </a>
      <a href="/portal/letters/new" class="btn-primary text-sm flex items-center gap-2">
        <i class="fas fa-pen" aria-hidden="true"></i>
        Write Letter
      </a>
    </div>
  </div>

  <!-- Search & filter bar -->
  <div class="flex flex-col sm:flex-row gap-3 mb-5">
    <div class="relative flex-1 max-w-sm">
      <i class="fas fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-text-secondary text-sm" aria-hidden="true"></i>
      <input type="search" id="search-input" placeholder="Search by title or subject…"
        class="w-full pl-10 pr-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
    </div>
  </div>

  <!-- Stats bar -->
  <div id="result-count" class="text-xs text-text-secondary mb-4"></div>

  <!-- Letters list -->
  <div id="letters-list" class="space-y-3">
    <div class="flex items-center justify-center h-32 text-text-secondary text-sm">
      <i class="fas fa-spinner fa-spin mr-2"></i> Loading…
    </div>
  </div>

  <div class="mt-6 text-center">
    <button id="load-more-btn" class="hidden btn-outline text-sm">Load more</button>
  </div>

  <!-- Delete confirmation modal -->
  <div id="delete-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-large max-w-sm w-full p-6">
      <h3 class="font-semibold text-text-primary mb-2">Delete letter?</h3>
      <p class="text-sm text-text-secondary mb-1">This will permanently delete both files from GitHub and remove the record.</p>
      <p id="delete-modal-title" class="text-sm font-medium text-text-primary mb-5"></p>
      <div class="flex gap-2 justify-end">
        <button onclick="closeDeleteModal()" class="btn-outline text-sm">Cancel</button>
        <button id="delete-confirm-btn" class="btn-primary text-sm bg-red-600 hover:bg-red-700 border-red-600">Delete</button>
      </div>
    </div>
  </div>

  <div id="toast" class="hidden fixed bottom-6 right-6 px-4 py-2.5 rounded-lg shadow-large text-sm z-50 text-white"></div>

  <script define:vars={{ isAdmin: user.role === 'admin' }}>
    let currentOffset = 0;
    let currentQ = '';
    const LIMIT = 20;
    let debounceTimer;
    let pendingDeleteId = null;

    async function loadLetters(reset) {
      if (reset) currentOffset = 0;
      const params = new URLSearchParams({ limit: String(LIMIT), offset: String(currentOffset) });
      if (currentQ) params.set('q', currentQ);

      const res = await fetch(`/api/v1/letters?${params}`, { credentials: 'include' });
      const { letters, total } = res.ok ? await res.json() : { letters: [], total: 0 };

      const container = document.getElementById('letters-list');
      if (reset) container.innerHTML = '';

      document.getElementById('result-count').textContent =
        total > 0 ? `${total} letter${total !== 1 ? 's' : ''} in archive` : '';

      if (!letters.length && currentOffset === 0) {
        container.innerHTML = `
          <div class="text-center py-16">
            <div class="w-16 h-16 bg-primary-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <i class="fas fa-envelope-open-text text-primary-600 text-2xl"></i>
            </div>
            <h3 class="font-semibold text-text-primary mb-2">No letters yet</h3>
            <p class="text-sm text-text-secondary mb-4">Generated letters will appear here after you write and save them.</p>
            <a href="/portal/letters/new" class="btn-primary text-sm">Write First Letter</a>
          </div>`;
        document.getElementById('load-more-btn').classList.add('hidden');
        return;
      }

      letters.forEach(l => {
        const card = document.createElement('div');
        card.className = 'bg-white rounded-xl border border-border-light p-4 flex items-start justify-between gap-4 hover:shadow-soft transition-shadow';
        const createdDate = new Date(l.created_at).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
        const createdTime = new Date(l.created_at).toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' });
        const templateName = l.letterhead_templates?.name ?? '—';

        const safeTitle = l.title.replace(/\\/g,'\\\\').replace(/'/g,'\\\'');
        card.innerHTML = `
          <div class="flex items-start gap-3 min-w-0 flex-1">
            <div class="w-10 h-10 rounded-xl bg-primary-50 flex items-center justify-center flex-shrink-0 mt-0.5">
              <i class="fas fa-file-alt text-primary-600"></i>
            </div>
            <div class="min-w-0">
              <h3 class="font-semibold text-text-primary truncate">${l.title}</h3>
              ${l.subject ? `<p class="text-xs text-text-secondary mt-0.5 truncate">Subject: ${l.subject}</p>` : ''}
              ${l.recipient ? `<p class="text-xs text-text-secondary truncate">To: ${l.recipient.split('\n')[0]}</p>` : ''}
              <div class="flex items-center gap-3 mt-2">
                <span class="text-xs text-text-secondary">
                  <i class="fas fa-file-alt mr-0.5"></i> ${templateName}
                </span>
                <span class="text-xs text-text-secondary">
                  <i class="fas fa-clock mr-0.5"></i> ${createdDate}, ${createdTime}
                </span>
                ${l.signatures_used?.length ? `<span class="text-xs text-text-secondary"><i class="fas fa-signature mr-0.5"></i> ${l.signatures_used.join(', ')}</span>` : ''}
              </div>
            </div>
          </div>
          <div class="flex items-center gap-1 flex-shrink-0">
            <a href="/portal/letters/${l.id}" title="Edit letter"
              class="p-2 rounded-lg text-text-secondary hover:bg-gray-100 hover:text-primary-600 transition-colors text-sm">
              <i class="fas fa-edit"></i></a>
            ${l.git_path_pdf ? `<button onclick="downloadLetter('${l.id}','pdf','${safeTitle}')" title="Download PDF"
              class="p-2 rounded-lg text-red-500 hover:bg-red-50 hover:text-red-700 transition-colors text-sm">
              <i class="fas fa-file-pdf"></i></button>` : ''}
            ${l.git_path_docx ? `<button onclick="downloadLetter('${l.id}','docx','${safeTitle}')" title="Download DOCX"
              class="p-2 rounded-lg text-blue-500 hover:bg-blue-50 hover:text-blue-700 transition-colors text-sm">
              <i class="fas fa-file-word"></i></button>` : ''}
            ${isAdmin ? `<button onclick="openDeleteModal('${l.id}', '${safeTitle}')"
              title="Delete" class="p-2 rounded-lg text-text-secondary hover:text-red-600 hover:bg-red-50 transition-colors text-sm">
              <i class="fas fa-trash"></i></button>` : ''}
          </div>`;
        container.appendChild(card);
      });

      currentOffset += letters.length;
      document.getElementById('load-more-btn').classList.toggle('hidden', currentOffset >= total);
    }

    async function downloadLetter(id, format, title) {
      showToast(`Downloading ${format.toUpperCase()}…`, false);
      try {
        const res = await fetch(`/api/v1/letters/${id}?format=${format}`, { credentials: 'include' });
        if (!res.ok) { showToast('Download failed', true); return; }
        const blob = await res.blob();
        const blobUrl = URL.createObjectURL(blob);
        const a = Object.assign(document.createElement('a'), { href: blobUrl, download: `${title}.${format}` });
        document.body.appendChild(a); a.click();
        document.body.removeChild(a); URL.revokeObjectURL(blobUrl);
      } catch (e) { showToast('Download failed: ' + e.message, true); }
    }
    window.downloadLetter = downloadLetter;

    function openDeleteModal(id, title) {
      pendingDeleteId = id;
      document.getElementById('delete-modal-title').textContent = `"${title}"`;
      document.getElementById('delete-modal').classList.remove('hidden');
    }

    function closeDeleteModal() {
      pendingDeleteId = null;
      document.getElementById('delete-modal').classList.add('hidden');
    }

    document.getElementById('delete-confirm-btn').addEventListener('click', async () => {
      if (!pendingDeleteId) return;
      const btn = document.getElementById('delete-confirm-btn');
      btn.disabled = true; btn.textContent = 'Deleting…';
      const res = await fetch(`/api/v1/letters/${pendingDeleteId}`, { method: 'DELETE', credentials: 'include' });
      btn.disabled = false; btn.textContent = 'Delete';
      closeDeleteModal();
      if (res.ok || res.status === 204) {
        showToast('Letter deleted', false);
        loadLetters(true);
      } else {
        const d = await res.json();
        showToast(d.error ?? 'Delete failed', true);
      }
    });

    document.getElementById('search-input').addEventListener('input', (e) => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        currentQ = e.target.value.trim();
        loadLetters(true);
      }, 350);
    });

    document.getElementById('load-more-btn').addEventListener('click', () => loadLetters(false));

    function showToast(msg, isError) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = `fixed bottom-6 right-6 px-4 py-2.5 rounded-lg shadow-large text-sm z-50 text-white ${isError ? 'bg-red-600' : 'bg-green-600'}`;
      setTimeout(() => t.classList.add('hidden'), 3500);
    }

    window.openDeleteModal = openDeleteModal;
    window.closeDeleteModal = closeDeleteModal;
    loadLetters(true);
  </script>
</PortalLayout>

---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user || !['executive','admin'].includes(user.role)) return Astro.redirect('/portal/events');

const CATEGORIES = ['Cultural','Sports','Governance','Social','Educational','Religious','General'];
---

<PortalLayout title="Create Event" user={user} activeModule="events">
  <div class="mb-6">
    <nav class="text-sm text-text-secondary mb-3">
      <a href="/portal/events" class="hover:text-primary-600">Events</a>
      <span class="mx-2">›</span><span class="text-text-primary">New Event</span>
    </nav>
    <h1 class="text-2xl font-bold text-text-primary">Create Event</h1>
  </div>

  <div class="max-w-2xl">
    <div id="error-banner" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>

    <form id="event-form" class="bg-white rounded-xl border border-border-light p-6 space-y-5">
      <div>
        <label for="title" class="block text-sm font-medium text-text-primary mb-1.5">Event Name <span class="text-red-500">*</span></label>
        <input type="text" id="title" name="title" required maxlength="200"
          placeholder="e.g. Ugadi Cultural Festival 2025"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="category" class="block text-sm font-medium text-text-primary mb-1.5">Category <span class="text-red-500">*</span></label>
          <select id="category" name="category" required
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
            {CATEGORIES.map(c => <option value={c}>{c}</option>)}
          </select>
        </div>
        <div>
          <label for="capacity" class="block text-sm font-medium text-text-primary mb-1.5">Capacity</label>
          <input type="number" id="capacity" name="capacity" min="1"
            placeholder="Max attendees"
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="starts_at" class="block text-sm font-medium text-text-primary mb-1.5">Start Date & Time <span class="text-red-500">*</span></label>
          <input type="datetime-local" id="starts_at" name="starts_at" required
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
        </div>
        <div>
          <label for="ends_at" class="block text-sm font-medium text-text-primary mb-1.5">End Date & Time <span class="text-red-500">*</span></label>
          <input type="datetime-local" id="ends_at" name="ends_at" required
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
        </div>
      </div>

      <div>
        <label for="location" class="block text-sm font-medium text-text-primary mb-1.5">Venue</label>
        <input type="text" id="location" name="location" maxlength="200"
          placeholder="e.g. Community Hall, UTA MACS"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <div>
        <label for="description" class="block text-sm font-medium text-text-primary mb-1.5">Description</label>
        <textarea id="description" name="description" rows="4"
          placeholder="Describe the event, agenda, and any special instructions…"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none"></textarea>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <button type="submit" id="submit-btn" class="btn-primary flex items-center gap-2">
          <i class="fas fa-calendar-plus" aria-hidden="true"></i>
          <span id="btn-text">Create Event</span>
          <span id="btn-spinner" class="hidden"><i class="fas fa-spinner fa-spin" aria-hidden="true"></i></span>
        </button>
        <a href="/portal/events" class="btn-outline">Cancel</a>
      </div>
    </form>
  </div>

  <script>
    const form = document.getElementById('event-form') as HTMLFormElement;
    const errorBanner = document.getElementById('error-banner')!;
    const btnText = document.getElementById('btn-text')!;
    const btnSpinner = document.getElementById('btn-spinner')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const startsAt = new Date((fd.get('starts_at') as string)).toISOString();
      const endsAt = new Date((fd.get('ends_at') as string)).toISOString();

      if (new Date(endsAt) <= new Date(startsAt)) {
        errorBanner.textContent = 'End time must be after start time.';
        errorBanner.classList.remove('hidden');
        return;
      }

      errorBanner.classList.add('hidden');
      btnText.classList.add('hidden');
      btnSpinner.classList.remove('hidden');
      submitBtn.disabled = true;

      const res = await fetch('/api/v1/events', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
        body: JSON.stringify({
          title: fd.get('title'),
          description: fd.get('description'),
          category: fd.get('category'),
          starts_at: startsAt,
          ends_at: endsAt,
          location: fd.get('location') || null,
          capacity: fd.get('capacity') ? Number(fd.get('capacity')) : null,
        }),
      });

      const data = await res.json();
      if (res.ok) {
        window.location.href = '/portal/events';
      } else {
        errorBanner.textContent = data.detail ?? data.error ?? 'Failed to create event.';
        errorBanner.classList.remove('hidden');
        btnText.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
        submitBtn.disabled = false;
      }
    });
  </script>
</PortalLayout>

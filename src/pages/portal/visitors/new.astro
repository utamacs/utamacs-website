---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';
import { getSupabaseServiceClient } from '@lib/services/providers/supabase/SupabaseDB';

const user = Astro.locals.user;
if (!user || user.role === 'security_guard') return Astro.redirect('/portal/visitors');

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const sb = getSupabaseServiceClient();
const { data: units } = await sb.from('units').select('id, unit_number, block').eq('society_id', SOCIETY_ID).order('unit_number');
---

<PortalLayout title="Pre-Approve Visitor" user={user} activeModule="visitor_mgmt">
  <div class="mb-6">
    <nav class="text-sm text-text-secondary mb-3">
      <a href="/portal/visitors" class="hover:text-primary-600">Visitors</a>
      <span class="mx-2">›</span><span class="text-text-primary">Pre-Approve</span>
    </nav>
    <h1 class="text-2xl font-bold text-text-primary">Pre-Approve a Visitor</h1>
    <p class="text-sm text-text-secondary mt-1">Generate a QR code for your expected visitor. Security will scan it at the gate.</p>
  </div>

  <div class="max-w-lg">
    <div id="error-banner" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
    <div id="success-panel" class="hidden mb-4 p-5 bg-green-50 border border-green-200 rounded-xl">
      <div class="flex items-center gap-2 text-green-700 font-semibold mb-2">
        <i class="fas fa-check-circle" aria-hidden="true"></i>
        Pre-approval created!
      </div>
      <p class="text-sm text-green-700">Your visitor has been pre-approved. Share the approval details with your visitor.</p>
    </div>

    <form id="preapproval-form" class="bg-white rounded-xl border border-border-light p-6 space-y-5">
      <div>
        <label for="visitor_name" class="block text-sm font-medium text-text-primary mb-1.5">Visitor Name <span class="text-red-500">*</span></label>
        <input type="text" id="visitor_name" name="visitor_name" required maxlength="100"
          placeholder="Full name of visitor"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <div>
        <label for="visitor_phone" class="block text-sm font-medium text-text-primary mb-1.5">Visitor Phone</label>
        <input type="tel" id="visitor_phone" name="visitor_phone" maxlength="15"
          placeholder="10-digit mobile number"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
        <p class="text-xs text-text-secondary mt-1">Stored as a one-way hash — not retrievable (DPDPA compliance).</p>
      </div>

      <div>
        <label for="unit_id" class="block text-sm font-medium text-text-primary mb-1.5">Your Unit <span class="text-red-500">*</span></label>
        <select id="unit_id" name="unit_id" required
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
          <option value="">Select your flat</option>
          {(units ?? []).map((u: {id: string; unit_number: string; block: string | null}) => (
            <option value={u.id}>{u.unit_number}{u.block ? ` – Block ${u.block}` : ''}</option>
          ))}
        </select>
      </div>

      <div>
        <label for="purpose" class="block text-sm font-medium text-text-primary mb-1.5">Purpose of Visit</label>
        <input type="text" id="purpose" name="purpose" maxlength="200"
          placeholder="e.g. House guest, Plumber, Delivery"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="expected_date" class="block text-sm font-medium text-text-primary mb-1.5">Expected Date <span class="text-red-500">*</span></label>
          <input type="date" id="expected_date" name="expected_date" required
            min={new Date().toISOString().split('T')[0]}
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
        </div>
        <div>
          <label for="expected_time_from" class="block text-sm font-medium text-text-primary mb-1.5">Expected From</label>
          <input type="time" id="expected_time_from" name="expected_time_from"
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
        </div>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <button type="submit" id="submit-btn" class="btn-primary flex items-center gap-2">
          <i class="fas fa-qrcode" aria-hidden="true"></i>
          <span id="btn-text">Generate Pre-Approval</span>
          <span id="btn-spinner" class="hidden"><i class="fas fa-spinner fa-spin" aria-hidden="true"></i></span>
        </button>
        <a href="/portal/visitors" class="btn-outline">Cancel</a>
      </div>
    </form>
  </div>

  <script>
    const form = document.getElementById('preapproval-form') as HTMLFormElement;
    const errorBanner = document.getElementById('error-banner')!;
    const successPanel = document.getElementById('success-panel')!;
    const btnText = document.getElementById('btn-text')!;
    const btnSpinner = document.getElementById('btn-spinner')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBanner.classList.add('hidden');
      btnText.classList.add('hidden');
      btnSpinner.classList.remove('hidden');
      submitBtn.disabled = true;

      const fd = new FormData(form);
      const res = await fetch('/api/v1/visitors/pre-approvals', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
        body: JSON.stringify({
          visitor_name: fd.get('visitor_name'),
          visitor_phone: fd.get('visitor_phone') || null,
          unit_id: fd.get('unit_id'),
          purpose: fd.get('purpose') || null,
          expected_date: fd.get('expected_date'),
          expected_time_from: fd.get('expected_time_from') ? `${fd.get('expected_date')}T${fd.get('expected_time_from')}:00+05:30` : null,
        }),
      });

      const data = await res.json();
      if (res.ok) {
        form.classList.add('hidden');
        successPanel.classList.remove('hidden');
      } else {
        errorBanner.textContent = data.detail ?? data.error ?? 'Failed to create pre-approval.';
        errorBanner.classList.remove('hidden');
        btnText.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
        submitBtn.disabled = false;
      }
    });
  </script>
</PortalLayout>

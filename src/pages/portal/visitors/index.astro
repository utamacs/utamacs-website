---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';
import { getSupabaseServiceClient } from '@lib/services/providers/supabase/SupabaseDB';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const isGuard = user.role === 'security_guard';
const isExec  = ['executive', 'admin'].includes(user.role) || user.isAdmin ||
                ['executive','secretary','president'].includes((user as any).portalRole ?? '');

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const sb = getSupabaseServiceClient();

// Resident's unit (for pre-fills and gate approval scoping)
const { data: profile } = await sb.from('profiles').select('unit_id').eq('id', user.id).single();
const myUnitId = profile?.unit_id ?? null;

// Server-side pending gate approvals for residents (initial render)
let pendingGateRequests: Array<{
  id: string; visitor_name: string; visitor_type: string | null;
  vehicle_number: string | null; purpose: string | null;
  created_at: string; expires_at: string;
  units: { unit_number: string; block: string | null } | null;
  profiles: { display_name: string | null } | null;
}> = [];

if (!isGuard && myUnitId) {
  const { data } = await sb
    .from('visitor_gate_requests')
    .select('id, visitor_name, visitor_type, vehicle_number, purpose, created_at, expires_at, units(unit_number, block), profiles!requested_by(display_name)')
    .eq('society_id', SOCIETY_ID)
    .eq('host_unit_id', myUnitId)
    .eq('status', 'pending')
    .gte('expires_at', new Date().toISOString())
    .order('created_at', { ascending: false });
  pendingGateRequests = (data ?? []) as typeof pendingGateRequests;
}

const VISITOR_TYPES = [
  { value: 'guest',              label: 'Guest' },
  { value: 'relative',           label: 'Relative' },
  { value: 'friend',             label: 'Friend' },
  { value: 'domestic_help',      label: 'Domestic Help' },
  { value: 'cook',               label: 'Cook' },
  { value: 'driver',             label: 'Driver' },
  { value: 'nurse',              label: 'Nurse / Caregiver' },
  { value: 'tutor',              label: 'Tutor' },
  { value: 'plumber',            label: 'Plumber' },
  { value: 'electrician',        label: 'Electrician' },
  { value: 'carpenter',          label: 'Carpenter' },
  { value: 'painter',            label: 'Painter' },
  { value: 'pest_control_tech',  label: 'Pest Control Tech' },
  { value: 'courier',            label: 'Courier' },
  { value: 'food_delivery',      label: 'Food Delivery' },
  { value: 'grocery_delivery',   label: 'Grocery Delivery' },
  { value: 'ecommerce_delivery', label: 'E-commerce Delivery' },
  { value: 'cab_driver',         label: 'Cab Driver' },
  { value: 'auto_driver',        label: 'Auto Driver' },
  { value: 'medical',            label: 'Medical / Doctor' },
  { value: 'emergency',          label: 'Emergency' },
  { value: 'real_estate_agent',  label: 'Real Estate Agent' },
  { value: 'prospective_buyer',  label: 'Prospective Buyer' },
  { value: 'prospective_tenant', label: 'Prospective Tenant' },
  { value: 'maintenance_staff',  label: 'Maintenance Staff' },
  { value: 'security_audit',     label: 'Security Audit' },
  { value: 'govt_official',      label: 'Govt. Official' },
  { value: 'other',              label: 'Other' },
];
---

<PortalLayout title="Visitor Management" user={user} activeModule="visitor_mgmt">

  <!-- How it works -->
  <details class="mb-6 group rounded-xl border border-primary-100 bg-gradient-to-r from-primary-50/50 to-blue-50/20 overflow-hidden">
    <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer list-none select-none hover:bg-primary-50/60 transition-colors">
      <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-project-diagram text-white text-xs" aria-hidden="true"></i>
      </div>
      <span class="text-sm font-medium text-text-primary flex-1">All visitors are logged at the gate — residents pre-share a time-bound QR pass or OTP; guards scan or verify before admitting. Walk-in visitors can be gate-approved by the resident in real time.</span>
      <span class="text-xs text-primary-600 flex items-center gap-1.5 flex-shrink-0 font-medium">
        How it works
        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200 group-open:rotate-180" aria-hidden="true"></i>
      </span>
    </summary>
    <div class="px-5 pb-5">
      <div class="pt-4 border-t border-primary-100 space-y-4">
        <!-- Path A: QR / OTP pass flow -->
        <p class="text-[11px] font-semibold text-text-secondary uppercase tracking-wide">Path A — Pre-Approved Visitor (QR / OTP Pass)</p>
        <div class="process-snake-flow -mx-1 px-1">
          <div class="flex-shrink-0 w-44 rounded-lg border border-dashed border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">Create Pass</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">Resident sets time window</p>
            <p class="text-[10px] text-blue-400 whitespace-nowrap">2h / 6h / 24h / custom</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">Share Pass</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">QR image or 6-digit OTP</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Visitor Arrives</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">Shows QR or quotes OTP</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-amber-300 bg-amber-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-amber-800 whitespace-nowrap">Guard Scans / Enters</p>
            <p class="text-[11px] text-amber-700 mt-0.5 whitespace-nowrap">Camera QR or OTP field</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-green-300 bg-green-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-green-800 whitespace-nowrap">Entry Logged</p>
            <p class="text-[11px] text-green-700 mt-0.5 whitespace-nowrap">Scan count incremented</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-gray-300 bg-gray-100 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Exit Logged</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">Departure recorded</p>
          </div>
        </div>
        <!-- Path B: Walk-in with gate approval -->
        <p class="text-[11px] font-semibold text-text-secondary uppercase tracking-wide mt-3">Path B — Walk-in Visitor (Gate Approval)</p>
        <div class="process-snake-flow -mx-1 px-1">
          <div class="flex-shrink-0 w-44 rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Walk-in Arrives</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">No pre-approval</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-amber-300 bg-amber-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-amber-800 whitespace-nowrap">Guard Requests Approval</p>
            <p class="text-[11px] text-amber-700 mt-0.5 whitespace-nowrap">Sends to resident portal</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">Resident Decides</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">Approve / Reject in 10 min</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-green-300 bg-green-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-green-800 whitespace-nowrap">Entry Auto-Logged</p>
            <p class="text-[11px] text-green-700 mt-0.5 whitespace-nowrap">On approval, log created</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-gray-300 bg-gray-100 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Guard Notified</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">Decision shown live (10s poll)</p>
          </div>
        </div>
        <div class="flex items-center gap-2 text-xs text-red-600">
          <i class="fas fa-arrow-turn-down text-red-400 text-[10px]" aria-hidden="true"></i>
          <span class="font-medium">Pass Invalid</span>
          <span class="text-red-500">— Guard sees red modal if pass is expired, maxed out (all entries used) or the window hasn't started yet; visitor is not admitted</span>
        </div>
        <div class="flex items-center gap-2 text-xs text-red-600">
          <i class="fas fa-arrow-turn-down text-red-400 text-[10px]" aria-hidden="true"></i>
          <span class="font-medium">Gate Request Expired</span>
          <span class="text-red-500">— Approval requests auto-expire after 10 minutes; guard must re-submit or log as walk-in directly</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mt-1">
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-qrcode text-primary-400 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>QR pass encodes a verify URL — guard's camera decodes it, previews pass details in a modal, then taps "Admit" to record entry</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-key text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>6-digit OTP is shown on the pass image — visitor can quote it verbally; guard enters it in the OTP field as backup to QR scanning</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-repeat text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Multi-entry passes (up to 5 or unlimited) are supported — useful for vendors with multiple trips; scan count shown on each entry</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-clock text-amber-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Pass validity window enforced at the gate — guards can admit up to 30 minutes before the start time (configurable grace period)</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-mobile-alt text-primary-400 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Pass image can be downloaded or shared via WhatsApp/iMessage — visitor needs no app; the pass page works in any mobile browser</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-shield-alt text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Gate approval requests expire in 10 minutes — residents see a live countdown; guard's panel refreshes every 10 seconds for the decision</span>
          </div>
        </div>
      </div>
    </div>
  </details>

  <!-- Page header -->
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-primary-600 font-poppins">Visitor Management</h1>
      <p class="text-text-secondary text-sm mt-1">
        {isGuard ? 'Verify passes, log entries and exits.' : 'Create visitor passes and manage approvals.'}
      </p>
    </div>
    {!isGuard && (
      <a href="/portal/visitors/new" class="btn-primary text-sm flex items-center gap-2">
        <i class="fas fa-qrcode" aria-hidden="true"></i>
        Create Pass
      </a>
    )}
  </div>

  <!-- ── RESIDENT: Pending Gate Approvals ──────────────────────────────────── -->
  {!isGuard && (
    <div id="gate-approvals-section" class={pendingGateRequests.length ? '' : 'hidden'}>
      <div class="mb-6 rounded-xl border-2 border-amber-300 bg-amber-50 overflow-hidden">
        <div class="px-5 py-3 bg-amber-400/20 border-b border-amber-300 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <i class="fas fa-bell text-amber-700 animate-pulse" aria-hidden="true"></i>
            <span class="font-semibold text-amber-900">Gate Approval Needed</span>
            <span id="gate-count-badge" class="text-xs bg-amber-500 text-white px-2 py-0.5 rounded-full font-bold">
              {pendingGateRequests.length}
            </span>
          </div>
          <span class="text-xs text-amber-700">Guard is waiting — decide within 10 min</span>
        </div>
        <div id="gate-approvals-list" class="divide-y divide-amber-200">
          {pendingGateRequests.map(req => (
            <div class="gate-request-card px-5 py-4" data-id={req.id}>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-amber-200 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <i class="fas fa-user text-amber-700" aria-hidden="true"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="font-semibold text-text-primary">{req.visitor_name}</span>
                    {req.visitor_type && (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 text-amber-800 font-medium capitalize">
                        {req.visitor_type.replace(/_/g, ' ')}
                      </span>
                    )}
                  </div>
                  {req.purpose && <p class="text-sm text-text-secondary mt-0.5">{req.purpose}</p>}
                  <div class="flex items-center gap-3 mt-1 text-xs text-text-secondary flex-wrap">
                    {req.vehicle_number && <span><i class="fas fa-car mr-1" aria-hidden="true"></i>{req.vehicle_number}</span>}
                    <span>
                      <i class="fas fa-shield-alt mr-1" aria-hidden="true"></i>
                      Guard: {(req.profiles as any)?.display_name ?? 'Security guard'}
                    </span>
                    <span class="text-amber-600 font-medium gate-countdown" data-expires={req.expires_at}></span>
                  </div>
                </div>
                <div class="flex flex-col gap-2 flex-shrink-0">
                  <button
                    onclick={`decideGateRequest('${req.id}','approve')`}
                    class="px-4 py-2 bg-secondary-500 hover:bg-green-600 text-white rounded-xl text-sm font-medium transition-colors flex items-center gap-1.5">
                    <i class="fas fa-check" aria-hidden="true"></i>Approve
                  </button>
                  <button
                    onclick={`decideGateRequest('${req.id}','reject')`}
                    class="px-4 py-2 bg-white hover:bg-red-50 text-red-600 border border-red-300 rounded-xl text-sm font-medium transition-colors flex items-center gap-1.5">
                    <i class="fas fa-times" aria-hidden="true"></i>Reject
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- ── GUARD: QR / OTP Verification ─────────────────────────────────────── -->
  {isGuard && (
    <>
    <div class="mb-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <!-- OTP verification -->
      <div class="card-premium p-5">
        <h2 class="font-semibold text-text-primary mb-3 flex items-center gap-2">
          <i class="fas fa-key text-primary-500" aria-hidden="true"></i>
          Verify Entry Code (OTP)
        </h2>
        <p class="text-xs text-text-secondary mb-3">Visitor shows a 6-digit code — enter it to verify the pass.</p>
        <div id="otp-result" class="hidden mb-3 p-3 rounded-xl text-sm font-medium"></div>
        <form id="otp-form" class="flex gap-2">
          <input id="otp-input" type="text" inputmode="numeric" pattern="\d{6}" maxlength="6"
            placeholder="6-digit code" required
            class="form-input flex-1 text-center text-xl font-bold tracking-widest py-3 font-mono" />
          <button type="submit" class="btn-primary px-4 py-3 text-sm">
            <i class="fas fa-check" aria-hidden="true"></i>
          </button>
        </form>
      </div>

      <!-- QR scan -->
      <div class="card-premium p-5">
        <h2 class="font-semibold text-text-primary mb-3 flex items-center gap-2">
          <i class="fas fa-qrcode text-primary-500" aria-hidden="true"></i>
          Scan QR Code
        </h2>
        <p class="text-xs text-text-secondary mb-3">Open camera and point at the visitor's QR pass.</p>
        <div id="qr-result" class="hidden mb-3 p-3 rounded-xl text-sm font-medium"></div>
        <div id="qr-scanner-view" class="hidden mb-3 rounded-xl overflow-hidden bg-gray-900 relative" style="aspect-ratio:1">
          <video id="qr-video" class="w-full h-full object-cover" autoplay muted playsinline></video>
          <canvas id="qr-canvas" class="hidden"></canvas>
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class="w-40 h-40 border-2 border-primary-400 rounded-xl"></div>
          </div>
        </div>
        <button id="qr-scan-btn" class="btn-outline w-full text-sm">
          <i class="fas fa-camera mr-2" aria-hidden="true"></i>Open Camera to Scan
        </button>
        <button id="qr-stop-btn" class="hidden btn-outline w-full text-sm border-red-300 text-red-600 hover:bg-red-50 mt-2">
          <i class="fas fa-stop mr-2" aria-hidden="true"></i>Stop Camera
        </button>
      </div>
    </div>

    <!-- Guard: pending gate requests they submitted (waiting for resident decision) -->
    <div id="guard-pending-section" class="hidden mb-4">
      <div class="card-premium p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold text-text-primary flex items-center gap-2">
            <i class="fas fa-clock text-amber-500" aria-hidden="true"></i>
            Approval Requests
          </h2>
          <button id="refresh-pending-btn" class="text-xs text-primary-600 hover:underline" onclick="loadGuardPendingRequests()">
            <i class="fas fa-sync-alt mr-1" aria-hidden="true"></i>Refresh
          </button>
        </div>
        <div id="guard-pending-list" class="space-y-2"></div>
      </div>
    </div>

    <!-- Pass verified modal -->
    <div id="pass-verified-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
      <div class="bg-white rounded-2xl shadow-large w-full max-w-sm overflow-hidden">
        <div id="modal-header" class="p-5 flex items-center gap-3">
          <div id="modal-icon" class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0"></div>
          <div>
            <div id="modal-title" class="font-bold text-text-primary text-lg"></div>
            <div id="modal-sub" class="text-sm text-text-secondary"></div>
          </div>
        </div>
        <div id="modal-body" class="px-5 pb-3 text-sm text-text-secondary space-y-1.5"></div>
        <div class="p-5 flex gap-2">
          <button id="modal-admit-btn" class="btn-primary flex-1 text-sm hidden">
            <i class="fas fa-sign-in-alt mr-2" aria-hidden="true"></i>Admit Visitor
          </button>
          <button id="modal-close-btn" class="btn-outline flex-1 text-sm" onclick="closePassModal()">Close</button>
        </div>
      </div>
    </div>
    </>
  )}

  <!-- ── GUARD: Entry form + Active Visitors ───────────────────────────────── -->
  {isGuard && (
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
      <!-- Log Entry / Request Approval -->
      <div class="bg-white rounded-xl border border-border-light p-6">
        <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
          <i class="fas fa-sign-in-alt text-green-600" aria-hidden="true"></i>
          Log Entry
        </h2>
        <form id="entry-form" class="space-y-3">
          <input type="text" id="entry-visitor-name" placeholder="Visitor name *" required
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
          <input type="text" id="entry-unit" placeholder="Host unit (e.g. A-101) *" required
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
          <select id="entry-type"
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
            <option value="walk_in">Walk-in</option>
            <option value="pre_approved">Pre-Approved</option>
            <option value="delivery">Delivery</option>
            <option value="service">Service</option>
            <option value="vendor">Vendor</option>
          </select>
          <select id="entry-visitor-type"
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
            <option value="">Visitor type (optional)</option>
            {VISITOR_TYPES.map(vt => <option value={vt.value}>{vt.label}</option>)}
          </select>
          <select id="entry-gate"
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
            <option value="">Select gate</option>
          </select>
          <input type="text" id="entry-vehicle" placeholder="Vehicle number (optional)"
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
          <div class="flex gap-2">
            <button type="submit" class="btn-primary flex-1 text-sm">
              <i class="fas fa-sign-in-alt mr-2" aria-hidden="true"></i>Log Entry
            </button>
            <button type="button" id="request-approval-btn" class="btn-outline flex-1 text-sm"
              title="Request resident approval before entry">
              <i class="fas fa-bell mr-2" aria-hidden="true"></i>Request Approval
            </button>
          </div>
        </form>
      </div>

      <!-- Active Visitors -->
      <div class="bg-white rounded-xl border border-border-light p-6">
        <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
          <i class="fas fa-sign-out-alt text-red-600" aria-hidden="true"></i>
          Active Visitors
        </h2>
        <div id="active-visitors" class="space-y-3">
          <p class="text-sm text-text-secondary text-center py-4">Loading…</p>
        </div>
      </div>
    </div>
  )}

  <!-- ── RESIDENT: My Visitor Passes ──────────────────────────────────────── -->
  {!isGuard && (
    <div id="pre-approvals-panel" class="bg-white rounded-xl border border-border-light overflow-hidden mb-6">
      <div class="px-5 py-4 border-b border-border-light bg-gray-50 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-text-primary">My Visitor Passes</h2>
        <a href="/portal/visitors/new" class="btn-primary text-sm py-1.5 px-3">
          <i class="fas fa-qrcode mr-1.5" aria-hidden="true"></i>Create Pass
        </a>
      </div>
      <div id="pre-approvals-list" class="p-5">
        <p class="text-sm text-text-secondary text-center py-4">Loading…</p>
      </div>
    </div>
  )}

  <!-- ── Tabs ──────────────────────────────────────────────────────────────── -->
  <div class="flex gap-1 mb-4 bg-gray-100 rounded-xl p-1 w-fit">
    <button id="tab-logs" onclick="switchTab('logs')"
      class="tab-btn px-4 py-1.5 rounded-lg text-sm font-medium transition-colors bg-white text-text-primary shadow-soft">
      Visitor Logs
    </button>
    <button id="tab-deliveries" onclick="switchTab('deliveries')"
      class="tab-btn px-4 py-1.5 rounded-lg text-sm font-medium transition-colors text-text-secondary hover:text-text-primary">
      Deliveries
    </button>
  </div>

  <!-- Visitor Logs panel -->
  <div id="panel-logs" class="space-y-4">
    {(isExec || isGuard) && (
      <div class="flex flex-wrap items-center gap-3 bg-white border border-border-light rounded-xl px-4 py-3">
        <select id="filter-vtype"
          class="text-sm border border-border-light rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
          <option value="">All types</option>
          {VISITOR_TYPES.map(vt => <option value={vt.value}>{vt.label}</option>)}
        </select>
        <select id="filter-gate"
          class="text-sm border border-border-light rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
          <option value="">All gates</option>
        </select>
        <input type="date" id="filter-date-from"
          class="text-sm border border-border-light rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-primary-600" />
        <span class="text-text-secondary text-sm">to</span>
        <input type="date" id="filter-date-to"
          class="text-sm border border-border-light rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-primary-600" />
        <button id="filter-apply" class="btn-primary text-sm py-2">Apply</button>
        <button id="export-csv" class="btn-outline text-sm py-2 flex items-center gap-1.5 ml-auto">
          <i class="fas fa-download" aria-hidden="true"></i>Export CSV
        </button>
      </div>
    )}

    <div class="bg-white rounded-xl border border-border-light overflow-hidden">
      <div id="visitor-logs-list">
        <p class="text-sm text-text-secondary text-center py-6">Loading…</p>
      </div>
    </div>
  </div>

  <!-- Deliveries panel -->
  <div id="panel-deliveries" class="hidden">
    <div class="bg-white rounded-xl border border-border-light overflow-hidden mb-4">
      <div class="px-5 py-4 border-b border-border-light bg-gray-50 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-text-primary">Delivery Log</h2>
        <input type="date" id="delivery-date"
          class="text-sm border border-border-light rounded-lg px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>
      <div id="deliveries-list" class="p-5">
        <p class="text-sm text-text-secondary text-center py-4">Loading…</p>
      </div>
    </div>

    {isGuard && (
      <div class="bg-white rounded-xl border border-border-light p-5">
        <h2 class="text-lg font-semibold text-text-primary mb-4">Log New Delivery</h2>
        <form id="delivery-form" class="space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-text-primary mb-1">Host Unit <span class="text-red-500">*</span></label>
              <input type="text" id="del-unit" placeholder="e.g. A-101" required
                class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
            <div>
              <label class="block text-xs font-medium text-text-primary mb-1">Courier</label>
              <input type="text" id="del-courier" placeholder="e.g. Zomato, Swiggy"
                class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-text-primary mb-1">Tracking Number</label>
            <input type="text" id="del-tracking" placeholder="Optional"
              class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
          </div>
          <button type="submit" class="btn-primary text-sm">Log Delivery</button>
        </form>
      </div>
    )}
  </div>

</PortalLayout>

<!-- jsQR for QR code decoding in the browser camera feed -->
<script is:inline src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>

<script define:vars={{ isGuard, isExec, userId: user.id }}>
  const STATUS_BADGE = {
    approved:  'bg-green-100 text-green-700',
    pending:   'bg-yellow-100 text-yellow-700',
    used:      'bg-gray-100 text-gray-600',
    expired:   'bg-red-100 text-red-700',
    cancelled: 'bg-red-100 text-red-700',
  };

  let allGates = [];
  let qrStream = null;
  let qrAnimFrame = null;
  let pendingPassToken = null; // token waiting for admit action
  let guardPollTimer = null;

  // ── Tab switching ───────────────────────────────────────────────────────────
  function switchTab(tab) {
    const logs = document.getElementById('panel-logs');
    const deliveries = document.getElementById('panel-deliveries');
    const tabLogs = document.getElementById('tab-logs');
    const tabDel = document.getElementById('tab-deliveries');
    if (tab === 'logs') {
      logs?.classList.remove('hidden'); deliveries?.classList.add('hidden');
      tabLogs?.classList.add('bg-white','text-text-primary','shadow-soft');
      tabLogs?.classList.remove('text-text-secondary');
      tabDel?.classList.remove('bg-white','text-text-primary','shadow-soft');
      tabDel?.classList.add('text-text-secondary');
    } else {
      logs?.classList.add('hidden'); deliveries?.classList.remove('hidden');
      tabDel?.classList.add('bg-white','text-text-primary','shadow-soft');
      tabDel?.classList.remove('text-text-secondary');
      tabLogs?.classList.remove('bg-white','text-text-primary','shadow-soft');
      tabLogs?.classList.add('text-text-secondary');
      loadDeliveries();
    }
  }

  // ── Gates ───────────────────────────────────────────────────────────────────
  async function loadGates() {
    const res = await fetch('/api/v1/visitors/gates', { credentials: 'include' });
    if (!res.ok) return;
    allGates = await res.json();
    ['entry-gate', 'filter-gate'].forEach(id => {
      const el = document.getElementById(id);
      if (!el) return;
      allGates.forEach(g => {
        const opt = document.createElement('option');
        opt.value = g.id; opt.textContent = g.name;
        el.appendChild(opt);
      });
    });
  }

  // ── Visitor Logs ────────────────────────────────────────────────────────────
  function currentLogFilters() {
    return {
      visitor_type: document.getElementById('filter-vtype')?.value ?? '',
      gate_id:      document.getElementById('filter-gate')?.value ?? '',
      date_from:    document.getElementById('filter-date-from')?.value ?? '',
      date_to:      document.getElementById('filter-date-to')?.value ?? '',
    };
  }

  async function loadLogs(filters = {}) {
    const container = document.getElementById('visitor-logs-list');
    if (!container) return;
    const f = { ...currentLogFilters(), ...filters };
    const params = new URLSearchParams({ limit: '100' });
    if (f.visitor_type) params.set('visitor_type', f.visitor_type);
    if (f.gate_id)      params.set('gate_id', f.gate_id);
    if (f.date_from)    params.set('date_from', f.date_from);
    if (f.date_to)      params.set('date_to', f.date_to);

    const res = await fetch(`/api/v1/visitors/logs?${params}`, { credentials: 'include' });
    const logs = res.ok ? await res.json() : [];

    if (!logs.length) {
      container.innerHTML = '<p class="text-sm text-text-secondary text-center py-6">No visitor logs.</p>';
      return;
    }
    container.innerHTML = `
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-border-light">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Visitor</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary hidden md:table-cell">Unit</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Type</th>
            ${(isExec || isGuard) ? '<th class="px-4 py-3 text-left text-xs font-medium text-text-secondary hidden lg:table-cell">Gate</th>' : ''}
            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Entry</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Exit</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border-light">
          ${logs.map(l => `
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-text-primary">${l.visitor_name}</td>
              <td class="px-4 py-3 hidden md:table-cell text-text-secondary">${l.units?.unit_number ?? '—'}</td>
              <td class="px-4 py-3 text-text-secondary capitalize text-xs">
                ${l.visitor_type ? l.visitor_type.replace(/_/g,' ') : (l.entry_type ?? '').replace(/_/g,' ')}
              </td>
              ${(isExec || isGuard) ? `<td class="px-4 py-3 hidden lg:table-cell text-text-secondary text-xs">${l.gates?.name ?? '—'}</td>` : ''}
              <td class="px-4 py-3 text-text-secondary text-xs">${new Date(l.entry_time).toLocaleString('en-IN',{hour:'2-digit',minute:'2-digit',day:'numeric',month:'short'})}</td>
              <td class="px-4 py-3 text-xs ${l.exit_time ? 'text-text-secondary' : 'text-green-600 font-medium'}">
                ${l.exit_time ? new Date(l.exit_time).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) : '● Still inside'}
                ${isGuard && !l.exit_time ? `<button onclick="logExit('${l.id}')" class="ml-2 text-red-600 hover:underline text-xs">Exit</button>` : ''}
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table>`;
  }

  // ── Deliveries ──────────────────────────────────────────────────────────────
  async function loadDeliveries(date) {
    const container = document.getElementById('deliveries-list');
    if (!container) return;
    const d = date ?? new Date().toISOString().slice(0, 10);
    const res = await fetch(`/api/v1/visitors/deliveries?date=${d}`, { credentials: 'include' });
    const items = res.ok ? await res.json() : [];
    if (!items.length) {
      container.innerHTML = '<p class="text-sm text-text-secondary text-center py-4">No deliveries on this date.</p>';
      return;
    }
    container.innerHTML = `
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-border-light">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Unit</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Courier</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Received</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border-light">
          ${items.map(d => `
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-text-primary">${d.units?.unit_number ?? '—'}</td>
              <td class="px-4 py-3 text-text-secondary">${d.courier_company ?? '—'}${d.tracking_number ? ` <span class="text-xs">(${d.tracking_number})</span>` : ''}</td>
              <td class="px-4 py-3 text-xs text-text-secondary">${new Date(d.received_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})}</td>
              <td class="px-4 py-3">
                ${d.collected_at
                  ? `<span class="text-xs text-green-600 font-medium"><i class="fas fa-check-circle"></i> Collected ${new Date(d.collected_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})}</span>`
                  : isGuard
                    ? `<button onclick="markCollected('${d.id}')" class="text-xs bg-green-50 text-green-700 border border-green-200 px-2 py-1 rounded-lg hover:bg-green-100 font-medium">Mark Collected</button>`
                    : '<span class="text-xs text-amber-600 font-medium">Pending pickup</span>'
                }
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table>`;
  }

  // ── My Visitor Passes (resident) ────────────────────────────────────────────
  async function loadMyPasses() {
    const container = document.getElementById('pre-approvals-list');
    if (!container) return;
    const res = await fetch('/api/v1/visitors/passes', { credentials: 'include' });
    if (!res.ok) {
      container.innerHTML = '<p class="text-sm text-red-600 text-center py-4">Failed to load passes.</p>';
      return;
    }
    const data = await res.json();
    if (!data.length) {
      container.innerHTML = `
        <div class="text-center py-8">
          <i class="fas fa-qrcode text-4xl text-primary-200 mb-3" aria-hidden="true"></i>
          <p class="text-sm text-text-secondary">No visitor passes yet.</p>
          <a href="/portal/visitors/new" class="btn-primary text-sm mt-3 inline-flex items-center gap-2">
            <i class="fas fa-plus" aria-hidden="true"></i>Create your first pass
          </a>
        </div>`;
      return;
    }
    const now = new Date();
    container.innerHTML = `<div class="space-y-3">${data.map(p => {
      const validUntil = new Date(p.expires_at ?? p.expected_time_to);
      const isExpired = validUntil < now;
      const usedUp = p.scan_count >= p.max_uses;
      const displayStatus = usedUp ? 'used' : isExpired ? 'expired' : p.status;
      const badge = STATUS_BADGE[displayStatus] ?? 'bg-gray-100 text-gray-600';
      return `
        <div class="flex items-center justify-between p-3 rounded-xl border border-border-light hover:bg-gray-50 transition-colors">
          <div class="min-w-0">
            <div class="font-medium text-sm text-text-primary">${p.visitor_name}</div>
            <div class="text-xs text-text-secondary mt-0.5">
              ${p.purpose ? `${p.purpose} · ` : ''}
              Valid until ${new Date(p.expires_at ?? p.expected_time_to).toLocaleString('en-IN',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'})}
            </div>
            <div class="text-xs text-text-secondary mt-0.5">
              OTP: <span class="font-mono font-bold tracking-wider text-primary-600">${p.otp_code ?? '—'}</span>
              · ${p.scan_count ?? 0}/${p.max_uses ?? 1} entries used
            </div>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0 ml-3">
            <span class="text-xs px-2 py-1 rounded-full font-medium ${badge}">${displayStatus}</span>
            ${p.pass_token ? `<a href="/portal/visitors/pass/${p.pass_token}" class="text-xs text-primary-600 hover:underline font-medium" target="_blank">View Pass</a>` : ''}
          </div>
        </div>`;
    }).join('')}</div>`;
  }

  // ── Active Visitors (guard) ─────────────────────────────────────────────────
  async function loadActiveVisitors() {
    const container = document.getElementById('active-visitors');
    if (!container) return;
    const res = await fetch('/api/v1/visitors/logs', { credentials: 'include' });
    const logs = res.ok ? await res.json() : [];
    const active = logs.filter(l => !l.exit_time);
    if (!active.length) {
      container.innerHTML = '<p class="text-sm text-text-secondary text-center py-4">No active visitors.</p>';
      return;
    }
    container.innerHTML = active.map(l => `
      <div class="flex items-center justify-between p-3 rounded-lg border border-green-200 bg-green-50">
        <div>
          <div class="font-medium text-sm text-text-primary">${l.visitor_name}</div>
          <div class="text-xs text-text-secondary mt-0.5">
            Unit: ${l.units?.unit_number ?? '—'} · In: ${new Date(l.entry_time).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})}
            ${l.visitor_type ? `· ${l.visitor_type.replace(/_/g,' ')}` : ''}
          </div>
        </div>
        <button onclick="logExit('${l.id}')" class="text-xs bg-red-100 text-red-700 hover:bg-red-200 px-3 py-1.5 rounded-lg font-medium transition-colors">
          <i class="fas fa-sign-out-alt mr-1" aria-hidden="true"></i>Log Exit
        </button>
      </div>
    `).join('');
  }

  async function logExit(logId) {
    const res = await fetch(`/api/v1/visitors/logs/${logId}/exit`, { method: 'PUT', credentials: 'include' });
    if (res.ok) loadAll();
    else alert('Failed to log exit.');
  }

  async function markCollected(deliveryId) {
    const res = await fetch(`/api/v1/visitors/deliveries/${deliveryId}/collect`, { method: 'PUT', credentials: 'include' });
    if (res.ok) loadDeliveries(document.getElementById('delivery-date')?.value);
    else alert('Failed to mark as collected.');
  }

  async function loadAll() {
    await Promise.all([
      isGuard ? loadActiveVisitors() : loadMyPasses(),
      loadLogs(),
      isGuard ? loadGuardPendingRequests() : loadPendingGateApprovals(),
    ]);
  }

  // ── OTP Verification (guard) ────────────────────────────────────────────────
  document.getElementById('otp-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const otpInput = document.getElementById('otp-input');
    const otp = otpInput.value.trim();
    if (otp.length !== 6 || !/^\d{6}$/.test(otp)) {
      showOtpResult('error', 'Enter a valid 6-digit code.');
      return;
    }

    // Preview the pass first (GET — no side effects)
    const previewRes = await fetch(`/api/v1/visitors/verify?otp_code=${otp}`, { credentials: 'include' });

    if (!previewRes.ok) {
      const err = await previewRes.json().catch(() => ({}));
      showOtpResult('error', err.message ?? 'Invalid or expired OTP code.');
      return;
    }

    const pass = await previewRes.json();
    // Show modal — actual entry is recorded on "Admit"
    pendingPassToken = null;
    showPassModal(pass, 'otp', otp);
  });

  function showOtpResult(type, msg) {
    const el = document.getElementById('otp-result');
    if (!el) return;
    el.className = `mb-3 p-3 rounded-xl text-sm font-medium ${type === 'error' ? 'bg-red-50 text-red-700' : 'bg-green-50 text-green-700'}`;
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  // ── QR Camera Scan (guard) ──────────────────────────────────────────────────
  document.getElementById('qr-scan-btn')?.addEventListener('click', async () => {
    try {
      qrStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
      const video = document.getElementById('qr-video');
      video.srcObject = qrStream;
      document.getElementById('qr-scanner-view').classList.remove('hidden');
      document.getElementById('qr-scan-btn').classList.add('hidden');
      document.getElementById('qr-stop-btn').classList.remove('hidden');
      scanQrFrame(video);
    } catch {
      document.getElementById('qr-result').textContent = 'Camera access denied. Enter OTP instead.';
      document.getElementById('qr-result').className = 'mb-3 p-3 rounded-xl text-sm font-medium bg-red-50 text-red-700';
      document.getElementById('qr-result').classList.remove('hidden');
    }
  });

  document.getElementById('qr-stop-btn')?.addEventListener('click', stopQrCamera);

  function stopQrCamera() {
    if (qrAnimFrame) { cancelAnimationFrame(qrAnimFrame); qrAnimFrame = null; }
    if (qrStream) { qrStream.getTracks().forEach(t => t.stop()); qrStream = null; }
    document.getElementById('qr-scanner-view')?.classList.add('hidden');
    document.getElementById('qr-scan-btn')?.classList.remove('hidden');
    document.getElementById('qr-stop-btn')?.classList.add('hidden');
  }

  function scanQrFrame(video) {
    if (!qrStream) return;
    const canvas = document.getElementById('qr-canvas');
    if (!canvas) return;
    if (video.readyState !== video.HAVE_ENOUGH_DATA) {
      qrAnimFrame = requestAnimationFrame(() => scanQrFrame(video));
      return;
    }
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(video, 0, 0);
    const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);

    if (typeof jsQR !== 'undefined') {
      const code = jsQR(imageData.data, imageData.width, imageData.height);
      if (code?.data) {
        stopQrCamera();
        handleQrResult(code.data);
        return;
      }
    }
    qrAnimFrame = requestAnimationFrame(() => scanQrFrame(video));
  }

  async function handleQrResult(qrData) {
    // Extract token from URL or raw UUID
    let token = null;
    try {
      const url = new URL(qrData);
      token = url.searchParams.get('token');
    } catch {
      if (/^[0-9a-f-]{36}$/i.test(qrData)) token = qrData;
    }

    if (!token) {
      document.getElementById('qr-result').textContent = 'Invalid QR code — not a visitor pass.';
      document.getElementById('qr-result').className = 'mb-3 p-3 rounded-xl text-sm font-medium bg-red-50 text-red-700';
      document.getElementById('qr-result').classList.remove('hidden');
      return;
    }

    const res = await fetch(`/api/v1/visitors/verify?token=${encodeURIComponent(token)}`, { credentials: 'include' });
    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      document.getElementById('qr-result').textContent = err.message ?? 'Pass not found.';
      document.getElementById('qr-result').className = 'mb-3 p-3 rounded-xl text-sm font-medium bg-red-50 text-red-700';
      document.getElementById('qr-result').classList.remove('hidden');
      return;
    }

    const pass = await res.json();
    pendingPassToken = token;
    showPassModal(pass, 'qr', null);
  }

  // ── Pass Verified Modal ─────────────────────────────────────────────────────
  function showPassModal(pass, method, otpCode) {
    const modal = document.getElementById('pass-verified-modal');
    const icon  = document.getElementById('modal-icon');
    const title = document.getElementById('modal-title');
    const sub   = document.getElementById('modal-sub');
    const body  = document.getElementById('modal-body');
    const admitBtn = document.getElementById('modal-admit-btn');
    if (!modal) return;

    const fmt = iso => new Date(iso).toLocaleString('en-IN',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});

    if (pass.is_valid) {
      icon.className = 'w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 bg-green-100';
      icon.innerHTML = '<i class="fas fa-check-circle text-green-600 text-2xl"></i>';
      title.textContent = pass.visitor_name;
      sub.textContent = 'Pass is valid — visitor may enter';
      sub.className = 'text-sm text-green-600 font-medium';
      admitBtn.classList.remove('hidden');
      admitBtn.onclick = () => admitVisitor(method === 'qr' ? pendingPassToken : null, method === 'otp' ? otpCode : null);
    } else if (pass.is_expired) {
      icon.className = 'w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 bg-red-100';
      icon.innerHTML = '<i class="fas fa-times-circle text-red-600 text-2xl"></i>';
      title.textContent = pass.visitor_name;
      sub.textContent = 'Pass has expired';
      sub.className = 'text-sm text-red-600 font-medium';
      admitBtn.classList.add('hidden');
    } else if (pass.maxed_out) {
      icon.className = 'w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 bg-red-100';
      icon.innerHTML = '<i class="fas fa-ban text-red-600 text-2xl"></i>';
      title.textContent = pass.visitor_name;
      sub.textContent = 'Maximum entries reached';
      sub.className = 'text-sm text-red-600 font-medium';
      admitBtn.classList.add('hidden');
    } else if (pass.not_yet_valid) {
      icon.className = 'w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 bg-amber-100';
      icon.innerHTML = '<i class="fas fa-hourglass-half text-amber-600 text-2xl"></i>';
      title.textContent = pass.visitor_name;
      sub.textContent = 'Pass not yet valid';
      sub.className = 'text-sm text-amber-600 font-medium';
      admitBtn.classList.add('hidden');
    } else {
      icon.className = 'w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 bg-red-100';
      icon.innerHTML = '<i class="fas fa-exclamation-circle text-red-600 text-2xl"></i>';
      title.textContent = pass.visitor_name;
      sub.textContent = `Pass status: ${pass.status}`;
      sub.className = 'text-sm text-red-600 font-medium';
      admitBtn.classList.add('hidden');
    }

    body.innerHTML = [
      pass.purpose ? `<div><i class="fas fa-info-circle mr-1.5 text-primary-400"></i>${pass.purpose}</div>` : '',
      pass.unit ? `<div><i class="fas fa-home mr-1.5 text-primary-400"></i>Flat ${pass.unit.unit_number ?? ''}${pass.unit.block ? ` · Block ${pass.unit.block}` : ''}</div>` : '',
      pass.host ? `<div><i class="fas fa-user mr-1.5 text-primary-400"></i>Host: ${pass.host.display_name ?? '—'}</div>` : '',
      pass.valid_from ? `<div><i class="fas fa-clock mr-1.5 text-primary-400"></i>${fmt(pass.valid_from)} – ${fmt(pass.valid_until)}</div>` : '',
      pass.vehicle_number ? `<div><i class="fas fa-car mr-1.5 text-primary-400"></i>${pass.vehicle_number}</div>` : '',
      pass.guard_note ? `<div class="text-amber-700 bg-amber-50 rounded-lg px-3 py-2"><i class="fas fa-sticky-note mr-1.5"></i>${pass.guard_note}</div>` : '',
      `<div class="text-xs text-text-secondary pt-1">${pass.scan_count}/${pass.max_uses} entries used</div>`,
    ].filter(Boolean).join('');

    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closePassModal() {
    const modal = document.getElementById('pass-verified-modal');
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    pendingPassToken = null;
    // Reset OTP input
    const otpInput = document.getElementById('otp-input');
    if (otpInput) { otpInput.value = ''; }
    document.getElementById('otp-result')?.classList.add('hidden');
    document.getElementById('qr-result')?.classList.add('hidden');
  }

  async function admitVisitor(passToken, otpCode) {
    const body = { action: 'entry' };
    if (passToken) body.pass_token = passToken;
    if (otpCode)   body.otp_code   = otpCode;

    const res = await fetch('/api/v1/visitors/verify', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify(body),
    });

    if (res.ok) {
      const data = await res.json();
      closePassModal();
      showToast(`${data.visitor_name} admitted — entry logged.`, 'success');
      loadAll();
    } else {
      const err = await res.json().catch(() => ({}));
      showToast(err.message ?? 'Failed to record entry.', 'error');
    }
  }

  // ── Gate Approval: Guard side ───────────────────────────────────────────────
  // Guard polls every 10 seconds for updates on requests they submitted
  async function loadGuardPendingRequests() {
    const res = await fetch('/api/v1/visitors/gate-requests?status=pending', { credentials: 'include' });
    if (!res.ok) return;
    const requests = await res.json();

    const section = document.getElementById('guard-pending-section');
    const listEl  = document.getElementById('guard-pending-list');
    if (!section || !listEl) return;

    if (!requests.length) {
      section.classList.add('hidden');
      return;
    }

    section.classList.remove('hidden');
    listEl.innerHTML = requests.map(r => {
      const expires = new Date(r.expires_at);
      const secsLeft = Math.max(0, Math.floor((expires - Date.now()) / 1000));
      const minLeft = Math.floor(secsLeft / 60);
      const isExpired = secsLeft === 0;
      return `
        <div class="flex items-center justify-between p-3 rounded-xl border ${isExpired ? 'border-red-200 bg-red-50' : 'border-amber-200 bg-amber-50'}">
          <div>
            <div class="font-medium text-sm text-text-primary">${r.visitor_name}</div>
            <div class="text-xs text-text-secondary mt-0.5">
              Flat ${r.units?.unit_number ?? '—'}
              ${r.visitor_type ? `· ${r.visitor_type.replace(/_/g,' ')}` : ''}
              · ${isExpired ? '<span class="text-red-600 font-medium">Expired</span>' : `<span class="text-amber-700 font-medium">${minLeft}m remaining</span>`}
            </div>
          </div>
          <div class="flex gap-1.5">
            ${!isExpired ? `<span class="text-xs px-2 py-1 rounded-full bg-amber-200 text-amber-800 font-medium">Waiting</span>` : ''}
            <button onclick="cancelGateRequest('${r.id}')" class="text-xs text-red-600 hover:underline">Cancel</button>
          </div>
        </div>`;
    }).join('');
  }

  async function cancelGateRequest(id) {
    const res = await fetch(`/api/v1/visitors/gate-requests/${id}`, { method: 'DELETE', credentials: 'include' });
    if (res.ok) { loadGuardPendingRequests(); showToast('Request cancelled.', 'success'); }
    else showToast('Failed to cancel request.', 'error');
  }

  // Guard: "Request Approval" button — creates gate request instead of direct log
  document.getElementById('request-approval-btn')?.addEventListener('click', async () => {
    const name      = document.getElementById('entry-visitor-name')?.value.trim();
    const unitText  = document.getElementById('entry-unit')?.value.trim();
    const vtType    = document.getElementById('entry-visitor-type')?.value || null;
    const vehicle   = document.getElementById('entry-vehicle')?.value.trim() || null;

    if (!name || !unitText) {
      alert('Visitor name and host unit are required to request approval.');
      return;
    }

    const unitRes = await fetch(`/api/v1/visitors/lookup-unit?unit_number=${encodeURIComponent(unitText)}`, { credentials: 'include' });
    const unitData = unitRes.ok ? await unitRes.json() : null;
    if (!unitData?.id) { alert('Unit not found. Enter the exact unit number (e.g. A-101).'); return; }

    const res = await fetch('/api/v1/visitors/gate-requests', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify({ visitor_name: name, visitor_type: vtType, vehicle_number: vehicle, host_unit_id: unitData.id }),
    });

    if (res.ok) {
      showToast(`Approval requested for ${name} — waiting for resident response.`, 'success');
      loadGuardPendingRequests();
      // Start polling every 10s
      clearInterval(guardPollTimer);
      guardPollTimer = setInterval(loadGuardPendingRequests, 10000);
    } else {
      const d = await res.json().catch(() => ({}));
      showToast(d.message ?? 'Failed to send request.', 'error');
    }
  });

  // ── Gate Approval: Resident side ────────────────────────────────────────────
  async function loadPendingGateApprovals() {
    if (isGuard) return;
    const res = await fetch('/api/v1/visitors/gate-requests?status=pending', { credentials: 'include' });
    if (!res.ok) return;
    const requests = (await res.json()).filter(r => !r.is_expired);

    const section = document.getElementById('gate-approvals-section');
    const badge   = document.getElementById('gate-count-badge');
    const listEl  = document.getElementById('gate-approvals-list');
    if (!section) return;

    if (!requests.length) {
      section.classList.add('hidden');
      return;
    }

    section.classList.remove('hidden');
    if (badge) badge.textContent = requests.length;

    if (listEl) {
      listEl.innerHTML = requests.map(r => `
        <div class="gate-request-card px-5 py-4" data-id="${r.id}">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-amber-200 flex items-center justify-center flex-shrink-0 mt-0.5">
              <i class="fas fa-user text-amber-700"></i>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="font-semibold text-text-primary">${r.visitor_name}</span>
                ${r.visitor_type ? `<span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 text-amber-800 font-medium capitalize">${r.visitor_type.replace(/_/g,' ')}</span>` : ''}
              </div>
              ${r.purpose ? `<p class="text-sm text-text-secondary mt-0.5">${r.purpose}</p>` : ''}
              <div class="flex items-center gap-3 mt-1 text-xs text-text-secondary flex-wrap">
                ${r.vehicle_number ? `<span><i class="fas fa-car mr-1"></i>${r.vehicle_number}</span>` : ''}
                <span><i class="fas fa-shield-alt mr-1"></i>Guard: ${r.profiles?.display_name ?? 'Security guard'}</span>
                <span class="text-amber-600 font-medium gate-countdown" data-expires="${r.expires_at}"></span>
              </div>
            </div>
            <div class="flex flex-col gap-2 flex-shrink-0">
              <button onclick="decideGateRequest('${r.id}','approve')"
                class="px-4 py-2 bg-secondary-500 hover:bg-green-600 text-white rounded-xl text-sm font-medium transition-colors">
                <i class="fas fa-check mr-1"></i>Approve
              </button>
              <button onclick="decideGateRequest('${r.id}','reject')"
                class="px-4 py-2 bg-white hover:bg-red-50 text-red-600 border border-red-300 rounded-xl text-sm font-medium transition-colors">
                <i class="fas fa-times mr-1"></i>Reject
              </button>
            </div>
          </div>
        </div>`).join('');
    }

    // Start countdown timers
    startCountdowns();
  }

  async function decideGateRequest(id, action) {
    let note = '';
    if (action === 'reject') {
      note = prompt('Reason for rejection (optional):') ?? '';
    }

    const res = await fetch(`/api/v1/visitors/gate-requests/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify({ action, note: note || undefined }),
    });

    if (res.ok) {
      const data = await res.json();
      // Remove the card from UI
      document.querySelector(`.gate-request-card[data-id="${id}"]`)?.remove();
      const remaining = document.querySelectorAll('.gate-request-card').length;
      if (!remaining) document.getElementById('gate-approvals-section')?.classList.add('hidden');
      const badge = document.getElementById('gate-count-badge');
      if (badge) badge.textContent = remaining;

      const msg = action === 'approve'
        ? `${data.visitor_name ?? 'Visitor'} approved — entry has been logged.`
        : `${data.visitor_name ?? 'Visitor'} rejected.`;
      showToast(msg, action === 'approve' ? 'success' : 'error');
    } else {
      const err = await res.json().catch(() => ({}));
      showToast(err.message ?? 'Action failed. Please try again.', 'error');
    }
  }

  function startCountdowns() {
    document.querySelectorAll('.gate-countdown').forEach(el => {
      const expires = new Date(el.dataset.expires);
      const tick = () => {
        const secsLeft = Math.max(0, Math.floor((expires - Date.now()) / 1000));
        if (secsLeft === 0) {
          el.textContent = 'Expired';
          el.closest('.gate-request-card')?.remove();
          return;
        }
        const m = Math.floor(secsLeft / 60);
        const s = secsLeft % 60;
        el.textContent = `${m}:${String(s).padStart(2,'0')} remaining`;
        setTimeout(tick, 1000);
      };
      tick();
    });
  }

  // ── Filter bar events ───────────────────────────────────────────────────────
  document.getElementById('filter-apply')?.addEventListener('click', () => loadLogs());

  document.getElementById('export-csv')?.addEventListener('click', async () => {
    const f = currentLogFilters();
    const params = new URLSearchParams();
    if (f.visitor_type) params.set('visitor_type', f.visitor_type);
    if (f.gate_id)      params.set('gate_id', f.gate_id);
    if (f.date_from)    params.set('date_from', f.date_from);
    if (f.date_to)      params.set('date_to', f.date_to);
    const res = await fetch(`/api/v1/visitors/export?${params}`, { credentials: 'include' });
    if (!res.ok) { alert('Export failed. Please try again.'); return; }
    const blob = await res.blob();
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = `visitor-logs-${new Date().toISOString().slice(0,10)}.csv`;
    a.click(); URL.revokeObjectURL(url);
  });

  // ── Entry form (guard) ──────────────────────────────────────────────────────
  document.getElementById('entry-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name       = document.getElementById('entry-visitor-name').value.trim();
    const unitText   = document.getElementById('entry-unit').value.trim();
    const entryType  = document.getElementById('entry-type').value;
    const visitorType = document.getElementById('entry-visitor-type').value || null;
    const gateId     = document.getElementById('entry-gate').value || null;
    const vehicle    = document.getElementById('entry-vehicle').value.trim();

    if (!name || !unitText) return alert('Visitor name and host unit are required.');

    const unitRes = await fetch(`/api/v1/visitors/lookup-unit?unit_number=${encodeURIComponent(unitText)}`, { credentials: 'include' });
    const unitData = unitRes.ok ? await unitRes.json() : null;
    if (!unitData?.id) return alert('Unit not found. Please enter exact unit number (e.g. A-101).');

    const res = await fetch('/api/v1/visitors/logs', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
      body: JSON.stringify({
        visitor_name: name, host_unit_id: unitData.id, entry_type: entryType,
        visitor_type: visitorType, gate_id: gateId, vehicle_number: vehicle || null,
      }),
    });

    if (res.ok) {
      document.getElementById('entry-visitor-name').value = '';
      document.getElementById('entry-unit').value = '';
      document.getElementById('entry-vehicle').value = '';
      loadAll();
      showToast('Entry logged successfully.', 'success');
    } else {
      const d = await res.json();
      alert(d.detail ?? 'Failed to log entry.');
    }
  });

  // ── Delivery date picker ────────────────────────────────────────────────────
  const deliveryDateInput = document.getElementById('delivery-date');
  if (deliveryDateInput) {
    deliveryDateInput.value = new Date().toISOString().slice(0, 10);
    deliveryDateInput.addEventListener('change', () => loadDeliveries(deliveryDateInput.value));
  }

  // ── Delivery form (guard) ───────────────────────────────────────────────────
  document.getElementById('delivery-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const unitText = document.getElementById('del-unit').value.trim();
    const courier  = document.getElementById('del-courier').value.trim();
    const tracking = document.getElementById('del-tracking').value.trim();

    const unitRes = await fetch(`/api/v1/visitors/lookup-unit?unit_number=${encodeURIComponent(unitText)}`, { credentials: 'include' });
    const unitData = unitRes.ok ? await unitRes.json() : null;
    if (!unitData?.id) return alert('Unit not found. Please enter exact unit number (e.g. A-101).');

    const res = await fetch('/api/v1/visitors/deliveries', {
      method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ unit_id: unitData.id, courier_company: courier || null, tracking_number: tracking || null }),
    });

    if (res.ok) {
      document.getElementById('del-unit').value = '';
      document.getElementById('del-courier').value = '';
      document.getElementById('del-tracking').value = '';
      loadDeliveries(deliveryDateInput?.value);
      showToast('Delivery logged.', 'success');
    } else {
      const d = await res.json();
      alert(d.detail ?? d.error ?? 'Failed to log delivery.');
    }
  });

  // ── Toast ───────────────────────────────────────────────────────────────────
  function showToast(message, type) {
    const toast = document.createElement('div');
    const color = type === 'success' ? 'bg-secondary-500' : 'bg-red-500';
    toast.className = `fixed bottom-6 right-6 z-50 px-4 py-3 rounded-xl shadow-large text-sm font-medium text-white transform translate-y-4 opacity-0 transition-all duration-300 ${color}`;
    toast.textContent = message;
    document.body.appendChild(toast);
    requestAnimationFrame(() => toast.classList.remove('translate-y-4', 'opacity-0'));
    setTimeout(() => {
      toast.classList.add('translate-y-4', 'opacity-0');
      setTimeout(() => toast.remove(), 300);
    }, 3500);
  }

  // ── Expose globals for inline onclick handlers ──────────────────────────────
  window.switchTab          = switchTab;
  window.markCollected      = markCollected;
  window.logExit            = logExit;
  window.closePassModal     = closePassModal;
  window.decideGateRequest  = decideGateRequest;
  window.cancelGateRequest  = cancelGateRequest;
  window.loadGuardPendingRequests = loadGuardPendingRequests;

  // ── Init ────────────────────────────────────────────────────────────────────
  loadGates().then(() => loadAll());

  // Resident: poll for new gate requests every 30 seconds while page is open
  if (!isGuard) {
    setInterval(loadPendingGateApprovals, 30000);
  }
</script>

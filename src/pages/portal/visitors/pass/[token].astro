---
export const prerender = false;
// Public page — no auth required. Anyone with the URL can see the pass.
import { getSupabaseServiceClient } from '@lib/services/providers/supabase/SupabaseDB';

const { token } = Astro.params;
if (!token) return Astro.redirect('/portal');

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const PORTAL_URL = import.meta.env.PUBLIC_PORTAL_URL ?? 'https://portal.utamacs.org';
const sb = getSupabaseServiceClient();

const { data: pass, error } = await sb
  .from('visitor_pre_approvals')
  .select(`
    id, visitor_name, purpose, expected_time_from, expected_time_to, expires_at,
    status, otp_code, scan_count, max_uses, guard_note, vehicle_number,
    host_user_id,
    units!host_unit_id(unit_number, block)
  `)
  .eq('pass_token', token)
  .eq('society_id', SOCIETY_ID)
  .single();

if (error || !pass) {
  return new Response('Pass not found or cancelled.', { status: 404 });
}

// Fetch host display name separately (avoids FK resolution issues across auth.users/profiles)
let hostDisplayName: string | null = null;
if (pass.host_user_id) {
  const { data: profile } = await sb.from('profiles').select('display_name').eq('id', pass.host_user_id).single();
  hostDisplayName = (profile as { display_name?: string } | null)?.display_name ?? null;
}

const now = new Date();
const validUntil = new Date(pass.expires_at);
const validFrom  = pass.expected_time_from ? new Date(pass.expected_time_from) : null;
const isExpired  = validUntil < now;
const notYet     = validFrom ? validFrom > now : false;
const maxedOut   = pass.scan_count >= pass.max_uses;
const isValid    = !isExpired && !notYet && !maxedOut && pass.status === 'approved';

const hostName    = hostDisplayName ?? 'A resident';
const unitLabel   = pass.units ? `Flat ${(pass.units as { unit_number?: string; block?: string }).unit_number ?? ''}${(pass.units as { block?: string }).block ? ` · Block ${(pass.units as { block?: string }).block}` : ''}` : '';

const fmtDate = (iso: string) => new Date(iso).toLocaleDateString('en-IN', {
  weekday: 'short', day: 'numeric', month: 'long', year: 'numeric'
});
const fmtTime = (iso: string) => new Date(iso).toLocaleTimeString('en-IN', {
  hour: '2-digit', minute: '2-digit', hour12: true
});

const verifyUrl = `${PORTAL_URL}/api/v1/visitors/verify?token=${token}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>Visitor Pass — Urban Trilla Apartments</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" />
  <!-- QR code generation — client-side, no personal data sent externally -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js" crossorigin="anonymous" defer></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: #F0F4F8;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 24px 16px 48px;
    }
    .pass-wrap { width: 100%; max-width: 420px; }
    .pass-card {
      background: #fff;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(30,58,138,0.12), 0 2px 8px rgba(0,0,0,0.06);
    }
    .pass-header {
      background: #1E3A8A;
      padding: 24px 24px 20px;
      color: #fff;
    }
    .pass-header-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }
    .pass-logo { display: flex; align-items: center; gap: 10px; }
    .pass-logo-icon {
      width: 36px; height: 36px;
      background: rgba(255,255,255,0.2);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
    }
    .pass-logo-text { font-size: 15px; font-weight: 700; letter-spacing: -0.3px; }
    .pass-logo-sub { font-size: 11px; opacity: 0.75; margin-top: 1px; }
    .status-chip {
      padding: 4px 12px;
      border-radius: 100px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }
    .chip-valid   { background: rgba(16,185,129,0.2); color: #6EE7B7; }
    .chip-expired { background: rgba(239,68,68,0.2);  color: #FCA5A5; }
    .chip-used    { background: rgba(156,163,175,0.2); color: #D1D5DB; }
    .chip-soon    { background: rgba(245,158,11,0.2);  color: #FCD34D; }
    .pass-host {
      font-size: 20px;
      font-weight: 700;
      line-height: 1.2;
    }
    .pass-host-sub {
      font-size: 13px;
      opacity: 0.8;
      margin-top: 4px;
    }
    .pass-body { padding: 24px; }
    .visitor-name {
      font-size: 22px;
      font-weight: 800;
      color: #111827;
      margin-bottom: 4px;
    }
    .visitor-sub {
      font-size: 13px;
      color: #6B7280;
      margin-bottom: 20px;
    }

    /* QR section */
    .qr-section {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 20px 0;
    }
    #qr-canvas {
      border-radius: 12px;
      padding: 10px;
      background: #fff;
      border: 1px solid #E5E7EB;
    }
    .or-divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 16px 0;
      color: #9CA3AF;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 1px;
      width: 100%;
    }
    .or-divider::before, .or-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #E5E7EB;
    }

    /* OTP pill */
    .otp-pill {
      background: #1E3A8A;
      border-radius: 16px;
      padding: 14px 32px;
      text-align: center;
      width: 100%;
    }
    .otp-label { font-size: 11px; color: rgba(255,255,255,0.7); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }
    .otp-code  {
      font-size: 40px;
      font-weight: 800;
      color: #fff;
      letter-spacing: 6px;
      font-variant-numeric: tabular-nums;
    }

    /* Validity row */
    .validity-block {
      margin-top: 20px;
      padding: 14px 16px;
      background: #F8FAFC;
      border-radius: 12px;
      border: 1px solid #E5E7EB;
    }
    .validity-row {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 13px;
      color: #374151;
    }
    .validity-row + .validity-row { margin-top: 8px; }
    .validity-icon { color: #6B7280; width: 16px; flex-shrink: 0; margin-top: 1px; text-align: center; }
    .validity-label { font-weight: 600; }
    .validity-value { color: #6B7280; margin-top: 1px; font-size: 12px; }

    /* Status banner */
    .status-banner {
      margin-top: 16px;
      padding: 12px 14px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      font-weight: 500;
    }
    .banner-valid   { background: #ECFDF5; color: #065F46; border: 1px solid #A7F3D0; }
    .banner-expired { background: #FEF2F2; color: #991B1B; border: 1px solid #FECACA; }
    .banner-used    { background: #F9FAFB; color: #374151; border: 1px solid #E5E7EB; }
    .banner-soon    { background: #FFFBEB; color: #92400E; border: 1px solid #FDE68A; }

    .guard-note {
      margin-top: 12px;
      padding: 10px 14px;
      background: #FFFBEB;
      border: 1px solid #FDE68A;
      border-radius: 10px;
      font-size: 12px;
      color: #92400E;
    }

    .pass-footer {
      padding: 14px 24px 20px;
      border-top: 1px solid #F3F4F6;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .footer-address { font-size: 11px; color: #9CA3AF; line-height: 1.5; }

    /* Action buttons */
    .actions {
      margin-top: 16px;
      display: flex;
      gap: 10px;
    }
    .btn-download {
      flex: 1;
      background: #1E3A8A;
      color: #fff;
      border: none;
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-family: inherit;
    }
    .btn-download:hover { background: #1e40af; }
    .btn-share {
      background: #fff;
      color: #1E3A8A;
      border: 1.5px solid #1E3A8A;
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-family: inherit;
    }
    .btn-share:hover { background: #EFF6FF; }

    /* Expired overlay on QR */
    .qr-expired-overlay {
      position: relative;
    }
    .qr-expired-overlay::after {
      content: 'EXPIRED';
      position: absolute;
      inset: 0;
      background: rgba(239,68,68,0.85);
      color: #fff;
      font-size: 18px;
      font-weight: 800;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 12px;
      letter-spacing: 2px;
    }

    @media print {
      body { background: #fff; padding: 0; }
      .actions { display: none; }
    }
  </style>
</head>
<body>

<div class="pass-wrap">
  <!-- The pass card — this is also what gets rendered to canvas -->
  <div class="pass-card" id="pass-card">

    <!-- Header -->
    <div class="pass-header">
      <div class="pass-header-top">
        <div class="pass-logo">
          <div class="pass-logo-icon">
            <i class="fas fa-building" style="color:#fff; font-size:16px;"></i>
          </div>
          <div>
            <div class="pass-logo-text">UTA MACS</div>
            <div class="pass-logo-sub">Urban Trilla Apartments</div>
          </div>
        </div>
        <span class={`status-chip ${isValid ? 'chip-valid' : isExpired ? 'chip-expired' : notYet ? 'chip-soon' : 'chip-used'}`}>
          {isValid ? 'Valid' : isExpired ? 'Expired' : notYet ? 'Upcoming' : 'Used'}
        </span>
      </div>

      <div class="pass-host">{hostName} has invited you</div>
      {unitLabel && <div class="pass-host-sub">{unitLabel} · Kondakal, Shankarpalle</div>}
    </div>

    <!-- Body -->
    <div class="pass-body">
      <div class="visitor-name">{pass.visitor_name}</div>
      {pass.purpose && <div class="visitor-sub">{pass.purpose}</div>}

      <!-- QR + OTP -->
      <div class="qr-section">
        <div class={isExpired || maxedOut ? 'qr-expired-overlay' : ''} style="position:relative;">
          <div id="qr-canvas"></div>
        </div>

        <div class="or-divider">OR</div>

        <div class="otp-pill">
          <div class="otp-label">Entry Code</div>
          <div class="otp-code" id="otp-display">
            {pass.otp_code.split('').join(' ')}
          </div>
        </div>
      </div>

      <!-- Validity -->
      <div class="validity-block">
        {validFrom && (
          <div class="validity-row">
            <i class="fas fa-sign-in-alt validity-icon"></i>
            <div>
              <div class="validity-label">Valid from</div>
              <div class="validity-value">{fmtDate(pass.expected_time_from!)} · {fmtTime(pass.expected_time_from!)}</div>
            </div>
          </div>
        )}
        <div class={`validity-row ${validFrom ? 'mt-2' : ''}`}>
          <i class="fas fa-sign-out-alt validity-icon"></i>
          <div>
            <div class="validity-label">Valid until</div>
            <div class="validity-value">{fmtDate(pass.expires_at)} · {fmtTime(pass.expires_at)}</div>
          </div>
        </div>
        {pass.vehicle_number && (
          <div class="validity-row mt-2">
            <i class="fas fa-car validity-icon"></i>
            <div>
              <div class="validity-label">Vehicle</div>
              <div class="validity-value">{pass.vehicle_number}</div>
            </div>
          </div>
        )}
        {pass.max_uses > 1 && (
          <div class="validity-row mt-2">
            <i class="fas fa-repeat validity-icon"></i>
            <div>
              <div class="validity-label">Multi-entry</div>
              <div class="validity-value">{pass.scan_count} of {pass.max_uses} entries used</div>
            </div>
          </div>
        )}
      </div>

      <!-- Status banner -->
      <div class={`status-banner ${isValid ? 'banner-valid' : isExpired ? 'banner-expired' : notYet ? 'banner-soon' : 'banner-used'}`}>
        <i class={`fas ${isValid ? 'fa-check-circle' : isExpired ? 'fa-times-circle' : notYet ? 'fa-clock' : 'fa-check-double'}`}></i>
        <span>
          {isValid   ? 'Show this QR code or entry code at the gate' : ''}
          {isExpired ? 'This pass has expired and is no longer valid' : ''}
          {notYet    ? `Pass becomes valid from ${fmtTime(pass.expected_time_from!)}` : ''}
          {maxedOut && !isExpired ? 'All entry uses have been consumed for this pass' : ''}
        </span>
      </div>

      {pass.guard_note && (
        <div class="guard-note">
          <i class="fas fa-info-circle mr-1"></i>{pass.guard_note}
        </div>
      )}
    </div>

    <!-- Footer -->
    <div class="pass-footer">
      <div class="footer-address">
        Urban Trilla Apartments<br />
        Kondakal, Shankarpalle, RR Dist. · Telangana
      </div>
      <i class="fas fa-qrcode" style="color:#D1D5DB; font-size:20px;"></i>
    </div>
  </div>

  <!-- Download + Share actions (outside the card, not in screenshot) -->
  {isValid && (
    <div class="actions" id="action-bar">
      <button class="btn-download" id="download-btn" type="button">
        <i class="fas fa-download"></i> Download Pass
      </button>
      <button class="btn-share" id="share-btn" type="button">
        <i class="fas fa-share-alt"></i> Share
      </button>
    </div>
  )}
</div>

<script define:vars={{ token, verifyUrl, otpCode: pass.otp_code, visitorName: pass.visitor_name, isValid }}>
// Generate QR code — try immediately (if qrcodejs already loaded), then wait for it
function tryRenderQR() {
  const qrContainer = document.getElementById('qr-canvas');
  if (!qrContainer) return false;
  if (typeof window.QRCode === 'undefined') return false;
  // Guard against double-render if already has child nodes
  if (qrContainer.childNodes.length > 0) return true;
  try {
    new window.QRCode(qrContainer, {
      text: verifyUrl,
      width: 200,
      height: 200,
      colorDark: '#1E3A8A',
      colorLight: '#FFFFFF',
      correctLevel: window.QRCode.CorrectLevel.M,
    });
  } catch (e) {
    qrContainer.innerHTML = '<p style="font-size:11px;color:#9CA3AF;text-align:center;padding:8px;">QR unavailable — use entry code above</p>';
  }
  return true;
}

// Try on DOMContentLoaded (fires after deferred scripts run), then on load, then poll
document.addEventListener('DOMContentLoaded', () => { tryRenderQR(); });
window.addEventListener('load', () => {
  if (!tryRenderQR()) {
    // qrcodejs CDN may be slow — poll for up to 5 s
    let attempts = 0;
    const poll = setInterval(() => {
      if (tryRenderQR() || ++attempts >= 10) clearInterval(poll);
    }, 500);
  }
});

// Download the pass as a PNG image using canvas
document.getElementById('download-btn')?.addEventListener('click', async () => {
  const card = document.getElementById('pass-card');
  if (!card) return;

  const btn = document.getElementById('download-btn');
  if (btn) btn.textContent = 'Preparing…';

  try {
    // Use html2canvas via CDN if available, else fallback to print
    if (typeof window.html2canvas !== 'undefined') {
      const canvas = await window.html2canvas(card, {
        scale: 2,
        useCORS: true,
        backgroundColor: '#ffffff',
        logging: false,
      });
      const link = document.createElement('a');
      link.download = `utamacs-pass-${visitorName.replace(/\s+/g, '-')}.png`;
      link.href = canvas.toDataURL('image/png');
      link.click();
    } else {
      // Fallback: open print dialog
      window.print();
    }
  } catch {
    window.print();
  } finally {
    if (btn) { btn.innerHTML = '<i class="fas fa-download"></i> Download Pass'; }
  }
});

// Share via Web Share API
document.getElementById('share-btn')?.addEventListener('click', async () => {
  const shareUrl = window.location.href;
  const shareText = `${visitorName} is invited to Urban Trilla Apartments.\nEntry code: ${otpCode.split('').join(' ')}\nPass: ${shareUrl}`;

  if (navigator.share) {
    try {
      await navigator.share({ title: 'Visitor Pass — UTA MACS', text: shareText, url: shareUrl });
    } catch { /* user cancelled */ }
  } else {
    await navigator.clipboard.writeText(shareText).catch(() => {});
    const btn = document.getElementById('share-btn');
    if (btn) {
      btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
      setTimeout(() => { btn.innerHTML = '<i class="fas fa-share-alt"></i> Share'; }, 2000);
    }
  }
});
</script>

<!-- Load html2canvas for better image export -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js" crossorigin="anonymous" defer></script>

</body>
</html>

</PortalLayout>

<script>
  // ── Helper utilities ─────────────────────────────────────────────────────────
  function fmt(n: number) {
    return n >= 100000 ? `₹${(n/100000).toFixed(1)}L` : n >= 1000 ? `₹${(n/1000).toFixed(1)}K` : `₹${n}`;
  }
  function bar(label: string, value: number, max: number, color: string, suffix = '') {
    const pct = max > 0 ? Math.max(2, (value/max)*100) : 0;
    return `<div><div class="flex items-center justify-between text-xs text-text-secondary mb-1">
      <span>${label}</span><span class="font-medium text-text-primary">${value}${suffix}</span></div>
      <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden">
        <div class="h-full rounded-full" style="width:${pct}%;background:${color}"></div>
      </div></div>`;
  }
  function tbl(headers: string[], rows: (string|number)[][], colClass?: string[]) {
    const hdr = headers.map((h, i) => `<th class="text-left px-4 py-2.5 text-xs font-semibold text-text-secondary uppercase tracking-wide whitespace-nowrap ${colClass?.[i] ?? ''}">${h}</th>`).join('');
    const bdy = rows.map(r =>
      `<tr class="hover:bg-gray-50 border-t border-border-light">${r.map((c, i) =>
        `<td class="px-4 py-3 text-sm text-text-primary whitespace-nowrap ${colClass?.[i] ?? ''}">${c}</td>`
      ).join('')}</tr>`
    ).join('');
    return `<div class="overflow-x-auto"><table class="w-full"><thead class="bg-gray-50"><tr>${hdr}</tr></thead><tbody>${bdy}</tbody></table></div>`;
  }
  function emptyState(msg: string) {
    return `<div class="text-center py-12 text-text-secondary text-sm">${msg}</div>`;
  }
  function fmtDate(d: string|null) {
    return d ? new Date(d).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) : '—';
  }

  // ── Nav routing ──────────────────────────────────────────────────────────────
  let activeReport = 'overview';

  function showReport(id: string) {
    activeReport = id;
    document.querySelectorAll<HTMLElement>('.report-panel').forEach(p => p.classList.add('hidden'));
    const panel = document.getElementById(`panel-${id}`);
    if (panel) panel.classList.remove('hidden');
    document.querySelectorAll<HTMLButtonElement>('.report-nav-btn').forEach(btn => {
      const isActive = btn.getAttribute('data-report') === id;
      btn.className = `report-nav-btn w-full flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-left transition-colors ${
        isActive ? 'bg-primary-100 text-primary-700 font-medium' : 'text-text-secondary hover:bg-primary-50 hover:text-primary-700'
      }`;
    });
    (document.getElementById('mobile-report-select') as HTMLSelectElement).value = id;
    if (id === 'overview' && !overviewLoaded) loadOverview();
  }

  document.querySelectorAll<HTMLButtonElement>('.report-nav-btn').forEach(btn => {
    btn.addEventListener('click', () => showReport(btn.getAttribute('data-report')!));
  });
  document.getElementById('mobile-report-select')?.addEventListener('change', (e) => {
    showReport((e.target as HTMLSelectElement).value);
  });

  // ── Overview ─────────────────────────────────────────────────────────────────
  let overviewLoaded = false;
  const STATUS_COLORS: Record<string,string> = {
    Open:'#1E3A8A', Assigned:'#7C3AED', In_Progress:'#F59E0B',
    Resolved:'#10B981', Closed:'#6B7280', Waiting_for_User:'#EF4444',
  };

  async function loadOverview() {
    overviewLoaded = true;
    const res = await fetch('/api/v1/admin/analytics', { credentials: 'include' });
    if (!res.ok) {
      document.getElementById('ov-loading')!.innerHTML = '<div class="col-span-4 text-center py-6 text-red-500 text-sm">Failed to load analytics.</div>';
      return;
    }
    const d = await res.json();
    document.getElementById('ov-loading')!.classList.add('hidden');
    document.getElementById('ov-content')!.classList.remove('hidden');

    const kpis = [
      { label:'Open Complaints', value:d.complaints.open, sub:`of ${d.complaints.total} total`, color:'text-orange-600' },
      { label:'Collection Rate',  value:`${d.finance.collection_rate}%`, sub:`${fmt(d.finance.paid)} collected`, color: d.finance.collection_rate >= 80 ? 'text-green-600' : 'text-red-600' },
      { label:'Visitors (30d)',   value:d.visitors.last_30d, sub:'entries logged', color:'text-blue-600' },
      { label:'Active Members',   value:d.members.total, sub:`${d.members.owners} owners · ${d.members.tenants} tenants`, color:'text-primary-600' },
    ];
    document.getElementById('kpi-cards')!.innerHTML = kpis.map(k =>
      `<div class="bg-white rounded-xl border border-border-light p-5">
        <div class="text-xs font-medium text-text-secondary mb-2">${k.label}</div>
        <div class="text-2xl font-bold ${k.color}">${k.value}</div>
        <div class="text-xs text-text-secondary mt-1">${k.sub}</div>
      </div>`
    ).join('');

    const statusEntries = Object.entries(d.complaints.by_status as Record<string,number>).sort((a,b) => b[1]-a[1]);
    const maxS = Math.max(...statusEntries.map(([,v]) => v), 1);
    document.getElementById('complaint-chart')!.innerHTML = statusEntries.map(([s,c]) =>
      bar(s.replace('_',' '), c, maxS, STATUS_COLORS[s] ?? '#9CA3AF')
    ).join('');

    const { paid, pending, total_dues } = d.finance;
    const paidPct = total_dues > 0 ? Math.round((paid/total_dues)*100) : 0;
    document.getElementById('finance-chart')!.innerHTML = `
      <div class="flex items-center gap-4 mb-4">
        <div class="relative w-20 h-20 flex-shrink-0">
          <svg viewBox="0 0 36 36" class="w-20 h-20 -rotate-90">
            <circle cx="18" cy="18" r="15.9" fill="none" stroke="#E5E7EB" stroke-width="3"/>
            <circle cx="18" cy="18" r="15.9" fill="none" stroke="#10B981" stroke-width="3"
              stroke-dasharray="${paidPct} ${100-paidPct}" stroke-linecap="round"/>
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-sm font-bold text-text-primary">${paidPct}%</span>
          </div>
        </div>
        <div class="space-y-1.5 text-sm">
          <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-green-500"></div>
            <span class="text-text-secondary">Collected:</span><span class="font-medium">${fmt(paid)}</span></div>
          <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-red-400"></div>
            <span class="text-text-secondary">Pending:</span><span class="font-medium">${fmt(pending)}</span></div>
          <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-gray-300"></div>
            <span class="text-text-secondary">Total:</span><span class="font-medium">${fmt(total_dues)}</span></div>
        </div>
      </div>`;

    const trend = d.visitors.daily_trend as { date:string; count:number }[];
    const maxV = Math.max(...trend.map(t => t.count), 1);
    document.getElementById('visitor-trend')!.innerHTML = trend.map(t => {
      const h = Math.max(4, Math.round((t.count/maxV)*96));
      return `<div class="flex-1 bg-primary-600 rounded-t opacity-75 hover:opacity-100 transition-opacity" style="height:${h}px" title="${t.date}: ${t.count}"></div>`;
    }).join('');
    document.getElementById('visitor-dates')!.innerHTML = trend.map((t,i) => {
      const show = i === 0 || i === 6 || i === 13;
      return `<div class="flex-1 text-center text-xs text-text-secondary truncate">${show ? new Date(t.date).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) : ''}</div>`;
    }).join('');

    const typeEntries = Object.entries(d.visitors.by_type as Record<string,number>).sort((a,b) => b[1]-a[1]);
    const maxT = Math.max(...typeEntries.map(([,v]) => v), 1);
    document.getElementById('visitor-types')!.innerHTML = typeEntries.length
      ? typeEntries.map(([t,c]) => bar(t.replace('_',' '), c, maxT, '#1E3A8A')).join('')
      : emptyState('No visitor data.');

    const { owners, tenants, total } = d.members;
    const ownerPct = total > 0 ? Math.round((owners/total)*100) : 0;
    document.getElementById('member-composition')!.innerHTML = `
      <div class="flex h-4 bg-gray-100 rounded-full overflow-hidden mb-3">
        <div class="h-full bg-primary-600" style="width:${ownerPct}%"></div>
        <div class="h-full bg-secondary-500" style="width:${100-ownerPct}%"></div>
      </div>
      <div class="grid grid-cols-2 gap-4 text-center">
        <div class="p-4 bg-blue-50 rounded-xl"><div class="text-2xl font-bold text-primary-600">${owners}</div><div class="text-xs text-text-secondary mt-1">Owners (${ownerPct}%)</div></div>
        <div class="p-4 bg-green-50 rounded-xl"><div class="text-2xl font-bold text-green-600">${tenants}</div><div class="text-xs text-text-secondary mt-1">Tenants (${100-ownerPct}%)</div></div>
      </div>`;

    type MonthPL = { month:string; income:number; expenses:number; net:number };
    const pl = d.monthly_pl as MonthPL[];
    const plMax = Math.max(...pl.flatMap(m => [m.income, m.expenses]), 1);
    document.getElementById('monthly-pl')!.innerHTML = pl.map(m => {
      const [yr,mo] = m.month.split('-');
      const lbl = new Date(Number(yr),Number(mo)-1).toLocaleDateString('en-IN',{month:'short',year:'2-digit'});
      const nc = m.net >= 0 ? 'text-green-600' : 'text-red-600';
      return `<div class="flex items-center gap-3">
        <div class="w-12 text-xs text-text-secondary flex-shrink-0">${lbl}</div>
        <div class="flex-1">
          <div class="flex gap-1 mb-1"><div class="h-2 rounded bg-green-500" style="width:${Math.round((m.income/plMax)*100)}%"></div></div>
          <div class="flex gap-1"><div class="h-2 rounded bg-red-400" style="width:${Math.round((m.expenses/plMax)*100)}%"></div></div>
        </div>
        <div class="text-right flex-shrink-0 w-20">
          <div class="text-xs text-green-600">${fmt(m.income)}</div>
          <div class="text-xs text-red-500">${fmt(m.expenses)}</div>
        </div>
        <div class="text-xs font-semibold ${nc} w-14 text-right">${m.net>=0?'+':''}${fmt(m.net)}</div>
      </div>`;
    }).join('') + `<div class="flex items-center gap-2 mt-1 pt-2 border-t border-border-light">
      <div class="w-3 h-2 rounded bg-green-500"></div><span class="text-xs text-text-secondary">Income</span>
      <div class="w-3 h-2 rounded bg-red-400 ml-3"></div><span class="text-xs text-text-secondary">Expenses</span></div>`;

    type CollEff = { month:string; total:number; paid:number; rate:number };
    const eff = d.collection_efficiency as CollEff[];
    document.getElementById('collection-efficiency')!.innerHTML = eff.map(e => {
      const [yr,mo] = e.month.split('-');
      const lbl = new Date(Number(yr),Number(mo)-1).toLocaleDateString('en-IN',{month:'short',year:'2-digit'});
      const color = e.rate >= 80 ? '#10B981' : e.rate >= 60 ? '#F59E0B' : '#EF4444';
      return bar(`${lbl} — ${fmt(e.paid)} / ${fmt(e.total)}`, e.rate, 100, color, '%');
    }).join('') || emptyState('No dues data.');
  }

  // ── Collection report ─────────────────────────────────────────────────────────
  document.getElementById('col-generate')?.addEventListener('click', async () => {
    const from = (document.getElementById('col-from') as HTMLInputElement).value;
    const to   = (document.getElementById('col-to')   as HTMLInputElement).value;
    const wing = (document.getElementById('col-wing') as HTMLSelectElement).value;
    const mode = (document.getElementById('col-mode') as HTMLSelectElement).value;
    const params = new URLSearchParams({ from, to, wing, mode });
    document.getElementById('col-table')!.innerHTML = '<div class="text-center py-8 text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';
    const res = await fetch(`/api/v1/reports/collection?${params}`, { credentials: 'include' });
    if (!res.ok) { document.getElementById('col-table')!.innerHTML = emptyState('Failed to load.'); return; }
    const { rows, total, count }: any = await res.json();
    document.getElementById('col-summary')!.classList.remove('hidden');
    document.getElementById('col-total')!.textContent = fmt(total);
    document.getElementById('col-count')!.textContent = String(count);
    document.getElementById('col-avg')!.textContent = count > 0 ? fmt(Math.round(total/count)) : '₹0';
    const exportEl = document.getElementById('col-export') as HTMLAnchorElement;
    exportEl.href = `/api/v1/reports/collection?${params}&format=csv`;
    exportEl.classList.remove('hidden');
    if (!rows.length) { document.getElementById('col-table')!.innerHTML = emptyState('No payments found.'); return; }
    document.getElementById('col-table')!.innerHTML = tbl(
      ['Date','Receipt No.','Flat','Block','Member','Mode','Reference','Amount'],
      rows.map((r: any) => [
        fmtDate(r.paid_at),
        r.receipt_number ?? '—',
        r.maintenance_dues?.units?.unit_number ?? '—',
        r.maintenance_dues?.units?.block ?? '—',
        r.maintenance_dues?.profiles?.full_name ?? '—',
        (r.payment_mode ?? '').toUpperCase(),
        r.transaction_ref ?? '—',
        fmt(r.amount ?? 0),
      ]),
    );
  });

  // ── Dues report ───────────────────────────────────────────────────────────────
  document.getElementById('dues-generate')?.addEventListener('click', async () => {
    const wing   = (document.getElementById('dues-wing')    as HTMLSelectElement).value;
    const overdue = (document.getElementById('dues-overdue') as HTMLSelectElement).value;
    const period  = (document.getElementById('dues-period')  as HTMLSelectElement).value;
    const params = new URLSearchParams({ wing, overdue, period });
    document.getElementById('dues-table')!.innerHTML = '<div class="text-center py-8 text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';
    const res = await fetch(`/api/v1/reports/dues?${params}`, { credentials: 'include' });
    if (!res.ok) { document.getElementById('dues-table')!.innerHTML = emptyState('Failed to load.'); return; }
    const { rows, total, count, avg_overdue_days }: any = await res.json();
    document.getElementById('dues-summary')!.classList.remove('hidden');
    document.getElementById('dues-total')!.textContent = fmt(total);
    document.getElementById('dues-count')!.textContent = String(count);
    document.getElementById('dues-avg-days')!.textContent = String(avg_overdue_days) + 'd';
    const exportEl = document.getElementById('dues-export') as HTMLAnchorElement;
    exportEl.href = `/api/v1/reports/dues?${params}&format=csv`;
    exportEl.classList.remove('hidden');
    if (!rows.length) { document.getElementById('dues-table')!.innerHTML = emptyState('No pending dues found.'); return; }
    document.getElementById('dues-table')!.innerHTML = tbl(
      ['Flat','Block','Owner','Billing Period','Due Date','Base','Late Fee','Total','Overdue Days'],
      rows.map((r: any) => {
        const od = r.overdue_days;
        const odClass = od > 90 ? 'text-red-600 font-semibold' : od > 60 ? 'text-orange-500' : od > 30 ? 'text-amber-600' : '';
        return [
          r.units?.unit_number ?? '—',
          r.units?.block ?? '—',
          r.profiles?.full_name ?? '—',
          r.billing_periods?.name ?? '—',
          fmtDate(r.due_date),
          fmt(r.base_amount ?? 0),
          fmt(r.penalty_amount ?? 0),
          fmt(r.total_amount ?? 0),
          `<span class="${odClass}">${od}d</span>`,
        ];
      }),
    );
  });

  // ── Complaints report ─────────────────────────────────────────────────────────
  document.getElementById('cmp-generate')?.addEventListener('click', async () => {
    const from     = (document.getElementById('cmp-from')     as HTMLInputElement).value;
    const to       = (document.getElementById('cmp-to')       as HTMLInputElement).value;
    const priority = (document.getElementById('cmp-priority') as HTMLSelectElement).value;
    const category = (document.getElementById('cmp-category') as HTMLSelectElement).value;
    const params = new URLSearchParams({ from, to, priority, category });
    document.getElementById('cmp-table')!.innerHTML = '<div class="text-center py-8 text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';
    const res = await fetch(`/api/v1/reports/complaints?${params}`, { credentials: 'include' });
    if (!res.ok) { document.getElementById('cmp-table')!.innerHTML = emptyState('Failed to load.'); return; }
    const { rows, summary }: any = await res.json();
    document.getElementById('cmp-summary')!.classList.remove('hidden');
    document.getElementById('cmp-total')!.textContent    = String(summary.total);
    document.getElementById('cmp-resolved')!.textContent = String(summary.resolved);
    document.getElementById('cmp-sla')!.textContent      = String(summary.sla_breached);
    document.getElementById('cmp-avg-hrs')!.textContent  = summary.avg_resolution_hours + 'h';
    const exportEl = document.getElementById('cmp-export') as HTMLAnchorElement;
    exportEl.href = `/api/v1/reports/complaints?${params}&format=csv`;
    exportEl.classList.remove('hidden');
    if (!rows.length) { document.getElementById('cmp-table')!.innerHTML = emptyState('No complaints found.'); return; }
    document.getElementById('cmp-table')!.innerHTML = tbl(
      ['ID','Title','Category','Priority','Status','SLA','Raised By','Created','Hrs to Resolve'],
      rows.map((r: any) => [
        r.id.slice(-8).toUpperCase(),
        r.title ?? '—',
        r.category ?? '—',
        r.priority ?? '—',
        r.status ?? '—',
        r.sla_breached ? '<span class="text-red-600 font-medium">Breached</span>' : '<span class="text-green-600">OK</span>',
        r.profiles?.full_name ?? '—',
        fmtDate(r.created_at),
        r.resolution_hours != null ? `${r.resolution_hours}h` : '—',
      ]),
    );
  });

  // ── Facilities report ─────────────────────────────────────────────────────────
  document.getElementById('fac-generate')?.addEventListener('click', async () => {
    const from = (document.getElementById('fac-from') as HTMLInputElement).value;
    const to   = (document.getElementById('fac-to')   as HTMLInputElement).value;
    const params = new URLSearchParams({ from, to });
    document.getElementById('fac-table')!.innerHTML = '<div class="text-center py-8 text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';
    const res = await fetch(`/api/v1/reports/facilities?${params}`, { credentials: 'include' });
    if (!res.ok) { document.getElementById('fac-table')!.innerHTML = emptyState('Failed to load.'); return; }
    const { rows, count, total_revenue }: any = await res.json();
    document.getElementById('fac-summary')!.classList.remove('hidden');
    document.getElementById('fac-count')!.textContent   = String(count);
    document.getElementById('fac-revenue')!.textContent = fmt(total_revenue);
    const exportEl = document.getElementById('fac-export') as HTMLAnchorElement;
    exportEl.href = `/api/v1/reports/facilities?${params}&format=csv`;
    exportEl.classList.remove('hidden');
    if (!rows.length) { document.getElementById('fac-table')!.innerHTML = emptyState('No bookings found.'); return; }
    document.getElementById('fac-table')!.innerHTML = tbl(
      ['Facility','Date','Start','End','Member','Flat','Status','Amount'],
      rows.map((r: any) => [
        r.facilities?.name ?? '—',
        fmtDate(r.start_time),
        r.start_time ? new Date(r.start_time).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) : '—',
        r.end_time   ? new Date(r.end_time).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) : '—',
        r.profiles?.full_name ?? '—',
        `${r.units?.block ?? ''}${r.units?.unit_number ?? ''}`,
        r.status ?? '—',
        fmt(r.total_amount ?? 0),
      ]),
    );
  });

  // ── Visitors report ───────────────────────────────────────────────────────────
  document.getElementById('vis-generate')?.addEventListener('click', async () => {
    const from = (document.getElementById('vis-from') as HTMLInputElement).value;
    const to   = (document.getElementById('vis-to')   as HTMLInputElement).value;
    const type = (document.getElementById('vis-type') as HTMLSelectElement).value;
    const params = new URLSearchParams({ from, to, type });
    document.getElementById('vis-table')!.innerHTML = '<div class="text-center py-8 text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';
    const res = await fetch(`/api/v1/reports/visitors?${params}`, { credentials: 'include' });
    if (!res.ok) { document.getElementById('vis-table')!.innerHTML = emptyState('Failed to load.'); return; }
    const { rows }: any = await res.json();
    const exportEl = document.getElementById('vis-export') as HTMLAnchorElement;
    exportEl.href = `/api/v1/reports/visitors?${params}&format=csv`;
    exportEl.classList.remove('hidden');
    if (!rows.length) { document.getElementById('vis-table')!.innerHTML = emptyState('No visitor records found.'); return; }
    document.getElementById('vis-table')!.innerHTML = tbl(
      ['Date','Time','Visitor Name','Type','Purpose','Host Flat','Block','Exit'],
      rows.map((r: any) => [
        fmtDate(r.entry_time),
        r.entry_time ? new Date(r.entry_time).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) : '—',
        r.visitor_name ?? '—',
        (r.entry_type ?? '').replace('_',' '),
        r.purpose ?? '—',
        r.units?.unit_number ?? '—',
        r.units?.block ?? '—',
        r.exit_time ? new Date(r.exit_time).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) : '—',
      ]),
    );
  });

  // ── Tenant expiry report ───────────────────────────────────────────────────────
  document.getElementById('ten-generate')?.addEventListener('click', async () => {
    const wing = (document.getElementById('ten-wing') as HTMLSelectElement).value;
    const days = (document.getElementById('ten-days') as HTMLSelectElement).value;
    const params = new URLSearchParams({ wing, within_days: days });
    document.getElementById('ten-table')!.innerHTML = '<div class="text-center py-8 text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';
    const res = await fetch(`/api/v1/reports/tenant-expiry?${params}`, { credentials: 'include' });
    if (!res.ok) { document.getElementById('ten-table')!.innerHTML = emptyState('Failed to load.'); return; }
    const { rows, expired, expiring_soon }: any = await res.json();
    document.getElementById('ten-summary')!.classList.remove('hidden');
    document.getElementById('ten-expired')!.textContent = String(expired);
    document.getElementById('ten-soon')!.textContent    = String(expiring_soon);
    const exportEl = document.getElementById('ten-export') as HTMLAnchorElement;
    exportEl.href = `/api/v1/reports/tenant-expiry?${params}&format=csv`;
    exportEl.classList.remove('hidden');
    if (!rows.length) { document.getElementById('ten-table')!.innerHTML = emptyState('No expiring agreements found.'); return; }
    document.getElementById('ten-table')!.innerHTML = tbl(
      ['Tenant','Flat','Block','Agreement End','Days to Expiry','Status','KYC Status'],
      rows.map((r: any) => {
        const dClass = r.is_expired ? 'text-red-600 font-semibold' : r.days_to_expiry <= 30 ? 'text-amber-600' : 'text-text-primary';
        return [
          r.tenant_name ?? '—',
          r.units?.unit_number ?? '—',
          r.units?.block ?? '—',
          fmtDate(r.agreement_end_date),
          `<span class="${dClass}">${r.is_expired ? 'Expired' : `${r.days_to_expiry}d`}</span>`,
          r.is_expired ? '<span class="text-red-600">Expired</span>' : '<span class="text-amber-600">Expiring</span>',
          r.kyc_status ?? '—',
        ];
      }),
    );
  });

  // Load overview on initial render
  loadOverview();
</script>

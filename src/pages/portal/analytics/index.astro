            <div class="bg-white rounded-xl border border-border-light p-5 animate-pulse">
              <div class="h-3 bg-gray-200 rounded w-20 mb-3"></div>
              <div class="h-7 bg-gray-200 rounded w-16"></div>
            </div>
          ))}
        </div>
        <div id="ov-content" class="hidden space-y-6">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="kpi-cards"></div>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-white rounded-xl border border-border-light p-5">
              <h2 class="font-semibold text-text-primary mb-4">Complaints by Status</h2>
              <div id="complaint-chart" class="space-y-2.5"></div>
            </div>
            <div class="bg-white rounded-xl border border-border-light p-5">

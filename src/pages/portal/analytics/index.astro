---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';
import { getSupabaseServiceClient } from '@lib/services/providers/supabase/SupabaseDB';

const user = Astro.locals.user;
const canViewAnalytics = user && (
  ['executive', 'admin'].includes(user.role) ||
  ['executive', 'secretary', 'president'].includes(user.portalRole ?? '') ||
  user.isAdmin
);
if (!canViewAnalytics) return Astro.redirect('/portal');

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const sb = getSupabaseServiceClient();

// Fetch distinct wings for filter dropdowns
const { data: blockRows } = await sb
  .from('units')
  .select('block')
  .eq('society_id', SOCIETY_ID)
  .not('block', 'is', null);
const WINGS = [...new Set((blockRows ?? []).map((u: any) => u.block as string).filter(Boolean))].sort();

// Fetch billing periods for dues filter
const { data: periodRows } = await sb
  .from('billing_periods')
  .select('id, name')
  .eq('society_id', SOCIETY_ID)
  .order('created_at', { ascending: false })
  .limit(24);
const PERIODS = (periodRows ?? []) as { id: string; name: string }[];
---

<PortalLayout title="Analytics & Reports" user={user} activeModule="analytics">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-primary-600 font-poppins">Analytics & Reports</h1>
      <p class="text-text-secondary text-sm mt-1">Society performance overview and operational reports.</p>
    </div>
  </div>

  <div class="flex gap-6 items-start">

    <!-- Sidebar -->
    <div class="w-56 shrink-0 hidden lg:block">
      <div class="bg-white rounded-xl border border-border-light p-3 sticky top-4">
        <p class="text-xs font-semibold text-text-secondary uppercase tracking-wide px-2 py-1.5 mb-1">Reports</p>
        <nav id="report-nav" class="space-y-0.5">
          {[
            { id: 'overview',    label: 'Overview',             icon: 'fa-tachometer-alt' },
            { id: 'collection',  label: 'Collection Report',    icon: 'fa-rupee-sign'     },
            { id: 'dues',        label: 'Pending Dues',         icon: 'fa-exclamation-circle' },
            { id: 'complaints',  label: 'Complaint Resolution', icon: 'fa-tools'          },
            { id: 'facilities',  label: 'Facility Utilisation', icon: 'fa-building'       },
            { id: 'visitors',    label: 'Visitor Log',          icon: 'fa-user-check'     },
            { id: 'tenants',     label: 'Tenant Expiry',        icon: 'fa-key'            },
            { id: 'members',     label: 'Member Directory',     icon: 'fa-users'          },
          ].map(({ id, label, icon }) => (
            <button
              data-report={id}
              class={`report-nav-btn w-full flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-left transition-colors ${id === 'overview' ? 'bg-primary-100 text-primary-700 font-medium' : 'text-text-secondary hover:bg-primary-50 hover:text-primary-700'}`}
            >
              <i class={`fas ${icon} w-4 text-center text-[12px]`} aria-hidden="true"></i>
              {label}
            </button>
          ))}
        </nav>
      </div>
    </div>

    <!-- Mobile report selector -->
    <div class="lg:hidden w-full mb-4">
      <select id="mobile-report-select" class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
        <option value="overview">Overview</option>
        <option value="collection">Collection Report</option>
        <option value="dues">Pending Dues</option>
        <option value="complaints">Complaint Resolution</option>
        <option value="facilities">Facility Utilisation</option>
        <option value="visitors">Visitor Log</option>
        <option value="tenants">Tenant Expiry</option>
        <option value="members">Member Directory</option>
      </select>
    </div>

    <!-- Report panels -->
    <div class="flex-1 min-w-0 space-y-0">

      <!-- ── OVERVIEW ─────────────────────────────────────────────────────── -->
      <div id="panel-overview" class="report-panel space-y-6">
        <div id="ov-loading" class="grid grid-cols-2 md:grid-cols-4 gap-4">

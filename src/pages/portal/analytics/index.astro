---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
const canViewAnalytics = user && (
  ['executive', 'admin'].includes(user.role) ||
  ['executive', 'secretary', 'president'].includes(user.portalRole ?? '') ||
  user.isAdmin
);
if (!canViewAnalytics) return Astro.redirect('/portal');
---

<PortalLayout title="Analytics & Reports" user={user} activeModule="analytics">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-text-primary">Analytics & Reports</h1>
    <p class="text-sm text-text-secondary mt-1">Society performance overview and operational metrics.</p>
  </div>

  <!-- Loading skeleton -->
  <div id="loading-state" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    {Array.from({length: 4}).map(() => (
      <div class="bg-white rounded-xl border border-border-light p-5 animate-pulse">
        <div class="h-3 bg-gray-200 rounded w-20 mb-3"></div>
        <div class="h-7 bg-gray-200 rounded w-16"></div>
      </div>
    ))}
  </div>

  <div id="analytics-content" class="hidden space-y-6">
    <!-- KPI cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="kpi-cards"></div>

    <!-- Charts row -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Complaints by status -->
      <div class="bg-white rounded-xl border border-border-light p-5">
        <h2 class="text-lg font-semibold text-text-primary mb-4">Complaints by Status</h2>
        <div id="complaint-chart" class="space-y-2.5"></div>
      </div>

      <!-- Finance collection -->
      <div class="bg-white rounded-xl border border-border-light p-5">
        <h2 class="text-lg font-semibold text-text-primary mb-4">Finance Collection</h2>
        <div id="finance-chart"></div>
      </div>
    </div>

    <!-- Visitor trend -->
    <div class="bg-white rounded-xl border border-border-light p-5">
      <h2 class="text-lg font-semibold text-text-primary mb-1">Visitor Traffic (Last 14 Days)</h2>
      <p class="text-xs text-text-secondary mb-4">Daily entry count across all visitor types.</p>
      <div id="visitor-trend" class="flex items-end gap-1 h-32"></div>
      <div id="visitor-dates" class="flex gap-1 mt-1"></div>
    </div>

    <!-- Visitor types -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="bg-white rounded-xl border border-border-light p-5">
        <h2 class="text-lg font-semibold text-text-primary mb-4">Visitor Types (Last 30 Days)</h2>
        <div id="visitor-types" class="space-y-2.5"></div>
      </div>

      <!-- Members overview -->
      <div class="bg-white rounded-xl border border-border-light p-5">
        <h2 class="text-lg font-semibold text-text-primary mb-4">Member Composition</h2>
        <div id="member-composition"></div>
      </div>
    </div>

    <!-- Occupancy report -->
    <div class="bg-white rounded-xl border border-border-light p-5">
      <h2 class="text-lg font-semibold text-text-primary mb-1">Unit Occupancy</h2>
      <p class="text-xs text-text-secondary mb-4">Owner-occupied vs rented vs vacant across all active member units.</p>
      <div id="occupancy-chart"></div>
    </div>

    <!-- Monthly P&L -->
    <div class="bg-white rounded-xl border border-border-light p-5">
      <h2 class="text-lg font-semibold text-text-primary mb-1">Monthly P&amp;L (Last 6 Months)</h2>
      <p class="text-xs text-text-secondary mb-4">Collections (income) vs expenses per month.</p>
      <div id="monthly-pl" class="space-y-3"></div>
    </div>

    <!-- Collection efficiency -->
    <div class="bg-white rounded-xl border border-border-light p-5">
      <h2 class="text-lg font-semibold text-text-primary mb-1">Collection Efficiency by Month</h2>
      <p class="text-xs text-text-secondary mb-4">Percentage of dues collected relative to total billed per month.</p>
      <div id="collection-efficiency" class="space-y-2.5"></div>
    </div>
  </div>

  <script>
    const STATUS_COLORS: Record<string, string> = {
      Open: '#1E3A8A', Assigned: '#7C3AED', In_Progress: '#F59E0B',
      Resolved: '#10B981', Closed: '#6B7280', Waiting_for_User: '#EF4444',
    };

    function bar(label: string, value: number, max: number, color: string, suffix = '') {
      const pct = max > 0 ? Math.max(2, (value / max) * 100) : 0;
      return `
        <div>
          <div class="flex items-center justify-between text-xs text-text-secondary mb-1">
            <span>${label}</span><span class="font-medium text-text-primary">${value}${suffix}</span>
          </div>
          <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden">
            <div class="h-full rounded-full transition-all" style="width:${pct}%;background:${color}"></div>
          </div>
        </div>`;
    }

    function fmt(n: number) {
      return n >= 100000 ? `₹${(n / 100000).toFixed(1)}L` : n >= 1000 ? `₹${(n / 1000).toFixed(1)}K` : `₹${n}`;
    }

    async function loadAnalytics() {
      const res = await fetch('/api/v1/admin/analytics', { credentials: 'include' });
      if (!res.ok) {
        document.getElementById('loading-state').innerHTML = '<div class="col-span-4 text-center py-6 text-red-500 text-sm">Failed to load analytics.</div>';
        return;
      }
      const d = await res.json();

      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('analytics-content').classList.remove('hidden');

      // KPIs
      const kpis = [
        { label: 'Open Complaints', value: d.complaints.open, sub: `of ${d.complaints.total} total`, color: 'text-orange-600' },
        { label: 'Collection Rate', value: `${d.finance.collection_rate}%`, sub: `${fmt(d.finance.paid)} collected`, color: d.finance.collection_rate >= 80 ? 'text-green-600' : 'text-red-600' },
        { label: 'Visitors (30d)', value: d.visitors.last_30d, sub: 'entries logged', color: 'text-blue-600' },
        { label: 'Active Members', value: d.members.total, sub: `${d.members.owners} owners · ${d.members.tenants} tenants`, color: 'text-primary-600' },
      ];

      document.getElementById('kpi-cards')!.innerHTML = kpis.map(k => `
        <div class="bg-white rounded-xl border border-border-light p-5">
          <div class="text-xs font-medium text-text-secondary mb-2">${k.label}</div>
          <div class="text-2xl font-bold ${k.color}">${k.value}</div>
          <div class="text-xs text-text-secondary mt-1">${k.sub}</div>
        </div>
      `).join('');

      // Complaint status bars
      const statusEntries = Object.entries(d.complaints.by_status as Record<string, number>).sort((a, b) => b[1] - a[1]);
      const maxStatus = Math.max(...statusEntries.map(([, v]) => v), 1);
      document.getElementById('complaint-chart')!.innerHTML = statusEntries.map(([status, count]) =>
        bar(status.replace('_', ' '), count, maxStatus, STATUS_COLORS[status] ?? '#9CA3AF')
      ).join('');

      // Finance donut-style summary
      const { paid, pending, total_dues } = d.finance;
      const paidPct = total_dues > 0 ? Math.round((paid / total_dues) * 100) : 0;
      document.getElementById('finance-chart')!.innerHTML = `
        <div class="flex items-center gap-4 mb-4">
          <div class="relative w-24 h-24 flex-shrink-0">
            <svg viewBox="0 0 36 36" class="w-24 h-24 -rotate-90">
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="#E5E7EB" stroke-width="3"/>
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="#10B981" stroke-width="3"
                stroke-dasharray="${paidPct} ${100 - paidPct}" stroke-linecap="round"/>
            </svg>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="text-sm font-bold text-text-primary">${paidPct}%</span>
            </div>
          </div>
          <div class="space-y-2 text-sm">
            <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-green-500"></div><span class="text-text-secondary">Collected:</span><span class="font-medium">${fmt(paid)}</span></div>
            <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-red-400"></div><span class="text-text-secondary">Pending:</span><span class="font-medium">${fmt(pending)}</span></div>
            <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-gray-300"></div><span class="text-text-secondary">Total:</span><span class="font-medium">${fmt(total_dues)}</span></div>
          </div>
        </div>
        ${Object.entries(d.finance.by_status as Record<string,number>).map(([status, count]) =>
          bar(status, count, Object.values(d.finance.by_status as Record<string,number>).reduce((a,b) => a+b, 0), status === 'paid' ? '#10B981' : '#EF4444')
        ).join('')}
      `;

      // Visitor daily trend bar chart
      const trend = d.visitors.daily_trend as { date: string; count: number }[];
      const maxVisitors = Math.max(...trend.map(t => t.count), 1);
      const trendEl = document.getElementById('visitor-trend')!;
      const datesEl = document.getElementById('visitor-dates')!;
      trendEl.innerHTML = trend.map(t => {
        const h = Math.max(4, Math.round((t.count / maxVisitors) * 128));
        return `<div class="flex-1 bg-primary-600 rounded-t opacity-80 hover:opacity-100 transition-opacity" style="height:${h}px" title="${t.date}: ${t.count} visitors"></div>`;
      }).join('');
      datesEl.innerHTML = trend.map((t, i) => {
        const show = i === 0 || i === 6 || i === 13;
        const label = show ? new Date(t.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) : '';
        return `<div class="flex-1 text-center text-xs text-text-secondary truncate">${label}</div>`;
      }).join('');

      // Visitor types
      const typeEntries = Object.entries(d.visitors.by_type as Record<string, number>).sort((a, b) => b[1] - a[1]);
      const maxType = Math.max(...typeEntries.map(([, v]) => v), 1);
      document.getElementById('visitor-types')!.innerHTML = typeEntries.length
        ? typeEntries.map(([type, count]) => bar(type.replace('_', ' '), count, maxType, '#1E3A8A')).join('')
        : '<div class="text-sm text-text-secondary text-center py-4">No visitor data.</div>';

      // Member composition
      const { owners, tenants, total } = d.members;
      const ownerPct = total > 0 ? Math.round((owners / total) * 100) : 0;
      document.getElementById('member-composition')!.innerHTML = `
        <div class="flex items-center gap-3 mb-4">
          <div class="flex-1 h-4 bg-gray-100 rounded-full overflow-hidden flex">
            <div class="h-full bg-primary-600" style="width:${ownerPct}%"></div>
            <div class="h-full bg-green-500" style="width:${100 - ownerPct}%"></div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4 text-center">
          <div class="p-4 bg-blue-50 rounded-xl">
            <div class="text-2xl font-bold text-primary-600">${owners}</div>
            <div class="text-xs text-text-secondary mt-1">Owners (${ownerPct}%)</div>
          </div>
          <div class="p-4 bg-green-50 rounded-xl">
            <div class="text-2xl font-bold text-green-600">${tenants}</div>
            <div class="text-xs text-text-secondary mt-1">Tenants (${100 - ownerPct}%)</div>
          </div>
        </div>
      `;

      // Occupancy report
      const occ = d.occupancy;
      const occTotal = occ.total || 1;
      const occItems = [
        { label: 'Owner Occupied', count: occ.owner_occupied, color: '#1E3A8A' },
        { label: 'Rented', count: occ.rented, color: '#10B981' },
        { label: 'Vacant', count: occ.vacant, color: '#F59E0B' },
        ...Object.entries(occ.by_type as Record<string, number>)
          .filter(([k]) => !['owner_occupied','rented','vacant'].includes(k))
          .map(([k, v]) => ({ label: k.replace('_', ' '), count: v, color: '#9CA3AF' })),
      ];
      const maxOcc = Math.max(...occItems.map(o => o.count), 1);
      document.getElementById('occupancy-chart')!.innerHTML = `
        <div class="space-y-2.5 mb-4">
          ${occItems.map(o => bar(o.label, o.count, maxOcc, o.color, ` (${occTotal > 0 ? Math.round((o.count/occTotal)*100) : 0}%)`)).join('')}
        </div>
        <div class="grid grid-cols-3 gap-3 text-center">
          ${occItems.slice(0,3).map(o => `
            <div class="p-3 bg-gray-50 rounded-lg">
              <div class="text-xl font-bold" style="color:${o.color}">${o.count}</div>
              <div class="text-xs text-text-secondary">${o.label}</div>
            </div>`).join('')}
        </div>`;

      // Monthly P&L
      type MonthlyPL = { month: string; income: number; expenses: number; net: number };
      const pl = (d.monthly_pl as MonthlyPL[]);
      const plMax = Math.max(...pl.flatMap(m => [m.income, m.expenses]), 1);
      document.getElementById('monthly-pl')!.innerHTML = pl.map(m => {
        const [yr, mo] = m.month.split('-');
        const label = new Date(Number(yr), Number(mo) - 1).toLocaleDateString('en-IN', { month: 'short', year: '2-digit' });
        const netColor = m.net >= 0 ? 'text-green-600' : 'text-red-600';
        const netSign = m.net >= 0 ? '+' : '';
        return `
          <div class="flex items-center gap-3">
            <div class="w-14 text-xs text-text-secondary flex-shrink-0">${label}</div>
            <div class="flex-1">
              <div class="flex gap-1 mb-1">
                <div class="h-2 rounded bg-green-500" style="width:${Math.round((m.income/plMax)*100)}%;min-width:${m.income > 0 ? 4 : 0}px"></div>
              </div>
              <div class="flex gap-1">
                <div class="h-2 rounded bg-red-400" style="width:${Math.round((m.expenses/plMax)*100)}%;min-width:${m.expenses > 0 ? 4 : 0}px"></div>
              </div>
            </div>
            <div class="text-right flex-shrink-0 min-w-20">
              <div class="text-xs text-green-600">${fmt(m.income)}</div>
              <div class="text-xs text-red-500">${fmt(m.expenses)}</div>
            </div>
            <div class="text-xs font-semibold ${netColor} min-w-14 text-right">${netSign}${fmt(m.net)}</div>
          </div>`;
      }).join('') + `
        <div class="flex items-center gap-2 mt-1 pt-2 border-t border-border-light">
          <div class="w-3 h-2 rounded bg-green-500"></div><span class="text-xs text-text-secondary">Income</span>
          <div class="w-3 h-2 rounded bg-red-400 ml-3"></div><span class="text-xs text-text-secondary">Expenses</span>
        </div>`;

      // Collection efficiency
      type CollEff = { month: string; total: number; paid: number; rate: number };
      const eff = (d.collection_efficiency as CollEff[]);
      document.getElementById('collection-efficiency')!.innerHTML = eff.map(e => {
        const [yr, mo] = e.month.split('-');
        const label = new Date(Number(yr), Number(mo) - 1).toLocaleDateString('en-IN', { month: 'short', year: '2-digit' });
        const rateColor = e.rate >= 80 ? '#10B981' : e.rate >= 60 ? '#F59E0B' : '#EF4444';
        return bar(`${label} — ${fmt(e.paid)} / ${fmt(e.total)}`, e.rate, 100, rateColor, '%');
      }).join('') || '<div class="text-sm text-text-secondary text-center py-4">No dues data for the period.</div>';
    }

    loadAnalytics();
  </script>
</PortalLayout>

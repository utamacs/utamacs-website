---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';
import { getSupabaseServiceClient } from '@lib/services/providers/supabase/SupabaseDB';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
const isExec = ['executive', 'secretary', 'president'].includes(user.portalRole) || user.isAdmin;
const isAfm = user.portalRole === 'afm';
if (!isExec && !isAfm) return Astro.redirect('/portal');

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const sb = getSupabaseServiceClient();

const [{ data: templates }, { data: locations }, { data: staff }] = await Promise.all([
  sb.from('staff_activity_templates')
    .select('id, department, title, title_hi, title_te, frequency, frequency_days, location_variants, checklist, requires_photo, estimated_mins, is_active, created_at')
    .eq('society_id', SOCIETY_ID)
    .order('department')
    .order('frequency')
    .order('title'),
  sb.from('locations')
    .select('id, name, zone_type')
    .eq('society_id', SOCIETY_ID)
    .eq('is_active', true)
    .order('zone_type')
    .order('name'),
  sb.from('staff_members')
    .select('id, name, department, designation')
    .eq('society_id', SOCIETY_ID)
    .eq('is_active', true)
    .order('department')
    .order('name'),
]);

const DEPT_LABELS: Record<string, string> = {
  security: 'Security', housekeeping: 'Housekeeping', gardening: 'Gardening',
  maintenance: 'Maintenance', admin: 'Administration', multi: 'Multi',
};

const FREQ_BADGE: Record<string, string> = {
  daily:       'bg-primary-50 text-primary-700',
  weekly:      'bg-blue-50 text-blue-700',
  monthly:     'bg-purple-50 text-purple-700',
  quarterly:   'bg-amber-50 text-amber-700',
  half_yearly: 'bg-orange-50 text-orange-700',
  yearly:      'bg-red-50 text-red-700',
  on_demand:   'bg-gray-100 text-gray-600',
};

const ZONE_LABELS: Record<string, string> = {
  block: 'Block', common_area: 'Common Area', utility: 'Utility',
  amenity: 'Amenity', external: 'External',
};

const DAYS = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

const deptGroups: Record<string, typeof templates> = {};
for (const t of templates ?? []) {
  if (!deptGroups[t.department]) deptGroups[t.department] = [];
  deptGroups[t.department]!.push(t);
}

// Build a location name lookup for display
const locNames: Record<string, string> = {};
for (const l of locations ?? []) locNames[l.id] = l.name;
---

<PortalLayout title="Activity Templates" user={user} activeModule="staff_management">

  <!-- Process info panel -->
  <details class="mb-6 group rounded-xl border border-primary-100 bg-gradient-to-r from-primary-50/50 to-blue-50/20 overflow-hidden">
    <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer list-none select-none hover:bg-primary-50/60 transition-colors">
      <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-project-diagram text-white text-xs" aria-hidden="true"></i>
      </div>
      <span class="text-sm font-medium text-text-primary flex-1">50 HK PPM templates loaded; each template can span multiple locations, carry an asset link, and embed a structured inspection checklist — tasks fan out per location on each cycle.</span>
      <span class="text-xs text-primary-600 flex items-center gap-1.5 flex-shrink-0 font-medium">
        How it works
        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200 group-open:rotate-180" aria-hidden="true"></i>
      </span>
    </summary>
    <div class="px-5 pb-5">
      <div class="pt-4 border-t border-primary-100 space-y-4">
        <div class="process-snake-flow -mx-1 px-1">
          <div class="flex-shrink-0 w-44 rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Create Template</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">Or approve via supervisor</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">Set Frequency</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">Daily → Yearly · custom days</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">Tag Locations</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">A-Block / B-Block / Clubhouse…</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-amber-300 bg-amber-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-amber-800 whitespace-nowrap">Add Checklist</p>
            <p class="text-[11px] text-amber-700 mt-0.5 whitespace-nowrap">Steps · expected value · severity</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-green-300 bg-green-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-green-800 whitespace-nowrap">Activated</p>
            <p class="text-[11px] text-green-700 mt-0.5 whitespace-nowrap">PPM owner assigned</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-gray-300 bg-gray-100 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Tasks Generated</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">Per cycle · per location</p>
          </div>
        </div>
        <div class="flex items-center gap-2 text-xs text-amber-700">
          <i class="fas fa-arrow-turn-down text-amber-500 text-[10px]" aria-hidden="true"></i>
          <span class="font-medium">New template via Supervisor</span>
          <span class="text-amber-600">— Supervisors propose; AFM approves; on approval the template is auto-created and activated in the library</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mt-1">
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-calendar-alt text-primary-400 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Custom interval (frequency_days): set to <strong>15</strong> for "Monthly Twice" PPM tasks — overrides the default 30-day monthly cycle; scheduler generates tasks every 15 days</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-map-marker-alt text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Location variants: one template can cover multiple zones (A-Block, B-Block, C-Block, Clubhouse) — scheduler fans out one task instance per location per cycle</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-list-check text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Inspection checklist: each step carries an expected value and severity — <strong>critical</strong> step failure auto-raises a Complaint tagged to Maintenance dept</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-seedling text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>75+ templates seeded at setup (25 generic + 50 HK 52-Week PPM) — exec adds department SOPs; ANKURA Electrical PPM is handled as Vendor Work Orders</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-pause-circle text-red-400 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Templates deactivated without deletion — inactive templates stop generating new tasks; all historical task records are preserved for CLRA compliance reporting</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-user-hard-hat text-primary-400 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>PPM Owner: set a default assignee per template; tasks generated by the scheduler inherit the owner automatically — supervisor can re-assign per task instance</span>
          </div>
        </div>
      </div>
    </div>
  </details>

  <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
    <div>
      <nav class="text-sm text-text-secondary mb-1">
        <a href="/portal/staff-management" class="hover:text-primary-600">Staff Management</a>
        <span class="mx-2">›</span><span class="text-text-primary">Activities</span>
      </nav>
      <h1 class="text-2xl font-bold text-primary-600 font-poppins">Activity Template Library</h1>
      <p class="text-text-secondary text-sm mt-1">{(templates ?? []).filter(t => t.is_active).length} active templates across all departments</p>
    </div>
    <div class="flex gap-2">
      {isExec && (
        <button id="add-template-btn" class="btn-primary text-sm">
          <i class="fas fa-plus mr-1.5" aria-hidden="true"></i>Add Template
        </button>
      )}
      <a href="/portal/staff-management/proposals" class="btn-outline text-sm">
        <i class="fas fa-inbox mr-1.5" aria-hidden="true"></i>Proposals
      </a>
    </div>
  </div>

  <!-- Filter bar -->
  <div class="card-premium p-4 mb-5 flex flex-wrap gap-3">
    <select id="dept-filter" class="form-input py-2 text-sm w-44 bg-white">
      <option value="">All Departments</option>
      {Object.entries(DEPT_LABELS).map(([k, v]) => <option value={k}>{v}</option>)}
    </select>
    <select id="freq-filter" class="form-input py-2 text-sm w-36 bg-white">
      <option value="">All Frequencies</option>
      {Object.keys(FREQ_BADGE).map(f => <option value={f}>{f.replace('_', ' ')}</option>)}
    </select>
    <select id="loc-filter" class="form-input py-2 text-sm w-44 bg-white">
      <option value="">All Locations</option>
      {(locations ?? []).map(l => <option value={l.id}>{l.name}</option>)}
    </select>
  </div>

  {Object.entries(deptGroups).map(([dept, deptTemplates]) => (
    <div class="mb-6" data-dept={dept}>
      <div class="flex items-center gap-2 mb-3">
        <h2 class="text-base font-semibold text-text-primary">{DEPT_LABELS[dept] ?? dept}</h2>
        <span class="text-xs bg-primary-50 text-primary-600 px-2 py-0.5 rounded-full">{(deptTemplates ?? []).length}</span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {(deptTemplates ?? []).map(t => {
          const checklistCount = Array.isArray(t.checklist) ? t.checklist.length : 0;
          const locCount = Array.isArray(t.location_variants) ? t.location_variants.length : 0;
          const freqLabel = t.frequency_days ? `Every ${t.frequency_days}d` : t.frequency.replace('_', ' ');
          const locBadge = locCount > 0 ? FREQ_BADGE['on_demand'] : '';
          return (
            <div class={`card-premium p-4 template-card ${!t.is_active ? 'opacity-60' : ''}`}
                 data-dept={t.department}
                 data-freq={t.frequency}
                 data-locs={JSON.stringify(t.location_variants ?? [])}>
              <div class="flex items-start justify-between gap-2 mb-2">
                <div class="font-medium text-text-primary text-sm leading-snug flex-1">{t.title}</div>
                <span class={`text-xs px-2 py-0.5 rounded-full font-medium flex-shrink-0 ${FREQ_BADGE[t.frequency] ?? 'bg-gray-100 text-gray-600'}`}>
                  {freqLabel}
                </span>
              </div>
              {(t.title_hi || t.title_te) && (
                <div class="text-xs text-text-secondary space-y-0.5 mb-2">
                  {t.title_hi && <div>{t.title_hi}</div>}
                  {t.title_te && <div>{t.title_te}</div>}
                </div>
              )}
              <div class="flex flex-wrap items-center gap-2 text-xs text-text-secondary">
                {t.requires_photo && (
                  <span class="flex items-center gap-1 text-primary-500">
                    <i class="fas fa-camera" aria-hidden="true"></i>Photo
                  </span>
                )}
                {t.estimated_mins && (
                  <span class="flex items-center gap-1">
                    <i class="fas fa-clock" aria-hidden="true"></i>{t.estimated_mins} min
                  </span>
                )}
                {checklistCount > 0 && (
                  <span class="flex items-center gap-1 text-accent-600">
                    <i class="fas fa-list-check" aria-hidden="true"></i>{checklistCount} steps
                  </span>
                )}
                {locCount > 0 && (
                  <span class="flex items-center gap-1 text-secondary-600">
                    <i class="fas fa-map-marker-alt" aria-hidden="true"></i>
                    {locCount === 1
                      ? (locNames[(t.location_variants as string[])[0]] ?? '1 location')
                      : `${locCount} locations`}
                  </span>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  ))}

  <!-- Add Template Drawer -->
  <div id="add-template-panel" class="fixed inset-y-0 right-0 w-full sm:w-[560px] bg-white shadow-large z-40 transform translate-x-full transition-transform duration-300 overflow-y-auto">
    <div class="sticky top-0 bg-white border-b border-border-light p-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-primary-600">Add Activity Template</h2>
      <button id="close-template-panel" class="text-text-secondary hover:text-text-primary" aria-label="Close">
        <i class="fas fa-times text-xl" aria-hidden="true"></i>
      </button>
    </div>
    <div class="p-5">
      <div id="template-error" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>
      <form id="add-template-form" class="space-y-5">

        <!-- Titles -->
        <div class="space-y-3">
          <h3 class="text-sm font-semibold text-text-primary border-b border-border-light pb-1.5">Labels</h3>
          <div>
            <label class="form-label">Title (English) <span class="text-red-500">*</span></label>
            <input name="title" type="text" required maxlength="200" class="form-input" />
          </div>
          <div>
            <label class="form-label">Title in Hindi (हिन्दी)</label>
            <input name="title_hi" type="text" maxlength="200" class="form-input" />
          </div>
          <div>
            <label class="form-label">Title in Telugu (తెలుగు)</label>
            <input name="title_te" type="text" maxlength="200" class="form-input" />
          </div>
        </div>

        <!-- Dept + Frequency -->
        <div class="space-y-3">
          <h3 class="text-sm font-semibold text-text-primary border-b border-border-light pb-1.5">Schedule</h3>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="form-label">Department <span class="text-red-500">*</span></label>
              <select name="department" required class="form-input bg-white">
                {Object.entries(DEPT_LABELS).map(([k, v]) => <option value={k}>{v}</option>)}
              </select>
            </div>
            <div>
              <label class="form-label">Frequency <span class="text-red-500">*</span></label>
              <select id="freq-select" name="frequency" required class="form-input bg-white">
                {Object.keys(FREQ_BADGE).map(f => <option value={f}>{f.replace('_', ' ')}</option>)}
              </select>
            </div>
          </div>
          <!-- Custom interval — shown for monthly/quarterly when a non-default cadence is needed -->
          <div id="freq-days-row" class="hidden grid grid-cols-2 gap-3">
            <div>
              <label class="form-label">Custom interval (days)</label>
              <input id="freq-days-input" name="frequency_days" type="number" min="1" max="365" placeholder="e.g. 15 for twice-monthly" class="form-input" />
            </div>
            <div>
              <label class="form-label">Preferred day of week</label>
              <select name="preferred_day_of_week" class="form-input bg-white">
                <option value="">Any day in window</option>
                {DAYS.map((d, i) => <option value={i}>{d}</option>)}
              </select>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="form-label">Estimated duration (minutes)</label>
              <input name="estimated_mins" type="number" min="5" max="480" class="form-input" />
            </div>
          </div>
        </div>

        <!-- Location variants -->
        <div class="space-y-2">
          <h3 class="text-sm font-semibold text-text-primary border-b border-border-light pb-1.5">Location Variants</h3>
          <p class="text-xs text-text-secondary">If set, the scheduler creates one task instance per selected location each cycle (e.g. Parking Water Wash → A-Block, B-Block, C-Block, Clubhouse).</p>
          {(locations ?? []).length === 0 ? (
            <p class="text-xs text-text-secondary italic">No locations defined yet.</p>
          ) : (
            <div class="grid grid-cols-2 gap-y-1 max-h-48 overflow-y-auto border border-border-light rounded-lg p-3">
              {(() => {
                const grouped: any = {};
                for (const l of locations ?? []) {
                  const g = ZONE_LABELS[l.zone_type] ?? l.zone_type;
                  if (!grouped[g]) grouped[g] = [];
                  grouped[g]!.push(l);
                }
                return Object.entries(grouped).map(([zone, locs]) => (
                  <div class="col-span-2">
                    <div class="text-[10px] font-semibold text-text-secondary uppercase tracking-wide mt-2 mb-1 first:mt-0">{zone}</div>
                    <div class="grid grid-cols-2 gap-y-1">
                      {(locs ?? []).map(l => (
                        <label class="flex items-center gap-2 text-sm cursor-pointer hover:text-primary-600">
                          <input type="checkbox" name="location_variants" value={l.id}
                            class="w-3.5 h-3.5 accent-primary-600 flex-shrink-0" />
                          {l.name}
                        </label>
                      ))}
                    </div>
                  </div>
                ));
              })()}
            </div>
          )}
        </div>

        <!-- Assignment -->
        <div class="space-y-3">
          <h3 class="text-sm font-semibold text-text-primary border-b border-border-light pb-1.5">Assignment</h3>
          <div>
            <label class="form-label">Default PPM Owner (optional)</label>
            <select name="default_assigned_to" class="form-input bg-white">
              <option value="">Unassigned — supervisor delegates</option>
              {(staff ?? []).map(s => (
                <option value={s.id}>{s.name}{s.designation ? ` (${s.designation})` : ''} — {s.department}</option>
              ))}
            </select>
          </div>
          <div class="flex items-center gap-3">
            <input type="checkbox" name="requires_photo" id="tpl_photo" class="w-4 h-4 accent-primary-600" />
            <label for="tpl_photo" class="text-sm text-text-primary">Requires photo proof on completion</label>
          </div>
        </div>

        <!-- Inspection Checklist -->
        <div class="space-y-3">
          <div class="flex items-center justify-between border-b border-border-light pb-1.5">
            <h3 class="text-sm font-semibold text-text-primary">Inspection Checklist</h3>
            <button type="button" id="add-step-btn" class="btn-ghost text-xs px-2 py-1">
              <i class="fas fa-plus mr-1" aria-hidden="true"></i>Add Step
            </button>
          </div>
          <p class="text-xs text-text-secondary">Optional. Each step can carry an expected value (e.g. "≥ 1 MΩ") and severity — <span class="text-red-600 font-medium">critical</span> failures auto-raise a Complaint.</p>
          <div id="checklist-steps" class="space-y-3">
            <!-- Steps added dynamically -->
          </div>
          <p id="no-steps-msg" class="text-xs text-text-secondary italic">No steps yet — click Add Step above.</p>
        </div>

        <button type="submit" class="btn-primary w-full">Add Template</button>
      </form>
    </div>
  </div>
  <div id="template-backdrop" class="fixed inset-0 bg-black/40 z-30 hidden"></div>

</PortalLayout>

<script>
  // ── Drawer open / close ───────────────────────────────────────────────────
  const panel    = document.getElementById('add-template-panel');
  const backdrop = document.getElementById('template-backdrop');
  const open  = () => { panel.classList.remove('translate-x-full'); backdrop.classList.remove('hidden'); };
  const close = () => { panel.classList.add('translate-x-full');    backdrop.classList.add('hidden');    };
  document.getElementById('add-template-btn')?.addEventListener('click', open);
  document.getElementById('close-template-panel')?.addEventListener('click', close);
  backdrop.addEventListener('click', close);

  // ── Frequency → show custom interval row ─────────────────────────────────
  const freqSel  = document.getElementById('freq-select');
  const freqDays = document.getElementById('freq-days-row');
  function toggleFreqDays() {
    const show = ['monthly','quarterly','half_yearly','yearly'].includes(freqSel.value);
    freqDays.classList.toggle('hidden', !show);
  }
  freqSel?.addEventListener('change', toggleFreqDays);
  toggleFreqDays();

  // ── Filter bar ────────────────────────────────────────────────────────────
  const deptFilter = document.getElementById('dept-filter');
  const freqFilter = document.getElementById('freq-filter');
  const locFilter  = document.getElementById('loc-filter');

  function applyFilters() {
    const d = deptFilter.value;
    const f = freqFilter.value;
    const l = locFilter.value;
    document.querySelectorAll('.template-card').forEach(card => {
      const dOk = !d || card.dataset.dept === d;
      const fOk = !f || card.dataset.freq === f;
      const lOk = !l || (() => {
        try { return JSON.parse(card.dataset.locs || '[]').includes(l); } catch { return false; }
      })();
      card.style.display = (dOk && fOk && lOk) ? '' : 'none';
    });
  }
  deptFilter?.addEventListener('change', applyFilters);
  freqFilter?.addEventListener('change', applyFilters);
  locFilter?.addEventListener('change', applyFilters);

  // ── Checklist builder ─────────────────────────────────────────────────────
  let stepCounter = 0;

  function addStep() {
    stepCounter++;
    const container = document.getElementById('checklist-steps');
    const noMsg     = document.getElementById('no-steps-msg');
    noMsg?.classList.add('hidden');

    const row = document.createElement('div');
    row.className = 'checklist-step bg-gray-50 rounded-lg p-3 space-y-2 border border-border-light';
    row.dataset.step = String(stepCounter);
    row.innerHTML = `
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-semibold text-text-secondary">Step ${stepCounter}</span>
        <button type="button" onclick="removeStep(this)" class="text-red-400 hover:text-red-600 text-xs">
          <i class="fas fa-trash-alt"></i>
        </button>
      </div>
      <div>
        <label class="form-label text-xs">Step instruction (English) *</label>
        <input type="text" name="checklist_text_en_${stepCounter}" maxlength="500" required
          placeholder="e.g. Check oil level at sight glass"
          class="form-input text-sm py-1.5" />
      </div>
      <div>
        <label class="form-label text-xs">Expected value / pass condition</label>
        <input type="text" name="checklist_expected_${stepCounter}" maxlength="300"
          placeholder="e.g. OK / Low / Critical  |  ≥ 1 MΩ  |  No leaks"
          class="form-input text-sm py-1.5" />
      </div>
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-2">
          <select name="checklist_severity_${stepCounter}" class="form-input text-xs py-1 w-28 bg-white">
            <option value="warning">Warning</option>
            <option value="critical">Critical</option>
          </select>
          <span class="text-xs text-text-secondary">severity</span>
        </div>
        <label class="flex items-center gap-1.5 text-xs cursor-pointer">
          <input type="checkbox" name="checklist_photo_${stepCounter}" class="w-3.5 h-3.5 accent-primary-600" />
          Photo required
        </label>
      </div>
    `;
    container?.appendChild(row);
  }

  function removeStep(btn) {
    const row = btn.closest('.checklist-step');
    row?.remove();
    const remaining = document.querySelectorAll('.checklist-step');
    if (remaining.length === 0) document.getElementById('no-steps-msg')?.classList.remove('hidden');
    // Re-number displayed labels
    remaining.forEach((r, i) => {
      r.querySelector('span.text-xs.font-semibold').textContent = `Step ${i + 1}`;
    });
  }

  document.getElementById('add-step-btn')?.addEventListener('click', addStep);
  window.removeStep = removeStep;

  // ── Form submit ───────────────────────────────────────────────────────────
  document.getElementById('add-template-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form   = e.target;
    const fd     = new FormData(form);
    const errEl  = document.getElementById('template-error');
    errEl.classList.add('hidden');

    // Build location_variants array from checked checkboxes
    const locationVariants = Array.from(
      form.querySelectorAll('input[name="location_variants"]:checked')
    ).map(cb => cb.value);

    // Build checklist from step rows
    const steps = Array.from(document.querySelectorAll('.checklist-step'));
    const checklist = steps.map((row, i) => {
      const n = row.dataset.step;
      return {
        text_en:        (fd.get(`checklist_text_en_${n}`) || '').trim(),
        expected_value: (fd.get(`checklist_expected_${n}`) || '').trim() || undefined,
        severity:       fd.get(`checklist_severity_${n}`) || 'warning',
        photo_required: fd.has(`checklist_photo_${n}`),
      };
    }).filter(s => s.text_en);

    const body = {
      title:                 fd.get('title'),
      title_hi:              fd.get('title_hi') || undefined,
      title_te:              fd.get('title_te') || undefined,
      department:            fd.get('department'),
      frequency:             fd.get('frequency'),
      frequency_days:        fd.get('frequency_days') ? parseInt(fd.get('frequency_days')) : undefined,
      preferred_day_of_week: fd.get('preferred_day_of_week') !== '' ? parseInt(fd.get('preferred_day_of_week')) : undefined,
      estimated_mins:        fd.get('estimated_mins') ? parseInt(fd.get('estimated_mins')) : undefined,
      default_assigned_to:   fd.get('default_assigned_to') || undefined,
      requires_photo:        fd.has('requires_photo'),
      location_variants:     locationVariants.length ? locationVariants : undefined,
      checklist,
    };

    const submitBtn = form.querySelector('button[type="submit"]');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Adding…';

    try {
      const res = await fetch('/api/v1/staff-management/activities', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(body),
      });
      if (res.ok) {
        window.location.reload();
      } else {
        const d = await res.json().catch(() => ({}));
        errEl.textContent = d.message ?? 'Failed to add template.';
        errEl.classList.remove('hidden');
      }
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Add Template';
    }
  });
</script>

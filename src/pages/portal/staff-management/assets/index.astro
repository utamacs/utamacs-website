---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';
import { getSupabaseServiceClient } from '@lib/services/providers/supabase/SupabaseDB';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
const isExec = ['executive', 'secretary', 'president'].includes(user.portalRole) || user.isAdmin;
const isAfm  = user.portalRole === 'afm';
if (!isExec && !isAfm) return Astro.redirect('/portal');

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const sb = getSupabaseServiceClient();

const [{ data: assets }, { data: locations }] = await Promise.all([
  sb.from('assets')
    .select(`
      id, name, asset_code, category, make, model, serial_number,
      capacity, quantity, supplier, amc_vendor, amc_start_date, amc_end_date,
      install_date, warranty_expiry, location_notes, status, notes, created_at,
      location_id,
      locations ( id, name, zone_type )
    `)
    .eq('society_id', SOCIETY_ID)
    .order('category')
    .order('asset_code', { ascending: true, nullsFirst: false })
    .order('name'),
  sb.from('locations')
    .select('id, name, zone_type')
    .eq('society_id', SOCIETY_ID)
    .eq('is_active', true)
    .order('zone_type')
    .order('name'),
]);

const allAssets = assets ?? [];
const allLocations = locations ?? [];

// Stats
const today   = new Date().toISOString().slice(0, 10);
const cutoff90 = (() => { const d = new Date(); d.setDate(d.getDate() + 90); return d.toISOString().slice(0, 10); })();
const totalActive    = allAssets.filter(a => a.status === 'active').length;
const underMaint     = allAssets.filter(a => a.status === 'under_maintenance').length;
const amcExpirySoon  = allAssets.filter(a => a.amc_end_date && a.amc_end_date <= cutoff90).length;
const warExpirySoon  = allAssets.filter(a => a.warranty_expiry && a.warranty_expiry >= today && a.warranty_expiry <= cutoff90).length;

// Group locations by zone_type for the form
const locationsByZone: Record<string, typeof allLocations> = {};
for (const l of allLocations) {
  if (!locationsByZone[l.zone_type]) locationsByZone[l.zone_type] = [];
  locationsByZone[l.zone_type].push(l);
}

const CAT_LABELS: Record<string, string> = {
  electrical: 'Electrical', plumbing: 'Plumbing', fire_safety: 'Fire Safety',
  hvac: 'HVAC', mechanical: 'Mechanical', security: 'Security',
  civil: 'Civil', it: 'IT', general: 'General',
};

const CAT_ICONS: Record<string, string> = {
  electrical: 'fa-bolt', plumbing: 'fa-faucet', fire_safety: 'fa-fire-extinguisher',
  hvac: 'fa-wind', mechanical: 'fa-cogs', security: 'fa-shield-alt',
  civil: 'fa-building', it: 'fa-server', general: 'fa-cube',
};

const CAT_COLORS: Record<string, string> = {
  electrical: 'bg-yellow-100 text-yellow-800',
  plumbing:   'bg-blue-100 text-blue-800',
  fire_safety:'bg-red-100 text-red-800',
  hvac:       'bg-cyan-100 text-cyan-800',
  mechanical: 'bg-purple-100 text-purple-800',
  security:   'bg-slate-100 text-slate-800',
  civil:      'bg-orange-100 text-orange-800',
  it:         'bg-indigo-100 text-indigo-800',
  general:    'bg-gray-100 text-gray-600',
};

const STATUS_BADGE: Record<string, string> = {
  active:             'bg-green-100 text-green-700',
  under_maintenance:  'bg-amber-100 text-amber-700',
  decommissioned:     'bg-gray-100 text-gray-500',
};

function amcBadge(endDate: string | null): string {
  if (!endDate) return '';
  if (endDate < today) return 'expired';
  if (endDate <= cutoff90) return 'soon';
  return 'ok';
}

// categories present (for filter tabs)
const categories = Object.keys(CAT_LABELS) as (keyof typeof CAT_LABELS)[];

// Serialise for script
const assetsJson   = JSON.stringify(allAssets);
const locationsJson = JSON.stringify(allLocations);
---

<PortalLayout title="Asset Register" user={user} activeModule="staff_management">
  <!-- Page header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-primary-600 font-poppins">Asset Register</h1>
      <p class="text-text-secondary text-sm mt-1">Equipment inventory — {allAssets.length} assets across {Object.keys(CAT_LABELS).length} categories</p>
    </div>
    {isExec && (
      <button id="add-asset-btn" class="btn-primary flex items-center gap-2">
        <i class="fas fa-plus" aria-hidden="true"></i> Add Asset
      </button>
    )}
  </div>

  <!-- Stats row -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
    <div class="card-stats">
      <div class="number text-primary-600">{totalActive}</div>
      <div class="label">Active Assets</div>
    </div>
    <div class="card-stats">
      <div class="number text-amber-600">{underMaint}</div>
      <div class="label">Under Maintenance</div>
    </div>
    <div class="card-stats">
      <div class="number text-red-600">{amcExpirySoon}</div>
      <div class="label">AMC Due ≤90 Days</div>
    </div>
    <div class="card-stats">
      <div class="number text-amber-600">{warExpirySoon}</div>
      <div class="label">Warranty Expiring</div>
    </div>
  </div>

  <!-- Filter bar -->
  <div class="card-premium p-4 mb-6 flex flex-wrap items-center gap-3">
    <!-- Category tabs -->
    <div class="flex flex-wrap gap-1.5" id="cat-tabs">
      <button data-cat="all" class="cat-tab active px-3 py-1.5 rounded-lg text-sm font-medium transition-colors bg-primary-600 text-white">
        All
      </button>
      {categories.map(c => (
        <button data-cat={c} class={`cat-tab px-3 py-1.5 rounded-lg text-sm font-medium transition-colors bg-gray-100 text-text-secondary hover:bg-gray-200`}>
          <i class={`fas ${CAT_ICONS[c]} mr-1`} aria-hidden="true"></i>{CAT_LABELS[c]}
        </button>
      ))}
    </div>

    <div class="ml-auto flex items-center gap-3">
      <!-- Status filter -->
      <select id="status-filter" class="form-input !py-1.5 !px-3 text-sm w-44">
        <option value="">All Statuses</option>
        <option value="active">Active</option>
        <option value="under_maintenance">Under Maintenance</option>
        <option value="decommissioned">Decommissioned</option>
      </select>

      <!-- Expiry filter -->
      <select id="expiry-filter" class="form-input !py-1.5 !px-3 text-sm w-44">
        <option value="">All Assets</option>
        <option value="amc">AMC Due ≤90 Days</option>
        <option value="warranty">Warranty Expiring</option>
      </select>

      <!-- Search -->
      <div class="relative">
        <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-text-secondary text-sm" aria-hidden="true"></i>
        <input id="asset-search" type="text" placeholder="Search assets…"
          class="form-input !py-1.5 !pl-8 !pr-3 text-sm w-52" />
      </div>
    </div>
  </div>

  <!-- Results count -->
  <p class="text-text-secondary text-sm mb-3" id="results-count"></p>

  <!-- Asset grid -->
  <div id="asset-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {allAssets.map(a => {
      const amc = amcBadge(a.amc_end_date);
      const loc = (a as Record<string, unknown>).locations as {name: string} | null;
      return (
        <div
          class="card-premium p-4 cursor-pointer hover:shadow-medium transition-shadow asset-card"
          data-id={a.id}
          data-cat={a.category}
          data-status={a.status}
          data-amc-end={a.amc_end_date ?? ''}
          data-war-end={a.warranty_expiry ?? ''}
          data-search={`${a.name} ${a.asset_code ?? ''} ${a.make ?? ''} ${a.model ?? ''} ${a.serial_number ?? ''} ${loc?.name ?? ''}`.toLowerCase()}
        >
          <div class="flex items-start justify-between mb-3">
            <div class="flex items-center gap-2">
              <div class="w-9 h-9 rounded-lg bg-primary-100 flex items-center justify-center flex-shrink-0">
                <i class={`fas ${CAT_ICONS[a.category]} text-primary-600 text-sm`} aria-hidden="true"></i>
              </div>
              <div>
                <div class="font-semibold text-text-primary text-sm leading-tight">{a.name}</div>
                {a.asset_code && <div class="text-xs text-text-secondary font-mono">{a.asset_code}</div>}
              </div>
            </div>
            <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${STATUS_BADGE[a.status]}`}>
              {a.status === 'under_maintenance' ? 'Maintenance' : a.status.charAt(0).toUpperCase() + a.status.slice(1)}
            </span>
          </div>

          <div class="space-y-1 text-xs text-text-secondary mb-3">
            {a.make && <div><span class="font-medium">Make:</span> {a.make}{a.model ? ` · ${a.model}` : ''}</div>}
            {a.capacity && <div><span class="font-medium">Capacity:</span> {a.capacity}</div>}
            {a.serial_number && <div><span class="font-medium">S/N:</span> <span class="font-mono">{a.serial_number}</span></div>}
            {loc && <div><i class="fas fa-map-marker-alt mr-1 text-primary-400" aria-hidden="true"></i>{loc.name}{a.location_notes ? ` — ${a.location_notes}` : ''}</div>}
          </div>

          <div class="flex flex-wrap gap-1.5">
            <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${CAT_COLORS[a.category]}`}>
              {CAT_LABELS[a.category]}
            </span>
            {a.quantity > 1 && (
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                Qty: {a.quantity}
              </span>
            )}
            {amc === 'expired' && (
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">
                <i class="fas fa-exclamation-circle" aria-hidden="true"></i> AMC Expired
              </span>
            )}
            {amc === 'soon' && (
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">
                <i class="fas fa-clock" aria-hidden="true"></i> AMC Due Soon
              </span>
            )}
            {a.warranty_expiry && a.warranty_expiry >= today && a.warranty_expiry <= cutoff90 && (
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-600">
                <i class="fas fa-shield-alt" aria-hidden="true"></i> Warranty Ending
              </span>
            )}
          </div>
        </div>
      );
    })}
  </div>

  <!-- Empty state -->
  <div id="empty-state" class="hidden text-center py-16">
    <i class="fas fa-cogs text-5xl text-primary-200 mb-4" aria-hidden="true"></i>
    <h3 class="text-lg font-semibold text-text-primary mb-2">No assets found</h3>
    <p class="text-text-secondary text-sm mb-4">Try adjusting your filters or search term.</p>
  </div>

  <!-- ── Detail Drawer ───────────────────────────────────────────────────── -->
  <div id="detail-panel"
    class="fixed inset-y-0 right-0 w-full sm:w-[480px] bg-white shadow-large z-40 transform translate-x-full transition-transform duration-300 overflow-y-auto">
    <div class="sticky top-0 bg-white border-b border-border-light p-4 flex items-center justify-between">
      <h2 id="dp-title" class="text-lg font-semibold text-primary-600"></h2>
      <button id="close-panel" class="text-text-secondary hover:text-text-primary" aria-label="Close">
        <i class="fas fa-times text-xl" aria-hidden="true"></i>
      </button>
    </div>
    <div class="p-4 space-y-4" id="dp-body">
      <!-- filled by JS -->
    </div>
    {isExec && (
      <div class="sticky bottom-0 bg-white border-t border-border-light p-4 flex gap-3">
        <button id="dp-edit-btn" class="btn-primary flex-1">
          <i class="fas fa-edit mr-2" aria-hidden="true"></i>Edit Asset
        </button>
        <button id="dp-decommission-btn" class="btn-outline text-red-600 border-red-300 hover:bg-red-50 flex-1">
          <i class="fas fa-times-circle mr-2" aria-hidden="true"></i>Decommission
        </button>
      </div>
    )}
  </div>
  <div id="panel-backdrop" class="fixed inset-0 bg-black/40 z-30 hidden"></div>

  <!-- ── Add / Edit Drawer ──────────────────────────────────────────────── -->
  {isExec && (
    <div id="form-panel"
      class="fixed inset-y-0 right-0 w-full sm:w-[560px] bg-white shadow-large z-50 transform translate-x-full transition-transform duration-300 overflow-y-auto">
      <div class="sticky top-0 bg-white border-b border-border-light p-4 flex items-center justify-between">
        <h2 id="fp-title" class="text-lg font-semibold text-primary-600">Add Asset</h2>
        <button id="close-form" class="text-text-secondary hover:text-text-primary" aria-label="Close">
          <i class="fas fa-times text-xl" aria-hidden="true"></i>
        </button>
      </div>
      <form id="asset-form" class="p-4 space-y-4">
        <input type="hidden" id="asset-id" name="id" value="" />

        <!-- Name & Code -->
        <div class="grid grid-cols-2 gap-3">
          <div class="col-span-2">
            <label class="form-label" for="f-name">Asset Name <span class="text-red-500">*</span></label>
            <input id="f-name" name="name" type="text" class="form-input" placeholder="e.g. Transformer-1 (800 KVA)" required maxlength="200" />
          </div>
          <div>
            <label class="form-label" for="f-code">Asset Code</label>
            <input id="f-code" name="asset_code" type="text" class="form-input" placeholder="EL-001" maxlength="50" />
          </div>
          <div>
            <label class="form-label" for="f-quantity">Quantity</label>
            <input id="f-quantity" name="quantity" type="number" class="form-input" value="1" min="1" max="999" />
          </div>
        </div>

        <!-- Category & Status -->
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="form-label" for="f-category">Category <span class="text-red-500">*</span></label>
            <select id="f-category" name="category" class="form-input" required>
              <option value="">Select category</option>
              <option value="electrical">Electrical</option>
              <option value="plumbing">Plumbing</option>
              <option value="fire_safety">Fire Safety</option>
              <option value="hvac">HVAC</option>
              <option value="mechanical">Mechanical</option>
              <option value="security">Security</option>
              <option value="civil">Civil</option>
              <option value="it">IT</option>
              <option value="general">General</option>
            </select>
          </div>
          <div>
            <label class="form-label" for="f-status">Status</label>
            <select id="f-status" name="status" class="form-input">
              <option value="active">Active</option>
              <option value="under_maintenance">Under Maintenance</option>
              <option value="decommissioned">Decommissioned</option>
            </select>
          </div>
        </div>

        <!-- Make / Model / Serial -->
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="form-label" for="f-make">Make / Brand</label>
            <input id="f-make" name="make" type="text" class="form-input" placeholder="Kirloskar" maxlength="100" />
          </div>
          <div>
            <label class="form-label" for="f-model">Model / Part No.</label>
            <input id="f-model" name="model" type="text" class="form-input" maxlength="100" />
          </div>
          <div>
            <label class="form-label" for="f-serial">Serial Number</label>
            <input id="f-serial" name="serial_number" type="text" class="form-input" maxlength="100" />
          </div>
          <div>
            <label class="form-label" for="f-capacity">Capacity / Rating</label>
            <input id="f-capacity" name="capacity" type="text" class="form-input" placeholder="1000 KVA" maxlength="100" />
          </div>
        </div>

        <!-- Location -->
        <div>
          <label class="form-label" for="f-location">Location</label>
          <select id="f-location" name="location_id" class="form-input">
            <option value="">No location</option>
            {Object.entries(locationsByZone).map(([zone, locs]) => (
              <optgroup label={zone.replace('_', ' ').replace(/\b\w/g, c => c.toUpperCase())}>
                {locs.map(l => <option value={l.id}>{l.name}</option>)}
              </optgroup>
            ))}
          </select>
        </div>
        <div>
          <label class="form-label" for="f-loc-notes">Location Notes</label>
          <input id="f-loc-notes" name="location_notes" type="text" class="form-input"
            placeholder="e.g. HT Yard, next to LT panel" maxlength="200" />
        </div>

        <!-- Install & Warranty -->
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="form-label" for="f-install">Install Date</label>
            <input id="f-install" name="install_date" type="date" class="form-input" />
          </div>
          <div>
            <label class="form-label" for="f-warranty">Warranty Expiry</label>
            <input id="f-warranty" name="warranty_expiry" type="date" class="form-input" />
          </div>
        </div>

        <!-- Supplier -->
        <div>
          <label class="form-label" for="f-supplier">Supplier</label>
          <input id="f-supplier" name="supplier" type="text" class="form-input" maxlength="200" />
        </div>

        <!-- AMC -->
        <div class="border border-border-light rounded-xl p-4 space-y-3">
          <p class="text-sm font-semibold text-text-primary">AMC (Annual Maintenance Contract)</p>
          <div>
            <label class="form-label" for="f-amc-vendor">AMC Vendor</label>
            <input id="f-amc-vendor" name="amc_vendor" type="text" class="form-input" maxlength="200" />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="form-label" for="f-amc-start">AMC Start</label>
              <input id="f-amc-start" name="amc_start_date" type="date" class="form-input" />
            </div>
            <div>
              <label class="form-label" for="f-amc-end">AMC Expiry</label>
              <input id="f-amc-end" name="amc_end_date" type="date" class="form-input" />
            </div>
          </div>
        </div>

        <!-- Notes -->
        <div>
          <label class="form-label" for="f-notes">Notes</label>
          <textarea id="f-notes" name="notes" rows="3" class="form-input" maxlength="2000"></textarea>
        </div>

        <!-- Actions -->
        <div class="flex gap-3 pt-2">
          <button type="submit" id="form-submit-btn" class="btn-primary flex-1">
            <i class="fas fa-save mr-2" aria-hidden="true"></i>Save Asset
          </button>
          <button type="button" id="form-cancel-btn" class="btn-outline flex-1">Cancel</button>
        </div>
        <p id="form-error" class="form-error hidden"></p>
      </form>
    </div>
  )}

  <!-- Toast container -->
  <div id="toast-anchor" class="sr-only"></div>
</PortalLayout>

<script>
// All data injected inline to avoid define:vars TS issues
const ASSETS_DATA = JSON.parse(document.getElementById('__assets_data')?.textContent ?? '[]');
const LOC_MAP     = JSON.parse(document.getElementById('__loc_data')?.textContent ?? '[]')
  .reduce((m, l) => { m[l.id] = l; return m; }, {});
const CAT_LABELS  = { electrical:'Electrical', plumbing:'Plumbing', fire_safety:'Fire Safety', hvac:'HVAC', mechanical:'Mechanical', security:'Security', civil:'Civil', it:'IT', general:'General' };
const STATUS_LABELS = { active:'Active', under_maintenance:'Under Maintenance', decommissioned:'Decommissioned' };

// ── State ──────────────────────────────────────────────────────────────────
let activeCat    = 'all';
let activeStatus = '';
let activeExpiry = '';
let searchTerm   = '';
let currentAsset = null;

// ── Toast ──────────────────────────────────────────────────────────────────
function showToast(message, type = 'success') {
  const toast = document.createElement('div');
  const color = type === 'success' ? 'bg-secondary-500' : 'bg-red-500';
  toast.className = `fixed bottom-6 right-6 z-50 px-4 py-3 rounded-xl shadow-large text-sm font-medium text-white transform translate-y-4 opacity-0 transition-all duration-300 ${color}`;
  toast.textContent = message;
  document.body.appendChild(toast);
  requestAnimationFrame(() => toast.classList.remove('translate-y-4', 'opacity-0'));
  setTimeout(() => { toast.classList.add('translate-y-4', 'opacity-0'); setTimeout(() => toast.remove(), 300); }, 3000);
}

// ── Filtering ──────────────────────────────────────────────────────────────
function applyFilters() {
  const today   = new Date().toISOString().slice(0, 10);
  const cutoff  = (() => { const d = new Date(); d.setDate(d.getDate() + 90); return d.toISOString().slice(0, 10); })();
  const cards   = document.querySelectorAll('.asset-card');
  let shown     = 0;

  cards.forEach(card => {
    const cat     = card.getAttribute('data-cat') ?? '';
    const status  = card.getAttribute('data-status') ?? '';
    const amcEnd  = card.getAttribute('data-amc-end') ?? '';
    const warEnd  = card.getAttribute('data-war-end') ?? '';
    const search  = card.getAttribute('data-search') ?? '';

    const matchCat    = activeCat === 'all' || cat === activeCat;
    const matchStatus = !activeStatus || status === activeStatus;
    const matchSearch = !searchTerm || search.includes(searchTerm.toLowerCase());
    let   matchExpiry = true;
    if (activeExpiry === 'amc')      matchExpiry = !!amcEnd && amcEnd <= cutoff;
    if (activeExpiry === 'warranty') matchExpiry = !!warEnd && warEnd >= today && warEnd <= cutoff;

    const visible = matchCat && matchStatus && matchSearch && matchExpiry;
    (card as HTMLElement).style.display = visible ? '' : 'none';
    if (visible) shown++;
  });

  const count = document.getElementById('results-count');
  if (count) count.textContent = `Showing ${shown} asset${shown === 1 ? '' : 's'}`;
  const empty = document.getElementById('empty-state');
  if (empty) empty.classList.toggle('hidden', shown > 0);
}

// ── Category tabs ──────────────────────────────────────────────────────────
document.querySelectorAll('.cat-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    activeCat = btn.getAttribute('data-cat') ?? 'all';
    document.querySelectorAll('.cat-tab').forEach(b => {
      const active = b === btn;
      b.classList.toggle('bg-primary-600', active);
      b.classList.toggle('text-white', active);
      b.classList.toggle('bg-gray-100', !active);
      b.classList.toggle('text-text-secondary', !active);
    });
    applyFilters();
  });
});

document.getElementById('status-filter')?.addEventListener('change', e => {
  activeStatus = (e.target as HTMLSelectElement).value;
  applyFilters();
});

document.getElementById('expiry-filter')?.addEventListener('change', e => {
  activeExpiry = (e.target as HTMLSelectElement).value;
  applyFilters();
});

let searchTimer = 0;
document.getElementById('asset-search')?.addEventListener('input', e => {
  clearTimeout(searchTimer);
  searchTimer = window.setTimeout(() => {
    searchTerm = (e.target as HTMLInputElement).value.trim();
    applyFilters();
  }, 200);
});

// ── Detail drawer ──────────────────────────────────────────────────────────
function openDetail(assetId) {
  const asset = ASSETS_DATA.find(a => a.id === assetId);
  if (!asset) return;
  currentAsset = asset;

  const loc  = asset.location_id ? LOC_MAP[asset.location_id] : null;
  const today = new Date().toISOString().slice(0, 10);
  const cut90 = (() => { const d = new Date(); d.setDate(d.getDate() + 90); return d.toISOString().slice(0, 10); })();

  document.getElementById('dp-title').textContent = asset.name;

  function row(label, value, extra = '') {
    if (!value && value !== 0) return '';
    return `<div class="flex justify-between text-sm border-b border-border-light pb-2">
      <span class="text-text-secondary font-medium w-40 flex-shrink-0">${label}</span>
      <span class="text-text-primary text-right">${value}${extra}</span>
    </div>`;
  }

  function amcClass(end) {
    if (!end) return '';
    if (end < today) return 'text-red-600 font-semibold';
    if (end <= cut90) return 'text-amber-600 font-semibold';
    return '';
  }

  const amcEndClass = amcClass(asset.amc_end_date);
  const warClass    = asset.warranty_expiry && asset.warranty_expiry >= today && asset.warranty_expiry <= cut90
    ? 'text-amber-600 font-semibold' : '';

  document.getElementById('dp-body').innerHTML = `
    <div class="space-y-2">
      ${row('Asset Code',  asset.asset_code)}
      ${row('Category',    CAT_LABELS[asset.category] ?? asset.category)}
      ${row('Status',      STATUS_LABELS[asset.status] ?? asset.status)}
      ${row('Quantity',    asset.quantity > 1 ? asset.quantity : null)}
      ${row('Capacity',    asset.capacity)}
      ${row('Make',        asset.make)}
      ${row('Model',       asset.model)}
      ${row('Serial No.',  asset.serial_number)}
      ${row('Location',    loc ? loc.name : null)}
      ${asset.location_notes ? row('Loc. Notes',  asset.location_notes) : ''}
      ${row('Installed',   asset.install_date)}
      ${asset.warranty_expiry ? `<div class="flex justify-between text-sm border-b border-border-light pb-2">
        <span class="text-text-secondary font-medium w-40">Warranty Expiry</span>
        <span class="${warClass} text-right">${asset.warranty_expiry}</span>
      </div>` : ''}
      ${row('Supplier',    asset.supplier)}
    </div>

    ${asset.amc_vendor || asset.amc_end_date ? `
    <div class="border border-border-light rounded-xl p-4 space-y-2">
      <p class="text-sm font-semibold text-text-primary mb-3">AMC Details</p>
      ${row('Vendor',    asset.amc_vendor)}
      ${row('AMC Start', asset.amc_start_date)}
      ${asset.amc_end_date ? `<div class="flex justify-between text-sm border-b border-border-light pb-2">
        <span class="text-text-secondary font-medium w-40">AMC Expiry</span>
        <span class="${amcEndClass} text-right">${asset.amc_end_date}${asset.amc_end_date < today ? ' — EXPIRED' : asset.amc_end_date <= cut90 ? ' — Due Soon' : ''}</span>
      </div>` : ''}
    </div>` : ''}

    ${asset.notes ? `<div class="text-sm text-text-secondary bg-section-alt rounded-xl p-3">${asset.notes}</div>` : ''}
  `;

  document.getElementById('detail-panel').classList.replace('translate-x-full', 'translate-x-0');
  document.getElementById('panel-backdrop').classList.remove('hidden');
}

function closeDetail() {
  document.getElementById('detail-panel').classList.replace('translate-x-0', 'translate-x-full');
  document.getElementById('panel-backdrop').classList.add('hidden');
  currentAsset = null;
}

document.querySelectorAll('.asset-card').forEach(card => {
  card.addEventListener('click', () => openDetail(card.getAttribute('data-id')));
});

document.getElementById('close-panel')?.addEventListener('click', closeDetail);
document.getElementById('panel-backdrop')?.addEventListener('click', () => {
  closeDetail();
  closeForm();
});

// ── Form drawer ────────────────────────────────────────────────────────────
let editingId = null;

function openForm(asset = null) {
  const form = document.getElementById('asset-form') as HTMLFormElement;
  const fpTitle = document.getElementById('fp-title');
  editingId = asset?.id ?? null;
  fpTitle.textContent = asset ? 'Edit Asset' : 'Add Asset';

  form.reset();
  document.getElementById('asset-id').value = '';
  document.getElementById('f-quantity').value = '1';

  if (asset) {
    document.getElementById('asset-id').value    = asset.id;
    document.getElementById('f-name').value      = asset.name;
    document.getElementById('f-code').value      = asset.asset_code ?? '';
    document.getElementById('f-quantity').value  = asset.quantity ?? 1;
    document.getElementById('f-category').value  = asset.category;
    document.getElementById('f-status').value    = asset.status;
    document.getElementById('f-make').value      = asset.make ?? '';
    document.getElementById('f-model').value     = asset.model ?? '';
    document.getElementById('f-serial').value    = asset.serial_number ?? '';
    document.getElementById('f-capacity').value  = asset.capacity ?? '';
    document.getElementById('f-location').value  = asset.location_id ?? '';
    document.getElementById('f-loc-notes').value = asset.location_notes ?? '';
    document.getElementById('f-install').value   = asset.install_date ?? '';
    document.getElementById('f-warranty').value  = asset.warranty_expiry ?? '';
    document.getElementById('f-supplier').value  = asset.supplier ?? '';
    document.getElementById('f-amc-vendor').value= asset.amc_vendor ?? '';
    document.getElementById('f-amc-start').value = asset.amc_start_date ?? '';
    document.getElementById('f-amc-end').value   = asset.amc_end_date ?? '';
    document.getElementById('f-notes').value     = asset.notes ?? '';
  }

  document.getElementById('form-error').classList.add('hidden');
  closeDetail();
  document.getElementById('form-panel').classList.replace('translate-x-full', 'translate-x-0');
  document.getElementById('panel-backdrop').classList.remove('hidden');
}

function closeForm() {
  document.getElementById('form-panel')?.classList.replace('translate-x-0', 'translate-x-full');
  document.getElementById('panel-backdrop').classList.add('hidden');
  editingId = null;
}

document.getElementById('add-asset-btn')?.addEventListener('click', () => openForm(null));
document.getElementById('close-form')?.addEventListener('click', closeForm);
document.getElementById('form-cancel-btn')?.addEventListener('click', closeForm);

document.getElementById('dp-edit-btn')?.addEventListener('click', () => {
  if (currentAsset) openForm(currentAsset);
});

// ── Decommission ───────────────────────────────────────────────────────────
document.getElementById('dp-decommission-btn')?.addEventListener('click', async () => {
  if (!currentAsset) return;
  if (!confirm(`Mark "${currentAsset.name}" as decommissioned?`)) return;
  try {
    const res = await fetch(`/api/v1/staff-management/assets/${currentAsset.id}`, {
      method: 'DELETE',
    });
    if (!res.ok) throw new Error((await res.json()).message ?? 'Error');
    showToast('Asset marked as decommissioned');
    closeDetail();
    setTimeout(() => location.reload(), 500);
  } catch (e) {
    showToast(e.message ?? 'Failed', 'error');
  }
});

// ── Form submit ────────────────────────────────────────────────────────────
document.getElementById('asset-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const form     = e.target as HTMLFormElement;
  const errEl    = document.getElementById('form-error');
  const submitBtn= document.getElementById('form-submit-btn');
  errEl.classList.add('hidden');

  const data: Record<string, unknown> = {
    name:          (document.getElementById('f-name') as HTMLInputElement).value.trim(),
    asset_code:    (document.getElementById('f-code') as HTMLInputElement).value.trim() || null,
    quantity:      Number((document.getElementById('f-quantity') as HTMLInputElement).value) || 1,
    category:      (document.getElementById('f-category') as HTMLSelectElement).value,
    status:        (document.getElementById('f-status') as HTMLSelectElement).value,
    make:          (document.getElementById('f-make') as HTMLInputElement).value.trim() || null,
    model:         (document.getElementById('f-model') as HTMLInputElement).value.trim() || null,
    serial_number: (document.getElementById('f-serial') as HTMLInputElement).value.trim() || null,
    capacity:      (document.getElementById('f-capacity') as HTMLInputElement).value.trim() || null,
    location_id:   (document.getElementById('f-location') as HTMLSelectElement).value || null,
    location_notes:(document.getElementById('f-loc-notes') as HTMLInputElement).value.trim() || null,
    install_date:  (document.getElementById('f-install') as HTMLInputElement).value || null,
    warranty_expiry:(document.getElementById('f-warranty') as HTMLInputElement).value || null,
    supplier:      (document.getElementById('f-supplier') as HTMLInputElement).value.trim() || null,
    amc_vendor:    (document.getElementById('f-amc-vendor') as HTMLInputElement).value.trim() || null,
    amc_start_date:(document.getElementById('f-amc-start') as HTMLInputElement).value || null,
    amc_end_date:  (document.getElementById('f-amc-end') as HTMLInputElement).value || null,
    notes:         (document.getElementById('f-notes') as HTMLTextAreaElement).value.trim() || null,
  };

  const isEdit  = !!editingId;
  const url     = isEdit ? `/api/v1/staff-management/assets/${editingId}` : '/api/v1/staff-management/assets';
  const method  = isEdit ? 'PUT' : 'POST';

  submitBtn.textContent = 'Saving…';
  (submitBtn as HTMLButtonElement).disabled = true;

  try {
    const res = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    const json = await res.json();
    if (!res.ok) throw new Error(json.message ?? 'Failed to save asset.');
    showToast(isEdit ? 'Asset updated.' : 'Asset added.');
    closeForm();
    setTimeout(() => location.reload(), 500);
  } catch (err) {
    errEl.textContent = err.message ?? 'Unexpected error.';
    errEl.classList.remove('hidden');
  } finally {
    submitBtn.textContent = 'Save Asset';
    (submitBtn as HTMLButtonElement).disabled = false;
  }
});

// Initial count
applyFilters();
</script>

<!-- Inline JSON blobs for JS consumption -->
<script id="__assets_data" type="application/json" set:html={assetsJson}></script>
<script id="__loc_data" type="application/json" set:html={locationsJson}></script>
</PortalLayout>

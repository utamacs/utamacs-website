---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';
import { getSupabaseServiceClient } from '@lib/services/providers/supabase/SupabaseDB';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
const isStaffRole = ['staff', 'supervisor', 'afm'].includes(user.portalRole);
const isExec = ['executive', 'secretary', 'president'].includes(user.portalRole) || user.isAdmin;
if (!isStaffRole && !isExec) return Astro.redirect('/portal');

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const sb = getSupabaseServiceClient();

// Date range: current month
const now = new Date();
const monthStart = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().split('T')[0];
const monthEnd = new Date(now.getFullYear(), now.getMonth() + 1, 0).toISOString().split('T')[0];

let records: { date: string; check_in: string | null; check_out: string | null; status: string; check_in_method: string; overtime_mins: number | null; notes: string | null }[] = [];
let staffName = '';
let presentCount = 0;
let absentCount = 0;

if (isStaffRole) {
  const { data: sm } = await sb.from('staff_members').select('id, name').eq('user_id', user.id).eq('society_id', SOCIETY_ID).single();
  if (sm) {
    staffName = sm.name;
    const { data } = await sb.from('staff_attendance')
      .select('date, check_in, check_out, status, check_in_method, overtime_mins, notes')
      .eq('staff_id', sm.id)
      .gte('date', monthStart)
      .lte('date', monthEnd)
      .order('date', { ascending: false });
    records = data ?? [];
    presentCount = records.filter(r => r.status === 'present').length;
    absentCount = records.filter(r => r.status === 'absent').length;
  }
}

const STATUS_BADGE: Record<string, string> = {
  present:   'bg-secondary-500/10 text-secondary-500',
  absent:    'bg-red-50 text-red-600',
  half_day:  'bg-amber-50 text-amber-700',
  leave:     'bg-blue-50 text-blue-600',
  holiday:   'bg-purple-50 text-purple-600',
};

const METHOD_ICON: Record<string, string> = {
  manual: 'fa-hand-pointer',
  qr: 'fa-qrcode',
  whatsapp: 'fa-whatsapp fab',
  biometric: 'fa-fingerprint',
};
---

<PortalLayout title="My Attendance" user={user} activeModule="staff_attendance">

  <!-- Process info panel -->
  <details class="mb-6 group rounded-xl border border-primary-100 bg-gradient-to-r from-primary-50/50 to-blue-50/20 overflow-hidden">
    <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer list-none select-none hover:bg-primary-50/60 transition-colors">
      <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-project-diagram text-white text-xs" aria-hidden="true"></i>
      </div>
      <span class="text-sm font-medium text-text-primary flex-1">Daily check-in and check-out records with automatic overtime calculation — supervisors can mark absent or leave for staff who have not clocked in.</span>
      <span class="text-xs text-primary-600 flex items-center gap-1.5 flex-shrink-0 font-medium">
        How it works
        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200 group-open:rotate-180" aria-hidden="true"></i>
      </span>
    </summary>
    <div class="px-5 pb-5">
      <div class="pt-4 border-t border-primary-100 space-y-4">
        <div class="process-snake-flow -mx-1 px-1">
          <div class="flex-shrink-0 w-44 rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Shift Begins</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">Scheduled shift time</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">Check In</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">QR / manual / WhatsApp</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">Work Period</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">Tasks in progress</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-amber-300 bg-amber-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-amber-800 whitespace-nowrap">Overtime Tracked</p>
            <p class="text-[11px] text-amber-700 mt-0.5 whitespace-nowrap">Hours beyond threshold</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-green-300 bg-green-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-green-800 whitespace-nowrap">Check Out</p>
            <p class="text-[11px] text-green-700 mt-0.5 whitespace-nowrap">Total hours calculated</p>
          </div>
          <div class="flex-shrink-0 w-44 rounded-lg border border-gray-300 bg-gray-100 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Record Filed</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">Feeds monthly report</p>
          </div>
        </div>
        <div class="flex items-center gap-2 text-xs text-red-600">
          <i class="fas fa-arrow-turn-down text-red-400 text-[10px]" aria-hidden="true"></i>
          <span class="font-medium">No Check-in</span>
          <span class="text-red-500">— After grace period, supervisor can mark Absent, Half-Day, Leave or Holiday; late-check-in alert sent at 30 minutes (configurable)</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mt-1">
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-sign-in-alt text-primary-400 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Check-in methods: <strong>Manual</strong> (exec/guard entry), <strong>QR scan</strong> (staff QR token), <strong>WhatsApp</strong> (text-based), <strong>Biometric</strong> (hardware integration)</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-clock text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Overtime threshold configurable via Rules Engine (default: 9 hours) — any hours beyond are logged as OT and flagged in monthly reports</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-calendar-check text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Status options: <strong>Present</strong>, <strong>Absent</strong>, <strong>Half-Day</strong>, <strong>Leave</strong>, <strong>Holiday</strong> — only supervisors and exec can set Absent/Leave/Holiday</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-file-alt text-primary-400 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Monthly attendance summary feeds CLRA Form B statutory wage register — present days, OT hours and leave balance exported together</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-chart-bar text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Attendance % = (present days ÷ working days) × 100 — displayed per staff member in the monthly staff report</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-bell text-red-400 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Late check-in alert threshold: 30 minutes after shift start (configurable in Rules Engine under STAFF_LATE_CHECKIN_ALERT_MINS)</span>
          </div>
        </div>
      </div>
    </div>
  </details>

  <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
    <div>
      <h1 class="text-2xl font-bold text-primary-600 font-poppins">My Attendance</h1>
      <p class="text-text-secondary text-sm mt-1">
        {now.toLocaleDateString('en-IN', { month: 'long', year: 'numeric' })}
        {isStaffRole && ` · ${staffName}`}
      </p>
    </div>
    <div class="flex gap-2">
      <select id="month-picker" class="form-input py-2 text-sm bg-white w-36">
        {Array.from({ length: 6 }, (_, i) => {
          const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
          const val = d.toISOString().slice(0, 7);
          return <option value={val} selected={i === 0}>{d.toLocaleDateString('en-IN', { month: 'long', year: 'numeric' })}</option>;
        })}
      </select>
    </div>
  </div>

  <!-- Summary cards -->
  {isStaffRole && (
    <div class="grid grid-cols-3 gap-4 mb-6">
      <div class="card-premium p-4 text-center">
        <div class="text-2xl font-bold text-secondary-500">{presentCount}</div>
        <div class="text-xs text-text-secondary mt-0.5">Present</div>
      </div>
      <div class="card-premium p-4 text-center">
        <div class="text-2xl font-bold text-red-600">{absentCount}</div>
        <div class="text-xs text-text-secondary mt-0.5">Absent</div>
      </div>
      <div class="card-premium p-4 text-center">
        <div class="text-2xl font-bold text-primary-600">{records.filter(r => (r.overtime_mins ?? 0) > 0).length}</div>
        <div class="text-xs text-text-secondary mt-0.5">OT Days</div>
      </div>
    </div>
  )}

  <!-- Attendance records -->
  <div class="card-premium overflow-hidden">
    <div class="p-4 border-b border-border-light flex items-center justify-between">
      <h2 class="font-semibold text-text-primary">Attendance Log</h2>
      {isExec && (
        <a href="/portal/staff-management/reports" class="text-sm text-primary-600 hover:underline">
          Full Report →
        </a>
      )}
    </div>
    {records.length === 0 ? (
      <div class="text-center py-10">
        <i class="fas fa-calendar-times text-4xl text-primary-200 mb-3" aria-hidden="true"></i>
        <p class="text-sm text-text-secondary">No attendance records for this month.</p>
      </div>
    ) : (
      <div class="divide-y divide-border-light">
        {records.map(r => {
          const inTime = r.check_in ? new Date(r.check_in).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) : '—';
          const outTime = r.check_out ? new Date(r.check_out).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) : '—';
          const date = new Date(r.date);
          return (
            <div class="flex items-center gap-4 px-4 py-3 hover:bg-gray-50 transition-colors">
              <div class="w-14 text-center flex-shrink-0">
                <div class="text-base font-bold text-text-primary">{date.getDate()}</div>
                <div class="text-xs text-text-secondary">{date.toLocaleDateString('en-IN', { weekday: 'short' })}</div>
              </div>
              <div class="flex-1 grid grid-cols-2 sm:grid-cols-4 gap-2 text-sm">
                <div>
                  <div class="text-xs text-text-secondary mb-0.5">Check-in</div>
                  <div class="font-medium text-text-primary">{inTime}</div>
                </div>
                <div>
                  <div class="text-xs text-text-secondary mb-0.5">Check-out</div>
                  <div class="font-medium text-text-primary">{outTime}</div>
                </div>
                <div class="hidden sm:block">
                  <div class="text-xs text-text-secondary mb-0.5">Method</div>
                  <div class="text-text-secondary">
                    <i class={`fas ${METHOD_ICON[r.check_in_method] ?? 'fa-hand-pointer'} mr-1 text-xs`} aria-hidden="true"></i>
                    <span class="text-xs capitalize">{r.check_in_method}</span>
                  </div>
                </div>
                {r.overtime_mins != null && r.overtime_mins > 0 && (
                  <div class="hidden sm:block">
                    <div class="text-xs text-text-secondary mb-0.5">Overtime</div>
                    <div class="text-xs text-accent-500 font-medium">+{r.overtime_mins}m</div>
                  </div>
                )}
              </div>
              <span class={`text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0 capitalize ${STATUS_BADGE[r.status] ?? 'bg-gray-100 text-gray-600'}`}>
                {r.status.replace('_', ' ')}
              </span>
            </div>
          );
        })}
      </div>
    )}
  </div>
</PortalLayout>

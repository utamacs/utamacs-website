---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';
import { getSupabaseServiceClient } from '@lib/services/providers/supabase/SupabaseDB';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
const isExec = ['executive', 'secretary', 'president'].includes(user.portalRole) || user.isAdmin;
const isAfm = user.portalRole === 'afm';
if (!isExec && !isAfm) return Astro.redirect('/portal');

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const sb = getSupabaseServiceClient();

const { data: agencies } = await sb
  .from('staff_agencies')
  .select('id, name, type, contact_name, contact_phone, psara_number, psara_expiry, contract_start, contract_end, monthly_rate, is_active')
  .eq('society_id', SOCIETY_ID)
  .order('type')
  .order('name');

const today = new Date();
const thirtyDays = new Date(today.getTime() + 30 * 24 * 60 * 60 * 1000);

function psaraStatus(expiry: string | null) {
  if (!expiry) return { label: 'Not Set', color: 'bg-gray-100 text-gray-600' };
  const d = new Date(expiry);
  if (d < today) return { label: 'Expired', color: 'bg-red-50 text-red-600' };
  if (d < thirtyDays) return { label: 'Expiring Soon', color: 'bg-amber-50 text-amber-600' };
  return { label: 'Valid', color: 'bg-secondary-500/10 text-secondary-500' };
}

const TYPE_LABELS: Record<string, string> = {
  security: 'Security', housekeeping: 'Housekeeping', gardening: 'Gardening',
  maintenance: 'Maintenance', multi_service: 'Multi-Service',
};
---

<PortalLayout title="Agency Management" user={user} activeModule="staff_management">
  <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
    <div>
      <nav class="text-sm text-text-secondary mb-1">
        <a href="/portal/staff-management" class="hover:text-primary-600">Staff Management</a>
        <span class="mx-2">›</span><span class="text-text-primary">Agencies</span>
      </nav>
      <h1 class="text-2xl font-bold text-primary-600 font-poppins">Agency Management</h1>
      <p class="text-text-secondary text-sm mt-1">PSARA licences, PF/ESIC, and contract tracking</p>
    </div>
    {isExec && (
      <button id="add-agency-btn" class="btn-primary text-sm">
        <i class="fas fa-plus mr-1.5" aria-hidden="true"></i>Add Agency
      </button>
    )}
  </div>

  {(agencies ?? []).length === 0 ? (
    <div class="text-center py-16">
      <i class="fas fa-building text-5xl text-primary-200 mb-4" aria-hidden="true"></i>
      <h3 class="text-lg font-semibold text-text-primary mb-2">No agencies registered</h3>
      <p class="text-text-secondary text-sm mb-4">Add agencies to track PSARA licences and contracts.</p>
      {isExec && <button id="add-agency-empty-btn" class="btn-primary text-sm">Add Agency</button>}
    </div>
  ) : (
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      {(agencies ?? []).map(agency => {
        const ps = psaraStatus(agency.psara_expiry);
        return (
          <div class={`card-premium p-5 ${!agency.is_active ? 'opacity-60' : ''}`}>
            <div class="flex items-start justify-between mb-3">
              <div>
                <div class="font-semibold text-text-primary">{agency.name}</div>
                <div class="text-xs text-text-secondary mt-0.5">{TYPE_LABELS[agency.type] ?? agency.type}</div>
              </div>
              <span class={`text-xs px-2.5 py-1 rounded-full font-medium ${agency.is_active ? 'bg-secondary-500/10 text-secondary-500' : 'bg-gray-100 text-gray-600'}`}>
                {agency.is_active ? 'Active' : 'Inactive'}
              </span>
            </div>

            <div class="grid grid-cols-2 gap-2 text-sm mb-3">
              {agency.contact_name && (
                <div class="col-span-2">
                  <span class="text-text-secondary">Contact: </span>
                  <span class="text-text-primary">{agency.contact_name}</span>
                  {agency.contact_phone && <span class="text-primary-600 ml-2">{agency.contact_phone}</span>}
                </div>
              )}
              {agency.monthly_rate && (
                <div>
                  <span class="text-text-secondary">Rate: </span>
                  <span class="text-text-primary font-medium">₹{Number(agency.monthly_rate).toLocaleString('en-IN')}/mo</span>
                </div>
              )}
              {agency.contract_end && (
                <div>
                  <span class="text-text-secondary">Contract till: </span>
                  <span class="text-text-primary">{new Date(agency.contract_end).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
                </div>
              )}
            </div>

            {agency.type === 'security' && (
              <div class="flex items-center gap-2 pt-2 border-t border-border-light">
                <span class="text-xs text-text-secondary">PSARA:</span>
                <span class="text-xs font-medium text-text-primary">{agency.psara_number ?? '—'}</span>
                <span class={`text-xs px-2 py-0.5 rounded-full font-medium ml-auto ${ps.color}`}>{ps.label}</span>
              </div>
            )}
          </div>
        );
      })}
    </div>
  )}

  <!-- Add Agency Drawer -->
  <div id="add-agency-panel" class="fixed inset-y-0 right-0 w-full sm:w-[480px] bg-white shadow-large z-40 transform translate-x-full transition-transform duration-300 overflow-y-auto">
    <div class="sticky top-0 bg-white border-b border-border-light p-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-primary-600">Add Agency</h2>
      <button id="close-agency-panel" class="text-text-secondary hover:text-text-primary" aria-label="Close">
        <i class="fas fa-times text-xl" aria-hidden="true"></i>
      </button>
    </div>
    <div class="p-4">
      <div id="agency-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>
      <form id="add-agency-form" class="space-y-4">
        <div>
          <label class="form-label">Agency Name <span class="text-red-500">*</span></label>
          <input name="name" type="text" required maxlength="200" class="form-input" />
        </div>
        <div>
          <label class="form-label">Type <span class="text-red-500">*</span></label>
          <select name="type" required class="form-input bg-white">
            {Object.entries(TYPE_LABELS).map(([k, v]) => <option value={k}>{v}</option>)}
          </select>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="form-label">Contact Name</label>
            <input name="contact_name" type="text" maxlength="100" class="form-input" />
          </div>
          <div>
            <label class="form-label">Contact Phone</label>
            <input name="contact_phone" type="tel" maxlength="15" class="form-input" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="form-label">PF Number</label>
            <input name="pf_number" type="text" maxlength="50" class="form-input" />
          </div>
          <div>
            <label class="form-label">ESIC Number</label>
            <input name="esic_number" type="text" maxlength="50" class="form-input" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="form-label">PSARA Licence No.</label>
            <input name="psara_number" type="text" maxlength="50" class="form-input" />
          </div>
          <div>
            <label class="form-label">PSARA Expiry</label>
            <input name="psara_expiry" type="date" class="form-input" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="form-label">Contract Start</label>
            <input name="contract_start" type="date" class="form-input" />
          </div>
          <div>
            <label class="form-label">Contract End</label>
            <input name="contract_end" type="date" class="form-input" />
          </div>
        </div>
        <div>
          <label class="form-label">Monthly Rate (₹)</label>
          <input name="monthly_rate" type="number" min="0" step="100" class="form-input" placeholder="e.g. 45000" />
        </div>
        <button type="submit" class="btn-primary w-full">Add Agency</button>
      </form>
    </div>
  </div>
  <div id="agency-backdrop" class="fixed inset-0 bg-black/40 z-30 hidden"></div>
</PortalLayout>

<script>
const panel = document.getElementById('add-agency-panel')!;
const backdrop = document.getElementById('agency-backdrop')!;
const open = () => { panel.classList.remove('translate-x-full'); backdrop.classList.remove('hidden'); };
const close = () => { panel.classList.add('translate-x-full'); backdrop.classList.add('hidden'); };
document.getElementById('add-agency-btn')?.addEventListener('click', open);
document.getElementById('add-agency-empty-btn')?.addEventListener('click', open);
document.getElementById('close-agency-panel')?.addEventListener('click', close);
backdrop.addEventListener('click', close);

document.getElementById('add-agency-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target as HTMLFormElement);
  const body = Object.fromEntries(fd.entries());
  const errEl = document.getElementById('agency-error')!;
  errEl.classList.add('hidden');
  const res = await fetch('/api/v1/staff/agencies', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
  if (res.ok) { window.location.reload(); }
  else { const d = await res.json().catch(() => ({})); errEl.textContent = d.message ?? 'Failed to add agency.'; errEl.classList.remove('hidden'); }
});
</script>

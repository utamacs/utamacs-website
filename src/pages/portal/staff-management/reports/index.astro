---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';
import { getSupabaseServiceClient } from '@lib/services/providers/supabase/SupabaseDB';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
const isSupervisorPlus = ['supervisor', 'afm'].includes(user.portalRole) ||
  ['executive', 'secretary', 'president'].includes(user.portalRole) || user.isAdmin;
if (!isSupervisorPlus) return Astro.redirect('/portal');

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const sb = getSupabaseServiceClient();
const now = new Date();
const monthStart = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().split('T')[0];
const monthEnd = new Date(now.getFullYear(), now.getMonth() + 1, 0).toISOString().split('T')[0];

// Attendance summary this month
const { data: attRows } = await sb
  .from('staff_attendance')
  .select('staff_id, status, date')
  .eq('society_id', SOCIETY_ID)
  .gte('date', monthStart)
  .lte('date', monthEnd);

// Task completion summary
const { data: taskRows } = await sb
  .from('staff_task_assignments')
  .select('status, assigned_to, due_date')
  .eq('society_id', SOCIETY_ID)
  .gte('due_date', monthStart)
  .lte('due_date', monthEnd);

// Staff list for name lookup
const { data: staffList } = await sb
  .from('staff_members')
  .select('id, name, department')
  .eq('society_id', SOCIETY_ID)
  .eq('is_active', true);

const staffMap = Object.fromEntries((staffList ?? []).map(s => [s.id, { name: s.name, dept: s.department ?? 'other' }]));

// Build per-staff summaries
const staffSummaries: Record<string, { name: string; dept: string; present: number; absent: number; tasks_done: number; tasks_pending: number; tasks_overdue: number }> = {};
for (const s of staffList ?? []) {
  staffSummaries[s.id] = { name: s.name, dept: s.department ?? 'other', present: 0, absent: 0, tasks_done: 0, tasks_pending: 0, tasks_overdue: 0 };
}
for (const r of attRows ?? []) {
  if (staffSummaries[r.staff_id]) {
    if (r.status === 'present') staffSummaries[r.staff_id]!.present++;
    else if (r.status === 'absent') staffSummaries[r.staff_id]!.absent++;
  }
}
for (const t of taskRows ?? []) {
  if (staffSummaries[t.assigned_to]) {
    if (t.status === 'completed') staffSummaries[t.assigned_to]!.tasks_done++;
    else if (t.status === 'overdue') staffSummaries[t.assigned_to]!.tasks_overdue++;
    else if (t.status === 'pending') staffSummaries[t.assigned_to]!.tasks_pending++;
  }
}

const summaryRows = Object.values(staffSummaries);
const totalPresent = summaryRows.reduce((s, r) => s + r.present, 0);
const totalAbsent  = summaryRows.reduce((s, r) => s + r.absent, 0);
const totalDone    = summaryRows.reduce((s, r) => s + r.tasks_done, 0);
const totalOverdue = summaryRows.reduce((s, r) => s + r.tasks_overdue, 0);
---

<PortalLayout title="Staff Reports" user={user} activeModule="staff_reports">
  <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
    <div>
      <h1 class="text-2xl font-bold text-primary-600 font-poppins">Staff Reports</h1>
      <p class="text-text-secondary text-sm mt-1">
        {now.toLocaleDateString('en-IN', { month: 'long', year: 'numeric' })} summary
      </p>
    </div>
    <div class="flex gap-2">
      <select id="report-month" class="form-input py-2 text-sm bg-white w-36">
        {Array.from({ length: 6 }, (_, i) => {
          const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
          const val = d.toISOString().slice(0, 7);
          return <option value={val} selected={i === 0}>{d.toLocaleDateString('en-IN', { month: 'long', year: 'numeric' })}</option>;
        })}
      </select>
      <button id="export-btn" class="btn-outline text-sm">
        <i class="fas fa-download mr-1.5" aria-hidden="true"></i>Export
      </button>
    </div>
  </div>

  <!-- Month totals -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    {[
      { label: 'Total Attendance Days', value: totalPresent, icon: 'fa-check-circle', color: 'text-secondary-500', bg: 'bg-secondary-500/10' },
      { label: 'Total Absent Days',     value: totalAbsent,  icon: 'fa-times-circle', color: 'text-red-600',       bg: 'bg-red-50'          },
      { label: 'Tasks Completed',       value: totalDone,    icon: 'fa-tasks',        color: 'text-primary-600',   bg: 'bg-primary-50'      },
      { label: 'Tasks Overdue',         value: totalOverdue, icon: 'fa-exclamation-circle', color: 'text-accent-500', bg: 'bg-amber-50'     },
    ].map(k => (
      <div class="card-premium p-4">
        <div class={`w-9 h-9 ${k.bg} rounded-xl flex items-center justify-center mb-2`}>
          <i class={`fas ${k.icon} ${k.color} text-sm`} aria-hidden="true"></i>
        </div>
        <div class={`text-2xl font-bold ${k.color}`}>{k.value}</div>
        <div class="text-xs text-text-secondary mt-0.5">{k.label}</div>
      </div>
    ))}
  </div>

  <!-- Per-staff table -->
  <div class="card-premium overflow-hidden">
    <div class="p-4 border-b border-border-light flex items-center justify-between">
      <h2 class="font-semibold text-text-primary">Staff Breakdown</h2>
      <div class="flex gap-2">
        <input id="staff-search" type="search" placeholder="Search staff…" class="form-input py-1.5 text-sm w-40" />
        <select id="dept-filter" class="form-input py-1.5 text-sm bg-white w-36">
          <option value="">All Depts</option>
          {['security','housekeeping','gardening','maintenance','admin'].map(d => (
            <option value={d}>{d.charAt(0).toUpperCase() + d.slice(1)}</option>
          ))}
        </select>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-text-secondary uppercase tracking-wide">Staff</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-text-secondary uppercase tracking-wide">Dept</th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-text-secondary uppercase tracking-wide">Present</th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-text-secondary uppercase tracking-wide">Absent</th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-text-secondary uppercase tracking-wide">Tasks Done</th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-text-secondary uppercase tracking-wide">Overdue</th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-text-secondary uppercase tracking-wide">Attendance %</th>
          </tr>
        </thead>
        <tbody id="staff-table-body" class="divide-y divide-border-light">
          {summaryRows.map(row => {
            const total = row.present + row.absent;
            const pct = total > 0 ? Math.round(row.present / total * 100) : 0;
            return (
              <tr class="staff-row hover:bg-gray-50 transition-colors" data-name={row.name.toLowerCase()} data-dept={row.dept}>
                <td class="px-4 py-3 font-medium text-text-primary">{row.name}</td>
                <td class="px-4 py-3 text-text-secondary capitalize">{row.dept}</td>
                <td class="px-4 py-3 text-center text-secondary-500 font-semibold">{row.present}</td>
                <td class="px-4 py-3 text-center text-red-600">{row.absent}</td>
                <td class="px-4 py-3 text-center text-primary-600">{row.tasks_done}</td>
                <td class="px-4 py-3 text-center text-accent-500">{row.tasks_overdue}</td>
                <td class="px-4 py-3 text-center">
                  <div class="flex items-center justify-center gap-2">
                    <div class="w-16 h-1.5 bg-gray-200 rounded-full overflow-hidden">
                      <div class="h-full bg-secondary-500 rounded-full" style={`width: ${pct}%`}></div>
                    </div>
                    <span class={`text-xs font-medium ${pct >= 90 ? 'text-secondary-500' : pct >= 75 ? 'text-amber-600' : 'text-red-600'}`}>{pct}%</span>
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>
</PortalLayout>

<script>
const staffSearch = document.getElementById('staff-search') as HTMLInputElement;
const deptFilter  = document.getElementById('dept-filter') as HTMLSelectElement;
function filter() {
  const q = staffSearch.value.toLowerCase();
  const d = deptFilter.value;
  document.querySelectorAll<HTMLElement>('.staff-row').forEach(row => {
    row.style.display = ((!q || row.dataset.name?.includes(q)) && (!d || row.dataset.dept === d)) ? '' : 'none';
  });
}
staffSearch.addEventListener('input', filter);
deptFilter.addEventListener('change', filter);

document.getElementById('report-month')?.addEventListener('change', (e) => {
  const month = (e.target as HTMLSelectElement).value;
  window.location.href = `/portal/staff-management/reports?month=${month}`;
});

document.getElementById('export-btn')?.addEventListener('click', () => {
  const month = (document.getElementById('report-month') as HTMLSelectElement).value;
  window.location.href = `/api/v1/staff/reports/export?month=${month}`;
});
</script>

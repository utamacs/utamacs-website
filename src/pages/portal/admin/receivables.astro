---
export const prerender = false;
import PortalLayout from '@components/portal/PortalLayout.astro';
import { resolveFromRequest } from '@lib/permissions';
import { getSupabaseServiceClient } from '@lib/services/providers/supabase/SupabaseDB';

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const user = await resolveFromRequest(Astro.request, SOCIETY_ID);
if (!user) return Astro.redirect('/portal/login');

const isPrivileged = user.isAdmin ||
  ['executive','secretary','president'].includes(user.portalRole ?? '') ||
  ['executive','admin'].includes(user.role ?? '');
if (!isPrivileged) return new Response('Forbidden', { status: 403 });

const sb = getSupabaseServiceClient();

const [{ data: categories }, { data: subcategories }, { data: lateRules }] = await Promise.all([
  sb.from('receivable_categories')
    .select('id, name, description, hsn_sac_code, is_active, display_order')
    .eq('society_id', SOCIETY_ID).order('display_order').order('name'),
  sb.from('receivable_subcategories')
    .select('id, category_id, name, calculation_type, amount, frequency, apply_to_wings, gst_rate, is_active, display_order')
    .eq('society_id', SOCIETY_ID).order('display_order').order('name'),
  sb.from('late_fee_rules')
    .select('id, subcategory_id, grace_period_days, fee_type, fee_amount, fee_frequency, max_fee_cap, waiver_type, receivable_subcategories(name)')
    .eq('society_id', SOCIETY_ID).order('created_at'),
]);

const cats  = categories   ?? [];
const subs  = subcategories ?? [];
const rules = lateRules     ?? [];
---

<PortalLayout title="Receivables Configuration" user={user} activeModule="admin_receivables">
  <!-- Page header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-primary-600 font-poppins">Receivables Configuration</h1>
      <p class="text-text-secondary text-sm mt-1">Manage charge categories, sub-categories, and late fee rules</p>
    </div>
  </div>

  <!-- Tabs -->
  <div class="border-b border-border-light mb-6">
    <nav class="-mb-px flex gap-6" id="tabs">
      {(['categories','subcategories','late-fee-rules'] as const).map((t, i) => (
        <button
          data-tab={t}
          class={`tab-btn pb-3 px-1 text-sm font-medium border-b-2 transition-colors ${i === 0 ? 'border-primary-600 text-primary-600' : 'border-transparent text-text-secondary hover:text-text-primary'}`}
        >
          {t === 'categories' ? 'Categories' : t === 'subcategories' ? 'Sub-Categories' : 'Late Fee Rules'}
        </button>
      ))}
    </nav>
  </div>

  <!-- ── Tab 1: Categories ───────────────────────────────────────────── -->
  <div id="tab-categories" class="tab-panel">
    <div class="flex justify-end mb-4">
      <button onclick="openCatModal()" class="btn-primary text-sm px-4 py-2">
        <i class="fas fa-plus mr-2"></i>Add Category
      </button>
    </div>
    <div class="card-premium overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-border-light">
            <th class="px-4 py-3 text-left font-medium text-text-secondary">Name</th>
            <th class="px-4 py-3 text-left font-medium text-text-secondary">HSN/SAC</th>
            <th class="px-4 py-3 text-left font-medium text-text-secondary">Description</th>
            <th class="px-4 py-3 text-center font-medium text-text-secondary">Status</th>
            <th class="px-4 py-3 text-center font-medium text-text-secondary">Actions</th>
          </tr>
        </thead>
        <tbody id="cat-table-body">
          {cats.length === 0 && (
            <tr><td colspan="5" class="px-4 py-10 text-center text-text-secondary">No categories yet</td></tr>
          )}
          {cats.map((c: any) => (
            <tr class="border-b border-border-light hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-text-primary">{c.name}</td>
              <td class="px-4 py-3 text-text-secondary font-mono text-xs">{c.hsn_sac_code ?? '—'}</td>
              <td class="px-4 py-3 text-text-secondary text-xs">{c.description ?? '—'}</td>
              <td class="px-4 py-3 text-center">
                <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${c.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>
                  {c.is_active ? 'Active' : 'Inactive'}
                </span>
              </td>
              <td class="px-4 py-3 text-center">
                <button onclick={`editCat(${JSON.stringify(c)})`} class="text-primary-600 hover:text-primary-800 mr-3 text-xs font-medium">Edit</button>
                <button onclick={`toggleCat('${c.id}',${!c.is_active})`} class={`text-xs font-medium ${c.is_active ? 'text-amber-600 hover:text-amber-800' : 'text-green-600 hover:text-green-800'}`}>
                  {c.is_active ? 'Deactivate' : 'Activate'}
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- ── Tab 2: Sub-Categories ──────────────────────────────────────── -->
  <div id="tab-subcategories" class="tab-panel hidden">
    <div class="flex items-center justify-between mb-4">
      <select id="filter-category" class="form-input w-48 text-sm" onchange="filterSubs(this.value)">
        <option value="">All Categories</option>
        {cats.map((c: any) => <option value={c.id}>{c.name}</option>)}
      </select>
      <button onclick="openSubModal()" class="btn-primary text-sm px-4 py-2">
        <i class="fas fa-plus mr-2"></i>Add Sub-Category
      </button>
    </div>
    <div class="card-premium overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-border-light">
            <th class="px-4 py-3 text-left font-medium text-text-secondary">Category</th>
            <th class="px-4 py-3 text-left font-medium text-text-secondary">Sub-Category</th>
            <th class="px-4 py-3 text-left font-medium text-text-secondary">Type</th>
            <th class="px-4 py-3 text-right font-medium text-text-secondary">Amount</th>
            <th class="px-4 py-3 text-left font-medium text-text-secondary">Frequency</th>
            <th class="px-4 py-3 text-center font-medium text-text-secondary">GST</th>
            <th class="px-4 py-3 text-center font-medium text-text-secondary">Status</th>
            <th class="px-4 py-3 text-center font-medium text-text-secondary">Actions</th>
          </tr>
        </thead>
        <tbody id="sub-table-body">
          {subs.length === 0 && (
            <tr><td colspan="8" class="px-4 py-10 text-center text-text-secondary">No sub-categories yet</td></tr>
          )}
          {subs.map((s: any) => {
            const cat = cats.find((c: any) => c.id === s.category_id);
            return (
              <tr class="border-b border-border-light hover:bg-gray-50 sub-row" data-cat={s.category_id}>
                <td class="px-4 py-3 text-text-secondary text-xs">{cat?.name ?? '—'}</td>
                <td class="px-4 py-3 font-medium text-text-primary">{s.name}</td>
                <td class="px-4 py-3 text-text-secondary capitalize">{s.calculation_type.replace('_',' ')}</td>
                <td class="px-4 py-3 text-right font-mono">
                  {s.amount != null ? `₹${Number(s.amount).toLocaleString('en-IN')}` : '—'}
                </td>
                <td class="px-4 py-3 text-text-secondary capitalize">{s.frequency.replace('_',' ')}</td>
                <td class="px-4 py-3 text-center text-text-secondary">{s.gst_rate}%</td>
                <td class="px-4 py-3 text-center">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${s.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>
                    {s.is_active ? 'Active' : 'Inactive'}
                  </span>
                </td>
                <td class="px-4 py-3 text-center">
                  <button onclick={`editSub(${JSON.stringify(s)})`} class="text-primary-600 hover:text-primary-800 mr-3 text-xs font-medium">Edit</button>
                  <button onclick={`toggleSub('${s.id}',${!s.is_active})`} class={`text-xs font-medium ${s.is_active ? 'text-amber-600 hover:text-amber-800' : 'text-green-600 hover:text-green-800'}`}>
                    {s.is_active ? 'Deactivate' : 'Activate'}
                  </button>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>

  <!-- ── Tab 3: Late Fee Rules ──────────────────────────────────────── -->
  <div id="tab-late-fee-rules" class="tab-panel hidden">
    <div class="flex justify-end mb-4">
      <button onclick="openRuleModal()" class="btn-primary text-sm px-4 py-2">
        <i class="fas fa-plus mr-2"></i>Add Rule
      </button>
    </div>
    <div class="card-premium overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-border-light">
            <th class="px-4 py-3 text-left font-medium text-text-secondary">Sub-Category</th>
            <th class="px-4 py-3 text-center font-medium text-text-secondary">Grace (days)</th>
            <th class="px-4 py-3 text-left font-medium text-text-secondary">Fee</th>
            <th class="px-4 py-3 text-left font-medium text-text-secondary">Frequency</th>
            <th class="px-4 py-3 text-right font-medium text-text-secondary">Cap</th>
            <th class="px-4 py-3 text-left font-medium text-text-secondary">Waiver</th>
            <th class="px-4 py-3 text-center font-medium text-text-secondary">Actions</th>
          </tr>
        </thead>
        <tbody>
          {rules.length === 0 && (
            <tr><td colspan="7" class="px-4 py-10 text-center text-text-secondary">No late fee rules yet</td></tr>
          )}
          {rules.map((r: any) => (
            <tr class="border-b border-border-light hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-text-primary">{(r.receivable_subcategories as any)?.name ?? '—'}</td>
              <td class="px-4 py-3 text-center text-text-secondary">{r.grace_period_days}</td>
              <td class="px-4 py-3">
                <span class="font-mono">
                  {r.fee_type === 'fixed' ? `₹${Number(r.fee_amount).toLocaleString('en-IN')}` : `${r.fee_amount}%`}
                </span>
              </td>
              <td class="px-4 py-3 text-text-secondary capitalize">{r.fee_frequency.replace('_',' ')}</td>
              <td class="px-4 py-3 text-right text-text-secondary font-mono">
                {r.max_fee_cap != null ? `₹${Number(r.max_fee_cap).toLocaleString('en-IN')}` : '—'}
              </td>
              <td class="px-4 py-3 text-text-secondary capitalize">{r.waiver_type}</td>
              <td class="px-4 py-3 text-center">
                <button onclick={`editRule(${JSON.stringify(r)})`} class="text-primary-600 hover:text-primary-800 mr-3 text-xs font-medium">Edit</button>
                <button onclick={`deleteRule('${r.id}')`} class="text-red-500 hover:text-red-700 text-xs font-medium">Delete</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- ── Category Modal ────────────────────────────────────────────── -->
  <div id="cat-modal" class="fixed inset-0 bg-black/40 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-large w-full max-w-md">
      <div class="p-5 border-b border-border-light flex items-center justify-between">
        <h3 id="cat-modal-title" class="text-lg font-semibold text-primary-600">Add Category</h3>
        <button onclick="closeCatModal()" class="text-text-secondary hover:text-text-primary"><i class="fas fa-times text-xl"></i></button>
      </div>
      <form id="cat-form" class="p-5 space-y-4">
        <input type="hidden" id="cat-id" />
        <div>
          <label class="form-label">Name <span class="text-red-500">*</span></label>
          <input id="cat-name" name="name" class="form-input" required maxlength="100" />
        </div>
        <div>
          <label class="form-label">Description</label>
          <textarea id="cat-desc" name="description" class="form-input h-20 resize-none" maxlength="500"></textarea>
        </div>
        <div>
          <label class="form-label">HSN/SAC Code</label>
          <input id="cat-hsn" name="hsn_sac_code" class="form-input" maxlength="20" placeholder="e.g. 999741" />
        </div>
        <div class="flex gap-3 pt-2">
          <button type="submit" class="btn-primary flex-1 text-sm py-2.5">Save Category</button>
          <button type="button" onclick="closeCatModal()" class="btn-outline flex-1 text-sm py-2.5">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Sub-Category Modal ────────────────────────────────────────── -->
  <div id="sub-modal" class="fixed inset-0 bg-black/40 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-large w-full max-w-lg overflow-y-auto max-h-[90vh]">
      <div class="p-5 border-b border-border-light flex items-center justify-between sticky top-0 bg-white">
        <h3 id="sub-modal-title" class="text-lg font-semibold text-primary-600">Add Sub-Category</h3>
        <button onclick="closeSubModal()" class="text-text-secondary hover:text-text-primary"><i class="fas fa-times text-xl"></i></button>
      </div>
      <form id="sub-form" class="p-5 space-y-4">
        <input type="hidden" id="sub-id" />
        <div>
          <label class="form-label">Category <span class="text-red-500">*</span></label>
          <select id="sub-category-id" name="category_id" class="form-input" required>
            <option value="">— Select Category —</option>
            {cats.map((c: any) => <option value={c.id}>{c.name}</option>)}
          </select>
        </div>
        <div>
          <label class="form-label">Sub-Category Name <span class="text-red-500">*</span></label>
          <input id="sub-name" name="name" class="form-input" required maxlength="100" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="form-label">Calculation Type</label>
            <select id="sub-calc-type" name="calculation_type" class="form-input" onchange="toggleAmountField()">
              <option value="fixed">Fixed ₹</option>
              <option value="per_sqft">Per Sq.Ft</option>
              <option value="per_unit">Per Unit</option>
              <option value="variable">Variable</option>
            </select>
          </div>
          <div id="amount-field">
            <label class="form-label">Amount / Rate</label>
            <input id="sub-amount" name="amount" type="number" min="0" step="0.01" class="form-input" placeholder="₹" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="form-label">Frequency</label>
            <select id="sub-frequency" name="frequency" class="form-input">
              <option value="monthly">Monthly</option>
              <option value="quarterly">Quarterly</option>
              <option value="half_yearly">Half-Yearly</option>
              <option value="annually">Annually</option>
              <option value="one_time">One-Time</option>
            </select>
          </div>
          <div>
            <label class="form-label">GST Rate</label>
            <select id="sub-gst" name="gst_rate" class="form-input">
              <option value="0">0% (Exempt)</option>
              <option value="5">5%</option>
              <option value="12">12%</option>
              <option value="18" selected>18%</option>
            </select>
          </div>
        </div>
        <div>
          <label class="form-label">Apply to Wings (leave blank for all)</label>
          <input id="sub-wings" name="apply_to_wings" class="form-input" placeholder="e.g. A, B, C (comma-separated)" />
          <p class="text-xs text-text-secondary mt-1">Leave blank to apply to all wings</p>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="submit" class="btn-primary flex-1 text-sm py-2.5">Save Sub-Category</button>
          <button type="button" onclick="closeSubModal()" class="btn-outline flex-1 text-sm py-2.5">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Late Fee Rule Modal ───────────────────────────────────────── -->
  <div id="rule-modal" class="fixed inset-0 bg-black/40 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-large w-full max-w-lg overflow-y-auto max-h-[90vh]">
      <div class="p-5 border-b border-border-light flex items-center justify-between sticky top-0 bg-white">
        <h3 id="rule-modal-title" class="text-lg font-semibold text-primary-600">Add Late Fee Rule</h3>
        <button onclick="closeRuleModal()" class="text-text-secondary hover:text-text-primary"><i class="fas fa-times text-xl"></i></button>
      </div>
      <form id="rule-form" class="p-5 space-y-4">
        <input type="hidden" id="rule-id" />
        <div>
          <label class="form-label">Sub-Category <span class="text-red-500">*</span></label>
          <select id="rule-subcat-id" name="subcategory_id" class="form-input" required>
            <option value="">— Select Sub-Category —</option>
            {subs.filter((s: any) => s.is_active).map((s: any) => (
              <option value={s.id}>{s.name}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="form-label">Grace Period (days after due date)</label>
          <input id="rule-grace" name="grace_period_days" type="number" min="0" class="form-input" value="5" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="form-label">Fee Type</label>
            <select id="rule-fee-type" name="fee_type" class="form-input" onchange="updateFeeLabel()">
              <option value="fixed">Fixed ₹</option>
              <option value="percentage">Percentage %</option>
            </select>
          </div>
          <div>
            <label class="form-label" id="rule-fee-label">Fee Amount (₹)</label>
            <input id="rule-fee-amount" name="fee_amount" type="number" min="0" step="0.01" class="form-input" required />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="form-label">Charge Frequency</label>
            <select id="rule-fee-freq" name="fee_frequency" class="form-input">
              <option value="one_time">One-Time</option>
              <option value="monthly">Monthly (recurring)</option>
            </select>
          </div>
          <div>
            <label class="form-label">Maximum Cap ₹ (optional)</label>
            <input id="rule-cap" name="max_fee_cap" type="number" min="0" step="0.01" class="form-input" placeholder="No cap" />
          </div>
        </div>
        <div>
          <label class="form-label">Waiver Policy</label>
          <select id="rule-waiver" name="waiver_type" class="form-input">
            <option value="none">No Waiver</option>
            <option value="full">Full Waiver Available</option>
            <option value="partial">Partial Waiver Available</option>
          </select>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="submit" class="btn-primary flex-1 text-sm py-2.5">Save Rule</button>
          <button type="button" onclick="closeRuleModal()" class="btn-outline flex-1 text-sm py-2.5">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</PortalLayout>

<script>
// ── Tab switching ────────────────────────────────────────────────────────────
document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => {
      b.classList.replace('border-primary-600','border-transparent');
      b.classList.replace('text-primary-600','text-text-secondary');
    });
    btn.classList.replace('border-transparent','border-primary-600');
    btn.classList.replace('text-text-secondary','text-primary-600');

    document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
    document.getElementById(`tab-${btn.dataset.tab}`)?.classList.remove('hidden');
  });
});

function showToast(msg: string, type: 'success'|'error' = 'success') {
  const t = document.createElement('div');
  t.className = `fixed bottom-6 right-6 z-50 px-4 py-3 rounded-xl shadow-large text-sm font-medium text-white transform translate-y-4 opacity-0 transition-all duration-300 ${type === 'success' ? 'bg-secondary-500' : 'bg-red-500'}`;
  t.textContent = msg;
  document.body.appendChild(t);
  requestAnimationFrame(() => t.classList.remove('translate-y-4','opacity-0'));
  setTimeout(() => { t.classList.add('translate-y-4','opacity-0'); setTimeout(() => t.remove(), 300); }, 3000);
}

// ── Categories ───────────────────────────────────────────────────────────────
function openCatModal(data?: any) {
  (document.getElementById('cat-modal-title') as HTMLElement).textContent = data ? 'Edit Category' : 'Add Category';
  (document.getElementById('cat-id') as HTMLInputElement).value = data?.id ?? '';
  (document.getElementById('cat-name') as HTMLInputElement).value = data?.name ?? '';
  (document.getElementById('cat-desc') as HTMLTextAreaElement).value = data?.description ?? '';
  (document.getElementById('cat-hsn') as HTMLInputElement).value = data?.hsn_sac_code ?? '';
  document.getElementById('cat-modal')!.classList.remove('hidden');
}
function editCat(data: any) { openCatModal(data); }
function closeCatModal() { document.getElementById('cat-modal')!.classList.add('hidden'); }

document.getElementById('cat-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const id   = (document.getElementById('cat-id') as HTMLInputElement).value;
  const body: Record<string,unknown> = {
    name:         (document.getElementById('cat-name') as HTMLInputElement).value.trim(),
    description:  (document.getElementById('cat-desc') as HTMLTextAreaElement).value.trim(),
    hsn_sac_code: (document.getElementById('cat-hsn') as HTMLInputElement).value.trim(),
    is_active:    true,
  };
  if (id) body.id = id;
  const res = await fetch('/api/v1/admin/receivables/categories', {
    method: id ? 'PATCH' : 'POST',
    headers: { 'Content-Type': 'application/json' },
    credentials: 'include',
    body: JSON.stringify(body),
  });
  if (res.ok) { closeCatModal(); showToast(id ? 'Category updated' : 'Category created'); setTimeout(() => location.reload(), 500); }
  else { const d = await res.json(); showToast(d.message ?? 'Error saving category', 'error'); }
});

async function toggleCat(id: string, active: boolean) {
  const res = await fetch('/api/v1/admin/receivables/categories', {
    method: 'PATCH', headers: {'Content-Type':'application/json'}, credentials: 'include',
    body: JSON.stringify({ id, is_active: active }),
  });
  if (res.ok) { showToast(active ? 'Category activated' : 'Category deactivated'); setTimeout(() => location.reload(), 500); }
  else showToast('Error updating category', 'error');
}

// ── Sub-Categories ───────────────────────────────────────────────────────────
function openSubModal(data?: any) {
  (document.getElementById('sub-modal-title') as HTMLElement).textContent = data ? 'Edit Sub-Category' : 'Add Sub-Category';
  (document.getElementById('sub-id') as HTMLInputElement).value = data?.id ?? '';
  (document.getElementById('sub-category-id') as HTMLSelectElement).value = data?.category_id ?? '';
  (document.getElementById('sub-name') as HTMLInputElement).value = data?.name ?? '';
  (document.getElementById('sub-calc-type') as HTMLSelectElement).value = data?.calculation_type ?? 'fixed';
  (document.getElementById('sub-amount') as HTMLInputElement).value = data?.amount ?? '';
  (document.getElementById('sub-frequency') as HTMLSelectElement).value = data?.frequency ?? 'monthly';
  (document.getElementById('sub-gst') as HTMLSelectElement).value = String(data?.gst_rate ?? 18);
  (document.getElementById('sub-wings') as HTMLInputElement).value = Array.isArray(data?.apply_to_wings) ? data.apply_to_wings.join(', ') : '';
  toggleAmountField();
  document.getElementById('sub-modal')!.classList.remove('hidden');
}
function editSub(data: any) { openSubModal(data); }
function closeSubModal() { document.getElementById('sub-modal')!.classList.add('hidden'); }

function toggleAmountField() {
  const type = (document.getElementById('sub-calc-type') as HTMLSelectElement).value;
  const field = document.getElementById('amount-field') as HTMLElement;
  field.style.opacity = type === 'variable' ? '0.4' : '1';
  (document.getElementById('sub-amount') as HTMLInputElement).disabled = type === 'variable';
}

document.getElementById('sub-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const id = (document.getElementById('sub-id') as HTMLInputElement).value;
  const wingsRaw = (document.getElementById('sub-wings') as HTMLInputElement).value.trim();
  const wings = wingsRaw ? wingsRaw.split(',').map(w => w.trim()).filter(Boolean) : [];
  const body: Record<string,unknown> = {
    category_id:      (document.getElementById('sub-category-id') as HTMLSelectElement).value,
    name:             (document.getElementById('sub-name') as HTMLInputElement).value.trim(),
    calculation_type: (document.getElementById('sub-calc-type') as HTMLSelectElement).value,
    amount:           (document.getElementById('sub-amount') as HTMLInputElement).value || null,
    frequency:        (document.getElementById('sub-frequency') as HTMLSelectElement).value,
    gst_rate:         Number((document.getElementById('sub-gst') as HTMLSelectElement).value),
    apply_to_wings:   wings,
    is_active:        true,
  };
  if (id) body.id = id;
  const res = await fetch('/api/v1/admin/receivables/subcategories', {
    method: id ? 'PATCH' : 'POST',
    headers: {'Content-Type':'application/json'}, credentials: 'include',
    body: JSON.stringify(body),
  });
  if (res.ok) { closeSubModal(); showToast(id ? 'Sub-category updated' : 'Sub-category created'); setTimeout(() => location.reload(), 500); }
  else { const d = await res.json(); showToast(d.message ?? 'Error saving sub-category', 'error'); }
});

async function toggleSub(id: string, active: boolean) {
  const res = await fetch('/api/v1/admin/receivables/subcategories', {
    method: 'PATCH', headers: {'Content-Type':'application/json'}, credentials: 'include',
    body: JSON.stringify({ id, is_active: active }),
  });
  if (res.ok) { showToast(active ? 'Activated' : 'Deactivated'); setTimeout(() => location.reload(), 500); }
  else showToast('Error', 'error');
}

function filterSubs(catId: string) {
  document.querySelectorAll<HTMLTableRowElement>('.sub-row').forEach(r => {
    r.style.display = (!catId || r.dataset.cat === catId) ? '' : 'none';
  });
}

// ── Late Fee Rules ───────────────────────────────────────────────────────────
function openRuleModal(data?: any) {
  (document.getElementById('rule-modal-title') as HTMLElement).textContent = data ? 'Edit Late Fee Rule' : 'Add Late Fee Rule';
  (document.getElementById('rule-id') as HTMLInputElement).value = data?.id ?? '';
  (document.getElementById('rule-subcat-id') as HTMLSelectElement).value = data?.subcategory_id ?? '';
  (document.getElementById('rule-grace') as HTMLInputElement).value = String(data?.grace_period_days ?? 5);
  (document.getElementById('rule-fee-type') as HTMLSelectElement).value = data?.fee_type ?? 'fixed';
  (document.getElementById('rule-fee-amount') as HTMLInputElement).value = data?.fee_amount ?? '';
  (document.getElementById('rule-fee-freq') as HTMLSelectElement).value = data?.fee_frequency ?? 'one_time';
  (document.getElementById('rule-cap') as HTMLInputElement).value = data?.max_fee_cap ?? '';
  (document.getElementById('rule-waiver') as HTMLSelectElement).value = data?.waiver_type ?? 'none';
  updateFeeLabel();
  document.getElementById('rule-modal')!.classList.remove('hidden');
}
function editRule(data: any) { openRuleModal(data); }
function closeRuleModal() { document.getElementById('rule-modal')!.classList.add('hidden'); }
function updateFeeLabel() {
  const type = (document.getElementById('rule-fee-type') as HTMLSelectElement).value;
  (document.getElementById('rule-fee-label') as HTMLElement).textContent = type === 'fixed' ? 'Fee Amount (₹)' : 'Rate (%)';
}

document.getElementById('rule-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const id = (document.getElementById('rule-id') as HTMLInputElement).value;
  const body: Record<string,unknown> = {
    subcategory_id:    (document.getElementById('rule-subcat-id') as HTMLSelectElement).value,
    grace_period_days: Number((document.getElementById('rule-grace') as HTMLInputElement).value),
    fee_type:          (document.getElementById('rule-fee-type') as HTMLSelectElement).value,
    fee_amount:        Number((document.getElementById('rule-fee-amount') as HTMLInputElement).value),
    fee_frequency:     (document.getElementById('rule-fee-freq') as HTMLSelectElement).value,
    max_fee_cap:       (document.getElementById('rule-cap') as HTMLInputElement).value || null,
    waiver_type:       (document.getElementById('rule-waiver') as HTMLSelectElement).value,
  };
  if (id) body.id = id;
  const res = await fetch('/api/v1/admin/receivables/late-fee-rules', {
    method: id ? 'PATCH' : 'POST',
    headers: {'Content-Type':'application/json'}, credentials: 'include',
    body: JSON.stringify(body),
  });
  if (res.ok) { closeRuleModal(); showToast(id ? 'Rule updated' : 'Rule created'); setTimeout(() => location.reload(), 500); }
  else { const d = await res.json(); showToast(d.message ?? 'Error saving rule', 'error'); }
});

async function deleteRule(id: string) {
  if (!confirm('Delete this late fee rule?')) return;
  const res = await fetch(`/api/v1/admin/receivables/late-fee-rules?id=${id}`, { method: 'DELETE', credentials: 'include' });
  if (res.ok) { showToast('Rule deleted'); setTimeout(() => location.reload(), 500); }
  else showToast('Error deleting rule', 'error');
}
</script>

---
export const prerender = false;
import PortalLayout from '@components/portal/PortalLayout.astro';
import { resolveFromRequest } from '@lib/permissions';
import { getSupabaseServiceClient } from '@lib/services/providers/supabase/SupabaseDB';

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const user = await resolveFromRequest(Astro.request, SOCIETY_ID);
if (!user) return Astro.redirect('/portal/login');

const isPrivileged = ['executive','secretary','president'].includes(user.portalRole ?? '') || user.isAdmin;
if (!isPrivileged) return new Response('Forbidden', { status: 403 });

const sb = getSupabaseServiceClient();

const { data: memberships } = await sb
  .from('memberships')
  .select(`
    id, member_name, member_type, joint_owner_names, status,
    sale_deed_key, sale_deed_number, sale_deed_date,
    admission_fee_paid, admission_fee_paid_at, admission_fee_receipt_no,
    share_capital_paid, share_capital_paid_at, byelaw_copy_fee_paid,
    membership_number, share_certificate_number, share_certificate_issued_at,
    voting_eligible, declaration_signed, submitted_at, reviewed_at,
    rejection_reason, created_at,
    units!memberships_unit_id_fkey(unit_number, block),
    profiles!memberships_profile_id_fkey(email)
  `)
  .eq('society_id', SOCIETY_ID)
  .order('created_at', { ascending: false });

// Stats
const all = memberships ?? [];
const pending = all.filter(m => ['applied','fees_pending','fees_confirmed'].includes(m.status));
const approved = all.filter(m => m.status === 'approved');
const withCert = all.filter(m => m.share_certificate_number);

const statusLabels: Record<string, string> = {
  applied: 'Applied',
  fees_pending: 'Fees Pending',
  fees_confirmed: 'Fees Confirmed',
  approved: 'Approved',
  suspended: 'Suspended',
  transferred: 'Transferred',
  deceased: 'Deceased',
  rejected: 'Rejected',
};
const statusColors: Record<string, string> = {
  applied: 'bg-blue-100 text-blue-700',
  fees_pending: 'bg-amber-100 text-amber-700',
  fees_confirmed: 'bg-yellow-100 text-yellow-700',
  approved: 'bg-green-100 text-green-700',
  suspended: 'bg-red-100 text-red-700',
  rejected: 'bg-red-100 text-red-700',
  transferred: 'bg-gray-100 text-gray-600',
  deceased: 'bg-gray-100 text-gray-600',
};
---
<PortalLayout title="Membership Registry" user={user} activeModule="admin">
  <!-- Page header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-primary-600 font-poppins">Membership Registry</h1>
      <p class="text-text-secondary text-sm mt-1">Byelaw Ch.4 — one member per flat; admission ₹1,000 + share ₹1,000</p>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="grid grid-cols-4 gap-4 mb-6">
    <div class="card-stats">
      <div class="number">{all.length}</div>
      <div class="label">Total Applications</div>
    </div>
    <div class="card-stats">
      <div class="number text-amber-600">{pending.length}</div>
      <div class="label">Pending Review</div>
    </div>
    <div class="card-stats">
      <div class="number text-secondary-500">{approved.length}</div>
      <div class="label">Active Members</div>
    </div>
    <div class="card-stats">
      <div class="number text-primary-600">{withCert.length}</div>
      <div class="label">Share Certificates Issued</div>
    </div>
  </div>

  <!-- Filter tabs -->
  <div class="flex gap-2 mb-4 flex-wrap">
    <button class="filter-tab active" data-status="all">All ({all.length})</button>
    <button class="filter-tab" data-status="applied">Applied ({all.filter(m => m.status==='applied').length})</button>
    <button class="filter-tab" data-status="fees_pending">Fees Pending ({all.filter(m => m.status==='fees_pending').length})</button>
    <button class="filter-tab" data-status="fees_confirmed">Fees Confirmed ({all.filter(m => m.status==='fees_confirmed').length})</button>
    <button class="filter-tab" data-status="approved">Approved ({approved.length})</button>
    <button class="filter-tab" data-status="rejected">Rejected ({all.filter(m => m.status==='rejected').length})</button>
  </div>

  <!-- Search -->
  <div class="mb-4">
    <input type="search" id="search-input" placeholder="Search by name, flat, certificate no…"
      class="form-input max-w-sm">
  </div>

  <!-- Memberships table -->
  {all.length === 0 ? (
    <div class="text-center py-16">
      <i class="fas fa-id-card text-5xl text-primary-200 mb-4" aria-hidden="true"></i>
      <h3 class="text-lg font-semibold text-text-primary mb-2">No membership applications yet</h3>
      <p class="text-text-secondary text-sm">Applications submitted by flat owners will appear here</p>
    </div>
  ) : (
    <div class="card-premium overflow-hidden">
      <table class="w-full">
        <thead class="bg-section-alt border-b border-border-light">
          <tr>
            <th class="text-left text-xs font-semibold text-text-secondary p-3 uppercase tracking-wide">Member / Flat</th>
            <th class="text-left text-xs font-semibold text-text-secondary p-3 uppercase tracking-wide">Sale Deed</th>
            <th class="text-left text-xs font-semibold text-text-secondary p-3 uppercase tracking-wide">Fees</th>
            <th class="text-left text-xs font-semibold text-text-secondary p-3 uppercase tracking-wide">Certificate</th>
            <th class="text-left text-xs font-semibold text-text-secondary p-3 uppercase tracking-wide">Status</th>
            <th class="text-left text-xs font-semibold text-text-secondary p-3 uppercase tracking-wide">Actions</th>
          </tr>
        </thead>
        <tbody id="memberships-tbody">
          {all.map(m => {
            const unit = (m as any).units;
            const profile = (m as any).profiles;
            const feesOk = m.admission_fee_paid && m.share_capital_paid;
            return (
              <tr class="border-b border-border-light hover:bg-section-alt/50 member-row"
                data-status={m.status}
                data-search={`${m.member_name} ${unit?.unit_number ?? ''} ${unit?.block ?? ''} ${m.share_certificate_number ?? ''} ${m.membership_number ?? ''}`.toLowerCase()}>
                <td class="p-3">
                  <p class="font-medium text-text-primary text-sm">{m.member_name}</p>
                  <p class="text-xs text-text-secondary">{unit?.block} — {unit?.unit_number}</p>
                  {profile?.email && <p class="text-xs text-text-secondary">{profile.email}</p>}
                  <span class="text-xs text-text-secondary capitalize">{m.member_type?.replace(/_/g,' ')}</span>
                </td>
                <td class="p-3">
                  {m.sale_deed_key ? (
                    <div>
                      <button class="text-xs text-primary-600 hover:underline" onclick={`viewDoc('${m.id}','deed')`}>
                        <i class="fas fa-file-pdf mr-1"></i>View deed
                      </button>
                      {m.sale_deed_number && <p class="text-xs text-text-secondary">{m.sale_deed_number}</p>}
                      {m.sale_deed_date && <p class="text-xs text-text-secondary">{new Date(m.sale_deed_date).toLocaleDateString('en-IN')}</p>}
                    </div>
                  ) : (
                    <span class="text-xs text-amber-600"><i class="fas fa-exclamation-triangle mr-1"></i>Not uploaded</span>
                  )}
                </td>
                <td class="p-3">
                  <div class="space-y-1">
                    <div class="flex items-center gap-1">
                      <i class={`fas fa-circle text-xs ${m.admission_fee_paid ? 'text-secondary-500' : 'text-amber-400'}`}></i>
                      <span class="text-xs">Admission ₹1k</span>
                    </div>
                    <div class="flex items-center gap-1">
                      <i class={`fas fa-circle text-xs ${m.share_capital_paid ? 'text-secondary-500' : 'text-amber-400'}`}></i>
                      <span class="text-xs">Share ₹1k</span>
                    </div>
                  </div>
                </td>
                <td class="p-3">
                  {m.share_certificate_number ? (
                    <div>
                      <p class="text-xs font-semibold text-primary-600">{m.share_certificate_number}</p>
                      {m.share_certificate_issued_at && <p class="text-xs text-text-secondary">{new Date(m.share_certificate_issued_at).toLocaleDateString('en-IN')}</p>}
                    </div>
                  ) : (
                    <span class="text-xs text-text-secondary">—</span>
                  )}
                </td>
                <td class="p-3">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${statusColors[m.status] ?? 'bg-gray-100 text-gray-600'}`}>
                    {statusLabels[m.status] ?? m.status}
                  </span>
                  {m.voting_eligible && (
                    <span class="ml-1 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-600">
                      <i class="fas fa-vote-yea mr-1"></i>Voter
                    </span>
                  )}
                </td>
                <td class="p-3">
                  <button class="text-xs btn-ghost px-2 py-1" onclick={`openDetail('${JSON.stringify(m).replace(/'/g, "\\'")}')`}>
                    <i class="fas fa-edit mr-1"></i>Manage
                  </button>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}

  <!-- Detail / Manage panel -->
  <div id="detail-panel" class="fixed inset-y-0 right-0 w-full sm:w-96 lg:w-[520px] bg-white shadow-large z-40 transform translate-x-full transition-transform duration-300 overflow-y-auto">
    <div class="sticky top-0 bg-white border-b border-border-light p-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-primary-600" id="panel-title">Manage Membership</h2>
      <button id="close-panel" class="text-text-secondary hover:text-text-primary" aria-label="Close">
        <i class="fas fa-times text-xl"></i>
      </button>
    </div>
    <div class="p-4" id="panel-body"><!-- filled by JS --></div>
  </div>
  <div id="panel-backdrop" class="fixed inset-0 bg-black/40 z-30 hidden"></div>
</PortalLayout>

<style>
  .filter-tab {
    @apply px-3 py-1.5 text-sm font-medium rounded-lg border border-border-light text-text-secondary bg-white hover:bg-section-alt transition-colors;
  }
  .filter-tab.active {
    @apply bg-primary-600 text-white border-primary-600;
  }
</style>

<script>
  // Filter tabs
  document.querySelectorAll('.filter-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-tab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const status = (btn as HTMLElement).dataset.status;
      document.querySelectorAll('.member-row').forEach(row => {
        const r = row as HTMLElement;
        r.style.display = (status === 'all' || r.dataset.status === status) ? '' : 'none';
      });
    });
  });

  // Search
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase();
    document.querySelectorAll('.member-row').forEach(row => {
      const r = row as HTMLElement;
      (r as HTMLElement).style.display = r.dataset.search?.includes(q) ? '' : 'none';
    });
  });

  // Panel
  const panel = document.getElementById('detail-panel')!;
  const backdrop = document.getElementById('panel-backdrop')!;
  const panelBody = document.getElementById('panel-body')!;
  const panelTitle = document.getElementById('panel-title')!;

  function closePanel() {
    panel.classList.add('translate-x-full');
    backdrop.classList.add('hidden');
  }
  document.getElementById('close-panel')?.addEventListener('click', closePanel);
  backdrop.addEventListener('click', closePanel);

  window.openDetail = (mStr: string) => {
    const m = JSON.parse(mStr);
    panelTitle.textContent = `${m.member_name} — ${m.units?.block} ${m.units?.unit_number}`;

    const feesHtml = `
      <div class="space-y-3 mb-4">
        <div class="flex items-center justify-between">
          <span class="text-sm">Admission Fee ₹1,000</span>
          ${m.admission_fee_paid
            ? `<span class="text-secondary-500 text-sm font-medium"><i class="fas fa-check-circle mr-1"></i>Paid</span>`
            : `<button class="btn-secondary text-xs px-3 py-1" onclick="confirmFee('${m.id}','admission')">Confirm Received</button>`}
        </div>
        ${m.admission_fee_paid ? `<div class="ml-4">
          <input type="text" placeholder="Receipt No." value="${m.admission_fee_receipt_no ?? ''}"
            class="form-input text-xs py-1" id="receipt-no-${m.id}">
          <button class="text-xs text-primary-600 ml-2" onclick="saveReceipt('${m.id}')">Save</button>
        </div>` : ''}
        <div class="flex items-center justify-between">
          <span class="text-sm">Share Capital ₹1,000</span>
          ${m.share_capital_paid
            ? `<span class="text-secondary-500 text-sm font-medium"><i class="fas fa-check-circle mr-1"></i>Paid</span>`
            : `<button class="btn-secondary text-xs px-3 py-1" onclick="confirmFee('${m.id}','share_capital')">Confirm Received</button>`}
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm">Byelaw Copy Fee ₹250</span>
          ${m.byelaw_copy_fee_paid
            ? `<span class="text-secondary-500 text-sm font-medium"><i class="fas fa-check-circle mr-1"></i>Paid</span>`
            : `<button class="btn-ghost text-xs px-3 py-1" onclick="confirmFee('${m.id}','byelaw_copy')">Mark Paid</button>`}
        </div>
      </div>`;

    const statusActions = [];
    if (m.status === 'applied' || m.status === 'fees_pending') {
      statusActions.push(`<button class="btn-secondary text-sm" onclick="transition('${m.id}','fees_confirmed')">Confirm Fees</button>`);
    }
    if (m.status === 'fees_confirmed') {
      statusActions.push(`<button class="btn-primary text-sm" onclick="approveMembership('${m.id}')">Approve Membership</button>`);
    }
    if (m.status === 'approved') {
      statusActions.push(`<button class="btn-primary text-sm" onclick="openCertModal('${m.id}')">Issue Share Certificate</button>`);
      statusActions.push(`<button class="btn-ghost text-sm text-red-600" onclick="transition('${m.id}','suspended')">Suspend</button>`);
    }
    if (m.status === 'suspended') {
      statusActions.push(`<button class="btn-secondary text-sm" onclick="transition('${m.id}','approved')">Reinstate</button>`);
    }
    if (['applied','fees_pending','fees_confirmed'].includes(m.status)) {
      statusActions.push(`<button class="btn-ghost text-sm text-red-600" onclick="rejectMembership('${m.id}')">Reject</button>`);
    }

    panelBody.innerHTML = `
      <div class="space-y-4">
        <div class="bg-section-alt rounded-xl p-4">
          <p class="text-xs text-text-secondary mb-1">Member Type</p>
          <p class="text-sm font-medium capitalize">${(m.member_type ?? '').replace(/_/g,' ')}</p>
          ${m.joint_owner_names?.length ? `<p class="text-xs text-text-secondary mt-1">Co-owners: ${m.joint_owner_names.join(', ')}</p>` : ''}
        </div>

        <div>
          <p class="text-sm font-semibold text-text-primary mb-2">Fee Collection (Byelaw 4.1)</p>
          ${feesHtml}
        </div>

        <div>
          <p class="text-sm font-semibold text-text-primary mb-2">Actions</p>
          <div class="flex flex-wrap gap-2">
            ${statusActions.join('')}
          </div>
        </div>

        ${m.status === 'approved' && !m.share_certificate_number ? `
        <div class="bg-primary-50 rounded-xl p-4">
          <p class="text-sm font-semibold text-primary-600 mb-3">
            <i class="fas fa-certificate mr-2"></i>Issue Share Certificate (Byelaw 4.12)
          </p>
          <p class="text-xs text-text-secondary mb-2">Certificate must be signed by President and Secretary per Byelaw 4.12</p>
          <div class="space-y-2">
            <input type="text" id="cert-number" placeholder="Certificate No. e.g. UTA-MACS-SC-001"
              class="form-input text-sm" maxlength="30">
            <input type="text" id="member-number" placeholder="Membership No. e.g. UTA-M-001"
              class="form-input text-sm" maxlength="30">
            <button class="btn-primary text-sm w-full" onclick="issueCert('${m.id}')">
              <i class="fas fa-certificate mr-2"></i>Issue Certificate
            </button>
          </div>
        </div>` : ''}

        ${m.share_certificate_number ? `
        <div class="bg-green-50 border border-green-200 rounded-xl p-4">
          <p class="text-xs text-text-secondary mb-1">Share Certificate</p>
          <p class="font-semibold text-primary-600">${m.share_certificate_number}</p>
          ${m.share_certificate_issued_at ? `<p class="text-xs text-text-secondary">Issued: ${new Date(m.share_certificate_issued_at).toLocaleDateString('en-IN')}</p>` : ''}
        </div>` : ''}

        ${m.rejection_reason ? `
        <div class="bg-red-50 border border-red-200 rounded-xl p-3">
          <p class="text-xs font-medium text-red-700">Rejection reason: ${m.rejection_reason}</p>
        </div>` : ''}

        <div class="border-t border-border-light pt-4">
          <p class="text-xs text-text-secondary">Applied: ${m.submitted_at ? new Date(m.submitted_at).toLocaleDateString('en-IN') : '—'}</p>
          ${m.reviewed_at ? `<p class="text-xs text-text-secondary">Reviewed: ${new Date(m.reviewed_at).toLocaleDateString('en-IN')}</p>` : ''}
        </div>
      </div>`;

    panel.classList.remove('translate-x-full');
    backdrop.classList.remove('hidden');
  };

  async function patchMembership(id: string, body: Record<string, unknown>) {
    const res = await fetch(`/api/v1/memberships/${id}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    if (res.ok) {
      showToast('Updated successfully');
      setTimeout(() => location.reload(), 800);
    } else {
      const err = await res.json();
      showToast(err.message ?? 'Update failed', 'error');
    }
  }

  window.confirmFee = (id: string, feeType: string) => {
    const updates: Record<string, unknown> = {};
    if (feeType === 'admission') updates.admission_fee_paid = true;
    else if (feeType === 'share_capital') updates.share_capital_paid = true;
    else if (feeType === 'byelaw_copy') updates.byelaw_copy_fee_paid = true;
    patchMembership(id, updates);
  };

  window.saveReceipt = (id: string) => {
    const val = (document.getElementById(`receipt-no-${id}`) as HTMLInputElement)?.value ?? '';
    patchMembership(id, { admission_fee_receipt_no: val });
  };

  window.transition = (id: string, status: string) => patchMembership(id, { status });

  window.approveMembership = (id: string) => patchMembership(id, { status: 'approved' });

  window.rejectMembership = (id: string) => {
    const reason = prompt('Rejection reason (required):');
    if (!reason?.trim()) return;
    patchMembership(id, { status: 'rejected', rejection_reason: reason.trim() });
  };

  window.issueCert = (id: string) => {
    const certNum = (document.getElementById('cert-number') as HTMLInputElement)?.value?.trim();
    const memberNum = (document.getElementById('member-number') as HTMLInputElement)?.value?.trim();
    if (!certNum) { showToast('Certificate number required', 'error'); return; }
    patchMembership(id, { share_certificate_number: certNum, membership_number: memberNum || null });
  };

  window.viewDoc = async (id: string, type: string) => {
    const url = type === 'deed' ? `/api/v1/memberships/${id}/sale-deed` : '';
    if (!url) return;
    const res = await fetch(url);
    if (res.ok) { const { signed_url } = await res.json(); window.open(signed_url, '_blank'); }
    else showToast('Could not load document', 'error');
  };

  function showToast(message: string, type = 'success') {
    const toast = document.createElement('div');
    toast.className = `fixed bottom-6 right-6 z-50 px-4 py-3 rounded-xl shadow-large text-sm font-medium text-white transform translate-y-4 opacity-0 transition-all duration-300 ${type === 'success' ? 'bg-secondary-500' : 'bg-red-500'}`;
    toast.textContent = message;
    document.body.appendChild(toast);
    requestAnimationFrame(() => toast.classList.remove('translate-y-4', 'opacity-0'));
    setTimeout(() => { toast.classList.add('translate-y-4', 'opacity-0'); setTimeout(() => toast.remove(), 300); }, 3000);
  }
</script>

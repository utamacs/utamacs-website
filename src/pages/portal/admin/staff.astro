---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user || !['security_guard', 'executive', 'admin'].includes(user.role)) {
  return Astro.redirect('/portal');
}

const isGuard = user.role === 'security_guard';
const today = new Date().toISOString().split('T')[0];
---

<PortalLayout title="Staff Attendance" user={user} activeModule="compliance">
  <div class="mb-6 flex items-center justify-between">
    <div>
      {!isGuard && (
        <nav class="text-sm text-text-secondary mb-2">
          <a href="/portal/admin" class="hover:text-primary-600">Admin</a>
          <span class="mx-2">›</span><span class="text-text-primary">Staff Attendance</span>
        </nav>
      )}
      <h1 class="text-2xl font-bold text-text-primary">Staff Attendance</h1>
      <p class="text-sm text-text-secondary mt-1">Log and view staff check-in / check-out.</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Log entry -->
    <div class="bg-white rounded-xl border border-border-light p-6">
      <h2 class="font-semibold text-text-primary mb-4 flex items-center gap-2">
        <i class="fas fa-sign-in-alt text-green-600" aria-hidden="true"></i>
        Log Check-In
      </h2>
      <div id="checkin-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>
      <form id="checkin-form" class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-text-primary mb-1.5">Staff Name <span class="text-red-500">*</span></label>
          <input type="text" name="staff_name" required maxlength="100" placeholder="e.g. Raju Kumar"
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-primary mb-1.5">Staff Type <span class="text-red-500">*</span></label>
          <select name="staff_type" required class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
            <option value="">Select type</option>
            <option value="security">Security Guard</option>
            <option value="housekeeping">Housekeeping</option>
            <option value="maintenance">Maintenance</option>
            <option value="gardening">Gardening</option>
            <option value="other">Other</option>
          </select>
        </div>
        <button type="submit" class="btn-primary w-full text-sm flex items-center justify-center gap-2">
          <i class="fas fa-sign-in-alt" aria-hidden="true"></i>Log Check-In
        </button>
      </form>
    </div>

    <!-- Active staff / check-out -->
    <div class="bg-white rounded-xl border border-border-light p-6">
      <h2 class="font-semibold text-text-primary mb-4 flex items-center gap-2">
        <i class="fas fa-users text-blue-600" aria-hidden="true"></i>
        Active Staff (Today)
      </h2>
      <div id="active-staff-list" class="space-y-3">
        <div class="text-sm text-text-secondary text-center py-4">Loading…</div>
      </div>
    </div>
  </div>

  <!-- Date selector + full log -->
  <div class="mt-6 bg-white rounded-xl border border-border-light overflow-hidden">
    <div class="px-5 py-4 border-b border-border-light bg-gray-50 flex items-center justify-between">
      <h2 class="font-semibold text-text-primary">Attendance Log</h2>
      <input type="date" id="date-picker" value={today} max={today}
        class="text-sm border border-border-light rounded-lg px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-primary-600" />
    </div>
    <div id="attendance-log">
      <div class="text-center py-8 text-text-secondary text-sm">Loading…</div>
    </div>
  </div>

  <script define:vars={{ today }}>
    async function loadAttendance(date: string) {
      const res = await fetch(`/api/v1/admin/staff-attendance?date=${date}`, { credentials: 'include' });
      const records = res.ok ? await res.json() : [];

      // Active (no check_out) shown in active panel only for today
      if (date === today) {
        const active = records.filter((r: any) => !r.check_out);
        const activeContainer = document.getElementById('active-staff-list')!;
        if (!active.length) {
          activeContainer.innerHTML = '<div class="text-sm text-text-secondary text-center py-4">No staff currently on premises.</div>';
        } else {
          activeContainer.innerHTML = active.map((r: any) => `
            <div class="flex items-center justify-between p-3 rounded-lg border border-green-200 bg-green-50">
              <div>
                <div class="font-medium text-sm text-text-primary">${r.staff_name}</div>
                <div class="text-xs text-text-secondary mt-0.5 capitalize">${r.staff_type} · In: ${new Date(r.check_in).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})}</div>
              </div>
              <button onclick="checkOut('${r.id}')" class="text-xs bg-red-100 text-red-700 hover:bg-red-200 px-3 py-1.5 rounded-lg font-medium transition-colors">
                <i class="fas fa-sign-out-alt mr-1"></i>Check Out
              </button>
            </div>
          `).join('');
        }
      }

      // Full log table
      const logContainer = document.getElementById('attendance-log')!;
      if (!records.length) {
        logContainer.innerHTML = '<div class="text-center py-8 text-text-secondary text-sm">No attendance records for this date.</div>';
        return;
      }

      logContainer.innerHTML = `
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-border-light">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Name</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Type</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Check-In</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Check-Out</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary hidden md:table-cell">Hours</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border-light">
            ${records.map((r: any) => {
              let hours = '—';
              if (r.check_out) {
                const diff = (new Date(r.check_out).getTime() - new Date(r.check_in).getTime()) / 3600000;
                hours = diff.toFixed(1) + 'h';
              }
              return `
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-3 font-medium text-text-primary">${r.staff_name}</td>
                  <td class="px-4 py-3 text-text-secondary capitalize">${r.staff_type}</td>
                  <td class="px-4 py-3 text-text-secondary">${new Date(r.check_in).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})}</td>
                  <td class="px-4 py-3 ${r.check_out ? 'text-text-secondary' : 'text-green-600 font-medium'}">
                    ${r.check_out ? new Date(r.check_out).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) : '● Active'}
                  </td>
                  <td class="px-4 py-3 text-text-secondary hidden md:table-cell">${hours}</td>
                </tr>
              `;
            }).join('')}
          </tbody>
        </table>`;
    }

    async function checkOut(id: string) {
      const res = await fetch('/api/v1/admin/staff-attendance', {
        method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ check_out_id: id }),
      });
      if (res.ok) loadAttendance(today);
      else alert('Failed to log check-out.');
    }

    document.getElementById('checkin-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target as HTMLFormElement);
      const errEl = document.getElementById('checkin-error')!;
      errEl.classList.add('hidden');

      const res = await fetch('/api/v1/admin/staff-attendance', {
        method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ staff_name: fd.get('staff_name'), staff_type: fd.get('staff_type') }),
      });

      if (res.ok) {
        (e.target as HTMLFormElement).reset();
        loadAttendance(today);
      } else {
        const d = await res.json();
        errEl.textContent = d.detail ?? d.error ?? 'Failed to log check-in.';
        errEl.classList.remove('hidden');
      }
    });

    document.getElementById('date-picker')?.addEventListener('change', (e) => {
      loadAttendance((e.target as HTMLInputElement).value);
    });

    (window as any).checkOut = checkOut;
    loadAttendance(today);
  </script>
</PortalLayout>

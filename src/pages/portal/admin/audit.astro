---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user || user.role !== 'admin') return Astro.redirect('/portal/admin');
---

<PortalLayout title="Audit Logs" user={user} activeModule="compliance">
  <div class="mb-6">
    <nav class="text-sm text-text-secondary mb-3">
      <a href="/portal/admin" class="hover:text-primary-600">Admin</a>
      <span class="mx-2">›</span><span class="text-text-primary">Audit Logs</span>
    </nav>
    <h1 class="text-2xl font-bold text-text-primary">Audit Logs</h1>
    <p class="text-sm text-text-secondary mt-1">Append-only activity trail. IP addresses stored as SHA-256 hashes (DPDPA 2023).</p>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-xl border border-border-light p-4 mb-5">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div>
        <label class="block text-xs font-medium text-text-secondary mb-1">Action</label>
        <select id="filter-action" class="w-full px-3 py-2 border border-border-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
          <option value="">All actions</option>
          {['CREATE','UPDATE','DELETE','LOGIN','LOGOUT','EXPORT','ROLE_CHANGE','PAYMENT','DATA_ERASURE'].map(a => (
            <option value={a}>{a}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-text-secondary mb-1">Resource</label>
        <select id="filter-resource" class="w-full px-3 py-2 border border-border-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
          <option value="">All resources</option>
          {['auth','profiles','complaints','notices','events','polls','payments','visitor_logs','facilities','community_posts','documents','vendors','work_orders'].map(r => (
            <option value={r}>{r.replace('_', ' ')}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-text-secondary mb-1">From</label>
        <input type="date" id="filter-from" class="w-full px-3 py-2 border border-border-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>
      <div>
        <label class="block text-xs font-medium text-text-secondary mb-1">To</label>
        <input type="date" id="filter-to" class="w-full px-3 py-2 border border-border-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>
    </div>
    <div class="flex gap-2 mt-3">
      <button id="apply-filters" class="btn-primary text-xs px-4 py-2">Apply Filters</button>
      <button id="clear-filters" class="btn-outline text-xs px-4 py-2">Clear</button>
      <span id="result-count" class="ml-auto text-xs text-text-secondary self-center"></span>
    </div>
  </div>

  <!-- Log table -->
  <div class="bg-white rounded-xl border border-border-light overflow-hidden">
    <div id="audit-table-container">
      <div class="text-center py-10 text-text-secondary text-sm">Loading…</div>
    </div>
  </div>

  <!-- Pagination -->
  <div class="flex items-center justify-between mt-4">
    <button id="prev-btn" class="hidden btn-outline text-sm">← Previous</button>
    <div id="page-info" class="text-xs text-text-secondary mx-auto"></div>
    <button id="next-btn" class="hidden btn-outline text-sm">Next →</button>
  </div>

  <script>
    const ACTION_COLORS: Record<string, string> = {
      CREATE: 'bg-green-100 text-green-700',
      UPDATE: 'bg-blue-100 text-blue-700',
      DELETE: 'bg-red-100 text-red-700',
      LOGIN: 'bg-gray-100 text-gray-600',
      LOGOUT: 'bg-gray-100 text-gray-600',
      PAYMENT: 'bg-amber-100 text-amber-700',
      ROLE_CHANGE: 'bg-purple-100 text-purple-700',
      DATA_ERASURE: 'bg-red-200 text-red-800',
      EXPORT: 'bg-indigo-100 text-indigo-700',
    };

    const LIMIT = 50;
    let currentOffset = 0;
    let totalLogs = 0;

    function getFilters() {
      return {
        action: (document.getElementById('filter-action') as HTMLSelectElement).value,
        resource_type: (document.getElementById('filter-resource') as HTMLSelectElement).value,
        from: (document.getElementById('filter-from') as HTMLInputElement).value,
        to: (document.getElementById('filter-to') as HTMLInputElement).value,
      };
    }

    async function loadLogs(offset = 0) {
      currentOffset = offset;
      const filters = getFilters();
      const params = new URLSearchParams({ limit: String(LIMIT), offset: String(offset) });
      if (filters.action) params.set('action', filters.action);
      if (filters.resource_type) params.set('resource_type', filters.resource_type);
      if (filters.from) params.set('from', new Date(filters.from).toISOString());
      if (filters.to) {
        const toDate = new Date(filters.to);
        toDate.setHours(23, 59, 59, 999);
        params.set('to', toDate.toISOString());
      }

      const container = document.getElementById('audit-table-container')!;
      container.innerHTML = '<div class="text-center py-10 text-text-secondary text-sm">Loading…</div>';

      const res = await fetch(`/api/v1/admin/audit-logs?${params}`, { credentials: 'include' });
      if (!res.ok) {
        container.innerHTML = '<div class="text-center py-10 text-red-500 text-sm">Failed to load audit logs.</div>';
        return;
      }

      const { logs, total } = await res.json();
      totalLogs = total;

      document.getElementById('result-count')!.textContent = `${total.toLocaleString()} entries`;

      if (!logs.length) {
        container.innerHTML = '<div class="text-center py-10 text-text-secondary text-sm">No audit logs matching the current filters.</div>';
        updatePagination();
        return;
      }

      container.innerHTML = `
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-border-light">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Time</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Action</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary">Resource</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary hidden md:table-cell">User</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary hidden lg:table-cell">Details</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border-light">
              ${logs.map((l: any) => `
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-3 text-xs text-text-secondary whitespace-nowrap">
                    ${new Date(l.created_at).toLocaleString('en-IN', {day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'})}
                  </td>
                  <td class="px-4 py-3">
                    <span class="text-xs px-2 py-0.5 rounded-full font-medium ${ACTION_COLORS[l.action] ?? 'bg-gray-100 text-gray-600'}">
                      ${l.action}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-xs text-text-secondary">
                    <div>${l.resource_type?.replace('_', ' ')}</div>
                    ${l.resource_id ? `<div class="font-mono text-xs text-gray-400 truncate max-w-24">${l.resource_id.slice(0, 8)}…</div>` : ''}
                  </td>
                  <td class="px-4 py-3 text-xs text-text-secondary hidden md:table-cell">
                    ${l.profiles?.full_name ?? `<span class="font-mono text-gray-400">${l.user_id?.slice(0,8)}…</span>`}
                  </td>
                  <td class="px-4 py-3 text-xs text-text-secondary hidden lg:table-cell max-w-xs">
                    ${l.new_values ? `<code class="bg-gray-50 px-1.5 py-0.5 rounded text-xs break-all">${JSON.stringify(l.new_values).slice(0, 100)}</code>` : '—'}
                  </td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>`;

      updatePagination();
    }

    function updatePagination() {
      const prevBtn = document.getElementById('prev-btn')!;
      const nextBtn = document.getElementById('next-btn')!;
      const pageInfo = document.getElementById('page-info')!;

      const start = totalLogs === 0 ? 0 : currentOffset + 1;
      const end = Math.min(currentOffset + LIMIT, totalLogs);
      pageInfo.textContent = totalLogs > 0 ? `Showing ${start}–${end} of ${totalLogs.toLocaleString()}` : '';

      prevBtn.classList.toggle('hidden', currentOffset === 0);
      nextBtn.classList.toggle('hidden', currentOffset + LIMIT >= totalLogs);
    }

    document.getElementById('apply-filters')!.addEventListener('click', () => loadLogs(0));

    document.getElementById('clear-filters')!.addEventListener('click', () => {
      (document.getElementById('filter-action') as HTMLSelectElement).value = '';
      (document.getElementById('filter-resource') as HTMLSelectElement).value = '';
      (document.getElementById('filter-from') as HTMLInputElement).value = '';
      (document.getElementById('filter-to') as HTMLInputElement).value = '';
      loadLogs(0);
    });

    document.getElementById('prev-btn')!.addEventListener('click', () => loadLogs(currentOffset - LIMIT));
    document.getElementById('next-btn')!.addEventListener('click', () => loadLogs(currentOffset + LIMIT));

    loadLogs(0);
  </script>
</PortalLayout>

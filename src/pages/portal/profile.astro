---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';
import { getSupabaseServiceClient } from '@lib/services/providers/supabase/SupabaseDB';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const sb = getSupabaseServiceClient();
const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';

const { data: profile } = await sb
  .from('profiles')
  .select(`
    full_name, residency_type, move_in_date, consent_version, consent_at,
    emergency_contact_name, emergency_contact_phone, emergency_contact_rel,
    num_occupants, nri_flag, avatar_url,
    units(unit_number, block, floor, area_sqft, unit_type)
  `)
  .eq('id', user.id)
  .eq('society_id', SOCIETY_ID)
  .single();

const p = profile as any;
const initials = p?.full_name
  ? p.full_name.split(' ').map((n: string) => n[0]).slice(0, 2).join('').toUpperCase()
  : user.email[0].toUpperCase();
---

<PortalLayout title="My Profile" user={user} activeModule="profile">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-primary-600 font-poppins">My Profile</h1>
      <p class="text-sm text-text-secondary mt-1">Account details, emergency contact, and data privacy settings.</p>
    </div>
  </div>

  <div class="max-w-lg space-y-6">

    <!-- ── Profile card ──────────────────────────────────────────────────── -->
    <div class="card-premium p-6">
      <!-- Avatar + identity -->
      <div class="flex items-center gap-4 mb-5">
        <div class="relative">
          <div class="w-16 h-16 rounded-full bg-primary-100 flex items-center justify-center overflow-hidden">
            {p?.avatar_url
              ? <img id="avatar-img" src={p.avatar_url} alt="Profile photo"
                     class="w-full h-full object-cover" />
              : <span id="avatar-initials" class="text-2xl font-bold text-primary-600">{initials}</span>
            }
          </div>
          <label for="avatar-file"
                 class="absolute -bottom-1 -right-1 w-6 h-6 rounded-full bg-primary-600 text-white
                        flex items-center justify-center cursor-pointer hover:bg-primary-700 transition-colors"
                 title="Change photo">
            <i class="fas fa-camera text-xs" aria-hidden="true"></i>
            <input type="file" id="avatar-file" accept="image/jpeg,image/png,image/webp"
                   class="sr-only" aria-label="Upload profile photo" />
          </label>
        </div>
        <div>
          <div class="text-lg font-bold text-text-primary">{p?.full_name ?? '—'}</div>
          <div class="text-sm text-text-secondary">{user.email}</div>
          <div class="text-xs text-text-secondary mt-0.5 capitalize">{user.role?.replace('_', ' ')}</div>
        </div>
      </div>
      <div id="avatar-progress" class="hidden mb-3 text-xs text-primary-600">
        <i class="fas fa-spinner fa-spin mr-1" aria-hidden="true"></i>Uploading photo…
      </div>

      <!-- Unit details -->
      <div class="divide-y divide-border-light text-sm">
        <div class="flex justify-between py-2.5">
          <span class="text-text-secondary">Unit</span>
          <span class="text-text-primary font-medium">
            {p?.units?.unit_number ?? '—'}{p?.units?.block ? ` – Block ${p.units.block}` : ''}
          </span>
        </div>
        {p?.units?.floor != null && (
          <div class="flex justify-between py-2.5">
            <span class="text-text-secondary">Floor</span>
            <span class="text-text-primary">{p.units.floor}</span>
          </div>
        )}
        {p?.units?.area_sqft && (
          <div class="flex justify-between py-2.5">
            <span class="text-text-secondary">Area</span>
            <span class="text-text-primary">{p.units.area_sqft} sq.ft</span>
          </div>
        )}
        <div class="flex justify-between py-2.5">
          <span class="text-text-secondary">Residency Type</span>
          <span class="text-text-primary capitalize">{p?.residency_type ?? '—'}</span>
        </div>
        <div class="flex justify-between py-2.5">
          <span class="text-text-secondary">Member Since</span>
          <span class="text-text-primary">
            {p?.move_in_date
              ? new Date(p.move_in_date).toLocaleDateString('en-IN', {day:'numeric',month:'long',year:'numeric'})
              : '—'}
          </span>
        </div>
        {p?.num_occupants != null && (
          <div class="flex justify-between py-2.5">
            <span class="text-text-secondary">Occupants</span>
            <span class="text-text-primary">{p.num_occupants}</span>
          </div>
        )}
        {p?.nri_flag && (
          <div class="flex justify-between py-2.5">
            <span class="text-text-secondary">NRI Status</span>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">
              NRI
            </span>
          </div>
        )}
      </div>
    </div>

    <!-- ── Emergency Contact ──────────────────────────────────────────────── -->
    <div class="card-premium p-6">
      <h2 class="text-lg font-semibold text-text-primary mb-1 flex items-center gap-2">
        <i class="fas fa-phone-alt text-primary-600 text-sm" aria-hidden="true"></i>
        Emergency Contact
      </h2>
      <p class="text-xs text-text-secondary mb-4">
        Visible only to the executive committee in emergencies. Not shared with other residents.
      </p>

      <form id="emergency-form" class="space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="form-label" for="ec-name">Full Name</label>
            <input type="text" id="ec-name" name="emergency_contact_name" class="form-input"
                   maxlength="100" value={p?.emergency_contact_name ?? ''}
                   placeholder="e.g. Ramesh Kumar" />
          </div>
          <div>
            <label class="form-label" for="ec-phone">Mobile Number</label>
            <input type="tel" id="ec-phone" name="emergency_contact_phone" class="form-input"
                   maxlength="20" value={p?.emergency_contact_phone ?? ''}
                   placeholder="e.g. 98765 43210" />
          </div>
        </div>
        <div>
          <label class="form-label" for="ec-rel">Relationship</label>
          <select id="ec-rel" name="emergency_contact_rel" class="form-input">
            <option value="">Select relationship</option>
            {['Spouse','Parent','Child','Sibling','Friend','Other'].map(r => (
              <option value={r} selected={p?.emergency_contact_rel === r}>{r}</option>
            ))}
          </select>
        </div>
        <div class="flex items-center gap-3">
          <button type="submit" class="btn-primary text-sm py-2">
            <i class="fas fa-save mr-1.5" aria-hidden="true"></i>Save Emergency Contact
          </button>
          <span id="ec-status" class="text-sm hidden"></span>
        </div>
      </form>
    </div>

    <!-- ── DPDPA Privacy Rights ───────────────────────────────────────────── -->
    <div class="card-premium p-6">
      <h2 class="text-lg font-semibold text-text-primary mb-1 flex items-center gap-2">
        <i class="fas fa-shield-alt text-primary-600 text-sm" aria-hidden="true"></i>
        Data Privacy (DPDPA 2023)
      </h2>
      <p class="text-xs text-text-secondary mb-4">Your rights under the Digital Personal Data Protection Act 2023.</p>

      <div id="consent-status" class="mb-4 p-3 bg-gray-50 rounded-lg text-sm">
        <span class="text-text-secondary">Checking consent status…</span>
      </div>

      <div class="space-y-3">
        <div class="p-4 border border-border-light rounded-xl">
          <div class="font-medium text-sm text-text-primary mb-1">Right to Access</div>
          <p class="text-xs text-text-secondary mb-2">Request a copy of all data we hold about you.</p>
          <button id="download-data-btn" class="btn-outline text-xs flex items-center gap-1.5">
            <i class="fas fa-download" aria-hidden="true"></i>
            Request Data Export
          </button>
        </div>

        <div class="p-4 border border-red-200 rounded-xl bg-red-50">
          <div class="font-medium text-sm text-red-700 mb-1">Right to Erasure</div>
          <p class="text-xs text-red-600 mb-2">
            Permanently anonymize your personal data (name, phone, unit). Society records such as
            maintenance dues and complaint history are retained as required by TS MACS Act 1995.
          </p>
          <button id="erase-data-btn" class="text-xs bg-red-100 text-red-700 hover:bg-red-200 border border-red-300 px-3 py-1.5 rounded-lg font-medium transition-colors flex items-center gap-1.5">
            <i class="fas fa-trash" aria-hidden="true"></i>
            Request Data Erasure
          </button>
        </div>
      </div>
    </div>

    <!-- ── Security ──────────────────────────────────────────────────────── -->
    <div class="card-premium p-6">
      <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
        <i class="fas fa-lock text-primary-600 text-sm" aria-hidden="true"></i>
        Security
      </h2>
      <button id="change-password-btn" class="btn-outline text-sm flex items-center gap-2">
        <i class="fas fa-key" aria-hidden="true"></i>
        Change Password
      </button>
      <div id="password-msg" class="hidden mt-3 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">
        Password reset email sent. Check your inbox.
      </div>
    </div>

  </div>

  <script define:vars={{ userId: user.id, userEmail: user.email }}>
    // ── Toast ──────────────────────────────────────────────────────────────
    function showToast(msg, type = 'success') {
      const t = document.createElement('div');
      t.className = `fixed bottom-6 right-6 z-50 px-4 py-3 rounded-xl shadow-large text-sm font-medium
        text-white transform translate-y-4 opacity-0 transition-all duration-300
        ${type === 'success' ? 'bg-secondary-500' : 'bg-red-500'}`;
      t.textContent = msg;
      document.body.appendChild(t);
      requestAnimationFrame(() => t.classList.remove('translate-y-4','opacity-0'));
      setTimeout(() => { t.classList.add('translate-y-4','opacity-0'); setTimeout(() => t.remove(), 300); }, 3000);
    }

    // ── Avatar upload ──────────────────────────────────────────────────────
    document.getElementById('avatar-file')?.addEventListener('change', async (e) => {
      const file = e.target.files?.[0];
      if (!file) return;
      if (file.size > 2 * 1024 * 1024) { showToast('Photo must be under 2 MB', 'error'); return; }

      const progress = document.getElementById('avatar-progress');
      progress?.classList.remove('hidden');

      const fd = new FormData();
      fd.append('file', file);
      try {
        const res = await fetch('/api/v1/profile/avatar', { method: 'POST', body: fd });
        if (!res.ok) throw new Error((await res.json()).message ?? 'Upload failed');
        const { avatar_url } = await res.json();

        // Update UI without reload
        const img = document.getElementById('avatar-img');
        const initials = document.getElementById('avatar-initials');
        if (img) { img.src = avatar_url; }
        else if (initials) {
          const newImg = document.createElement('img');
          newImg.id = 'avatar-img'; newImg.src = avatar_url; newImg.alt = 'Profile photo';
          newImg.className = 'w-full h-full object-cover';
          initials.replaceWith(newImg);
        }
        showToast('Profile photo updated');
      } catch (err) {
        showToast(err.message, 'error');
      } finally {
        progress?.classList.add('hidden');
      }
    });

    // ── Emergency contact save ─────────────────────────────────────────────
    document.getElementById('emergency-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target);
      const data = Object.fromEntries(fd);
      const status = document.getElementById('ec-status');

      try {
        const res = await fetch('/api/v1/profile', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            emergency_contact_name:  data.emergency_contact_name  || null,
            emergency_contact_phone: data.emergency_contact_phone || null,
            emergency_contact_rel:   data.emergency_contact_rel   || null,
          }),
        });
        if (!res.ok) throw new Error((await res.json()).message ?? 'Save failed');
        showToast('Emergency contact saved');
        if (status) {
          status.textContent = '✓ Saved';
          status.className = 'text-sm text-secondary-600';
          status.classList.remove('hidden');
          setTimeout(() => status.classList.add('hidden'), 3000);
        }
      } catch (err) {
        showToast(err.message, 'error');
      }
    });

    // ── Consent ────────────────────────────────────────────────────────────
    async function loadConsentStatus() {
      const res = await fetch('/api/v1/members/consent', { credentials: 'include' });
      if (!res.ok) return;
      const d = await res.json();
      const el = document.getElementById('consent-status');

      if (d.needs_consent) {
        el.className = 'mb-4 p-3 bg-yellow-50 border border-yellow-200 rounded-lg text-sm';
        el.innerHTML = `
          <div class="text-yellow-700 font-medium mb-1">Privacy policy update required</div>
          <p class="text-yellow-600 text-xs mb-2">Please accept the updated privacy policy (v${d.current_policy_version}).</p>
          <button onclick="acceptConsent(${d.current_policy_version})"
                  class="text-xs bg-yellow-100 text-yellow-700 hover:bg-yellow-200 border border-yellow-300
                         px-3 py-1.5 rounded-lg font-medium transition-colors">
            Accept Privacy Policy v${d.current_policy_version}
          </button>`;
      } else {
        el.className = 'mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm';
        const at = d.accepted_at
          ? new Date(d.accepted_at).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'})
          : 'Unknown';
        el.innerHTML = `<span class="text-green-700"><i class="fas fa-check-circle mr-1"></i>Privacy policy v${d.accepted_version} accepted on ${at}.</span>`;
      }
    }

    async function acceptConsent(version) {
      const res = await fetch('/api/v1/members/consent', {
        method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ version }),
      });
      if (res.ok) loadConsentStatus();
    }

    document.getElementById('download-data-btn')?.addEventListener('click', () => {
      alert('Data export requests are processed within 30 days as required by DPDPA 2023. Please email management@utamacs.org with your request.');
    });

    document.getElementById('erase-data-btn')?.addEventListener('click', async () => {
      if (!confirm(
        'PERMANENT ACTION: This will anonymize your personal data and revoke your portal access.\n\n' +
        'Society records (dues, complaints) are retained as required by law.\n\nAre you sure?'
      )) return;
      const res = await fetch(`/api/v1/members/${userId}/personal-data`, { method: 'DELETE', credentials: 'include' });
      if (res.ok) {
        alert('Your personal data has been anonymized. You will now be signed out.');
        window.location.href = '/portal/login';
      } else {
        const d = await res.json();
        alert(d.detail ?? d.error ?? 'Erasure failed. Please contact management.');
      }
    });

    document.getElementById('change-password-btn')?.addEventListener('click', async () => {
      const res = await fetch('/api/v1/auth/forgot-password', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: userEmail }),
      });
      if (res.ok) document.getElementById('password-msg')?.classList.remove('hidden');
      else alert('Failed to send reset email. Please try again.');
    });

    window.acceptConsent = acceptConsent;
    loadConsentStatus();
  </script>
</PortalLayout>

---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';
import { resolveFromRequest } from '@lib/permissions';

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const user = await resolveFromRequest(Astro.request, SOCIETY_ID);
if (!user) return Astro.redirect('/portal/login');

const isExec = ['executive', 'secretary', 'president'].includes(user.portalRole ?? '') || user.isAdmin;
---

<PortalLayout title="Notifications" user={user} activeModule="notifications">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-text-primary">Notifications</h1>
      <p class="text-sm text-text-secondary mt-1">Your recent alerts and updates.</p>
    </div>
    <button id="mark-all-btn" class="btn-outline text-sm flex items-center gap-2">
      <i class="fas fa-check-double" aria-hidden="true"></i>
      Mark all read
    </button>
  </div>

  <!-- Main tabs -->
  <div class="flex gap-2 mb-5 border-b border-border-light">
    <button id="tab-feed" class="main-tab px-4 py-2 text-sm font-medium text-primary-600 border-b-2 border-primary-600 -mb-px">
      Feed <span id="unread-badge" class="hidden ml-1 bg-primary-600 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full"></span>
    </button>
    <button id="tab-prefs" class="main-tab px-4 py-2 text-sm font-medium text-text-secondary hover:text-primary-600 border-b-2 border-transparent">Preferences</button>
    {isExec && (
      <button id="tab-email-queue" class="main-tab px-4 py-2 text-sm font-medium text-text-secondary hover:text-primary-600 border-b-2 border-transparent">
        Email Queue
        <span id="queue-badge" class="hidden ml-1 bg-amber-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full"></span>
      </button>
    )}
  </div>

  <!-- Feed panel -->
  <div id="panel-feed">
    <!-- Status filters -->
    <div class="flex gap-2 mb-3 flex-wrap">
      <button data-filter="all" class="filter-tab text-xs px-3 py-1.5 rounded-full font-medium border bg-primary-600 text-white border-primary-600">All</button>
      <button data-filter="unread" class="filter-tab text-xs px-3 py-1.5 rounded-full font-medium border bg-white text-text-secondary border-border-light hover:border-primary-600 hover:text-primary-600">Unread</button>
    </div>
    <!-- Type filters -->
    <div class="flex gap-2 mb-5 flex-wrap">
      <button data-type="" class="type-tab text-xs px-3 py-1 rounded-full font-medium bg-gray-100 text-text-secondary hover:bg-primary-50 hover:text-primary-600">All types</button>
      {['complaint','notice','event','poll','payment','community','visitor','facility','amc','feedback'].map(t => (
        <button data-type={t} class="type-tab text-xs px-3 py-1 rounded-full font-medium bg-gray-100 text-text-secondary hover:bg-primary-50 hover:text-primary-600 capitalize">{t.replace('_',' ')}</button>
      ))}
    </div>

    <div class="bg-white rounded-xl border border-border-light overflow-hidden">
      <div id="notifications-list">
        <div class="text-sm text-text-secondary text-center py-10">Loading…</div>
      </div>
    </div>
  </div>

  <!-- Email Queue panel (exec only) -->
  {isExec && (
    <div id="panel-email-queue" class="hidden">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-lg font-semibold text-text-primary">Outbound Email Queue</h2>
          <p class="text-xs text-text-secondary mt-0.5">Pending and recently sent emails. Enable email via the Rules admin page (NOTIFICATION_EMAIL_ENABLED).</p>
        </div>
        <div class="flex gap-2">
          <button id="process-queue-btn" class="btn-primary text-sm flex items-center gap-1.5 px-3 py-2">
            <i class="fas fa-paper-plane text-xs" aria-hidden="true"></i> Process Queue
          </button>
          <button id="send-digest-btn" class="btn-outline text-sm flex items-center gap-1.5 px-3 py-2">
            <i class="fas fa-newspaper text-xs" aria-hidden="true"></i> Send Digests
          </button>
        </div>
      </div>

      <div class="card-premium overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border-light bg-section-alt text-xs font-medium text-text-secondary">
                <th class="px-4 py-2 text-left">To</th>
                <th class="px-4 py-2 text-left">Subject</th>
                <th class="px-4 py-2 text-center">Status</th>
                <th class="px-4 py-2 text-center">Retries</th>
                <th class="px-4 py-2 text-left">Scheduled</th>
                <th class="px-4 py-2 text-left">Sent At</th>
              </tr>
            </thead>
            <tbody id="email-queue-rows">
              <tr><td colspan="6" class="py-10 text-center text-text-secondary text-sm">Loading…</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  )}

  <!-- Preferences panel -->
  <div id="panel-prefs" class="hidden">
    <div class="card-premium p-6 space-y-6">
      <div>
        <h2 class="text-base font-semibold text-text-primary mb-1">Notification Categories</h2>
        <p class="text-sm text-text-secondary mb-4">Choose which events you want to be notified about.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="category-toggles">
          <!-- Populated by JS -->
        </div>
      </div>

      <div class="border-t border-border-light pt-5">
        <h2 class="text-base font-semibold text-text-primary mb-4">Delivery Channels</h2>
        <div class="space-y-3" id="channel-toggles">
          <!-- Populated by JS -->
        </div>
      </div>

      <div class="border-t border-border-light pt-5">
        <h2 class="text-base font-semibold text-text-primary mb-1">Quiet Hours</h2>
        <p class="text-sm text-text-secondary mb-4">Suppress notifications outside these hours.</p>
        <div class="flex items-center gap-4">
          <div>
            <label class="form-label text-xs" for="quiet-start">From</label>
            <input id="quiet-start" type="time" class="form-input text-sm" style="width:130px" />
          </div>
          <div>
            <label class="form-label text-xs" for="quiet-end">To</label>
            <input id="quiet-end" type="time" class="form-input text-sm" style="width:130px" />
          </div>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <button id="save-prefs-btn" class="btn-primary text-sm flex items-center gap-2">
          <i class="fas fa-save" aria-hidden="true"></i> Save Preferences
        </button>
        <span id="prefs-status" class="hidden text-sm text-secondary-500"></span>
      </div>
    </div>
  </div>

  <script>
    const TYPE_ICONS: Record<string, string> = {
      complaint: 'fa-wrench text-orange-500',
      event: 'fa-calendar text-blue-500',
      notice: 'fa-bullhorn text-purple-500',
      poll: 'fa-poll text-teal-500',
      community: 'fa-comments text-cyan-500',
      payment: 'fa-rupee-sign text-green-500',
      visitor: 'fa-user-check text-indigo-500',
      facility: 'fa-building text-pink-500',
      system: 'fa-cog text-gray-500',
      security_alert: 'fa-shield-alt text-red-500',
    };

    const TYPE_LINKS: Record<string, (id: string) => string> = {
      complaint: (id) => `/portal/complaints/${id}`,
      event: (id) => `/portal/events/${id}`,
      notice: (id) => `/portal/notices/${id}`,
      poll: (id) => `/portal/polls/${id}`,
      facility: (id) => `/portal/facilities/${id}`,
      community: (id) => `/portal/community/${id}`,
    };

    let currentFilter = 'all';
    let currentType = '';

    async function loadNotifications() {
      const container = document.getElementById('notifications-list')!;
      const params = new URLSearchParams({ limit: '30' });
      if (currentFilter === 'unread') params.set('unread', 'true');
      if (currentType) params.set('type', currentType);

      const res = await fetch(`/api/v1/notifications?${params}`, { credentials: 'include' });
      const items = res.ok ? await res.json() : [];

      if (!items.length) {
        container.innerHTML = '<div class="text-sm text-text-secondary text-center py-10">No notifications yet.</div>';
        return;
      }

      const unreadCount = items.filter((n: any) => !n.is_read).length;
      const badge = document.getElementById('unread-badge');
      if (unreadCount > 0 && badge) {
        badge.textContent = unreadCount > 99 ? '99+' : String(unreadCount);
        badge.classList.remove('hidden');
      } else if (badge) {
        badge.classList.add('hidden');
      }
      document.title = unreadCount > 0 ? `(${unreadCount}) Notifications — UTA MACS` : 'Notifications — UTA MACS';

      container.innerHTML = items.map((n: any) => {
        const icon = TYPE_ICONS[n.type] ?? 'fa-bell text-gray-400';
        const linkFn = TYPE_LINKS[n.type];
        const link = linkFn && n.reference_id ? linkFn(n.reference_id) : null;
        const timeAgo = formatTimeAgo(new Date(n.created_at));

        return `
          <div class="flex items-start gap-4 px-5 py-4 border-b border-border-light last:border-b-0 ${n.is_read ? '' : 'bg-blue-50'}" data-id="${n.id}">
            <div class="w-9 h-9 rounded-full bg-white border border-border-light flex items-center justify-center flex-shrink-0 mt-0.5">
              <i class="fas ${icon} text-sm" aria-hidden="true"></i>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-2">
                <div>
                  <div class="text-sm font-medium text-text-primary">${n.title}</div>
                  <div class="text-sm text-text-secondary mt-0.5">${n.body}</div>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                  ${!n.is_read ? '<div class="w-2 h-2 rounded-full bg-primary-600 mt-1"></div>' : ''}
                  <button onclick="deleteNotification('${n.id}')" title="Delete notification"
                    class="text-text-secondary hover:text-red-500 transition-colors opacity-0 group-hover:opacity-100 p-1"
                    aria-label="Delete notification">
                    <i class="fas fa-trash-alt text-xs" aria-hidden="true"></i>
                  </button>
                </div>
              </div>
              <div class="flex items-center gap-3 mt-2">
                <span class="text-xs text-text-secondary">${timeAgo}</span>
                ${link ? `<a href="${link}" class="text-xs text-primary-600 hover:underline">View →</a>` : ''}
                ${!n.is_read ? `<button onclick="markRead('${n.id}')" class="text-xs text-text-secondary hover:text-primary-600">Mark read</button>` : ''}
                <button onclick="deleteNotification('${n.id}')" class="text-xs text-red-400 hover:text-red-600">Delete</button>
              </div>
            </div>
          </div>
        `;
      }).join('');
    }

    function formatTimeAgo(date: Date): string {
      const diff = Date.now() - date.getTime();
      const mins = Math.floor(diff / 60000);
      if (mins < 1) return 'Just now';
      if (mins < 60) return `${mins}m ago`;
      const hrs = Math.floor(mins / 60);
      if (hrs < 24) return `${hrs}h ago`;
      return date.toLocaleDateString('en-IN', { day: 'numeric', month: 'short' });
    }

    async function markRead(id: string) {
      await fetch('/api/v1/notifications/mark-read', {
        method: 'PUT', credentials: 'include', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids: [id] }),
      });
      loadNotifications();
    }

    document.getElementById('mark-all-btn')!.addEventListener('click', async () => {
      await fetch('/api/v1/notifications/mark-read', {
        method: 'PUT', credentials: 'include', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({}),
      });
      loadNotifications();
    });

    document.querySelectorAll('.filter-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-tab').forEach(b => {
          b.classList.remove('bg-primary-600', 'text-white', 'border-primary-600');
          b.classList.add('bg-white', 'text-text-secondary', 'border-border-light');
        });
        btn.classList.add('bg-primary-600', 'text-white', 'border-primary-600');
        btn.classList.remove('bg-white', 'text-text-secondary', 'border-border-light');
        currentFilter = (btn as HTMLElement).dataset.filter!;
        loadNotifications();
      });
    });

    document.querySelectorAll('.type-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.type-tab').forEach(b => {
          b.className = 'type-tab text-xs px-3 py-1 rounded-full font-medium bg-gray-100 text-text-secondary hover:bg-primary-50 hover:text-primary-600 capitalize';
        });
        btn.className = 'type-tab text-xs px-3 py-1 rounded-full font-medium bg-primary-600 text-white capitalize';
        currentType = (btn as HTMLElement).dataset.type!;
        loadNotifications();
      });
    });

    async function deleteNotification(id: string) {
      if (!confirm('Delete this notification?')) return;
      const res = await fetch(`/api/v1/notifications?id=${id}`, {
        method: 'DELETE', credentials: 'include',
      });
      if (res.ok) loadNotifications();
    }
    (window as any).deleteNotification = deleteNotification;

    // ── Main tab switching ────────────────────────────────────────────────────
    const ACTIVE_TAB = 'main-tab px-4 py-2 text-sm font-medium text-primary-600 border-b-2 border-primary-600 -mb-px';
    const INACT_TAB  = 'main-tab px-4 py-2 text-sm font-medium text-text-secondary hover:text-primary-600 border-b-2 border-transparent';

    function switchTab(active: string) {
      const panels = ['feed', 'prefs', 'email-queue'];
      panels.forEach(p => {
        document.getElementById(`panel-${p}`)?.classList.add('hidden');
        const tab = document.getElementById(`tab-${p}`);
        if (tab) tab.className = INACT_TAB;
      });
      document.getElementById(`panel-${active}`)?.classList.remove('hidden');
      const activeTab = document.getElementById(`tab-${active}`);
      if (activeTab) activeTab.className = ACTIVE_TAB;
    }

    document.getElementById('tab-feed')!.addEventListener('click', () => switchTab('feed'));
    document.getElementById('tab-prefs')!.addEventListener('click', () => {
      switchTab('prefs');
      if (!prefsLoaded) loadPrefs();
    });
    document.getElementById('tab-email-queue')?.addEventListener('click', () => {
      switchTab('email-queue');
      loadEmailQueue();
    });

    // ── Preferences ───────────────────────────────────────────────────────────
    let prefsLoaded = false;
    let currentPrefs: Record<string, any> = {};

    const CATEGORY_PREFS: [string, string, string][] = [
      ['complaints',    'Complaints',         'fa-wrench'],
      ['notices',       'Notices',            'fa-bullhorn'],
      ['events',        'Events',             'fa-calendar'],
      ['polls',         'Polls & Voting',     'fa-poll'],
      ['payments',      'Payments & Finance', 'fa-rupee-sign'],
      ['visitor_alerts','Visitor Alerts',     'fa-user-check'],
      ['community',     'Community Board',    'fa-comments'],
      ['marketplace',   'Marketplace',        'fa-shopping-bag'],
      ['feedback',      'Feedback Replies',   'fa-star'],
      ['snags',         'Snag Updates',       'fa-hammer'],
      ['gallery',       'Gallery',            'fa-images'],
      ['maids',         'Maid Registry',      'fa-users'],
    ];

    const CHANNEL_PREFS: [string, string, string][] = [
      ['email_enabled',         'Email notifications',   'fa-envelope'],
      ['email_digest_enabled',  'Daily digest email',    'fa-calendar-check'],
      ['sms_enabled',           'SMS',                   'fa-sms'],
      ['push_enabled',          'Push',                  'fa-mobile-alt'],
      ['whatsapp_enabled',      'WhatsApp',              'fa-whatsapp'],
    ];

    function toggleSwitch(key: string, checked: boolean) {
      return `
        <label class="flex items-center justify-between gap-4 p-3 rounded-xl border border-border-light bg-white cursor-pointer hover:bg-primary-50/30 transition-colors">
          <div class="flex items-center gap-2.5">
            <i class="fas ${CATEGORY_PREFS.find(c=>c[0]===key)?.[2] ?? CHANNEL_PREFS.find(c=>c[0]===key)?.[2] ?? 'fa-bell'} text-primary-600 text-sm w-4 text-center" aria-hidden="true"></i>
            <span class="text-sm text-text-primary">${CATEGORY_PREFS.find(c=>c[0]===key)?.[1] ?? CHANNEL_PREFS.find(c=>c[0]===key)?.[1] ?? key}</span>
          </div>
          <input type="checkbox" data-key="${key}" ${checked ? 'checked' : ''} class="w-4 h-4 accent-primary-600 cursor-pointer" />
        </label>
      `;
    }

    async function loadPrefs() {
      const res = await fetch('/api/v1/notifications/preferences', { credentials: 'include' });
      if (!res.ok) return;
      currentPrefs = await res.json();
      prefsLoaded = true;

      const catEl = document.getElementById('category-toggles')!;
      catEl.innerHTML = CATEGORY_PREFS.map(([key]) => toggleSwitch(key, currentPrefs[key] !== false)).join('');

      const chanEl = document.getElementById('channel-toggles')!;
      chanEl.innerHTML = CHANNEL_PREFS.map(([key]) => toggleSwitch(key, currentPrefs[key] === true)).join('');

      (document.getElementById('quiet-start') as HTMLInputElement).value = currentPrefs.quiet_hours_start ?? '';
      (document.getElementById('quiet-end')   as HTMLInputElement).value = currentPrefs.quiet_hours_end   ?? '';
    }

    document.getElementById('save-prefs-btn')!.addEventListener('click', async () => {
      const btn    = document.getElementById('save-prefs-btn') as HTMLButtonElement;
      const status = document.getElementById('prefs-status')!;
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin" aria-hidden="true"></i> Saving…';

      const updates: Record<string, unknown> = {};
      document.querySelectorAll('[data-key]').forEach(el => {
        const input = el as HTMLInputElement;
        updates[input.dataset.key!] = input.checked;
      });
      updates.quiet_hours_start = (document.getElementById('quiet-start') as HTMLInputElement).value || null;
      updates.quiet_hours_end   = (document.getElementById('quiet-end')   as HTMLInputElement).value || null;

      try {
        const res = await fetch('/api/v1/notifications/preferences', {
          method: 'PATCH', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(updates),
        });
        if (!res.ok) throw new Error('Save failed');
        status.textContent = 'Saved.';
        status.classList.remove('hidden');
        setTimeout(() => status.classList.add('hidden'), 2500);
      } catch {
        status.textContent = 'Error saving preferences.';
        status.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save" aria-hidden="true"></i> Save Preferences';
      }
    });

    // ── Email Queue (exec only) ───────────────────────────────────────────────
    async function loadEmailQueue() {
      const tbody = document.getElementById('email-queue-rows');
      if (!tbody) return;
      tbody.innerHTML = '<tr><td colspan="6" class="py-8 text-center text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</td></tr>';

      const res = await fetch('/api/v1/notifications/email-queue', { credentials: 'include' });
      if (!res.ok) { tbody.innerHTML = '<tr><td colspan="6" class="py-8 text-center text-red-600 text-sm">Failed to load.</td></tr>'; return; }
      const data = await res.json();
      const rows: unknown[] = data.rows ?? [];

      const badge = document.getElementById('queue-badge');
      const pending = rows.filter((r: any) => r.status === 'pending').length;
      if (pending > 0 && badge) { badge.textContent = String(pending); badge.classList.remove('hidden'); }
      else if (badge) badge.classList.add('hidden');

      if (!rows.length) {
        tbody.innerHTML = '<tr><td colspan="6" class="py-10 text-center text-text-secondary text-sm">Email queue is empty.</td></tr>';
        return;
      }

      const statusCls: Record<string, string> = {
        pending: 'bg-amber-100 text-amber-700',
        sent:    'bg-green-100 text-green-700',
        failed:  'bg-red-100 text-red-700',
        cancelled: 'bg-gray-100 text-gray-500',
      };

      tbody.innerHTML = rows.map((r: any) => `
        <tr class="border-b border-border-light hover:bg-section-alt text-xs">
          <td class="px-4 py-2 text-text-secondary">${r.to_email}</td>
          <td class="px-4 py-2 text-text-primary max-w-[240px] truncate" title="${r.subject}">${r.subject}</td>
          <td class="px-4 py-2 text-center">
            <span class="inline-flex px-2 py-0.5 rounded-full font-medium ${statusCls[r.status] ?? ''}">${r.status}</span>
          </td>
          <td class="px-4 py-2 text-center text-text-secondary">${r.retry_count ?? 0}/${r.max_retries ?? 3}</td>
          <td class="px-4 py-2 text-text-secondary">${r.scheduled_for ? new Date(r.scheduled_for).toLocaleString('en-IN') : '—'}</td>
          <td class="px-4 py-2 text-text-secondary">${r.sent_at ? new Date(r.sent_at).toLocaleString('en-IN') : '—'}</td>
        </tr>
      `).join('');
    }

    document.getElementById('process-queue-btn')?.addEventListener('click', async () => {
      const btn = document.getElementById('process-queue-btn') as HTMLButtonElement;
      btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Processing…';
      const res = await fetch('/api/v1/notifications/process-email-queue', { method: 'POST', credentials: 'include' });
      btn.disabled = false; btn.innerHTML = '<i class="fas fa-paper-plane mr-2"></i>Process Queue';
      const data = await res.json();
      if (res.ok) {
        const msg = data.skipped ? 'Email disabled (check NOTIFICATION_EMAIL_ENABLED rule).' :
                    `Sent: ${data.sent}, Failed: ${data.transient_failed}, Permanent: ${data.permanent_failed}`;
        alert(msg);
        loadEmailQueue();
      } else { alert(data.message ?? 'Failed.'); }
    });

    document.getElementById('send-digest-btn')?.addEventListener('click', async () => {
      const btn = document.getElementById('send-digest-btn') as HTMLButtonElement;
      btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Sending…';
      const res = await fetch('/api/v1/notifications/send-digest', { method: 'POST', credentials: 'include' });
      btn.disabled = false; btn.innerHTML = '<i class="fas fa-newspaper mr-2"></i>Send Digests';
      const data = await res.json();
      if (res.ok) {
        alert(`Digests enqueued: ${data.enqueued}. Skipped (no notifs): ${data.skipped_no_notifs}. Skipped (no email): ${data.skipped_no_email}.`);
        loadEmailQueue();
      } else { alert(data.message ?? 'Failed.'); }
    });

    (window as any).markRead = markRead;
    loadNotifications();
  </script>
</PortalLayout>

---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';
import { getSupabaseServiceClient } from '@lib/services/providers/supabase/SupabaseDB';

const user = Astro.locals.user;
const isPrivileged = user && (['executive', 'admin'].includes(user.role) ||
  ['executive', 'secretary', 'president'].includes(user.portalRole ?? '') || user.isAdmin);
if (!isPrivileged) return Astro.redirect('/portal/notices');

const CATEGORIES = ['General','Urgent','Maintenance','Financial','Events','Governance'];
const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const sb = getSupabaseServiceClient();
const { data: blockRows } = await sb.from('units').select('block').eq('society_id', SOCIETY_ID).not('block', 'is', null);
const BLOCKS = [...new Set((blockRows ?? []).map((u: any) => u.block as string).filter(Boolean))].sort();
---

<PortalLayout title="New Notice" user={user} activeModule="notices">
  <div class="mb-6">
    <nav class="text-sm text-text-secondary mb-3">
      <a href="/portal/notices" class="hover:text-primary-600">Notices</a>
      <span class="mx-2">›</span><span class="text-text-primary">New Notice</span>
    </nav>
    <h1 class="text-2xl font-bold text-text-primary">Post a Notice</h1>
  </div>

  <div class="max-w-2xl">
    <div id="error-banner" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>

    <form id="notice-form" class="bg-white rounded-xl border border-border-light p-6 space-y-5">

      <!-- Title -->
      <div>
        <label for="title" class="block text-sm font-medium text-text-primary mb-1.5">
          Title <span class="text-red-500">*</span>
        </label>
        <input type="text" id="title" name="title" required maxlength="200"
          placeholder="e.g. Water Supply Interruption – 25th April"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <!-- Category + Audience -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="category" class="block text-sm font-medium text-text-primary mb-1.5">
            Category <span class="text-red-500">*</span>
          </label>
          <select id="category" name="category" required
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
            {CATEGORIES.map(c => <option value={c}>{c}</option>)}
          </select>
        </div>
        <div>
          <label for="target_audience" class="block text-sm font-medium text-text-primary mb-1.5">Audience</label>
          <select id="target_audience" name="target_audience"
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
            <option value="all">All Residents</option>
            <option value="owners">Owners Only</option>
            <option value="tenants">Tenants Only</option>
          </select>
        </div>
      </div>

      <!-- Wing / Block targeting -->
      {BLOCKS.length > 0 && (
        <div>
          <label class="block text-sm font-medium text-text-primary mb-1.5">
            Target Wings / Blocks <span class="text-text-secondary font-normal">(optional — leave blank for all)</span>
          </label>
          <div class="flex flex-wrap gap-2" id="block-checkboxes">
            {BLOCKS.map(b => (
              <label class="flex items-center gap-1.5 text-sm cursor-pointer">
                <input type="checkbox" name="target_blocks" value={b}
                  class="rounded border-border-light text-primary-600" />
                <span>Block {b}</span>
              </label>
            ))}
          </div>
        </div>
      )}

      <!-- Expiry date -->
      <div>
        <label for="expires_at" class="block text-sm font-medium text-text-primary mb-1.5">
          Expiry Date <span class="text-text-secondary font-normal">(optional — notice auto-hides after this date)</span>
        </label>
        <input type="date" id="expires_at" name="expires_at"
          class="text-sm border border-border-light rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <!-- Body -->
      <div>
        <label for="body" class="block text-sm font-medium text-text-primary mb-1.5">Body</label>
        <textarea id="body" name="body" rows="8"
          placeholder="Notice content (supports basic HTML: <p>, <strong>, <em>, <ul>, <li>)"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none font-mono"></textarea>
        <p class="text-xs text-text-secondary mt-1">HTML is sanitized server-side before saving.</p>
      </div>

      <!-- Attachment -->
      <div>
        <label class="block text-sm font-medium text-text-primary mb-1.5">
          Attachment <span class="text-text-secondary font-normal">(optional — image or PDF, max 10 MB)</span>
        </label>
        <div id="att-drop-zone"
          class="border-2 border-dashed border-border-light rounded-xl p-5 text-center cursor-pointer hover:border-primary-600 transition-colors"
          role="button" tabindex="0" aria-label="Click or drag to attach a file">
          <i class="fas fa-cloud-upload-alt text-2xl text-text-secondary mb-2" aria-hidden="true"></i>
          <p class="text-sm text-text-secondary">Drag & drop or <span class="text-primary-600 font-medium">click to browse</span></p>
          <p class="text-xs text-text-secondary mt-1">JPEG, PNG, WebP, PDF</p>
          <input type="file" id="att-file-input" accept="image/jpeg,image/png,image/webp,application/pdf"
            class="hidden" aria-hidden="true" />
        </div>
        <div id="att-preview" class="hidden mt-2 flex items-center gap-3 p-2.5 bg-gray-50 rounded-lg border border-border-light text-sm">
          <i id="att-icon" class="fas fa-file flex-shrink-0" aria-hidden="true"></i>
          <span id="att-name" class="flex-1 truncate"></span>
          <span id="att-size" class="text-text-secondary text-xs"></span>
          <button type="button" id="att-remove" class="text-text-secondary hover:text-red-500 ml-1" aria-label="Remove attachment">
            <i class="fas fa-times" aria-hidden="true"></i>
          </button>
        </div>
      </div>

      <!-- Video URL -->
      <div>
        <label for="video_url" class="block text-sm font-medium text-text-primary mb-1.5">
          Video Link <span class="text-text-secondary font-normal">(optional — YouTube or other URL)</span>
        </label>
        <input type="url" id="video_url" name="video_url" maxlength="500"
          placeholder="https://youtube.com/watch?v=..."
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <!-- Status / Scheduling -->
      <div class="bg-gray-50 border border-border-light rounded-xl p-4 space-y-3">
        <p class="text-sm font-medium text-text-primary">Publishing</p>
        <div class="flex flex-wrap gap-3">
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="radio" name="pub_mode" value="publish" checked
              class="text-primary-600 border-border-light focus:ring-primary-600" />
            <span>Publish now</span>
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="radio" name="pub_mode" value="schedule"
              class="text-primary-600 border-border-light focus:ring-primary-600" />
            <span>Schedule</span>
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="radio" name="pub_mode" value="draft"
              class="text-primary-600 border-border-light focus:ring-primary-600" />
            <span>Save as draft</span>
          </label>
        </div>
        <div id="schedule-row" class="hidden">
          <label for="scheduled_at" class="block text-xs font-medium text-text-secondary mb-1">Publish at</label>
          <input type="datetime-local" id="scheduled_at" name="scheduled_at"
            class="text-sm border border-border-light rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-primary-600" />
        </div>
      </div>

      <!-- Options -->
      <div class="flex flex-wrap items-center gap-5">
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="is_pinned" name="is_pinned" class="rounded border-border-light text-primary-600" />
          <span>Pin to top</span>
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="requires_acknowledgement" name="requires_acknowledgement" class="rounded border-border-light text-primary-600" />
          <span>Require acknowledgement</span>
        </label>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3 pt-2">
        <button type="submit" id="submit-btn" class="btn-primary flex items-center gap-2">
          <i class="fas fa-bell" aria-hidden="true"></i>
          <span id="btn-text">Post Notice</span>
          <span id="btn-spinner" class="hidden"><i class="fas fa-spinner fa-spin" aria-hidden="true"></i></span>
        </button>
        <a href="/portal/notices" class="btn-outline">Cancel</a>
      </div>
    </form>
  </div>

  <script>
    const form       = document.getElementById('notice-form') as HTMLFormElement;
    const errorBanner = document.getElementById('error-banner')!;
    const btnText    = document.getElementById('btn-text')!;
    const btnSpinner = document.getElementById('btn-spinner')!;
    const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement;
    const dropZone   = document.getElementById('att-drop-zone')!;
    const fileInput  = document.getElementById('att-file-input') as HTMLInputElement;
    const preview    = document.getElementById('att-preview')!;
    const scheduleRow = document.getElementById('schedule-row')!;

    const ALLOWED = new Set(['image/jpeg','image/png','image/webp','application/pdf']);
    const MAX = 10 * 1024 * 1024;
    let attachedFile: File | null = null;

    // ── Scheduling mode ──────────────────────────────────────────────────────
    document.querySelectorAll('input[name="pub_mode"]').forEach(r => {
      r.addEventListener('change', () => {
        const mode = (document.querySelector('input[name="pub_mode"]:checked') as HTMLInputElement).value;
        scheduleRow.classList.toggle('hidden', mode !== 'schedule');
        btnText.textContent = mode === 'draft' ? 'Save Draft' : 'Post Notice';
      });
    });

    // ── File drop zone ───────────────────────────────────────────────────────
    dropZone.addEventListener('click', () => fileInput.click());
    dropZone.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') fileInput.click(); });
    dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-primary-600'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-primary-600'));
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault(); dropZone.classList.remove('border-primary-600');
      const f = e.dataTransfer?.files[0];
      if (f) setFile(f);
    });
    fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) setFile(fileInput.files[0]); fileInput.value = ''; });

    function setFile(f: File) {
      if (!ALLOWED.has(f.type)) { alert('Only JPEG, PNG, WebP, or PDF allowed.'); return; }
      if (f.size > MAX) { alert('File must be under 10 MB.'); return; }
      attachedFile = f;
      preview.classList.remove('hidden');
      document.getElementById('att-name')!.textContent = f.name;
      document.getElementById('att-size')!.textContent = `${(f.size/1024).toFixed(0)} KB`;
      const icon = document.getElementById('att-icon')!;
      icon.className = f.type === 'application/pdf' ? 'fas fa-file-pdf text-red-500 flex-shrink-0' : 'fas fa-image text-blue-500 flex-shrink-0';
    }

    document.getElementById('att-remove')?.addEventListener('click', () => {
      attachedFile = null;
      preview.classList.add('hidden');
    });

    // ── Form submit ──────────────────────────────────────────────────────────
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBanner.classList.add('hidden');
      btnText.classList.add('hidden');
      btnSpinner.classList.remove('hidden');
      submitBtn.disabled = true;

      const fd = new FormData(form);
      const mode = (document.querySelector('input[name="pub_mode"]:checked') as HTMLInputElement).value;
      const statusMap: Record<string, string> = { publish: 'published', schedule: 'scheduled', draft: 'draft' };

      const checkedBlocks = [...document.querySelectorAll<HTMLInputElement>('input[name="target_blocks"]:checked')]
        .map(cb => cb.value).filter(Boolean);
      const expiresAt = (fd.get('expires_at') as string)?.trim() || null;

      const payload: Record<string, unknown> = {
        title:                    fd.get('title'),
        body:                     fd.get('body'),
        category:                 fd.get('category'),
        target_audience:          fd.get('target_audience'),
        is_pinned:                (document.getElementById('is_pinned') as HTMLInputElement).checked,
        requires_acknowledgement: (document.getElementById('requires_acknowledgement') as HTMLInputElement).checked,
        status:                   statusMap[mode],
        video_url:                (fd.get('video_url') as string)?.trim() || undefined,
        target_blocks:            checkedBlocks.length ? checkedBlocks : undefined,
        expires_at:               expiresAt || undefined,
      };

      if (mode === 'schedule') {
        const sa = fd.get('scheduled_at') as string;
        if (!sa) {
          errorBanner.textContent = 'Please select a publish date/time for scheduled notices.';
          errorBanner.classList.remove('hidden');
          btnText.classList.remove('hidden');
          btnSpinner.classList.add('hidden');
          submitBtn.disabled = false;
          return;
        }
        payload.scheduled_at = new Date(sa).toISOString();
      }

      // Step 1: create notice
      const res = await fetch('/api/v1/notices', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        credentials: 'include', body: JSON.stringify(payload),
      });
      const data = await res.json();

      if (!res.ok) {
        errorBanner.textContent = data.detail ?? data.error ?? 'Failed to post notice.';
        errorBanner.classList.remove('hidden');
        btnText.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
        submitBtn.disabled = false;
        return;
      }

      const noticeId = data.id;

      // Step 2: upload attachment if provided
      if (attachedFile) {
        const attFd = new FormData();
        attFd.append('file', attachedFile);
        try {
          await fetch(`/api/v1/notices/${noticeId}/attachment`, {
            method: 'POST', credentials: 'include', body: attFd,
          });
        } catch {
          // Non-fatal
        }
      }

      window.location.href = '/portal/notices';
    });
  </script>
</PortalLayout>

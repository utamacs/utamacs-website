---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user || !['executive','admin'].includes(user.role)) return Astro.redirect('/portal/notices');

const CATEGORIES = ['General','Urgent','Maintenance','Financial','Events','Governance'];
---

<PortalLayout title="New Notice" user={user} activeModule="notices">
  <div class="mb-6">
    <nav class="text-sm text-text-secondary mb-3">
      <a href="/portal/notices" class="hover:text-primary-600">Notices</a>
      <span class="mx-2">›</span><span class="text-text-primary">New Notice</span>
    </nav>
    <h1 class="text-2xl font-bold text-text-primary">Post a Notice</h1>
  </div>

  <div class="max-w-2xl">
    <div id="error-banner" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>

    <form id="notice-form" class="bg-white rounded-xl border border-border-light p-6 space-y-5">
      <div>
        <label for="title" class="block text-sm font-medium text-text-primary mb-1.5">Title <span class="text-red-500">*</span></label>
        <input type="text" id="title" name="title" required maxlength="200"
          placeholder="e.g. Water Supply Interruption – 25th April"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="category" class="block text-sm font-medium text-text-primary mb-1.5">Category <span class="text-red-500">*</span></label>
          <select id="category" name="category" required
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
            {CATEGORIES.map(c => <option value={c}>{c}</option>)}
          </select>
        </div>
        <div>
          <label for="target_audience" class="block text-sm font-medium text-text-primary mb-1.5">Audience</label>
          <select id="target_audience" name="target_audience"
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
            <option value="all">All Residents</option>
            <option value="owners">Owners Only</option>
            <option value="tenants">Tenants Only</option>
          </select>
        </div>
      </div>

      <div>
        <label for="body" class="block text-sm font-medium text-text-primary mb-1.5">Body</label>
        <textarea id="body" name="body" rows="8"
          placeholder="Notice content (supports basic HTML: <p>, <strong>, <em>, <ul>, <li>)"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none font-mono"></textarea>
        <p class="text-xs text-text-secondary mt-1">HTML is sanitized server-side before saving.</p>
      </div>

      <div class="flex items-center gap-6">
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="is_pinned" name="is_pinned" class="rounded border-border-light text-primary-600" />
          <span>Pin to top</span>
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="requires_acknowledgement" name="requires_acknowledgement" class="rounded border-border-light text-primary-600" />
          <span>Require acknowledgement</span>
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="publish_now" name="publish_now" checked class="rounded border-border-light text-primary-600" />
          <span>Publish immediately</span>
        </label>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <button type="submit" id="submit-btn" class="btn-primary flex items-center gap-2">
          <i class="fas fa-bell" aria-hidden="true"></i>
          <span id="btn-text">Post Notice</span>
          <span id="btn-spinner" class="hidden"><i class="fas fa-spinner fa-spin" aria-hidden="true"></i></span>
        </button>
        <a href="/portal/notices" class="btn-outline">Cancel</a>
      </div>
    </form>
  </div>

  <script>
    const form = document.getElementById('notice-form') as HTMLFormElement;
    const errorBanner = document.getElementById('error-banner')!;
    const btnText = document.getElementById('btn-text')!;
    const btnSpinner = document.getElementById('btn-spinner')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBanner.classList.add('hidden');
      btnText.classList.add('hidden');
      btnSpinner.classList.remove('hidden');
      submitBtn.disabled = true;

      const fd = new FormData(form);
      const publishNow = (document.getElementById('publish_now') as HTMLInputElement).checked;

      const res = await fetch('/api/v1/notices', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
        body: JSON.stringify({
          title: fd.get('title'),
          body: fd.get('body'),
          category: fd.get('category'),
          target_audience: fd.get('target_audience'),
          is_pinned: (document.getElementById('is_pinned') as HTMLInputElement).checked,
          requires_acknowledgement: (document.getElementById('requires_acknowledgement') as HTMLInputElement).checked,
          publish_now: publishNow,
        }),
      });

      const data = await res.json();
      if (res.ok) {
        // If publish_now, trigger publish
        if (publishNow) {
          await fetch(`/api/v1/notices/${data.id}/publish`, { method: 'POST', credentials: 'include' });
        }
        window.location.href = '/portal/notices';
      } else {
        errorBanner.textContent = data.detail ?? data.error ?? 'Failed to post notice.';
        errorBanner.classList.remove('hidden');
        btnText.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
        submitBtn.disabled = false;
      }
    });
  </script>
</PortalLayout>

---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const isExec = ['executive', 'admin'].includes(user.role) || user.isAdmin;
---

<PortalLayout title="Notices" user={user} activeModule="notices">
  <!-- Process info panel -->
  <details class="mb-6 group rounded-xl border border-primary-100 bg-gradient-to-r from-primary-50/50 to-blue-50/20 overflow-hidden">
    <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer list-none select-none hover:bg-primary-50/60 transition-colors">
      <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-project-diagram text-white text-xs" aria-hidden="true"></i>
      </div>
      <span class="text-sm font-medium text-text-primary flex-1">Official notices and circulars are drafted by authorised executives, published, and automatically notified to all residents.</span>
      <span class="text-xs text-primary-600 flex items-center gap-1.5 flex-shrink-0 font-medium">
        How it works
        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200 group-open:rotate-180" aria-hidden="true"></i>
      </span>
    </summary>
    <div class="px-5 pb-5">
      <div class="pt-4 border-t border-primary-100 space-y-4">
        <!-- Main flow -->
        <div class="process-snake-flow -mx-1 px-1">
          <div class="flex-shrink-0 w-52 rounded-lg border border-primary-300 bg-blue-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-primary-700 whitespace-nowrap">Draft</p>
            <p class="text-[11px] text-primary-600 mt-0.5 whitespace-nowrap">Secretary / President writes</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-amber-300 bg-amber-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-amber-800 whitespace-nowrap">Review</p>
            <p class="text-[11px] text-amber-700 mt-0.5 whitespace-nowrap">Second executive checks</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-green-300 bg-green-50 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-green-800 whitespace-nowrap">Published</p>
            <p class="text-[11px] text-green-700 mt-0.5 whitespace-nowrap">Visible to all members</p>
          </div>

          <div class="flex-shrink-0 w-52 rounded-lg border border-gray-300 bg-gray-100 px-3 py-3 text-center">
            <p class="text-[12px] font-semibold text-gray-700 whitespace-nowrap">Archived</p>
            <p class="text-[11px] text-gray-500 mt-0.5 whitespace-nowrap">Stored in Documents</p>
          </div>
        </div>
        <!-- Annotation row -->
        <div class="flex items-center gap-2 text-xs text-text-secondary">
          <i class="fas fa-info-circle text-primary-400 text-[10px]" aria-hidden="true"></i>
          <span>Email and portal notification sent automatically when a notice is published</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mt-1">
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Only Secretary or President can publish notices</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-exclamation-circle text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Urgent notices trigger an immediate email to all members</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-exclamation-circle text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Published notices cannot be edited — a corrigendum must be issued</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Notices are auto-archived after their effective date passes</span>
          </div>
        </div>
      </div>
    </div>
  </details>

  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-text-primary">Notices & Circulars</h1>
      <p class="text-sm text-text-secondary mt-1">Official communications from the management committee.</p>
    </div>
    {isExec && (
      <a href="/portal/notices/new" class="btn-primary text-sm flex items-center gap-2">
        <i class="fas fa-plus" aria-hidden="true"></i>
        New Notice
      </a>
    )}
  </div>

  {isExec && (
    <div class="flex gap-2 mb-5 border-b border-border-light">
      <button id="tab-published" class="notice-tab px-4 py-2 text-sm font-medium text-primary-600 border-b-2 border-primary-600 -mb-px">Published</button>
      <button id="tab-scheduled" class="notice-tab px-4 py-2 text-sm font-medium text-text-secondary hover:text-primary-600 border-b-2 border-transparent flex items-center gap-1.5">
        Scheduled
        <span id="scheduled-count" class="hidden text-xs bg-amber-100 text-amber-700 font-semibold px-1.5 py-0.5 rounded-full"></span>
      </button>
    </div>
  )}

  <div id="notices-list" class="space-y-4">
  </div>
  <div id="scheduled-list" class="hidden space-y-4">
    <div class="flex items-center justify-center h-32 text-text-secondary">
      <i class="fas fa-spinner fa-spin mr-2" aria-hidden="true"></i>
      Loading notices…
    </div>
  </div>

  <!-- Acknowledgement tracking drawer (exec only) -->
  {isExec && (
    <>
      <div id="ack-panel" class="fixed inset-y-0 right-0 w-full sm:w-96 lg:w-[480px] bg-white shadow-large z-40 transform translate-x-full transition-transform duration-300 overflow-y-auto">
        <div class="sticky top-0 bg-white border-b border-border-light p-4 flex items-center justify-between">
          <div>
            <h2 class="text-lg font-semibold text-primary-600">Acknowledgement Tracking</h2>
            <p id="ack-panel-title" class="text-xs text-text-secondary truncate max-w-[300px]"></p>
          </div>
          <button id="close-ack-panel" class="text-text-secondary hover:text-text-primary p-2 rounded-lg hover:bg-gray-100" aria-label="Close">
            <i class="fas fa-times text-xl" aria-hidden="true"></i>
          </button>
        </div>
        <div class="p-4">
          <!-- Summary cards -->
          <div id="ack-summary" class="grid grid-cols-3 gap-3 mb-5"></div>
          <!-- Progress bar -->
          <div class="mb-5">
            <div class="flex items-center justify-between text-xs text-text-secondary mb-1.5">
              <span>Acknowledgement rate</span>
              <span id="ack-pct" class="font-semibold text-primary-600"></span>
            </div>
            <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
              <div id="ack-progress-bar" class="h-2 bg-secondary-500 rounded-full transition-all duration-500" style="width:0%"></div>
            </div>
          </div>
          <!-- Members list -->
          <div id="ack-members" class="space-y-2"></div>
        </div>
      </div>
      <div id="ack-backdrop" class="fixed inset-0 bg-black/40 z-30 hidden"></div>
    </>
  )}

  <script define:vars={{ isExec }}>
    const CATEGORY_COLORS = {
      Urgent: 'border-red-400 bg-red-50',
      Financial: 'border-amber-400 bg-amber-50',
      Governance: 'border-purple-400 bg-purple-50',
      Maintenance: 'border-blue-400 bg-blue-50',
      Events: 'border-green-400 bg-green-50',
      General: 'border-gray-300 bg-white',
    };
    const CATEGORY_BADGE = {
      Urgent: 'bg-red-100 text-red-700',
      Financial: 'bg-amber-100 text-amber-700',
      Governance: 'bg-purple-100 text-purple-700',
      Maintenance: 'bg-blue-100 text-blue-700',
      Events: 'bg-green-100 text-green-700',
      General: 'bg-gray-100 text-gray-600',
    };

    // Track which notices have been acknowledged in this session
    const acknowledged = new Set();

    async function loadNotices() {
      const container = document.getElementById('notices-list');
      if (!container) return;
      try {
        const res = await fetch('/api/v1/notices', { credentials: 'include' });
        const notices = await res.json();
        if (!notices.length) {
          container.innerHTML = '<p class="text-center text-text-secondary py-12">No notices at this time.</p>';
          return;
        }

        // For notices requiring acknowledgement, pre-check status in parallel
        const ackNotices = notices.filter((n) => n.requires_acknowledgement);
        await Promise.all(ackNotices.map(async (n) => {
          const r = await fetch(`/api/v1/notices/${n.id}/acknowledge`, { credentials: 'include' }).catch(() => null);
          if (r?.ok) {
            const d = await r.json();
            if (d.acknowledged) acknowledged.add(n.id);
          }
        }));

        container.innerHTML = notices.map((n) => {
          const isAcknowledged = acknowledged.has(n.id);
          const ackAction = n.requires_acknowledgement
            ? isAcknowledged
              ? '<span class="text-xs text-green-600 font-medium flex items-center gap-1"><i class="fas fa-check-circle"></i> Acknowledged</span>'
              : `<button onclick="acknowledge('${n.id}', this)" class="text-xs bg-amber-50 border border-amber-300 text-amber-700 hover:bg-amber-100 px-3 py-1 rounded-lg font-medium transition-colors flex items-center gap-1"><i class="fas fa-pen"></i> Acknowledge</button>`
            : '';
          const trackBtn = isExec && n.requires_acknowledgement
            ? `<button onclick="openAckPanel('${n.id}', ${JSON.stringify(n.title)})" class="text-xs text-primary-600 hover:text-primary-800 flex items-center gap-1 font-medium"><i class="fas fa-users text-[11px]"></i> Track</button>`
            : '';
          const attachBtn = n.attachment_storage_key
            ? `<button onclick="viewAttachment('${n.id}', this)" class="text-xs text-primary-600 hover:text-primary-800 flex items-center gap-1 font-medium"><i class="fas fa-paperclip text-[11px]"></i> Attachment</button>`
            : '';
          return `
          <div class="bg-white rounded-xl border border-l-4 ${CATEGORY_COLORS[n.category] ?? 'border-gray-300'} p-5">
            <div class="flex items-start justify-between gap-4 mb-2">
              <h2 class="text-lg font-semibold text-text-primary">${n.is_pinned ? '📌 ' : ''}${n.title}</h2>
              <span class="flex-shrink-0 text-xs px-2 py-1 rounded-full font-medium ${CATEGORY_BADGE[n.category] ?? 'bg-gray-100 text-gray-600'}">${n.category}</span>
            </div>
            ${n.body ? `<div class="prose prose-sm text-text-secondary max-w-none mt-3 line-clamp-3">${n.body}</div>` : ''}
            <div class="flex items-center justify-between mt-3 flex-wrap gap-2">
              <span class="text-xs text-text-secondary">${new Date(n.created_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
              <div class="flex items-center gap-3">${attachBtn}${trackBtn}${ackAction}</div>
            </div>
          </div>
          `;
        }).join('');
      } catch {
        container.innerHTML = '<p class="text-center text-red-600 py-12">Failed to load notices.</p>';
      }
    }

    async function acknowledge(noticeId, btn) {
      btn.setAttribute('disabled', 'true');
      btn.textContent = 'Acknowledging…';
      const res = await fetch(`/api/v1/notices/${noticeId}/acknowledge`, {
        method: 'POST', credentials: 'include',
      });
      if (res.ok) {
        acknowledged.add(noticeId);
        btn.outerHTML = '<span class="text-xs text-green-600 font-medium flex items-center gap-1"><i class="fas fa-check-circle"></i> Acknowledged</span>';
      } else {
        btn.removeAttribute('disabled');
        btn.innerHTML = '<i class="fas fa-pen"></i> Acknowledge';
      }
    }

    async function viewAttachment(noticeId, btn) {
      btn.setAttribute('disabled', 'true');
      btn.innerHTML = '<i class="fas fa-spinner fa-spin text-[11px]"></i>';
      try {
        const res = await fetch(`/api/v1/notices/${noticeId}/attachment`, { credentials: 'include' });
        if (!res.ok) throw new Error('Failed');
        const { url } = await res.json();
        window.open(url, '_blank', 'noopener');
      } catch {
        showToast('Could not load attachment.', 'error');
      } finally {
        btn.removeAttribute('disabled');
        btn.innerHTML = '<i class="fas fa-paperclip text-[11px]"></i> Attachment';
      }
    }
    window.viewAttachment = viewAttachment;

    // ── Acknowledgement tracking panel (exec only) ────────────────────────────
    if (isExec) {
      const ackPanel    = document.getElementById('ack-panel');
      const ackBackdrop = document.getElementById('ack-backdrop');

      function closeAckPanel() {
        ackPanel?.classList.add('translate-x-full');
        ackBackdrop?.classList.add('hidden');
      }

      document.getElementById('close-ack-panel')?.addEventListener('click', closeAckPanel);
      ackBackdrop?.addEventListener('click', closeAckPanel);

      async function openAckPanel(noticeId, title) {
        // Show panel immediately with loading state
        document.getElementById('ack-panel-title').textContent = title;
        document.getElementById('ack-summary').innerHTML = '';
        document.getElementById('ack-members').innerHTML =
          '<div class="flex items-center justify-center h-24 text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';
        document.getElementById('ack-pct').textContent = '';
        document.getElementById('ack-progress-bar').style.width = '0%';
        ackPanel?.classList.remove('translate-x-full');
        ackBackdrop?.classList.remove('hidden');

        try {
          const res = await fetch(`/api/v1/notices/${noticeId}/acknowledgements`, { credentials: 'include' });
          if (!res.ok) throw new Error('Failed');
          const { summary, members } = await res.json();

          const pct = summary.total ? Math.round((summary.acknowledged_count / summary.total) * 100) : 0;
          document.getElementById('ack-pct').textContent = `${pct}%`;
          document.getElementById('ack-progress-bar').style.width = `${pct}%`;

          document.getElementById('ack-summary').innerHTML = `
            <div class="rounded-xl border border-border-light p-3 text-center">
              <p class="text-2xl font-bold text-text-primary">${summary.total}</p>
              <p class="text-xs text-text-secondary mt-0.5">Total members</p>
            </div>
            <div class="rounded-xl border border-green-200 bg-green-50 p-3 text-center">
              <p class="text-2xl font-bold text-secondary-500">${summary.acknowledged_count}</p>
              <p class="text-xs text-text-secondary mt-0.5">Acknowledged</p>
            </div>
            <div class="rounded-xl border border-amber-200 bg-amber-50 p-3 text-center">
              <p class="text-2xl font-bold text-amber-600">${summary.pending_count}</p>
              <p class="text-xs text-text-secondary mt-0.5">Pending</p>
            </div>
          `;

          const fmtDate = (iso) =>
            new Date(iso).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });

          document.getElementById('ack-members').innerHTML = members.length
            ? members.map((m) => `
              <div class="flex items-center gap-3 px-3 py-2.5 rounded-lg ${m.acknowledged_at ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-border-light'}">
                <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 text-sm font-bold ${m.acknowledged_at ? 'bg-secondary-500 text-white' : 'bg-gray-200 text-text-secondary'}">
                  ${m.name[0].toUpperCase()}
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-text-primary truncate">${m.name}</p>
                  <p class="text-xs text-text-secondary">${m.unit_number ? `Unit ${m.unit_number}` : 'No unit'}</p>
                </div>
                ${m.acknowledged_at
                  ? `<span class="text-xs text-secondary-500 font-medium flex items-center gap-1 flex-shrink-0"><i class="fas fa-check-circle"></i> ${fmtDate(m.acknowledged_at)}</span>`
                  : '<span class="text-xs text-amber-600 font-medium flex-shrink-0">Pending</span>'
                }
              </div>
            `).join('')
            : '<p class="text-sm text-text-secondary text-center py-6">No members found.</p>';
        } catch {
          document.getElementById('ack-members').innerHTML =
            '<p class="text-sm text-red-600 text-center py-6">Failed to load acknowledgement data.</p>';
        }
      }

      window.openAckPanel = openAckPanel;
    }

    window.acknowledge = acknowledge;
    loadNotices();

    // ── Scheduled notices tab (exec only) ─────────────────────────────────────
    if (isExec) {
      const tabPublished = document.getElementById('tab-published');
      const tabScheduled = document.getElementById('tab-scheduled');
      const publishedPanel = document.getElementById('notices-list');
      const scheduledPanel = document.getElementById('scheduled-list');
      const scheduledCount = document.getElementById('scheduled-count');

      async function loadScheduled() {
        if (!scheduledPanel) return;
        scheduledPanel.innerHTML = '<div class="flex items-center justify-center h-24 text-text-secondary text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</div>';
        const res = await fetch('/api/v1/notices?status=scheduled', { credentials: 'include' });
        const items = res.ok ? await res.json() : [];

        if (scheduledCount) {
          if (items.length > 0) {
            scheduledCount.textContent = String(items.length);
            scheduledCount.classList.remove('hidden');
          } else {
            scheduledCount.classList.add('hidden');
          }
        }

        if (!items.length) {
          scheduledPanel.innerHTML = '<div class="text-center py-12 text-text-secondary text-sm">No scheduled notices.</div>';
          return;
        }

        scheduledPanel.innerHTML = items.map((n) => `
          <div class="bg-white rounded-xl border border-amber-200 bg-amber-50/30 p-5 flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <i class="fas fa-clock text-amber-500 text-xs"></i>
                <span class="text-xs font-medium text-amber-700">Scheduled for ${new Date(n.scheduled_at).toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</span>
              </div>
              <h2 class="text-base font-semibold text-text-primary">${n.title}</h2>
              <span class="text-xs text-text-secondary">${n.category}</span>
            </div>
            <button onclick="publishNow('${n.id}', this)" class="flex-shrink-0 text-xs bg-primary-600 text-white px-3 py-1.5 rounded-lg hover:bg-primary-700 transition-colors flex items-center gap-1.5">
              <i class="fas fa-paper-plane text-xs"></i> Publish now
            </button>
          </div>
        `).join('');
      }

      async function publishNow(noticeId, btn) {
        if (!confirm('Publish this notice immediately to all members?')) return;
        btn.setAttribute('disabled', 'true');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin text-xs"></i>';
        const res = await fetch(`/api/v1/notices/${noticeId}/publish`, { method: 'POST', credentials: 'include' });
        if (res.ok) {
          showToast('Notice published successfully.');
          loadScheduled();
          loadNotices();
        } else {
          const d = await res.json().catch(() => ({}));
          showToast(d.message ?? 'Failed to publish.', 'error');
          btn.removeAttribute('disabled');
          btn.innerHTML = '<i class="fas fa-paper-plane text-xs"></i> Publish now';
        }
      }

      function showToast(message, type = 'success') {
        const toast = document.createElement('div');
        const color = type === 'success' ? 'bg-secondary-500' : 'bg-red-500';
        toast.className = `fixed bottom-6 right-6 z-50 px-4 py-3 rounded-xl shadow-large text-sm font-medium text-white transform translate-y-4 opacity-0 transition-all duration-300 ${color}`;
        toast.textContent = message;
        document.body.appendChild(toast);
        requestAnimationFrame(() => toast.classList.remove('translate-y-4', 'opacity-0'));
        setTimeout(() => { toast.classList.add('translate-y-4', 'opacity-0'); setTimeout(() => toast.remove(), 300); }, 3000);
      }

      window.publishNow = publishNow;

      tabPublished?.addEventListener('click', () => {
        tabPublished.classList.add('text-primary-600', 'border-primary-600');
        tabPublished.classList.remove('text-text-secondary', 'border-transparent');
        tabScheduled?.classList.remove('text-primary-600', 'border-primary-600');
        tabScheduled?.classList.add('text-text-secondary', 'border-transparent');
        publishedPanel?.classList.remove('hidden');
        scheduledPanel?.classList.add('hidden');
      });

      tabScheduled?.addEventListener('click', () => {
        tabScheduled.classList.add('text-primary-600', 'border-primary-600');
        tabScheduled.classList.remove('text-text-secondary', 'border-transparent');
        tabPublished?.classList.remove('text-primary-600', 'border-primary-600');
        tabPublished?.classList.add('text-text-secondary', 'border-transparent');
        scheduledPanel?.classList.remove('hidden');
        publishedPanel?.classList.add('hidden');
        loadScheduled();
      });

      // Load count badge on page load (non-blocking)
      loadScheduled().catch(() => {});
    }
  </script>
</PortalLayout>

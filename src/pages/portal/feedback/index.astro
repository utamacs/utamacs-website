---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const isPrivileged = ['executive', 'secretary', 'president'].includes(user.portalRole ?? '') || user.isAdmin;
---

<PortalLayout title="Feedback" user={user} activeModule="feedback">
  <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-primary-600 font-poppins">Resident Feedback</h1>
      <p class="text-text-secondary text-sm mt-1">
        {isPrivileged ? 'Review and respond to resident feedback.' : 'Share your thoughts and suggestions with the management.'}
      </p>
    </div>
    {!isPrivileged && (
      <button id="new-feedback-btn" class="btn-primary text-sm whitespace-nowrap">
        <i class="fas fa-comment-alt mr-2" aria-hidden="true"></i>Submit Feedback
      </button>
    )}
  </div>

  <!-- Exec: filters -->
  {isPrivileged && (
    <div class="flex flex-wrap gap-3 mb-4">
      <select id="filter-status" onchange="loadFeedback()"
        class="text-sm border border-border-light rounded-lg px-3 py-2 bg-white">
        <option value="">All Statuses</option>
        <option value="open">Open</option>
        <option value="acknowledged">Acknowledged</option>
        <option value="in_progress">In Progress</option>
        <option value="resolved">Resolved</option>
        <option value="closed">Closed</option>
      </select>
      <select id="filter-category" onchange="loadFeedback()"
        class="text-sm border border-border-light rounded-lg px-3 py-2 bg-white">
        <option value="">All Categories</option>
        <option value="general">General</option>
        <option value="maintenance">Maintenance</option>
        <option value="safety">Safety</option>
        <option value="amenities">Amenities</option>
        <option value="management">Management</option>
        <option value="events">Events</option>
        <option value="other">Other</option>
      </select>
    </div>
  )}

  <!-- Feedback list -->
  <div id="feedback-list">
    <div class="text-center py-12 text-text-secondary">
      <i class="fas fa-spinner fa-spin mr-2" aria-hidden="true"></i>Loading…
    </div>
  </div>

  <!-- Respond / detail drawer -->
  <div id="detail-panel" class="fixed inset-y-0 right-0 w-full sm:w-96 lg:w-[480px] bg-white shadow-large z-40 transform translate-x-full transition-transform duration-300 overflow-y-auto">
    <div class="sticky top-0 bg-white border-b border-border-light p-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-primary-600">Feedback Detail</h2>
      <button id="close-panel" class="text-text-secondary hover:text-text-primary p-2">
        <i class="fas fa-times text-xl" aria-hidden="true"></i>
      </button>
    </div>
    <div class="p-4" id="panel-body">
      <!-- dynamic content -->
    </div>
  </div>
  <div id="panel-backdrop" class="fixed inset-0 bg-black/40 z-30 hidden"></div>

  <!-- Submit Feedback Modal (member) -->
  {!isPrivileged && (
    <div id="feedback-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div class="bg-white rounded-2xl shadow-large w-full max-w-lg max-h-[90vh] overflow-y-auto">
        <div class="p-6 border-b border-border-light flex items-center justify-between sticky top-0 bg-white">
          <h2 class="text-lg font-semibold text-text-primary">Submit Feedback</h2>
          <button onclick="closeFeedbackModal()" class="p-2 rounded-lg hover:bg-gray-100 text-text-secondary">
            <i class="fas fa-times" aria-hidden="true"></i>
          </button>
        </div>
        <div class="p-6 space-y-4">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="fb-category" class="block text-sm font-medium text-text-primary mb-1">Category *</label>
              <select id="fb-category" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm">
                <option value="general">General</option>
                <option value="maintenance">Maintenance</option>
                <option value="safety">Safety</option>
                <option value="amenities">Amenities</option>
                <option value="management">Management</option>
                <option value="events">Events</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-text-primary mb-1">Overall Rating</label>
              <div class="flex gap-1 mt-1" id="star-row">
                {[1,2,3,4,5].map(n => (
                  <button type="button" data-star={n} class="star-btn text-2xl text-gray-300 hover:text-accent-500 transition-colors">★</button>
                ))}
              </div>
              <input type="hidden" id="fb-rating" value="" />
            </div>
          </div>
          <div>
            <label for="fb-subject" class="block text-sm font-medium text-text-primary mb-1">Subject *</label>
            <input id="fb-subject" type="text" maxlength="200" placeholder="Brief summary of your feedback"
              class="w-full border border-border-light rounded-lg px-3 py-2 text-sm" />
          </div>
          <div>
            <label for="fb-body" class="block text-sm font-medium text-text-primary mb-1">Details *</label>
            <textarea id="fb-body" rows="5" maxlength="2000" placeholder="Share your full feedback here…"
              class="w-full border border-border-light rounded-lg px-3 py-2 text-sm resize-none"></textarea>
          </div>
          <div class="bg-gray-50 border border-border-light rounded-xl p-4">
            <label class="flex items-center gap-3 text-sm cursor-pointer">
              <input type="checkbox" id="fb-anonymous" class="rounded border-border-light text-primary-600" />
              <div>
                <span class="font-medium">Submit anonymously</span>
                <p class="text-xs text-text-secondary">Management won't see your name or flat number</p>
              </div>
            </label>
          </div>
          <div id="fb-error" class="hidden text-sm text-red-600 bg-red-50 rounded-lg p-3"></div>
        </div>
        <div class="p-6 pt-0 flex gap-3">
          <button onclick="closeFeedbackModal()" class="flex-1 btn-outline text-sm">Cancel</button>
          <button id="fb-save-btn" class="flex-1 btn-primary text-sm">Submit</button>
        </div>
      </div>
    </div>
  )}

  <script define:vars={{ isPrivileged }}>
    const CATEGORY_LABELS = {
      general: 'General', maintenance: 'Maintenance', safety: 'Safety',
      amenities: 'Amenities', management: 'Management', events: 'Events', other: 'Other',
    };

    const STATUS_STYLES = {
      open:         'bg-blue-100 text-blue-700',
      acknowledged: 'bg-amber-100 text-amber-700',
      in_progress:  'bg-purple-100 text-purple-700',
      resolved:     'bg-green-100 text-green-700',
      closed:       'bg-gray-100 text-gray-600',
    };

    const PRIORITY_STYLES = {
      low:    'bg-gray-100 text-gray-600',
      normal: 'bg-blue-50 text-blue-600',
      high:   'bg-amber-100 text-amber-700',
      urgent: 'bg-red-100 text-red-700',
    };

    let feedbackData = [];

    async function loadFeedback() {
      const container = document.getElementById('feedback-list');
      const params = new URLSearchParams({ limit: '50' });
      if (isPrivileged) {
        const s = document.getElementById('filter-status')?.value;
        const c = document.getElementById('filter-category')?.value;
        if (s) params.set('status', s);
        if (c) params.set('category', c);
      }
      try {
        const res = await fetch(`/api/v1/feedback?${params}`, { credentials: 'include' });
        const data = await res.json();
        feedbackData = Array.isArray(data) ? data : [];

        if (!feedbackData.length) {
          container.innerHTML = `
            <div class="text-center py-16">
              <i class="fas fa-comment-alt text-5xl text-primary-200 mb-4" aria-hidden="true"></i>
              <h3 class="text-lg font-semibold text-text-primary mb-2">${isPrivileged ? 'No feedback yet' : 'You haven\'t submitted any feedback'}</h3>
              <p class="text-text-secondary text-sm">${isPrivileged ? 'Resident feedback will appear here.' : 'Share your thoughts with the management.'}</p>
              ${!isPrivileged ? '<button onclick="document.getElementById(\'new-feedback-btn\').click()" class="btn-primary text-sm mt-4">Submit Feedback</button>' : ''}
            </div>`;
          return;
        }

        container.innerHTML = `<div class="space-y-3">
          ${feedbackData.map(f => `
            <div class="card-premium p-5 cursor-pointer hover:shadow-medium transition-shadow"
                 onclick="openDetail('${f.id}')">
              <div class="flex items-start justify-between gap-4 mb-2">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap mb-1">
                    <span class="text-xs px-2 py-0.5 rounded-full bg-primary-50 text-primary-600 font-medium">
                      ${CATEGORY_LABELS[f.category] ?? f.category}
                    </span>
                    ${f.is_anonymous ? '<span class="text-xs text-text-secondary"><i class="fas fa-user-secret mr-1"></i>Anonymous</span>' : ''}
                    ${isPrivileged && f.priority !== 'normal'
                      ? `<span class="text-xs px-2 py-0.5 rounded-full capitalize font-medium ${PRIORITY_STYLES[f.priority] ?? ''}">${f.priority}</span>`
                      : ''}
                  </div>
                  <p class="font-medium text-text-primary text-sm">${f.subject}</p>
                  ${isPrivileged && f.units
                    ? `<p class="text-xs text-text-secondary mt-0.5">Unit ${f.units.unit_number ?? '—'}</p>`
                    : ''}
                </div>
                <div class="flex-shrink-0 flex flex-col items-end gap-1">
                  <span class="px-2.5 py-0.5 rounded-full text-xs font-medium capitalize ${STATUS_STYLES[f.status] ?? 'bg-gray-100 text-gray-600'}">
                    ${f.status.replace('_', ' ')}
                  </span>
                  ${f.rating ? `<span class="text-xs text-accent-500">${'★'.repeat(f.rating)}${'☆'.repeat(5 - f.rating)}</span>` : ''}
                </div>
              </div>
              <p class="text-sm text-text-secondary line-clamp-2">${isPrivileged ? (f.body ?? '') : ''}</p>
              <p class="text-xs text-text-secondary mt-2">${new Date(f.created_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}</p>
            </div>`).join('')}
        </div>`;
      } catch {
        container.innerHTML = `<div class="text-center text-red-600 py-8">Failed to load feedback.</div>`;
      }
    }

    function openDetail(feedbackId) {
      const f = feedbackData.find(x => x.id === feedbackId);
      if (!f) return;

      const panel = document.getElementById('detail-panel');
      const panelBody = document.getElementById('panel-body');

      const statusBadge = `<span class="px-2.5 py-0.5 rounded-full text-xs font-medium capitalize ${STATUS_STYLES[f.status] ?? ''}">${f.status.replace('_', ' ')}</span>`;

      panelBody.innerHTML = `
        <div class="space-y-4">
          <div>
            ${statusBadge}
            <h3 class="font-semibold text-text-primary mt-2">${f.subject}</h3>
            <div class="flex items-center gap-2 mt-1 text-xs text-text-secondary flex-wrap">
              <span class="capitalize">${CATEGORY_LABELS[f.category] ?? f.category}</span>
              <span>·</span>
              <span>${new Date(f.created_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
              ${f.is_anonymous ? '<span>· <i class="fas fa-user-secret mr-0.5"></i>Anonymous</span>' : ''}
              ${f.rating ? `<span>· ${'★'.repeat(f.rating)}</span>` : ''}
            </div>
          </div>

          ${isPrivileged && f.body ? `<div class="bg-gray-50 rounded-xl p-4 text-sm text-text-primary leading-relaxed">${f.body}</div>` : ''}
          ${!isPrivileged && f.body ? `<div class="bg-gray-50 rounded-xl p-4 text-sm text-text-primary leading-relaxed">${f.body}</div>` : ''}

          ${f.response ? `
            <div class="bg-green-50 border border-green-200 rounded-xl p-4">
              <p class="text-xs font-semibold text-green-700 mb-1"><i class="fas fa-reply mr-1"></i>Management Response</p>
              <p class="text-sm text-text-primary">${f.response}</p>
              ${f.responded_at ? `<p class="text-xs text-text-secondary mt-2">${new Date(f.responded_at).toLocaleDateString('en-IN')}</p>` : ''}
            </div>` : ''}

          ${isPrivileged ? `
            <div class="space-y-3 border-t border-border-light pt-4">
              <p class="text-sm font-semibold text-text-primary">Respond &amp; Update</p>
              <div class="grid grid-cols-2 gap-2">
                <div>
                  <label class="block text-xs font-medium text-text-primary mb-1">Status</label>
                  <select id="panel-status" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm">
                    ${['open','acknowledged','in_progress','resolved','closed'].map(s =>
                      `<option value="${s}" ${f.status === s ? 'selected' : ''}>${s.replace('_',' ')}</option>`
                    ).join('')}
                  </select>
                </div>
                <div>
                  <label class="block text-xs font-medium text-text-primary mb-1">Priority</label>
                  <select id="panel-priority" class="w-full border border-border-light rounded-lg px-3 py-2 text-sm">
                    ${['low','normal','high','urgent'].map(p =>
                      `<option value="${p}" ${f.priority === p ? 'selected' : ''}>${p}</option>`
                    ).join('')}
                  </select>
                </div>
              </div>
              <div>
                <label class="block text-xs font-medium text-text-primary mb-1">Response</label>
                <textarea id="panel-response" rows="4" maxlength="2000" placeholder="Write your response…"
                  class="w-full border border-border-light rounded-lg px-3 py-2 text-sm resize-none">${f.response ?? ''}</textarea>
              </div>
              <div id="panel-error" class="hidden text-sm text-red-600 bg-red-50 rounded-lg p-3"></div>
              <button onclick="saveResponse('${f.id}')" class="w-full btn-primary text-sm">
                <i class="fas fa-save mr-2" aria-hidden="true"></i>Save Response
              </button>
            </div>` : ''}

          ${!isPrivileged && f.status === 'open' ? `
            <button onclick="closeFeedbackEntry('${f.id}')" class="w-full btn-outline text-sm text-red-600 border-red-200 hover:bg-red-50">
              Close This Feedback
            </button>` : ''}
        </div>`;

      panel.classList.remove('translate-x-full');
      document.getElementById('panel-backdrop').classList.remove('hidden');
    }

    async function saveResponse(feedbackId) {
      const status   = document.getElementById('panel-status')?.value;
      const priority = document.getElementById('panel-priority')?.value;
      const response = document.getElementById('panel-response')?.value.trim();
      const errEl    = document.getElementById('panel-error');
      errEl.classList.add('hidden');

      try {
        const res = await fetch('/api/v1/feedback', {
          method: 'PATCH', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: feedbackId, status, priority, response: response || undefined }),
        });
        const data = await res.json();
        if (!res.ok) { errEl.textContent = data.message ?? 'Failed to save.'; errEl.classList.remove('hidden'); return; }
        closePanel();
        loadFeedback();
        showToast('Response saved.');
      } catch {
        errEl.textContent = 'Network error.';
        errEl.classList.remove('hidden');
      }
    }

    async function closeFeedbackEntry(feedbackId) {
      if (!confirm('Mark this feedback as closed?')) return;
      try {
        const res = await fetch('/api/v1/feedback', {
          method: 'PATCH', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: feedbackId, status: 'closed' }),
        });
        if (res.ok) { closePanel(); loadFeedback(); showToast('Feedback closed.'); }
      } catch { alert('Network error.'); }
    }

    function closePanel() {
      document.getElementById('detail-panel').classList.add('translate-x-full');
      document.getElementById('panel-backdrop').classList.add('hidden');
    }

    document.getElementById('close-panel')?.addEventListener('click', closePanel);
    document.getElementById('panel-backdrop')?.addEventListener('click', closePanel);

    // ── Submit Feedback Modal (member) ────────────────────────────────────────

    let selectedRating = 0;

    document.getElementById('new-feedback-btn')?.addEventListener('click', () => {
      document.getElementById('feedback-modal')?.classList.remove('hidden');
      document.getElementById('fb-error')?.classList.add('hidden');
    });

    function closeFeedbackModal() {
      document.getElementById('feedback-modal')?.classList.add('hidden');
    }

    // Star rating
    document.getElementById('star-row')?.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-star]');
      if (!btn) return;
      selectedRating = parseInt(btn.dataset.star ?? '0', 10);
      document.getElementById('fb-rating').value = String(selectedRating);
      document.querySelectorAll('.star-btn').forEach((s) => {
        const n = parseInt(s.dataset.star, 10);
        s.style.color = n <= selectedRating ? 'var(--color-accent-500, #F59E0B)' : '#D1D5DB';
      });
    });

    document.getElementById('fb-save-btn')?.addEventListener('click', async () => {
      const subject  = document.getElementById('fb-subject')?.value.trim();
      const body     = document.getElementById('fb-body')?.value.trim();
      const category = document.getElementById('fb-category')?.value;
      const isAnon   = document.getElementById('fb-anonymous')?.checked ?? false;
      const rating   = selectedRating || undefined;
      const errEl    = document.getElementById('fb-error');
      const btn      = document.getElementById('fb-save-btn');

      if (!subject) { errEl.textContent = 'Subject is required.'; errEl.classList.remove('hidden'); return; }
      if (!body || body.length < 10) { errEl.textContent = 'Please write at least 10 characters.'; errEl.classList.remove('hidden'); return; }

      btn.disabled = true; btn.textContent = 'Submitting…';
      errEl.classList.add('hidden');

      try {
        const res = await fetch('/api/v1/feedback', {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ subject, body, category, is_anonymous: isAnon, rating }),
        });
        const data = await res.json();
        if (!res.ok) { errEl.textContent = data.message ?? 'Failed to submit.'; errEl.classList.remove('hidden'); return; }
        closeFeedbackModal();
        loadFeedback();
        showToast('Feedback submitted. Thank you!');
      } catch {
        errEl.textContent = 'Network error.';
        errEl.classList.remove('hidden');
      } finally {
        btn.disabled = false; btn.textContent = 'Submit';
      }
    });

    function showToast(message, type = 'success') {
      const toast = document.createElement('div');
      const color = type === 'success' ? 'bg-secondary-500' : 'bg-red-500';
      toast.className = `fixed bottom-6 right-6 z-50 px-4 py-3 rounded-xl shadow-large text-sm font-medium text-white transform translate-y-4 opacity-0 transition-all duration-300 ${color}`;
      toast.textContent = message;
      document.body.appendChild(toast);
      requestAnimationFrame(() => toast.classList.remove('translate-y-4', 'opacity-0'));
      setTimeout(() => { toast.classList.add('translate-y-4', 'opacity-0'); setTimeout(() => toast.remove(), 300); }, 3000);
    }

    loadFeedback();
  </script>
</PortalLayout>

---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const canList = !['security_guard', 'vendor'].includes(user.role);
---

<PortalLayout title="Marketplace" user={user} activeModule="community">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <nav class="text-sm text-text-secondary mb-2">
        <a href="/portal/community" class="hover:text-primary-600">Community Board</a>
        <span class="mx-2">›</span><span class="text-text-primary">Marketplace</span>
      </nav>
      <h1 class="text-2xl font-bold text-text-primary">Marketplace</h1>
      <p class="text-sm text-text-secondary mt-1">Buy, sell, and exchange within Urban Trilla.</p>
    </div>
    {canList && (
      <a href="/portal/community/marketplace/new" class="btn-primary text-sm flex items-center gap-2">
        <i class="fas fa-plus" aria-hidden="true"></i>
        Post Listing
      </a>
    )}
  </div>

  <!-- Search + category filter -->
  <div class="flex flex-col sm:flex-row gap-3 mb-5">
    <div class="relative flex-1 max-w-sm">
      <i class="fas fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-text-secondary text-sm" aria-hidden="true"></i>
      <input type="search" id="search-input" placeholder="Search listings…"
        class="w-full pl-10 pr-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
    </div>
    <div class="flex gap-2 flex-wrap" id="cat-filters">
      {['All','Furniture','Electronics','Appliances','Books','Toys','Clothing','Sports','Vehicles','Services','Other'].map(c => (
        <button data-cat={c === 'All' ? '' : c}
          class={`filter-btn text-xs px-3 py-1.5 rounded-full font-medium border transition-colors whitespace-nowrap ${c === 'All' ? 'bg-primary-600 text-white border-primary-600' : 'bg-white text-text-secondary border-border-light hover:border-primary-600 hover:text-primary-600'}`}>
          {c}
        </button>
      ))}
    </div>
  </div>

  <!-- Results count -->
  <div id="result-count" class="text-xs text-text-secondary mb-4"></div>

  <!-- Grid -->
  <div id="listings-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
    {Array.from({length: 8}).map(() => (
      <div class="bg-white rounded-xl border border-border-light p-4 animate-pulse">
        <div class="h-3 bg-gray-200 rounded w-3/4 mb-2"></div>
        <div class="h-5 bg-gray-200 rounded w-1/3 mb-3"></div>
        <div class="h-2.5 bg-gray-100 rounded w-full mb-1"></div>
        <div class="h-2.5 bg-gray-100 rounded w-2/3"></div>
      </div>
    ))}
  </div>

  <div class="mt-6 text-center">
    <button id="load-more-btn" class="hidden btn-outline text-sm">Load more</button>
  </div>

  <script define:vars={{ userId: user.id }}>
    const CATEGORY_COLORS: Record<string, string> = {
      Furniture: 'bg-amber-100 text-amber-700',
      Electronics: 'bg-blue-100 text-blue-700',
      Appliances: 'bg-purple-100 text-purple-700',
      Books: 'bg-green-100 text-green-700',
      Toys: 'bg-pink-100 text-pink-700',
      Clothing: 'bg-indigo-100 text-indigo-700',
      Sports: 'bg-teal-100 text-teal-700',
      Vehicles: 'bg-orange-100 text-orange-700',
      Services: 'bg-cyan-100 text-cyan-700',
      Other: 'bg-gray-100 text-gray-600',
    };

    let currentCategory = '';
    let currentOffset = 0;
    let currentQ = '';
    const LIMIT = 12;
    let debounceTimer: ReturnType<typeof setTimeout>;

    async function loadListings(reset = false) {
      if (reset) { currentOffset = 0; }
      const params = new URLSearchParams({ limit: String(LIMIT), offset: String(currentOffset) });
      if (currentCategory) params.set('category', currentCategory);
      if (currentQ) params.set('q', currentQ);

      const res = await fetch(`/api/v1/community/marketplace?${params}`, { credentials: 'include' });
      const { listings, total } = res.ok ? await res.json() : { listings: [], total: 0 };

      const grid = document.getElementById('listings-grid')!;
      if (reset) grid.innerHTML = '';

      document.getElementById('result-count')!.textContent = total > 0 ? `${total} listing${total !== 1 ? 's' : ''} available` : '';

      if (!listings.length && currentOffset === 0) {
        grid.innerHTML = '<div class="col-span-full text-center py-12 text-text-secondary text-sm">No listings found.</div>';
        document.getElementById('load-more-btn')!.classList.add('hidden');
        return;
      }

      listings.forEach((l: any) => {
        const card = document.createElement('a');
        card.href = `/portal/community/marketplace/${l.id}`;
        card.className = 'bg-white rounded-xl border border-border-light p-4 hover:shadow-soft transition-shadow flex flex-col';
        card.innerHTML = `
          <div class="flex items-start justify-between gap-2 mb-2">
            <span class="text-xs px-2 py-0.5 rounded-full font-medium ${CATEGORY_COLORS[l.category] ?? 'bg-gray-100 text-gray-600'}">${l.category}</span>
            <span class="text-xs text-text-secondary whitespace-nowrap">${new Date(l.created_at).toLocaleDateString('en-IN', {day:'numeric',month:'short'})}</span>
          </div>
          <h3 class="font-semibold text-text-primary text-sm mb-1 line-clamp-2">${l.title}</h3>
          ${l.description ? `<p class="text-xs text-text-secondary line-clamp-2 mb-2 flex-1">${l.description}</p>` : '<div class="flex-1"></div>'}
          <div class="flex items-center justify-between mt-2 pt-2 border-t border-border-light">
            <div class="font-bold text-text-primary text-sm">
              ${l.price != null ? `₹${Number(l.price).toLocaleString('en-IN')}` : '<span class="text-text-secondary font-normal text-xs">Price on request</span>'}
            </div>
            <div class="text-xs text-text-secondary">${l.profiles?.full_name?.split(' ')[0] ?? 'Resident'} · ${l.units?.unit_number ?? ''}</div>
          </div>
        `;
        grid.appendChild(card);
      });

      currentOffset += listings.length;
      document.getElementById('load-more-btn')!.classList.toggle('hidden', currentOffset >= total);
    }

    document.getElementById('cat-filters')!.addEventListener('click', (e) => {
      const btn = (e.target as Element).closest('.filter-btn') as HTMLElement;
      if (!btn) return;
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('bg-primary-600', 'text-white', 'border-primary-600');
        b.classList.add('bg-white', 'text-text-secondary', 'border-border-light');
      });
      btn.classList.add('bg-primary-600', 'text-white', 'border-primary-600');
      btn.classList.remove('bg-white', 'text-text-secondary', 'border-border-light');
      currentCategory = btn.dataset.cat ?? '';
      loadListings(true);
    });

    document.getElementById('search-input')!.addEventListener('input', (e) => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        currentQ = (e.target as HTMLInputElement).value.trim();
        loadListings(true);
      }, 350);
    });

    document.getElementById('load-more-btn')!.addEventListener('click', () => loadListings(false));

    loadListings(true);
  </script>
</PortalLayout>

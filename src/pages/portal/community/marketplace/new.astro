---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user || ['security_guard', 'vendor'].includes(user.role)) {
  return Astro.redirect('/portal/community/marketplace');
}
---

<PortalLayout title="Post a Listing" user={user} activeModule="community">
  <div class="mb-6">
    <nav class="text-sm text-text-secondary mb-3">
      <a href="/portal/community" class="hover:text-primary-600">Community Board</a>
      <span class="mx-2">›</span>
      <a href="/portal/community/marketplace" class="hover:text-primary-600">Marketplace</a>
      <span class="mx-2">›</span><span class="text-text-primary">New Listing</span>
    </nav>
    <h1 class="text-2xl font-bold text-text-primary">Post a Listing</h1>
    <p class="text-sm text-text-secondary mt-1">Listings are visible to all residents and expire after 30 days.</p>
  </div>

  <div class="max-w-lg">
    <div id="error-banner" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>

    <form id="listing-form" class="bg-white rounded-xl border border-border-light p-6 space-y-5">
      <div>
        <label for="title" class="block text-sm font-medium text-text-primary mb-1.5">Title <span class="text-red-500">*</span></label>
        <input type="text" id="title" name="title" required maxlength="200"
          placeholder="e.g. IKEA dining table, good condition"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="category" class="block text-sm font-medium text-text-primary mb-1.5">Category <span class="text-red-500">*</span></label>
          <select id="category" name="category" required
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
            <option value="">Select</option>
            {['Furniture','Electronics','Appliances','Books','Toys','Clothing','Sports','Vehicles','Services','Other'].map(c => (
              <option value={c}>{c}</option>
            ))}
          </select>
        </div>
        <div>
          <label for="price" class="block text-sm font-medium text-text-primary mb-1.5">Price (₹)</label>
          <input type="number" id="price" name="price" min="0" step="1"
            placeholder="Leave blank = free / POA"
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
        </div>
      </div>

      <div>
        <label for="description" class="block text-sm font-medium text-text-primary mb-1.5">Description</label>
        <textarea id="description" name="description" rows="4" maxlength="1000"
          placeholder="Condition, dimensions, reason for selling…"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none"></textarea>
        <p class="text-xs text-text-secondary mt-1"><span id="char-count">0</span>/1000</p>
      </div>

      <div>
        <label for="contact_preference" class="block text-sm font-medium text-text-primary mb-1.5">Contact Preference</label>
        <select id="contact_preference" name="contact_preference"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
          <option value="message">Portal message only</option>
          <option value="phone">Phone call</option>
          <option value="both">Both</option>
        </select>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <button type="submit" id="submit-btn" class="btn-primary flex items-center gap-2">
          <i class="fas fa-tag" aria-hidden="true"></i>
          <span id="btn-text">Post Listing</span>
          <span id="btn-spinner" class="hidden"><i class="fas fa-spinner fa-spin" aria-hidden="true"></i></span>
        </button>
        <a href="/portal/community/marketplace" class="btn-outline">Cancel</a>
      </div>
    </form>
  </div>

  <script>
    const form = document.getElementById('listing-form') as HTMLFormElement;
    const errorBanner = document.getElementById('error-banner')!;
    const desc = document.getElementById('description') as HTMLTextAreaElement;
    const charCount = document.getElementById('char-count')!;
    const btnText = document.getElementById('btn-text')!;
    const btnSpinner = document.getElementById('btn-spinner')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    desc.addEventListener('input', () => { charCount.textContent = desc.value.length.toString(); });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBanner.classList.add('hidden');
      btnText.classList.add('hidden');
      btnSpinner.classList.remove('hidden');
      submitBtn.disabled = true;

      const fd = new FormData(form);
      const priceVal = fd.get('price');

      const res = await fetch('/api/v1/community/marketplace', {
        method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title: fd.get('title'),
          category: fd.get('category'),
          description: fd.get('description') || null,
          price: priceVal ? parseFloat(priceVal as string) : null,
          contact_preference: fd.get('contact_preference'),
        }),
      });

      const data = await res.json();
      if (res.ok) {
        window.location.href = `/portal/community/marketplace/${data.id}`;
      } else {
        errorBanner.textContent = data.detail ?? data.error ?? 'Failed to create listing.';
        errorBanner.classList.remove('hidden');
        btnText.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
        submitBtn.disabled = false;
      }
    });
  </script>
</PortalLayout>

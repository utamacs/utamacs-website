---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user || user.role === 'security_guard' || user.role === 'vendor') {
  return Astro.redirect('/portal/community');
}
---

<PortalLayout title="New Post" user={user} activeModule="community">
  <div class="mb-6">
    <nav class="text-sm text-text-secondary mb-3">
      <a href="/portal/community" class="hover:text-primary-600">Community Board</a>
      <span class="mx-2">›</span><span class="text-text-primary">New Post</span>
    </nav>
    <h1 class="text-2xl font-bold text-text-primary">Create a Post</h1>
    <p class="text-sm text-text-secondary mt-1">Share something with your community.</p>
  </div>

  <div class="max-w-2xl">
    <div id="error-banner" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>

    <form id="post-form" class="bg-white rounded-xl border border-border-light p-6 space-y-5">
      <div>
        <label for="category" class="block text-sm font-medium text-text-primary mb-1.5">Category <span class="text-red-500">*</span></label>
        <select id="category" name="category" required
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
          <option value="">Select category</option>
          <option value="General">General</option>
          <option value="Help">Help / Request</option>
          <option value="Lost_Found">Lost & Found</option>
          <option value="Recommendation">Recommendation</option>
          <option value="Alert">Alert</option>
        </select>
      </div>

      <div>
        <label for="title" class="block text-sm font-medium text-text-primary mb-1.5">Title <span class="text-red-500">*</span></label>
        <input type="text" id="title" name="title" required maxlength="200"
          placeholder="A short, descriptive title"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <div>
        <label for="body" class="block text-sm font-medium text-text-primary mb-1.5">Message <span class="text-red-500">*</span></label>
        <textarea id="body" name="body" required rows="6" maxlength="5000"
          placeholder="Share details, context, or your question…"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-vertical"></textarea>
        <p class="text-xs text-text-secondary mt-1"><span id="char-count">0</span>/5000</p>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <button type="submit" id="submit-btn" class="btn-primary flex items-center gap-2">
          <i class="fas fa-paper-plane" aria-hidden="true"></i>
          <span id="btn-text">Post to Community</span>
          <span id="btn-spinner" class="hidden"><i class="fas fa-spinner fa-spin" aria-hidden="true"></i></span>
        </button>
        <a href="/portal/community" class="btn-outline">Cancel</a>
      </div>
    </form>
  </div>

  <script>
    const form = document.getElementById('post-form') as HTMLFormElement;
    const errorBanner = document.getElementById('error-banner')!;
    const bodyEl = document.getElementById('body') as HTMLTextAreaElement;
    const charCount = document.getElementById('char-count')!;
    const btnText = document.getElementById('btn-text')!;
    const btnSpinner = document.getElementById('btn-spinner')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    bodyEl.addEventListener('input', () => { charCount.textContent = bodyEl.value.length.toString(); });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBanner.classList.add('hidden');
      btnText.classList.add('hidden');
      btnSpinner.classList.remove('hidden');
      submitBtn.disabled = true;

      const fd = new FormData(form);
      const res = await fetch('/api/v1/community/posts', {
        method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: fd.get('title'), body: fd.get('body'), category: fd.get('category') }),
      });

      const data = await res.json();
      if (res.ok) {
        window.location.href = `/portal/community/${data.id}`;
      } else {
        errorBanner.textContent = data.detail ?? data.error ?? 'Failed to create post.';
        errorBanner.classList.remove('hidden');
        btnText.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
        submitBtn.disabled = false;
      }
    });
  </script>
</PortalLayout>

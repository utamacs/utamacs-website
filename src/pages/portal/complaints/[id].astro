---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const { id } = Astro.params;
const created = Astro.url.searchParams.get('created') === '1';
const isExec = ['executive','admin'].includes(user.role);

const VALID_STATUS = ['Open','Assigned','In_Progress','Waiting_for_User','Resolved','Closed','Reopened'];
---

<PortalLayout title="Complaint Detail" user={user} activeModule="complaints">
  {created && (
    <div id="success-banner" class="mb-4 p-4 bg-green-50 border border-green-200 rounded-xl text-sm text-green-700 flex items-center gap-2">
      <i class="fas fa-check-circle" aria-hidden="true"></i>
      Your complaint has been submitted. Our team will respond within the SLA window.
    </div>
  )}

  <div id="detail-container">
    <div class="flex items-center justify-center h-48 text-text-secondary">
      <i class="fas fa-spinner fa-spin mr-2" aria-hidden="true"></i>
      Loading complaint…
    </div>
  </div>

  <script define:vars={{ id, isExec, userId: user.id, VALID_STATUS }}>
    const STATUS_BADGE = {
      Open: 'bg-red-100 text-red-700', Assigned: 'bg-blue-100 text-blue-700',
      In_Progress: 'bg-yellow-100 text-yellow-700', Waiting_for_User: 'bg-orange-100 text-orange-700',
      Resolved: 'bg-green-100 text-green-700', Closed: 'bg-gray-100 text-gray-600',
      Reopened: 'bg-purple-100 text-purple-700',
    };
    const PRIORITY_COLOR = { Critical: 'text-red-600', High: 'text-orange-500', Medium: 'text-yellow-600', Low: 'text-green-600' };

    let complaint = null;
    let execUsers = [];
    let existingRating = null;
    let attachments = [];

    async function load() {
      const [cRes, cmRes, usersRes, ratRes, attRes] = await Promise.all([
        fetch(`/api/v1/complaints/${id}`, { credentials: 'include' }),
        fetch(`/api/v1/complaints/${id}/comments`, { credentials: 'include' }),
        isExec ? fetch('/api/v1/members?limit=100', { credentials: 'include' }) : Promise.resolve(null),
        fetch(`/api/v1/complaints/${id}/rating`, { credentials: 'include' }),
        fetch(`/api/v1/complaints/${id}/attachments`, { credentials: 'include' }),
      ]);

      complaint = await cRes.json();
      const comments = cRes.ok ? (await cmRes.json()) : [];
      if (usersRes?.ok) {
        const mData = await usersRes.json();
        execUsers = (mData.data ?? mData ?? []).filter((m) => ['executive','admin'].includes(m.role ?? ''));
      }
      existingRating = ratRes.ok ? await ratRes.json() : null;
      attachments = attRes.ok ? (await attRes.json()) : [];

      render(complaint, comments);
    }

    function slaLabel(c) {
      if (!c.sla_deadline) return '';
      const slaDate = new Date(c.sla_deadline);
      const done = ['Resolved', 'Closed'].includes(c.status);
      const breached = slaDate < new Date() && !done;
      if (breached) return `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-700"><i class="fas fa-exclamation-triangle" aria-hidden="true"></i>SLA Overdue</span>`;
      return '';
    }

    function starsHtml(rating) {
      return Array.from({ length: 5 }, (_, i) =>
        `<i class="fas fa-star ${i < rating ? 'text-accent-500' : 'text-gray-300'}" aria-hidden="true"></i>`
      ).join('');
    }

    function attachmentsHtml() {
      if (!attachments.length) return '';
      return `
        <div class="bg-white rounded-xl border border-border-light p-6">
          <h2 class="text-lg font-semibold text-text-primary mb-4">Attachments</h2>
          <div class="space-y-2">
            ${attachments.map(a => `
              <a href="${a.url}" target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-3 p-2.5 rounded-lg border border-border-light hover:border-primary-600 hover:bg-primary-50 transition-colors text-sm">
                <i class="fas ${a.mime_type === 'application/pdf' ? 'fa-file-pdf text-red-500' : 'fa-image text-blue-500'} flex-shrink-0" aria-hidden="true"></i>
                <span class="flex-1 truncate">${a.file_name}</span>
                <span class="text-text-secondary text-xs">${(a.file_size_bytes / 1024).toFixed(0)} KB</span>
                <i class="fas fa-external-link-alt text-text-secondary text-xs" aria-hidden="true"></i>
              </a>
            `).join('')}
          </div>
        </div>`;
    }

    function ratingWidgetHtml(c) {
      const canRate = c.raised_by === userId && ['Resolved','Closed'].includes(c.status);
      if (!canRate) return '';

      if (existingRating) {
        return `
          <div class="bg-white rounded-xl border border-border-light p-5">
            <h2 class="text-lg font-semibold text-text-primary mb-2">Your Rating</h2>
            <div class="flex items-center gap-1 text-lg mb-1">${starsHtml(existingRating.rating)}</div>
            ${existingRating.feedback ? `<p class="text-sm text-text-secondary mt-1">"${existingRating.feedback}"</p>` : ''}
            <p class="text-xs text-text-secondary mt-2">Submitted ${new Date(existingRating.created_at).toLocaleDateString('en-IN')}</p>
          </div>`;
      }

      return `
        <div class="bg-white rounded-xl border border-border-light p-5">
          <h2 class="text-lg font-semibold text-text-primary mb-2">Rate Resolution</h2>
          <p class="text-xs text-text-secondary mb-3">How satisfied are you with how this was resolved?</p>
          <div id="star-picker" class="flex gap-1 mb-3" role="group" aria-label="Rating">
            ${Array.from({length:5},(_,i)=>`
              <button type="button" data-star="${i+1}"
                class="star-btn text-2xl text-gray-300 hover:text-accent-500 transition-colors focus:outline-none"
                aria-label="${i+1} star${i>0?'s':''}">
                <i class="fas fa-star" aria-hidden="true"></i>
              </button>`).join('')}
          </div>
          <textarea id="rating-feedback" rows="2" placeholder="Any comments? (optional)"
            class="w-full px-3 py-2 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none mb-3"
            maxlength="500"></textarea>
          <button id="submit-rating" class="btn-primary text-sm w-full" disabled>Submit Rating</button>
        </div>`;
    }

    function render(c, comments) {
      const container = document.getElementById('detail-container');
      const slaDate = c.sla_deadline ? new Date(c.sla_deadline) : null;
      const slaBreached = slaDate && slaDate < new Date() && !['Closed','Resolved'].includes(c.status);

      container.innerHTML = `
        <div class="mb-4">
          <nav class="text-sm text-text-secondary mb-3">
            <a href="/portal/complaints" class="hover:text-primary-600">Complaints</a>
            <span class="mx-2">›</span>
            <span class="text-text-primary font-mono">${c.ticket_number}</span>
          </nav>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <!-- Main detail -->
          <div class="lg:col-span-2 space-y-4">
            <div class="bg-white rounded-xl border border-border-light p-6">
              <div class="flex items-start justify-between gap-4 mb-2">
                <h1 class="text-2xl font-bold text-text-primary">${c.title}</h1>
                <span class="flex-shrink-0 px-3 py-1 rounded-full text-sm font-medium ${STATUS_BADGE[c.status] ?? 'bg-gray-100 text-gray-600'}">${c.status.replace(/_/g,' ')}</span>
              </div>
              ${slaBreached ? `<div class="mb-3">${slaLabel(c)}</div>` : ''}
              ${c.sub_category ? `<p class="text-xs text-text-secondary mb-3 font-medium">${c.category.replace(/_/g,' ')} › ${c.sub_category}</p>` : ''}
              ${c.description ? `<p class="text-sm text-text-secondary leading-relaxed mb-4">${c.description}</p>` : ''}
              <div class="grid grid-cols-2 gap-4 text-sm border-t border-border-light pt-4">
                <div><span class="text-text-secondary text-xs">Category</span><div class="font-medium mt-0.5">${c.category.replace(/_/g,' ')}</div></div>
                <div><span class="text-text-secondary text-xs">Priority</span><div class="font-medium mt-0.5 ${PRIORITY_COLOR[c.priority] ?? ''}">${c.priority}</div></div>
                ${slaDate ? `<div><span class="text-text-secondary text-xs">SLA Deadline</span><div class="font-medium mt-0.5 ${slaBreached ? 'text-red-600' : ''}">${slaDate.toLocaleString('en-IN')}</div></div>` : ''}
                <div><span class="text-text-secondary text-xs">Raised On</span><div class="font-medium mt-0.5">${new Date(c.created_at).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'})}</div></div>
              </div>
            </div>

            ${attachmentsHtml()}

            <!-- Comments thread -->
            <div class="bg-white rounded-xl border border-border-light p-6">
              <h2 class="text-lg font-semibold text-text-primary mb-4">Comments</h2>
              <div id="comments-list" class="space-y-4 mb-6">
                ${comments.length === 0 ? '<p class="text-sm text-text-secondary">No comments yet.</p>' :
                  comments.map(cm => `
                    <div class="flex gap-3 ${cm.is_internal ? 'bg-amber-50 border border-amber-200 rounded-lg p-3' : ''}">
                      <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-user text-primary-600 text-xs" aria-hidden="true"></i>
                      </div>
                      <div class="flex-1">
                        <div class="flex items-center gap-2 mb-1">
                          <span class="text-xs font-medium text-text-primary">${cm.user_id === userId ? 'You' : 'Management'}</span>
                          ${cm.is_internal ? '<span class="text-xs bg-amber-100 text-amber-700 px-1.5 py-0.5 rounded">Internal</span>' : ''}
                          <span class="text-xs text-text-secondary">${new Date(cm.created_at).toLocaleString('en-IN')}</span>
                        </div>
                        <p class="text-sm text-text-primary">${cm.comment}</p>
                      </div>
                    </div>
                  `).join('')}
              </div>

              <form id="comment-form" class="space-y-3">
                <textarea id="comment-text" rows="3" placeholder="Add a comment…"
                  class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none"></textarea>
                ${isExec ? `
                  <label class="flex items-center gap-2 text-sm cursor-pointer">
                    <input type="checkbox" id="is-internal" class="rounded border-border-light text-primary-600" />
                    <span class="text-text-secondary">Internal note (exec/admin only)</span>
                  </label>
                ` : ''}
                <button type="submit" class="btn-primary text-sm">Post Comment</button>
              </form>
            </div>
          </div>

          <!-- Sidebar -->
          <div class="space-y-4">
            ${isExec ? `
              <div class="bg-white rounded-xl border border-border-light p-5">
                <h2 class="text-lg font-semibold text-text-primary mb-4">Update Status</h2>
                <select id="status-select"
                  class="w-full px-3 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white mb-3">
                  ${VALID_STATUS.map(s => `<option value="${s}" ${s === c.status ? 'selected' : ''}>${s.replace(/_/g,' ')}</option>`).join('')}
                </select>
                <textarea id="status-note" rows="2" placeholder="Note (optional)"
                  class="w-full px-3 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none mb-3"></textarea>
                <button onclick="updateStatus()" class="btn-primary text-sm w-full">Update Status</button>
              </div>

              <div class="bg-white rounded-xl border border-border-light p-5">
                <h2 class="text-lg font-semibold text-text-primary mb-3">Assign To</h2>
                <select id="assign-select"
                  class="w-full px-3 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white mb-3">
                  <option value="">Unassigned</option>
                  ${execUsers.map((u) => `<option value="${u.id}" ${u.id === c.assigned_to ? 'selected' : ''}>${u.full_name ?? u.id}</option>`).join('')}
                </select>
                ${c.assigned_to ? `<div class="text-xs text-text-secondary mb-3">Currently assigned to: <span class="font-medium text-text-primary">${execUsers.find((u) => u.id === c.assigned_to)?.full_name ?? 'a team member'}</span></div>` : ''}
                <button onclick="assignComplaint()" class="btn-outline text-sm w-full">Save Assignment</button>
              </div>
            ` : ''}

            ${ratingWidgetHtml(c)}

            <div class="bg-white rounded-xl border border-border-light p-5">
              <h2 class="text-lg font-semibold text-text-primary mb-3">Details</h2>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between"><span class="text-text-secondary">Ticket</span><span class="font-mono text-xs font-medium">${c.ticket_number}</span></div>
                <div class="flex justify-between"><span class="text-text-secondary">SLA Hours</span><span>${c.sla_hours ?? '—'}h</span></div>
                <div class="flex justify-between"><span class="text-text-secondary">Reopen Count</span><span>${c.reopen_count}</span></div>
                ${c.resolved_at ? `<div class="flex justify-between"><span class="text-text-secondary">Resolved</span><span>${new Date(c.resolved_at).toLocaleDateString('en-IN')}</span></div>` : ''}
              </div>
            </div>
          </div>
        </div>
      `;

      document.getElementById('comment-form')?.addEventListener('submit', postComment);
      initRatingWidget();
    }

    function initRatingWidget() {
      const starPicker = document.getElementById('star-picker');
      const submitRating = document.getElementById('submit-rating');
      if (!starPicker || !submitRating) return;

      let selectedStar = 0;

      starPicker.querySelectorAll('.star-btn').forEach(btn => {
        btn.addEventListener('mouseenter', () => highlightStars(parseInt(btn.dataset.star)));
        btn.addEventListener('mouseleave', () => highlightStars(selectedStar));
        btn.addEventListener('click', () => {
          selectedStar = parseInt(btn.dataset.star);
          highlightStars(selectedStar);
          submitRating.disabled = false;
        });
      });

      submitRating.addEventListener('click', async () => {
        if (!selectedStar) return;
        const feedback = document.getElementById('rating-feedback').value.trim();
        submitRating.disabled = true;
        submitRating.textContent = 'Submitting…';
        const res = await fetch(`/api/v1/complaints/${id}/rating`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
          body: JSON.stringify({ rating: selectedStar, feedback: feedback || undefined }),
        });
        if (res.ok) { existingRating = await res.json(); load(); }
        else { submitRating.disabled = false; submitRating.textContent = 'Submit Rating'; alert('Failed to submit rating.'); }
      });
    }

    function highlightStars(n) {
      document.querySelectorAll('.star-btn').forEach((btn, i) => {
        btn.querySelector('i')?.classList.toggle('text-accent-500', i < n);
        btn.querySelector('i')?.classList.toggle('text-gray-300', i >= n);
      });
    }

    async function postComment(e) {
      e.preventDefault();
      const text = document.getElementById('comment-text').value.trim();
      if (!text) return;
      const isInternal = document.getElementById('is-internal')?.checked ?? false;
      const res = await fetch(`/api/v1/complaints/${id}/comments`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
        body: JSON.stringify({ comment: text, is_internal: isInternal }),
      });
      if (res.ok) { document.getElementById('comment-text').value = ''; load(); }
      else { const d = await res.json(); alert(d.detail ?? 'Failed to post comment'); }
    }

    async function updateStatus() {
      const status = document.getElementById('status-select').value;
      const note = document.getElementById('status-note').value;
      const res = await fetch(`/api/v1/complaints/${id}/status`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
        body: JSON.stringify({ status, note }),
      });
      if (res.ok) load();
      else { const d = await res.json(); alert(d.detail ?? 'Failed to update status'); }
    }

    async function assignComplaint() {
      const assignTo = document.getElementById('assign-select')?.value || null;
      const res = await fetch(`/api/v1/complaints/${id}/status`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
        body: JSON.stringify({ assigned_to: assignTo }),
      });
      if (res.ok) load();
      else { const d = await res.json(); alert(d.detail ?? 'Failed to assign complaint'); }
    }

    window.updateStatus = updateStatus;
    window.assignComplaint = assignComplaint;
    load();
  </script>
</PortalLayout>

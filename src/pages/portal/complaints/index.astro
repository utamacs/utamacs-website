---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';
import ComplaintsView from '@portal/ComplaintsView';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
---

<PortalLayout title="Complaints" user={user} activeModule="complaints">
  <!-- Process info panel -->
  <details class="mb-6 group rounded-xl border border-primary-100 bg-gradient-to-r from-primary-50/50 to-blue-50/20 overflow-hidden">
    <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer list-none select-none hover:bg-primary-50/60 transition-colors">
      <div class="w-7 h-7 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-project-diagram text-white text-xs" aria-hidden="true"></i>
      </div>
      <span class="text-sm font-medium text-text-primary flex-1">Residents raise maintenance complaints that are assigned to executives and tracked through to resolution.</span>
      <span class="text-xs text-primary-600 flex items-center gap-1.5 flex-shrink-0 font-medium">
        How it works
        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200 group-open:rotate-180" aria-hidden="true"></i>
      </span>
    </summary>
    <div class="px-5 pb-5">
      <div class="pt-4 border-t border-primary-100 space-y-4">
        <svg viewBox="0 0 800 90" class="w-full" role="img" aria-label="Complaint flow: Filed → Acknowledged → In Progress → Work Order → Resolved → Closed, with Escalated branch">
          <defs>
            <marker id="arr" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
              <path d="M0,0 L0,6 L8,3 z" fill="#94a3b8"/>
            </marker>
            <marker id="arr-red" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
              <path d="M0,0 L0,6 L8,3 z" fill="#dc2626"/>
            </marker>
          </defs>
          <!-- Step 1: Filed -->
          <rect x="10" y="15" width="105" height="55" rx="8" fill="#f3f4f6" stroke="#9ca3af" stroke-width="1.5"/>
          <text x="62" y="38" text-anchor="middle" font-size="11" font-weight="600" fill="#374151">Filed</text>
          <text x="62" y="54" text-anchor="middle" font-size="9" fill="#6b7280">Resident submits</text>
          <!-- Arrow -->
          <line x1="116" y1="42" x2="132" y2="42" stroke="#94a3b8" stroke-width="1.5" marker-end="url(#arr)"/>
          <!-- Step 2: Acknowledged -->
          <rect x="134" y="15" width="105" height="55" rx="8" fill="#fef3c7" stroke="#d97706" stroke-width="1.5"/>
          <text x="186" y="38" text-anchor="middle" font-size="11" font-weight="600" fill="#92400e">Acknowledged</text>
          <text x="186" y="54" text-anchor="middle" font-size="9" fill="#92400e">Exec assigned</text>
          <!-- Arrow -->
          <line x1="240" y1="42" x2="256" y2="42" stroke="#94a3b8" stroke-width="1.5" marker-end="url(#arr)"/>
          <!-- Step 3: In Progress -->
          <rect x="258" y="15" width="105" height="55" rx="8" fill="#dbeafe" stroke="#1E3A8A" stroke-width="1.5"/>
          <text x="310" y="38" text-anchor="middle" font-size="11" font-weight="600" fill="#1e40af">In Progress</text>
          <text x="310" y="54" text-anchor="middle" font-size="9" fill="#1e40af">Work underway</text>
          <!-- Arrow -->
          <line x1="364" y1="42" x2="380" y2="42" stroke="#94a3b8" stroke-width="1.5" marker-end="url(#arr)"/>
          <!-- Step 4: Work Order -->
          <rect x="382" y="15" width="105" height="55" rx="8" fill="#dbeafe" stroke="#1E3A8A" stroke-width="1.5"/>
          <text x="434" y="38" text-anchor="middle" font-size="11" font-weight="600" fill="#1e40af">Work Order</text>
          <text x="434" y="54" text-anchor="middle" font-size="9" fill="#1e40af">Vendor if needed</text>
          <!-- Arrow -->
          <line x1="488" y1="42" x2="504" y2="42" stroke="#94a3b8" stroke-width="1.5" marker-end="url(#arr)"/>
          <!-- Step 5: Resolved -->
          <rect x="506" y="15" width="105" height="55" rx="8" fill="#d1fae5" stroke="#059669" stroke-width="1.5"/>
          <text x="558" y="38" text-anchor="middle" font-size="11" font-weight="600" fill="#065f46">Resolved</text>
          <text x="558" y="54" text-anchor="middle" font-size="9" fill="#065f46">Resident confirms</text>
          <!-- Arrow -->
          <line x1="612" y1="42" x2="628" y2="42" stroke="#94a3b8" stroke-width="1.5" marker-end="url(#arr)"/>
          <!-- Step 6: Closed -->
          <rect x="630" y="15" width="105" height="55" rx="8" fill="#e5e7eb" stroke="#6b7280" stroke-width="1.5"/>
          <text x="682" y="38" text-anchor="middle" font-size="11" font-weight="600" fill="#374151">Closed</text>
          <text x="682" y="54" text-anchor="middle" font-size="9" fill="#6b7280">Record filed</text>
          <!-- Escalated branch from step 3 -->
          <line x1="310" y1="70" x2="310" y2="82" stroke="#dc2626" stroke-width="1.2" marker-end="url(#arr-red)"/>
          <text x="310" y="90" text-anchor="middle" font-size="8" fill="#dc2626">Escalated — No action in 7 days</text>
        </svg>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mt-1">
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-exclamation-circle text-accent-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Complaints automatically escalate to the President if not acknowledged within 48 hours</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Work orders can be created directly from a complaint for vendor-assisted repairs</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Residents receive a notification when their complaint status changes</span>
          </div>
          <div class="flex items-start gap-2 text-xs text-text-secondary">
            <i class="fas fa-check-circle text-secondary-500 mt-0.5 flex-shrink-0 text-[11px]"></i>
            <span>Closed complaints contribute to the maintenance performance report</span>
          </div>
        </div>
      </div>
    </div>
  </details>

  <ComplaintsView role={user.role} userId={user.id} client:load />
</PortalLayout>

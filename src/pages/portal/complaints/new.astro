---
export const prerender = false;
import PortalLayout from '@portal/PortalLayout.astro';
import { getSupabaseServiceClient } from '@lib/services/providers/supabase/SupabaseDB';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const SOCIETY_ID = import.meta.env.PUBLIC_SOCIETY_ID ?? '00000000-0000-0000-0000-000000000001';
const sb = getSupabaseServiceClient();
const { data: units } = await sb.from('units').select('id, unit_number, block').eq('society_id', SOCIETY_ID).order('unit_number');

const CATEGORIES = ['Plumbing','Electrical','Lift','Security','Housekeeping','Parking','Water_Supply','Maintenance','Common_Area','Pest_Control','Internet_Cable','Generator','Garden','Other'];
const PRIORITIES = ['Low','Medium','High','Critical'];
---

<PortalLayout title="Raise Complaint" user={user} activeModule="complaints">
  <div class="mb-6">
    <nav class="text-sm text-text-secondary mb-3">
      <a href="/portal/complaints" class="hover:text-primary-600">Complaints</a>
      <span class="mx-2">›</span>
      <span class="text-text-primary">New Complaint</span>
    </nav>
    <h1 class="text-2xl font-bold text-text-primary">Raise a Complaint</h1>
    <p class="text-sm text-text-secondary mt-1">Describe the issue clearly. Our team will respond within the SLA window.</p>
  </div>

  <div class="max-w-2xl">
    <div id="error-banner" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>

    <form id="complaint-form" class="bg-white rounded-xl border border-border-light p-6 space-y-5">

      <!-- Title -->
      <div>
        <label for="title" class="block text-sm font-medium text-text-primary mb-1.5">
          Issue Summary <span class="text-red-500">*</span>
        </label>
        <input type="text" id="title" name="title" required maxlength="200"
          placeholder="e.g. Lift not working in Block A"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600" />
      </div>

      <!-- Category + Priority -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="category" class="block text-sm font-medium text-text-primary mb-1.5">
            Category <span class="text-red-500">*</span>
          </label>
          <select id="category" name="category" required
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
            <option value="">Select category</option>
            {CATEGORIES.map(c => <option value={c}>{c.replace(/_/g, ' ')}</option>)}
          </select>
        </div>
        <div>
          <label for="priority" class="block text-sm font-medium text-text-primary mb-1.5">Priority</label>
          <select id="priority" name="priority"
            class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
            {PRIORITIES.map(p => <option value={p} selected={p === 'Medium'}>{p}</option>)}
          </select>
        </div>
      </div>

      <!-- Sub-category (populated dynamically) -->
      <div id="sub-category-row" class="hidden">
        <label for="sub_category" class="block text-sm font-medium text-text-primary mb-1.5">Sub-category</label>
        <select id="sub_category" name="sub_category"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
          <option value="">Select sub-category</option>
        </select>
      </div>

      <!-- Unit -->
      <div>
        <label for="unit_id" class="block text-sm font-medium text-text-primary mb-1.5">
          Your Unit <span class="text-red-500">*</span>
        </label>
        <select id="unit_id" name="unit_id" required
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 bg-white">
          <option value="">Select your flat</option>
          {(units ?? []).map((u: {id: string; unit_number: string; block: string | null}) => (
            <option value={u.id}>{u.unit_number}{u.block ? ` – Block ${u.block}` : ''}</option>
          ))}
        </select>
      </div>

      <!-- Description -->
      <div>
        <label for="description" class="block text-sm font-medium text-text-primary mb-1.5">
          Detailed Description
        </label>
        <textarea id="description" name="description" rows="5" maxlength="2000"
          placeholder="Describe when it started, how often it occurs, and any other relevant details…"
          class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 resize-none"></textarea>
        <p class="text-xs text-text-secondary mt-1">Max 2,000 characters</p>
      </div>

      <!-- Photo attachment drop zone -->
      <div>
        <label class="block text-sm font-medium text-text-primary mb-1.5">
          Photos / Documents <span class="text-text-secondary font-normal">(optional, up to 5 files, max 5 MB each)</span>
        </label>

        <div id="drop-zone"
          class="border-2 border-dashed border-border-light rounded-xl p-6 text-center cursor-pointer hover:border-primary-600 transition-colors"
          role="button" tabindex="0" aria-label="Click or drag to attach files">
          <i class="fas fa-cloud-upload-alt text-2xl text-text-secondary mb-2" aria-hidden="true"></i>
          <p class="text-sm text-text-secondary">Drag & drop or <span class="text-primary-600 font-medium">click to browse</span></p>
          <p class="text-xs text-text-secondary mt-1">JPEG, PNG, WebP, HEIC, PDF</p>
          <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp,image/heic,application/pdf"
            multiple class="hidden" aria-hidden="true" />
        </div>

        <div id="file-preview" class="mt-3 space-y-2 hidden"></div>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3 pt-2">
        <button type="submit" id="submit-btn" class="btn-primary flex items-center gap-2">
          <i class="fas fa-paper-plane" aria-hidden="true"></i>
          <span id="btn-text">Submit Complaint</span>
          <span id="btn-spinner" class="hidden"><i class="fas fa-spinner fa-spin" aria-hidden="true"></i></span>
        </button>
        <a href="/portal/complaints" class="btn-outline">Cancel</a>
      </div>
    </form>
  </div>

  <script>
    const form       = document.getElementById('complaint-form') as HTMLFormElement;
    const errorBanner = document.getElementById('error-banner')!;
    const btnText    = document.getElementById('btn-text')!;
    const btnSpinner = document.getElementById('btn-spinner')!;
    const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement;
    const catSelect  = document.getElementById('category') as HTMLSelectElement;
    const subRow     = document.getElementById('sub-category-row')!;
    const subSelect  = document.getElementById('sub_category') as HTMLSelectElement;
    const dropZone   = document.getElementById('drop-zone')!;
    const fileInput  = document.getElementById('file-input') as HTMLInputElement;
    const preview    = document.getElementById('file-preview')!;

    const ALLOWED_TYPES = new Set(['image/jpeg','image/png','image/webp','image/heic','application/pdf']);
    const MAX_BYTES = 5 * 1024 * 1024;
    const MAX_FILES = 5;
    let attachedFiles: File[] = [];

    // ── Sub-category loading ─────────────────────────────────────────────────
    catSelect.addEventListener('change', async () => {
      const cat = catSelect.value;
      subSelect.innerHTML = '<option value="">Select sub-category</option>';
      subRow.classList.add('hidden');
      if (!cat) return;

      const res = await fetch(`/api/v1/complaints/sub-categories?category=${encodeURIComponent(cat)}`, { credentials: 'include' });
      if (!res.ok) return;
      const subs: { id: string; sub_category: string }[] = await res.json();
      if (!subs.length) return;

      for (const s of subs) {
        const opt = document.createElement('option');
        opt.value = s.sub_category;
        opt.textContent = s.sub_category;
        subSelect.appendChild(opt);
      }
      subRow.classList.remove('hidden');
    });

    // ── File drop zone ───────────────────────────────────────────────────────
    dropZone.addEventListener('click', () => fileInput.click());
    dropZone.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') fileInput.click(); });

    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('border-primary-600', 'bg-primary-50');
    });
    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('border-primary-600', 'bg-primary-50');
    });
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('border-primary-600', 'bg-primary-50');
      addFiles(Array.from(e.dataTransfer?.files ?? []));
    });
    fileInput.addEventListener('change', () => {
      addFiles(Array.from(fileInput.files ?? []));
      fileInput.value = '';
    });

    function addFiles(files: File[]) {
      const errors: string[] = [];
      for (const f of files) {
        if (attachedFiles.length >= MAX_FILES) { errors.push(`Max ${MAX_FILES} files allowed`); break; }
        if (!ALLOWED_TYPES.has(f.type)) { errors.push(`${f.name}: unsupported type`); continue; }
        if (f.size > MAX_BYTES) { errors.push(`${f.name}: exceeds 5 MB`); continue; }
        attachedFiles.push(f);
      }
      if (errors.length) showError(errors.join('; '));
      renderPreview();
    }

    function renderPreview() {
      if (!attachedFiles.length) { preview.classList.add('hidden'); return; }
      preview.classList.remove('hidden');
      preview.innerHTML = attachedFiles.map((f, i) => `
        <div class="flex items-center gap-3 p-2.5 bg-gray-50 rounded-lg border border-border-light text-sm">
          <i class="fas ${f.type === 'application/pdf' ? 'fa-file-pdf text-red-500' : 'fa-image text-blue-500'} flex-shrink-0" aria-hidden="true"></i>
          <span class="flex-1 truncate">${f.name}</span>
          <span class="text-text-secondary text-xs">${(f.size / 1024).toFixed(0)} KB</span>
          <button type="button" data-idx="${i}" class="remove-file text-text-secondary hover:text-red-500 ml-1" aria-label="Remove ${f.name}">
            <i class="fas fa-times" aria-hidden="true"></i>
          </button>
        </div>
      `).join('');

      preview.querySelectorAll('.remove-file').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt((btn as HTMLElement).dataset.idx!);
          attachedFiles.splice(idx, 1);
          renderPreview();
        });
      });
    }

    // ── Form submit ──────────────────────────────────────────────────────────
    function showError(msg: string) {
      errorBanner.textContent = msg;
      errorBanner.classList.remove('hidden');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBanner.classList.add('hidden');
      btnText.classList.add('hidden');
      btnSpinner.classList.remove('hidden');
      submitBtn.disabled = true;

      const fd = new FormData(form);
      const payload = {
        title:        fd.get('title'),
        category:     fd.get('category'),
        sub_category: fd.get('sub_category') || undefined,
        priority:     fd.get('priority'),
        unit_id:      fd.get('unit_id'),
        description:  fd.get('description'),
      };

      // Step 1: create complaint
      const res = await fetch('/api/v1/complaints', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(payload),
      });
      const data = await res.json();

      if (!res.ok) {
        showError(data.detail ?? data.error ?? 'Failed to submit complaint.');
        btnText.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
        submitBtn.disabled = false;
        return;
      }

      const complaintId = data.id;

      // Step 2: upload attachments (fire and forget errors — complaint is already saved)
      if (attachedFiles.length) {
        const uploadFd = new FormData();
        attachedFiles.forEach(f => uploadFd.append('files', f));
        try {
          await fetch(`/api/v1/complaints/${complaintId}/attachments`, {
            method: 'POST', credentials: 'include', body: uploadFd,
          });
        } catch {
          // Non-fatal — complaint is created; user can upload later
        }
      }

      window.location.href = `/portal/complaints/${complaintId}?created=1`;
    });
  </script>
</PortalLayout>

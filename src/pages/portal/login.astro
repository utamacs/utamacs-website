---
export const prerender = false;
import Layout from '@components/layout/PortalAuthLayout.astro';

const redirectTo = Astro.url.searchParams.get('next') ?? '/portal';
const expired    = Astro.url.searchParams.get('expired') === '1';

let errorMessage: string | null = null;
const errorCode = Astro.url.searchParams.get('error');
if (errorCode) {
  const map: Record<string, string> = {
    invalid_credentials: 'Incorrect email or password.',
    required: 'Email and password are required.',
    auth_callback_failed: 'Authentication failed. Please try again.',
  };
  errorMessage = map[errorCode] ?? 'Sign-in failed. Please try again.';
}
---

<Layout title="Resident Login – UTA MACS" description="Sign in to access the UTA MACS resident portal.">
  <section class="min-h-screen bg-gray-50 flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-3 justify-center">
          <div class="w-12 h-12 bg-primary-600 rounded-xl flex items-center justify-center">
            <i class="fas fa-building text-white text-xl" aria-hidden="true"></i>
          </div>
          <div class="text-left">
            <div class="font-bold text-primary-600 text-lg leading-tight">UTA MACS</div>
            <div class="text-xs text-text-secondary">Resident Portal</div>
          </div>
        </a>
      </div>

      <div class="bg-white rounded-2xl shadow-medium p-8">
        <h1 class="text-xl font-semibold text-text-primary mb-1">Welcome back</h1>
        <p class="text-small text-text-secondary mb-5">Sign in to your resident account</p>

        {expired && (
          <div class="mb-4 p-3 bg-amber-50 border border-amber-200 rounded-lg text-sm text-amber-700">
            Your session has expired. Please sign in again.
          </div>
        )}

        {errorMessage && (
          <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
            {errorMessage}
          </div>
        )}

        <!-- Tabs -->
        <div class="flex rounded-xl border border-border-light overflow-hidden mb-6">
          <button id="tab-email" onclick="switchTab('email')"
            class="flex-1 py-2 text-sm font-medium bg-primary-600 text-white transition-colors">
            Email & Password
          </button>
          <button id="tab-otp" onclick="switchTab('otp')"
            class="flex-1 py-2 text-sm font-medium bg-white text-text-secondary hover:bg-gray-50 transition-colors">
            Email OTP
          </button>
        </div>

        <!-- Email / Password panel -->
        <div id="panel-email">
          <form method="POST" action="/api/v1/auth/login" class="space-y-4">
            <input type="hidden" name="next" value={redirectTo} />
            <div>
              <label for="email" class="block text-sm font-medium text-text-primary mb-1.5">Email Address</label>
              <input
                type="email" id="email" name="email" required autocomplete="email"
                placeholder="you@example.com"
                class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 focus:border-transparent"
              />
            </div>
            <div>
              <label for="password" class="block text-sm font-medium text-text-primary mb-1.5">Password</label>
              <input
                type="password" id="password" name="password" required autocomplete="current-password"
                placeholder="••••••••"
                class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 focus:border-transparent"
              />
            </div>
            <div class="flex items-center justify-end text-sm">
              <a href="/portal/forgot-password" class="text-primary-600 hover:underline">Forgot password?</a>
            </div>
            <button type="submit" class="btn-primary w-full flex items-center justify-center gap-2">
              Sign In
            </button>
          </form>
        </div>

        <!-- Email OTP panel -->
        <div id="panel-otp" class="hidden">
          <div id="otp-error" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>

          <!-- Step 1: email -->
          <div id="otp-step-email" class="space-y-4">
            <div>
              <label for="otp-email" class="block text-sm font-medium text-text-primary mb-1.5">Email Address</label>
              <input type="email" id="otp-email" autocomplete="email" maxlength="255"
                placeholder="you@example.com"
                class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-600 focus:border-transparent" />
            </div>
            <button id="send-otp-btn" onclick="sendOtp()"
              class="btn-primary w-full flex items-center justify-center gap-2">
              <span id="send-otp-text">Send Sign-in Code</span>
              <span id="send-otp-spinner" class="hidden"><i class="fas fa-spinner fa-spin" aria-hidden="true"></i></span>
            </button>
          </div>

          <!-- Step 2: token -->
          <div id="otp-step-token" class="hidden space-y-4">
            <p id="otp-sent-msg" class="text-sm text-secondary-500 text-center"></p>
            <div>
              <label for="otp-token" class="block text-sm font-medium text-text-primary mb-1.5">Sign-in Code</label>
              <input type="text" id="otp-token" inputmode="numeric" pattern="[0-9]{8}" maxlength="8"
                placeholder="8-digit code"
                class="w-full px-4 py-2.5 border border-border-light rounded-xl text-sm text-center tracking-widest focus:outline-none focus:ring-2 focus:ring-primary-600 focus:border-transparent" />
            </div>
            <button id="verify-otp-btn" onclick="verifyOtp()"
              class="btn-primary w-full flex items-center justify-center gap-2">
              <span id="verify-otp-text">Verify & Sign In</span>
              <span id="verify-otp-spinner" class="hidden"><i class="fas fa-spinner fa-spin" aria-hidden="true"></i></span>
            </button>
            <button onclick="resetOtp()" class="btn-ghost w-full text-sm text-text-secondary">
              <i class="fas fa-arrow-left mr-1" aria-hidden="true"></i> Use a different email
            </button>
          </div>
        </div>

        <p class="mt-6 text-center text-xs text-text-secondary">
          Having trouble? Contact the Management Office.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  const redirectTo = new URLSearchParams(window.location.search).get('next') ?? '/portal';
  let otpEmail = '';

  function switchTab(tab: string) {
    const isOtp = tab === 'otp';
    document.getElementById('panel-email')!.classList.toggle('hidden', isOtp);
    document.getElementById('panel-otp')!.classList.toggle('hidden', !isOtp);
    const emailTab = document.getElementById('tab-email')!;
    const otpTab   = document.getElementById('tab-otp')!;
    emailTab.classList.toggle('bg-primary-600', !isOtp);
    emailTab.classList.toggle('text-white', !isOtp);
    emailTab.classList.toggle('bg-white', isOtp);
    emailTab.classList.toggle('text-text-secondary', isOtp);
    otpTab.classList.toggle('bg-primary-600', isOtp);
    otpTab.classList.toggle('text-white', isOtp);
    otpTab.classList.toggle('bg-white', !isOtp);
    otpTab.classList.toggle('text-text-secondary', !isOtp);
  }

  async function sendOtp() {
    const emailEl  = document.getElementById('otp-email') as HTMLInputElement;
    const errorEl  = document.getElementById('otp-error')!;
    const textEl   = document.getElementById('send-otp-text')!;
    const spinEl   = document.getElementById('send-otp-spinner')!;
    const btn      = document.getElementById('send-otp-btn') as HTMLButtonElement;

    errorEl.classList.add('hidden');
    const email = emailEl.value.trim().toLowerCase();
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errorEl.textContent = 'Enter a valid email address.';
      errorEl.classList.remove('hidden');
      return;
    }

    textEl.classList.add('hidden');
    spinEl.classList.remove('hidden');
    btn.disabled = true;

    try {
      const res  = await fetch('/api/v1/auth/send-otp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const data = await res.json();
      if (res.ok) {
        otpEmail = email;
        document.getElementById('otp-step-email')!.classList.add('hidden');
        document.getElementById('otp-step-token')!.classList.remove('hidden');
        document.getElementById('otp-sent-msg')!.textContent = `Sign-in code sent to ${email}`;
        document.getElementById('otp-token')?.focus();
      } else {
        errorEl.textContent = data.message ?? 'Failed to send code. Make sure your email is registered.';
        errorEl.classList.remove('hidden');
      }
    } catch {
      errorEl.textContent = 'Network error. Please check your connection.';
      errorEl.classList.remove('hidden');
    } finally {
      textEl.classList.remove('hidden');
      spinEl.classList.add('hidden');
      btn.disabled = false;
    }
  }

  async function verifyOtp() {
    const tokenEl  = document.getElementById('otp-token') as HTMLInputElement;
    const errorEl  = document.getElementById('otp-error')!;
    const textEl   = document.getElementById('verify-otp-text')!;
    const spinEl   = document.getElementById('verify-otp-spinner')!;
    const btn      = document.getElementById('verify-otp-btn') as HTMLButtonElement;

    errorEl.classList.add('hidden');
    const token = tokenEl.value.trim();
    if (!/^[0-9]{8}$/.test(token)) {
      errorEl.textContent = 'Enter the 8-digit sign-in code from your email.';
      errorEl.classList.remove('hidden');
      return;
    }

    textEl.classList.add('hidden');
    spinEl.classList.remove('hidden');
    btn.disabled = true;

    try {
      const res  = await fetch('/api/v1/auth/verify-otp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ email: otpEmail, token }),
      });
      const data = await res.json();
      if (res.ok) {
        window.location.href = data.next ?? redirectTo;
      } else {
        errorEl.textContent = data.message ?? 'Invalid or expired code. Please try again.';
        errorEl.classList.remove('hidden');
      }
    } catch {
      errorEl.textContent = 'Network error. Please check your connection.';
      errorEl.classList.remove('hidden');
    } finally {
      textEl.classList.remove('hidden');
      spinEl.classList.add('hidden');
      btn.disabled = false;
    }
  }

  function resetOtp() {
    otpEmail = '';
    (document.getElementById('otp-email') as HTMLInputElement).value = '';
    (document.getElementById('otp-token') as HTMLInputElement).value = '';
    document.getElementById('otp-step-email')!.classList.remove('hidden');
    document.getElementById('otp-step-token')!.classList.add('hidden');
    document.getElementById('otp-error')!.classList.add('hidden');
  }

  // expose to inline onclick handlers
  (window as unknown as Record<string, unknown>).switchTab = switchTab;
  (window as unknown as Record<string, unknown>).sendOtp   = sendOtp;
  (window as unknown as Record<string, unknown>).verifyOtp = verifyOtp;
  (window as unknown as Record<string, unknown>).resetOtp  = resetOtp;
</script>

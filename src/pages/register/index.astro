---
export const prerender = false;
import PortalAuthLayout from '@components/layout/PortalAuthLayout.astro';
---

<PortalAuthLayout title="Join UTA MACS Resident Portal">
  <section class="min-h-screen bg-gray-50 flex flex-col items-center justify-center px-4 py-12">
    <div class="w-full max-w-3xl">
      <!-- Header -->
      <div class="text-center mb-10">
        <a href="https://utamacs.org" class="inline-flex items-center gap-3 justify-center mb-4">
          <div class="w-12 h-12 bg-primary-600 rounded-xl flex items-center justify-center">
            <i class="fas fa-building text-white text-xl" aria-hidden="true"></i>
          </div>
          <div class="text-left">
            <div class="font-bold text-primary-600 text-lg leading-tight">UTA MACS</div>
            <div class="text-xs text-text-secondary">Urban Trilla Apartments</div>
          </div>
        </a>
        <h1 class="text-2xl font-bold text-text-primary font-poppins">Join the Resident Portal</h1>
        <p class="text-text-secondary text-sm mt-2">Submit a registration request. The management committee will review and send you an invite link.</p>
      </div>

      <!-- Type cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
        <!-- Owner -->
        <a href="/register/owner" class="bg-white rounded-xl border border-border-light shadow-soft hover:shadow-medium hover:border-primary-300 transition-all p-6 group text-center">
          <div class="w-14 h-14 bg-primary-50 rounded-xl flex items-center justify-center mx-auto mb-4 group-hover:bg-primary-100 transition-colors">
            <i class="fas fa-home text-primary-600 text-2xl" aria-hidden="true"></i>
          </div>
          <h2 class="text-base font-semibold text-text-primary mb-2">Owner Registration</h2>
          <p class="text-xs text-text-secondary">You own a flat in Urban Trilla Apartments. Upload your sale deed or allotment letter for verification.</p>
          <span class="mt-4 inline-flex items-center gap-1.5 text-xs font-medium text-primary-600 group-hover:gap-2.5 transition-all">
            Register as Owner <i class="fas fa-arrow-right text-[10px]" aria-hidden="true"></i>
          </span>
        </a>

        <!-- Tenant -->
        <a href="/register/tenant" class="bg-white rounded-xl border border-border-light shadow-soft hover:shadow-medium hover:border-secondary-500 transition-all p-6 group text-center">
          <div class="w-14 h-14 bg-green-50 rounded-xl flex items-center justify-center mx-auto mb-4 group-hover:bg-green-100 transition-colors">
            <i class="fas fa-key text-secondary-500 text-2xl" aria-hidden="true"></i>
          </div>
          <h2 class="text-base font-semibold text-text-primary mb-2">Tenant Registration</h2>
          <p class="text-xs text-text-secondary">You are renting a flat. Share your rental agreement and your landlord's contact for owner consent.</p>
          <span class="mt-4 inline-flex items-center gap-1.5 text-xs font-medium text-secondary-500 group-hover:gap-2.5 transition-all">
            Register as Tenant <i class="fas fa-arrow-right text-[10px]" aria-hidden="true"></i>
          </span>
        </a>

        <!-- Family member -->
        <a href="/portal/login?next=/register/secondary" class="bg-white rounded-xl border border-border-light shadow-soft hover:shadow-medium hover:border-purple-300 transition-all p-6 group text-center">
          <div class="w-14 h-14 bg-purple-50 rounded-xl flex items-center justify-center mx-auto mb-4 group-hover:bg-purple-100 transition-colors">
            <i class="fas fa-users text-purple-600 text-2xl" aria-hidden="true"></i>
          </div>
          <h2 class="text-base font-semibold text-text-primary mb-2">Add Family Member</h2>
          <p class="text-xs text-text-secondary">Already a registered resident? Add a spouse, parent, or child to your flat's household.</p>
          <span class="mt-4 inline-flex items-center gap-1.5 text-xs font-medium text-purple-600 group-hover:gap-2.5 transition-all">
            Sign in first <i class="fas fa-arrow-right text-[10px]" aria-hidden="true"></i>
          </span>
        </a>
      </div>

      <!-- Already registered -->
      <p class="text-center text-sm text-text-secondary">
        Already have an account?
        <a href="/portal/login" class="text-primary-600 hover:underline font-medium">Sign in here</a>
      </p>
    </div>
  </section>
</PortalAuthLayout>

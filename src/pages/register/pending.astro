---
export const prerender = false;
import PortalAuthLayout from '@components/layout/PortalAuthLayout.astro';
const ref = Astro.url.searchParams.get('ref') ?? '';
---

<PortalAuthLayout title="Registration Submitted – UTA MACS">
  <section class="min-h-screen bg-gray-50 flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md text-center">
      <div class="bg-white rounded-2xl shadow-medium p-10">
        <div class="w-16 h-16 bg-green-50 rounded-full flex items-center justify-center mx-auto mb-5">
          <i class="fas fa-check-circle text-secondary-500 text-3xl" aria-hidden="true"></i>
        </div>
        <h1 class="text-xl font-bold text-text-primary font-poppins mb-3">Request Submitted!</h1>
        <p class="text-sm text-text-secondary mb-5 leading-relaxed">
          Your registration request has been received. The UTA MACS executive committee will review it within <strong>5 working days</strong>. Once approved, you'll receive an email invite link to set up your portal account.
        </p>
        {ref && (
          <p class="text-xs text-text-secondary mb-5 font-mono bg-gray-50 rounded-lg px-3 py-2">
            Reference: {ref.slice(0, 8).toUpperCase()}
          </p>
        )}
        <div class="space-y-3">
          <a href="https://utamacs.org" class="btn-primary w-full flex items-center justify-center gap-2 text-sm">
            <i class="fas fa-home" aria-hidden="true"></i>
            Return to UTA MACS Website
          </a>
          <a href="/portal/login" class="btn-outline w-full flex items-center justify-center gap-2 text-sm">
            Already have an account? Sign in
          </a>
        </div>
        <p class="text-xs text-text-secondary mt-6">
          Having trouble? Email <a href="mailto:management@utamacs.org" class="text-primary-600 hover:underline">management@utamacs.org</a>
        </p>
      </div>
    </div>
  </section>
</PortalAuthLayout>

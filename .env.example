# ─────────────────────────────────────────────────────────────
# Provider selector — change to 'azure' to trigger migration
# ─────────────────────────────────────────────────────────────
PROVIDER=supabase

# ─────────────────────────────────────────────────────────────
# Common
# ─────────────────────────────────────────────────────────────
API_BASE_URL=https://portal.utamacs.org/api/v1

# AES-256 key for PII encryption — 32 bytes, base64-encoded
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_BASE64_KEY

# Daily salt for IP hashing (DPDPA compliance — rotate monthly)
IP_HASH_SALT=REPLACE_WITH_RANDOM_SALT

# ─────────────────────────────────────────────────────────────
# Supabase (active when PROVIDER=supabase)
# ─────────────────────────────────────────────────────────────
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# SERVER-SIDE ONLY — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ─────────────────────────────────────────────────────────────
# Azure (active when PROVIDER=azure)
# ─────────────────────────────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_DB_URL=
AZURE_STORAGE_CONNECTION=
AZURE_SIGNALR_CONNECTION=
AZURE_KEY_VAULT_URI=

# ─────────────────────────────────────────────────────────────
# Email (Resend — free 3K/month)
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_REPLACE_WITH_YOUR_RESEND_KEY

# ─────────────────────────────────────────────────────────────
# WhatsApp Business Cloud API (Meta Graph API v19.0)
# ─────────────────────────────────────────────────────────────
# Setup guide:
#   1. business.facebook.com → Create WhatsApp Business Account (WABA)
#   2. Meta Developer Console → WhatsApp → API Setup → copy Phone Number ID
#   3. Business Manager → System Users → generate permanent access token
#   4. TRAI DLT registration required for bulk messages to Indian numbers
#      (register at vodafone/jio/airtel DLT portal — takes 7–14 days)
#   5. Register each message template on DLT, then submit to Meta for approval
#   6. Set webhook URL in Meta console: https://portal.utamacs.org/api/webhooks/whatsapp
#
# System works in stub mode (logs only) if these vars are absent.
# Enable feature flag notifications → whatsapp_trai_dlt when live.
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_ACCESS_TOKEN=REPLACE_WITH_META_SYSTEM_USER_TOKEN
WHATSAPP_PHONE_NUMBER_ID=REPLACE_WITH_PHONE_NUMBER_ID
WHATSAPP_BUSINESS_ACCOUNT_ID=REPLACE_WITH_WABA_ID
WHATSAPP_WEBHOOK_VERIFY_TOKEN=REPLACE_WITH_ANY_RANDOM_SECRET_STRING

# ─────────────────────────────────────────────────────────────
# SMS (TRAI DLT — stub until registered)
# ─────────────────────────────────────────────────────────────
SMS_PROVIDER_API_KEY=REPLACE_WITH_MSG91_OR_KALEYRA_KEY
SMS_SENDER_ID=UTAMAC

# ─────────────────────────────────────────────────────────────
# GitHub Document Store (private repo — ALL file uploads go here)
# ALL documents and media are committed to this private repo via API.
# Supabase Storage is NOT used for file uploads.
#
# GITHUB_DOCS_REPO   — owner/repo, e.g. utamacs/utamacs-docs
# GITHUB_DOCS_TOKEN  — Personal Access Token with repo write scope
# GITHUB_DOCS_BRANCH — branch to commit to (default: main)
#
# Folder structure:
#   members/{unit_id}/              — member documents
#   staff-kyc/{staff_id}/           — staff KYC photos + ID docs
#   maids/{maid_id}/                — maid KYC photos + ID docs
#   tenant-kyc/{tenant_id}/         — tenant KYC documents
#   registration/{profile_id}/      — membership application docs
#   policies/{policy_id}/           — policy PDFs (versioned)
#   notices/{YYYY}/{notice_id}/     — notice attachments
#   parking/{unit_id}/              — RC / insurance docs
#   polls/exports/{YYYY}/           — poll result PDFs
#   vendors/{vendor_id}/invoices/   — vendor invoices
#   finance/invoices/{YYYY}/        — finance invoice PDFs
#   finance/receipts/{YYYY}/        — finance receipt PDFs
#   snags/{snag_id}/                — snag attachments
#   hoto/…  audit/…  letters/…      — HOTO platform documents
#   media/avatars/{profile_id}      — profile photos
#   media/gallery/{album_id}/       — gallery photos
#   media/events/{event_id}/        — event banners
#   media/community/{post_id}/      — community board images
#   media/marketplace/{listing_id}/ — marketplace listing images
#   media/complaints/{complaint_id}/— complaint attachment media
#   media/society/                  — society logo
# ─────────────────────────────────────────────────────────────
GITHUB_DOCS_REPO=utamacs/utamacs-docs
GITHUB_DOCS_TOKEN=ghp_REPLACE_WITH_YOUR_PAT
GITHUB_DOCS_BRANCH=main

# Legacy fallbacks — GITHUB_DOCS_* takes precedence; these are kept
# for backward compatibility with existing HOTO / Letters deployments.
GITHUB_LETTERS_REPO=utamacs/utamacs-letters
GITHUB_LETTERS_TOKEN=ghp_REPLACE_WITH_YOUR_PAT
GITHUB_LETTERS_BRANCH=main

# ─────────────────────────────────────────────────────────────
# Society defaults (seeded into DB, can be changed in admin UI)
# ─────────────────────────────────────────────────────────────
PUBLIC_SOCIETY_ID=00000000-0000-0000-0000-000000000001

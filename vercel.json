{
  "buildCommand": "npm run build:portal",
  "alias": ["portal.utamacs.org"],
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "astro",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/v1/automation/sla-escalation", "schedule": "0 * * * *" },
    { "path": "/api/v1/automation/payment-reminders", "schedule": "0 9 * * *" },
    { "path": "/api/v1/automation/expire-listings", "schedule": "0 2 * * *" },
    { "path": "/api/v1/automation/expire-preapprovals", "schedule": "0 1 * * *" }
  ]
}
